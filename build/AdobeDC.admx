<?xml version="1.0" encoding="utf-8"?>
<!-- ================================================================= -->
<!--                                                                   -->
<!--    ADMX templates created by Darren Milne                         -->
<!--    Source: https://github.com/systmworks/Adobe-DC-ADMX/           -->
<!--            https://github.com/systmworks/Adobe-DC-User-ADMX/      -->
<!--                                                                   -->
<!--    Merged: machine (v2.19) + user (v1.6) into a single template   -->
<!--    Merge rationale: Intune custom ADMX upload limit (20 files)    -->
<!--                                                                   -->
<!--    License: CC BY-SA 4.0                                          -->
<!--    Free to use and redistribute, including commercially, with     -->
<!--    attribution; ShareAlike applies to adaptations you distribute. -->
<!--                                                                   -->
<!-- ================================================================= -->

<policyDefinitions xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  revision="3.0" schemaVersion="1.0"
  xmlns="http://schemas.microsoft.com/GroupPolicy/2006/07/PolicyDefinitions">
  <policyNamespaces>
    <target prefix="AdobeDC" namespace="Adobe.Policies.AdobeDC" />
  </policyNamespaces>
  <resources minRequiredRevision="3.1.0" />
  <supportedOn>
    <definitions>
      <!-- Machine-scope supported-on definitions (Acrobat DC / Reader DC x86 + x64) -->
      <definition displayName="$(string.SupportedAcrobatDC_x86)" name="SupportedAcrobatDC_x86"/>
            <definition displayName="$(string.SupportedReaderDC_x86)" name="SupportedReaderDC_x86"/>
            <definition displayName="$(string.SupportedAcrobatDC_x64)" name="SupportedAcrobatDC_x64"/>
            <definition displayName="$(string.SupportedReaderDC_x64)" name="SupportedReaderDC_x64"/>

      <!-- User-scope supported-on definitions -->
      <definition displayName="$(string.SupportedAcrobatDC_User)" name="SupportedAcrobatDC_User"/>
            <definition displayName="$(string.SupportedReaderDC_User)" name="SupportedReaderDC_User"/>

      <!-- Browser extension supported-on (not tied to a specific Acrobat/Reader version) -->
      <definition displayName="$(string.SupportedBrowserExtension)" name="SupportedBrowserExtension"/>
    </definitions>
  </supportedOn>
  <categories>
    <!-- ============================================================= -->
    <!--  Machine-scope categories (Computer Configuration)            -->
    <!-- ============================================================= -->
    <category displayName="$(string.AdobeCategory)" name="AdobeCategory"/>
        <category displayName="$(string.AcrobatDCCategory)" name="AcrobatDCCategory">
          <parentCategory ref="AdobeCategory"/>
        </category>
        <category displayName="$(string.AcrobatDC_Arch_x86)" name="AcrobatDC_Arch_x86">
          <parentCategory ref="AcrobatDCCategory"/>
        </category>
        <category displayName="$(string.AcrobatDC_Arch_x64)" name="AcrobatDC_Arch_x64">
          <parentCategory ref="AcrobatDCCategory"/>
        </category>
        <category displayName="$(string.ReaderDCCategory)" name="ReaderDCCategory">
          <parentCategory ref="AdobeCategory"/>
        </category>
        <category displayName="$(string.ReaderDC_Arch_x86)" name="ReaderDC_Arch_x86">
          <parentCategory ref="ReaderDCCategory"/>
        </category>
        <category displayName="$(string.ReaderDC_Arch_x64)" name="ReaderDC_Arch_x64">
          <parentCategory ref="ReaderDCCategory"/>
        </category>
        <category displayName="$(string.Cat_CloudConnectors)" name="CloudConnectorsCategoryDC_x86">
          <parentCategory ref="AcrobatDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_CloudConnectors)" name="CloudConnectorsCategoryDC_x64">
          <parentCategory ref="AcrobatDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_ContextToolsSearch)" name="ContextToolsSearchCategoryDC_x86">
          <parentCategory ref="AcrobatDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_ContextToolsSearch)" name="ContextToolsSearchCategoryDC_x64">
          <parentCategory ref="AcrobatDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_DocsEditAccess)" name="DocsEditAccessCategoryDC_x86">
          <parentCategory ref="AcrobatDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_DocsEditAccess)" name="DocsEditAccessCategoryDC_x64">
          <parentCategory ref="AcrobatDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_MicrosoftPurviewMIP)" name="MicrosoftPurviewMIPCategoryDC_x86">
          <parentCategory ref="AcrobatDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_MicrosoftPurviewMIP)" name="MicrosoftPurviewMIPCategoryDC_x64">
          <parentCategory ref="AcrobatDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_SecurityExec)" name="SecurityExecCategoryDC_x86">
          <parentCategory ref="AcrobatDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_SecurityExec)" name="SecurityExecCategoryDC_x64">
          <parentCategory ref="AcrobatDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_SecurityTrust)" name="SecurityTrustCategoryDC_x86">
          <parentCategory ref="AcrobatDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_SecurityTrust)" name="SecurityTrustCategoryDC_x64">
          <parentCategory ref="AcrobatDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_SharingFeatures)" name="SharingFeaturesCategoryDC_x86">
          <parentCategory ref="AcrobatDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_SharingFeatures)" name="SharingFeaturesCategoryDC_x64">
          <parentCategory ref="AcrobatDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_StartupExperience)" name="StartupExperienceCategoryDC_x86">
          <parentCategory ref="AcrobatDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_StartupExperience)" name="StartupExperienceCategoryDC_x64">
          <parentCategory ref="AcrobatDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_UpdatesDesktop)" name="UpdatesDesktopCategoryDC_x86">
          <parentCategory ref="AcrobatDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_UpdatesDesktop)" name="UpdatesDesktopCategoryDC_x64">
          <parentCategory ref="AcrobatDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_Upsell)" name="UpsellCategoryDC_x86">
          <parentCategory ref="AcrobatDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_Upsell)" name="UpsellCategoryDC_x64">
          <parentCategory ref="AcrobatDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_CloudConnectors)" name="CloudConnectorsCategory_x86">
          <parentCategory ref="ReaderDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_CloudConnectors)" name="CloudConnectorsCategory_x64">
          <parentCategory ref="ReaderDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_ContextToolsSearch)" name="ContextToolsSearchCategory_x86">
          <parentCategory ref="ReaderDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_ContextToolsSearch)" name="ContextToolsSearchCategory_x64">
          <parentCategory ref="ReaderDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_DocsEditAccess)" name="DocsEditAccessCategory_x86">
          <parentCategory ref="ReaderDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_DocsEditAccess)" name="DocsEditAccessCategory_x64">
          <parentCategory ref="ReaderDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_MicrosoftPurviewMIP)" name="MicrosoftPurviewMIPCategory_x86">
          <parentCategory ref="ReaderDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_MicrosoftPurviewMIP)" name="MicrosoftPurviewMIPCategory_x64">
          <parentCategory ref="ReaderDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_SecurityExec)" name="SecurityExecCategory_x86">
          <parentCategory ref="ReaderDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_SecurityExec)" name="SecurityExecCategory_x64">
          <parentCategory ref="ReaderDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_SecurityTrust)" name="SecurityTrustCategory_x86">
          <parentCategory ref="ReaderDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_SecurityTrust)" name="SecurityTrustCategory_x64">
          <parentCategory ref="ReaderDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_SharingFeatures)" name="SharingFeaturesCategory_x86">
          <parentCategory ref="ReaderDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_SharingFeatures)" name="SharingFeaturesCategory_x64">
          <parentCategory ref="ReaderDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_StartupExperience)" name="StartupExperienceCategory_x86">
          <parentCategory ref="ReaderDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_StartupExperience)" name="StartupExperienceCategory_x64">
          <parentCategory ref="ReaderDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_UpdatesDesktop)" name="UpdatesDesktopCategory_x86">
          <parentCategory ref="ReaderDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_UpdatesDesktop)" name="UpdatesDesktopCategory_x64">
          <parentCategory ref="ReaderDC_Arch_x64"/>
        </category>
        <category displayName="$(string.Cat_Upsell)" name="UpsellCategory_x86">
          <parentCategory ref="ReaderDC_Arch_x86"/>
        </category>
        <category displayName="$(string.Cat_Upsell)" name="UpsellCategory_x64">
          <parentCategory ref="ReaderDC_Arch_x64"/>
        </category>

        <!-- Browser Extension (Acrobat extension for Chrome/Edge), sibling to Acrobat DC / Reader DC,           -->
        <!-- not tied to either product's architecture; the extension is the same regardless of desktop install -->
        <category displayName="$(string.BrowserExtensionCategory)" name="BrowserExtensionCategory">
          <parentCategory ref="AdobeCategory"/>
        </category>
        <category displayName="$(string.ChromeExtensionCategory)" name="ChromeExtensionCategory">
          <parentCategory ref="BrowserExtensionCategory"/>
        </category>
        <category displayName="$(string.EdgeExtensionCategory)" name="EdgeExtensionCategory">
          <parentCategory ref="BrowserExtensionCategory"/>
        </category>

    <!-- ============================================================= -->
    <!--  User-scope categories (User Configuration)                   -->
    <!-- ============================================================= -->
    <!-- Parent Category -->
        <category displayName="$(string.AdobeCategory_User)" name="AdobeCategory_User"/>

        <!-- Acrobat DC (User) Category -->
        <category displayName="$(string.AcrobatDCCategory_User)" name="AcrobatDCCategory_User">
          <parentCategory ref="AdobeCategory_User"/>
        </category>
        <category displayName="$(string.Cat_ContextToolsSearch_User)" name="ContextToolsSearchCategoryDC_User">
          <parentCategory ref="AcrobatDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_DocsEditAccess_User)" name="DocsEditAccessCategoryDC_User">
          <parentCategory ref="AcrobatDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_MicrosoftPurviewMIP_User)" name="MicrosoftPurviewMIPCategoryDC_User">
          <parentCategory ref="AcrobatDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_SecurityExec_User)" name="SecurityExecCategoryDC_User">
          <parentCategory ref="AcrobatDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_SecurityTrust_User)" name="SecurityTrustCategoryDC_User">
          <parentCategory ref="AcrobatDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_SharingFeatures_User)" name="SharingFeaturesCategoryDC_User">
          <parentCategory ref="AcrobatDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_StartupExperience_User)" name="StartupExperienceCategoryDC_User">
          <parentCategory ref="AcrobatDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_UpdatesDesktop_User)" name="UpdatesDesktopCategoryDC_User">
          <parentCategory ref="AcrobatDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_Upsell_User)" name="UpsellCategoryDC_User">
          <parentCategory ref="AcrobatDCCategory_User"/>
        </category>

        <!-- Reader DC (User) Category -->
        <category displayName="$(string.ReaderDCCategory_User)" name="ReaderDCCategory_User">
          <parentCategory ref="AdobeCategory_User"/>
        </category>
        <category displayName="$(string.Cat_ContextToolsSearch_User)" name="ContextToolsSearchCategory_User">
          <parentCategory ref="ReaderDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_DocsEditAccess_User)" name="DocsEditAccessCategory_User">
          <parentCategory ref="ReaderDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_MicrosoftPurviewMIP_User)" name="MicrosoftPurviewMIPCategory_User">
          <parentCategory ref="ReaderDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_SecurityExec_User)" name="SecurityExecCategory_User">
          <parentCategory ref="ReaderDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_SecurityTrust_User)" name="SecurityTrustCategory_User">
          <parentCategory ref="ReaderDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_SharingFeatures_User)" name="SharingFeaturesCategory_User">
          <parentCategory ref="ReaderDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_StartupExperience_User)" name="StartupExperienceCategory_User">
          <parentCategory ref="ReaderDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_UpdatesDesktop_User)" name="UpdatesDesktopCategory_User">
          <parentCategory ref="ReaderDCCategory_User"/>
        </category>
        <category displayName="$(string.Cat_Upsell_User)" name="UpsellCategory_User">
          <parentCategory ref="ReaderDCCategory_User"/>
        </category>
  </categories>
  <policies>

    <!-- ============================================================= -->
    <!--  Machine-scope policies (Computer Configuration)              -->
    <!--  Acrobat DC x86 → HKLM\SOFTWARE\WOW6432Node\Policies\Adobe   -->
    <!--  Acrobat DC x64 → HKLM\SOFTWARE\Policies\Adobe               -->
    <!-- ============================================================= -->
    <!-- ======================================== -->
        <!--                                          -->
        <!--    Adobe Acrobat DC (x64) - policies     -->
        <!--                                          -->
        <!-- ======================================== -->

        <!-- ======================================== -->
        <!--           Cloud and Connectors           -->
        <!-- ======================================== -->

        <!-- Cloud and Connectors > Adobe Fill and Sign (x64) -->
        <!-- bToggleFillSign   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9299 -->
        <policy class="Machine" displayName="$(string.bToggleFillSignDC_x64)" explainText="$(string.bToggleFillSignDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
          name="bToggleFillSignDC_x64" valueName="bToggleFillSign">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="0" />
          </enabledValue>
          <disabledValue>
            <decimal value="1" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > Box Cloud Connector (x64) -->
        <!-- bBoxConnectorEnabled   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9966 -->
        <policy class="Machine" displayName="$(string.bBoxConnectorEnabledDC_x64)" explainText="$(string.bBoxConnectorEnabledDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
          name="bBoxConnectorEnabledDC_x64" valueName="bBoxConnectorEnabled">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="1" />
          </enabledValue>
          <disabledValue>
            <decimal value="0" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > Document Cloud Services (x64) -->
        <!-- bToggleAdobeDocumentServices   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9204 -->
        <policy class="Machine" displayName="$(string.bToggleAdobeDocumentServicesDC_x64)" explainText="$(string.bToggleAdobeDocumentServicesDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
          name="bToggleAdobeDocumentServicesDC_x64" valueName="bToggleAdobeDocumentServices">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="0" />
          </enabledValue>
          <disabledValue>
            <decimal value="1" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > Document Cloud Storage (x64) -->
        <!-- bToggleDocumentCloud   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9877 -->
        <policy class="Machine" displayName="$(string.bToggleDocumentCloudDC_x64)" explainText="$(string.bToggleDocumentCloudDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
          name="bToggleDocumentCloudDC_x64" valueName="bToggleDocumentCloud">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="0" />
          </enabledValue>
          <disabledValue>
            <decimal value="1" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > Dropbox Cloud Connector (x64) -->
        <!-- bDropboxConnectorEnabled   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_10016 -->
        <policy class="Machine" displayName="$(string.bDropboxConnectorEnabledDC_x64)" explainText="$(string.bDropboxConnectorEnabledDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
          name="bDropboxConnectorEnabledDC_x64" valueName="bDropboxConnectorEnabled">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="1" />
          </enabledValue>
          <disabledValue>
            <decimal value="0" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > Generative AI Technology (x64) -->
        <!-- bEnableGentech   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html -->
        <policy class="Machine" displayName="$(string.bEnableGentechDC_x64)" explainText="$(string.bEnableGentechDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
          name="bEnableGentechDC_x64" valueName="bEnableGentech">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="1" />
          </enabledValue>
          <disabledValue>
            <decimal value="0" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > Google Drive Connector (x64) -->
        <!-- bGoogleDriveConnectorEnabled   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_10116 -->
        <policy class="Machine" displayName="$(string.bGoogleDriveConnectorEnabledDC_x64)" explainText="$(string.bGoogleDriveConnectorEnabledDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
          name="bGoogleDriveConnectorEnabledDC_x64" valueName="bGoogleDriveConnectorEnabled">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="1" />
          </enabledValue>
          <disabledValue>
            <decimal value="0" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > Hide Fill and Sign Send a Copy Button (x64) -->
        <!-- bToggleSendACopy   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9255 -->
        <policy class="Machine" displayName="$(string.bToggleSendACopyDC_x64)" explainText="$(string.bToggleSendACopyDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
          name="bToggleSendACopyDC_x64" valueName="bToggleSendACopy">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="0" />
          </enabledValue>
          <disabledValue>
            <decimal value="1" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > Hide Sign Out Menu Item (x64) -->
        <!-- bSuppressSignOut   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_10403 -->
        <policy class="Machine" displayName="$(string.bSuppressSignOutDC_x64)" explainText="$(string.bSuppressSignOutDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
          name="bSuppressSignOutDC_x64" valueName="bSuppressSignOut">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="1" />
          </enabledValue>
          <disabledValue>
            <decimal value="0" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > OneDrive Connector (x64) -->
        <!-- bOneDriveConnectorEnabled   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_10066 -->
        <policy class="Machine" displayName="$(string.bOneDriveConnectorEnabledDC_x64)" explainText="$(string.bOneDriveConnectorEnabledDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
          name="bOneDriveConnectorEnabledDC_x64" valueName="bOneDriveConnectorEnabled">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="1" />
          </enabledValue>
          <disabledValue>
            <decimal value="0" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > Preferences Synchronization (x64) -->
        <!-- bTogglePrefsSync   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9582 -->
        <policy class="Machine" displayName="$(string.bTogglePrefsSyncDC_x64)" explainText="$(string.bTogglePrefsSyncDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
          name="bTogglePrefsSyncDC_x64" valueName="bTogglePrefsSync">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="0" />
          </enabledValue>
          <disabledValue>
            <decimal value="1" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > Services and Web-Plugin Updates (x64) -->
        <!-- bUpdater   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9154 -->
        <policy class="Machine" displayName="$(string.bUpdater_UpdatesDC_x64)" explainText="$(string.bUpdater_UpdatesDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
          name="bUpdater_UpdatesDC_x64" valueName="bUpdater">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="1" />
          </enabledValue>
          <disabledValue>
            <decimal value="0" />
          </disabledValue>
        </policy>

        <!-- Cloud and Connectors > Third-Party Cloud Connectors (x64) -->
        <!-- bToggleWebConnectors   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9921 -->
        <policy class="Machine" displayName="$(string.bToggleWebConnectorsDC_x64)" explainText="$(string.bToggleWebConnectorsDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
          name="bToggleWebConnectorsDC_x64" valueName="bToggleWebConnectors">
          <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="0" />
          </enabledValue>
          <disabledValue>
            <decimal value="1" />
          </disabledValue>
        </policy>

        <!-- ======================================== -->
        <!--        Context, Tools and Search         -->
        <!-- ======================================== -->

        <!-- Context, Tools and Search > Auto UI Density Detection (x64) -->
        <!-- bUIDensityAutoDetectionEnabled   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html -->
        <policy class="Machine" displayName="$(string.bUIDensityAutoDetectionEnabledDC_x64)" explainText="$(string.bUIDensityAutoDetectionEnabledDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
          name="bUIDensityAutoDetectionEnabledDC_x64" valueName="bUIDensityAutoDetectionEnabled">
          <parentCategory ref="ContextToolsSearchCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="1" />
          </enabledValue>
          <disabledValue>
            <decimal value="0" />
          </disabledValue>
        </policy>

        <!-- Context, Tools and Search > Click-to-Edit Mode (x64) -->
        <!-- ADC4275035_ClickEdit   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureState.html -->
        <policy class="Machine" displayName="$(string.ADC4275035_ClickEditDC_x64)" explainText="$(string.ADC4275035_ClickEditDC_x64_Explain)" key="SOFTWARE\Adobe\Adobe Acrobat\DC\FeatureState"
          name="ADC4275035_ClickEditDC_x64" valueName="ADC4275035_ClickEdit">
          <parentCategory ref="ContextToolsSearchCategoryDC_x64"/>
          <supportedOn ref="SupportedAcrobatDC_x64"/>
          <enabledValue>
            <decimal value="1" />
