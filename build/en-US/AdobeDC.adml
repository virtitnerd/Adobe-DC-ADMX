<?xml version="1.0" encoding="utf-8"?>
<!-- Merged ADML: AdobeDC machine (v2.19) + user (v1.6) -->
<policyDefinitionResources xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  revision="3.0" schemaVersion="1.0"
  xmlns="http://schemas.microsoft.com/GroupPolicy/2006/07/PolicyDefinitions">
  <displayName>Adobe Acrobat DC (Machine + User)</displayName>
  <description>Merged machine-scope (v2.19) and user-scope (v1.6) Adobe DC ADMX policies.</description>
  <resources>
    <stringTable>
      <!-- Machine-scope strings -->
      <string id="SupportedAcrobatDC_x86">Adobe Acrobat DC (x86)</string>
            <string id="SupportedReaderDC_x86">Adobe Reader DC (x86)</string>
            <string id="SupportedAcrobatDC_x64">Adobe Acrobat DC (x64)</string>
            <string id="SupportedReaderDC_x64">Adobe Reader DC (x64)</string>
            <string id="SupportedBrowserExtension">Adobe Acrobat browser extension (Chrome/Edge)</string>

            <string id="AdobeCategory">Adobe</string>
            <string id="AcrobatDCCategory">Acrobat DC</string>
            <string id="AcrobatDC_Arch_x86">x86</string>
            <string id="AcrobatDC_Arch_x64">x64</string>
            <string id="ReaderDCCategory">Reader DC</string>
            <string id="ReaderDC_Arch_x86">x86</string>
            <string id="ReaderDC_Arch_x64">x64</string>
            <string id="BrowserExtensionCategory">Browser Extension</string>
            <string id="ChromeExtensionCategory">Google Chrome</string>
            <string id="EdgeExtensionCategory">Microsoft Edge</string>

            <string id="Cat_CloudConnectors">Cloud &amp; Connectors</string>
            <string id="Cat_ContextToolsSearch">Context, Tools &amp; Search</string>
            <string id="Cat_DocsEditAccess">Documents, Editing &amp; Accessibility</string>
            <string id="Cat_MicrosoftPurviewMIP">Microsoft Purview (MIP)</string>
            <string id="Cat_SecurityExec">Security: Execution &amp; Protection</string>
            <string id="Cat_SecurityTrust">Security: Trust &amp; Permissions</string>
            <string id="Cat_SharingFeatures">Sharing &amp; Features</string>
            <string id="Cat_StartupExperience">Startup &amp; Experience</string>
            <string id="Cat_UpdatesDesktop">Updates &amp; Desktop Integration</string>
            <string id="Cat_Upsell">Upsell</string>

            <!-- ======================================== -->
            <!--                                          -->
            <!-- Adobe Acrobat DC (x64) - policy strings  -->
            <!--                                          -->
            <!-- ======================================== -->

            <!-- ======================================== -->
            <!--           Cloud and Connectors           -->
            <!-- ======================================== -->

            <string id="bToggleFillSignDC_x64">Adobe Fill &amp; Sign</string>
            <string id="bToggleFillSignDC_x64_Explain">Disables Adobe Fill and Sign.

Possible values include:
0: Enable Adobe Fill and Sign.
1: Disable Adobe Fill and Sign.</string>
            <string id="bBoxConnectorEnabledDC_x64">Box Cloud Connector</string>
            <string id="bBoxConnectorEnabledDC_x64_Explain">Specifies whether to enable connection to the Box cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Box
1: Enable connection to Box</string>
            <string id="bToggleAdobeDocumentServicesDC_x64">Document Cloud Services</string>
            <string id="bToggleAdobeDocumentServicesDC_x64_Explain">Controls access to Adobe Document Cloud services excluding Acrobat Sign, preference sync, and third-party connectors.

Disabling this removes cloud-based features including Create PDF, Export PDF, Organize Pages, and Combine Files. To disable all hosted services including web-plugin updates, set bUpdater = 1 instead.

Possible values include:
0: Enable Document Cloud services.
1: Disable Document Cloud services.</string>
            <string id="bToggleDocumentCloudDC_x64">Document Cloud Storage</string>
            <string id="bToggleDocumentCloudDC_x64_Explain">Specifies whether to enable Document Cloud storage.

DC storage is enabled by default.

Possible values include:
0: Enable Document Cloud storage.
1: Disable Document Cloud storage.</string>
            <string id="bDropboxConnectorEnabledDC_x64">Dropbox Cloud Connector</string>
            <string id="bDropboxConnectorEnabledDC_x64_Explain">Specifies whether to enable connection to the Dropbox cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Dropbox
1: Enable connection to Dropbox</string>
            <string id="bEnableGentechDC_x64">Generative AI Technology</string>
            <string id="bEnableGentechDC_x64_Explain">Specifies whether to enable generative AI features in Acrobat and Reader.

Possible values include:
0: Disable generative AI features.
1: Enable generative AI features. Generative AI capabilities may rely on cloud services; verify organizational policies and Adobe documentation for data handling.</string>
            <string id="bGoogleDriveConnectorEnabledDC_x64">Google Drive Connector</string>
            <string id="bGoogleDriveConnectorEnabledDC_x64_Explain">Specifies whether to enable connection to the Google Drive cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Google Drive
1: Enable connection to Google Drive</string>
            <string id="bToggleSendACopyDC_x64">Hide Fill &amp; Sign Send a Copy Button</string>
            <string id="bToggleSendACopyDC_x64_Explain">Specifies whether to hide the Send a Copy button from the Fill &amp; Sign tool in Acrobat and Reader.

Possible values include:
0: Hide the button.
1: Show the button.</string>
            <string id="bSuppressSignOutDC_x64">Hide Sign Out Menu Item</string>
            <string id="bSuppressSignOutDC_x64_Explain">Specifies whether the sign-in and sign-out Help menu item should be enabled.

Possible values include:
0 or null: Don't disable the menu item.
1: Disable the Help menu item.</string>
            <string id="bOneDriveConnectorEnabledDC_x64">OneDrive Connector</string>
            <string id="bOneDriveConnectorEnabledDC_x64_Explain">Specifies whether to enable connection to the OneDrive cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to OneDrive
1: Enable connection to OneDrive</string>
            <string id="bTogglePrefsSyncDC_x64">Preferences Synchronization</string>
            <string id="bTogglePrefsSyncDC_x64_Explain">Controls whether application preferences are synchronized across devices via Adobe Document Cloud.

When a user is signed in with an Adobe ID, preferences can sync across desktop and mobile installations. Disabling this prevents preference data from leaving the managed environment and avoids unintended preference changes from personal devices.

Possible values include:
0: Enable preferences synchronization.
1: Disable preferences synchronization.</string>
            <string id="bUpdater_UpdatesDC_x64">Services &amp; Web-Plugin Updates</string>
            <string id="bUpdater_UpdatesDC_x64_Explain">Disables web-plugin component updates and all Adobe hosted services.

This is the master service switch for DC products under the cServices key, replacing the deprecated bEnableAcrobatHS preference. Setting to 1 disables both web-plugin updates and in-product cloud service access. To also remove the Updater UI, set bUpdater = 1 under the FeatureLockDown root key via the Services and Web-Plugin Updates policy.

Possible values include:
0: Enable cloud services and web-plugin updates.
1: Disable cloud services and web-plugin updates.</string>
            <string id="bToggleWebConnectorsDC_x64">Third-Party Cloud Connectors</string>
            <string id="bToggleWebConnectorsDC_x64_Explain">Controls in-product access to third-party cloud storage connectors such as Box, Dropbox, OneDrive, and Google Drive.

Disabling this removes the third-party connectors from the Home view, Open/Save dialogs, and the Add Account option. Individual connectors can be selectively re-enabled using bBoxConnectorEnabled, bDropboxConnectorEnabled, bGoogleDriveConnectorEnabled, and bOneDriveConnectorEnabled.

Possible values include:
0: Enable third-party cloud connectors.
1: Disable third-party cloud connectors.</string>

            <!-- ======================================== -->
            <!--        Context, Tools and Search         -->
            <!-- ======================================== -->

            <string id="bUIDensityAutoDetectionEnabledDC_x64">Auto UI Density Detection</string>
            <string id="bUIDensityAutoDetectionEnabledDC_x64_Explain">Specifies whether to disable the auto detection logic and bezel for changing Acrobat's display size.

By default, the UI is enabled so that a user may change the display size based on device screen size, resolution, and monitor scaling. 0: Disable the UI. 1: Show the UI.</string>
            <string id="ADC4275035_ClickEditDC_x64">Click-to-Edit Mode</string>
            <string id="ADC4275035_ClickEditDC_x64_Explain">Specifies whether to automatically enter edit mode when a user clicks a PDF object.

When enabled, clicking on an image or text results in edit tools appearing in the right-hand pane and edit mode is enabled in the Forms tool. Clicking on any form field enables the form authoring mode.

Possible values include:
0 or null: Do not dynamically switch into edit mode.
1: Automatically enter edit mode on user click.</string>
            <string id="bEnableCloudPoweredSearchTokenCachingDC_x64">Cloud Search Token Caching</string>
            <string id="bEnableCloudPoweredSearchTokenCachingDC_x64_Explain">Specifies whether to cache locally cloud-based search service suggestions.

Possible values include:
0 or null: Don't cache cloud search service suggestions
1: Cache suggestions</string>
            <string id="bEnableCloudPoweredSearchDC_x64">Cloud-Powered Search</string>
            <string id="bEnableCloudPoweredSearchDC_x64_Explain">Specifies whether to enable the cloud-based search service in the Find Tool.

Interacts with bEnableCloudPoweredSearchTokenCaching . Data sent to the cloud is not stored and is encrypted.

Possible values include:
0 or null: Don't enable the cloud search service
1: Enable the cloud search service</string>
            <string id="bEnableContextualTipsDC_x64">Contextual Help Tips</string>
            <string id="bEnableContextualTipsDC_x64_Explain">Controls whether to automatically display help tips based on the current context.

Possible values include:
0: Disable contextual tips.
1: Enable tips.</string>
            <string id="bEnableContextualToolbarDC_x64">Contextual Toolbar</string>
            <string id="bEnableContextualToolbarDC_x64_Explain">Specifies whether to show the context toolbar (popup) when selecting a PDF object.

When enabled, a popup, floating toolbar appears when a user interacts with a PDF. For example, selecting text displays text markup tools. Selecting an image displays sticky note and editing tools.

Possible values include:
0: Don't show context toolbars.
1: Show toolbars.</string>
            <string id="bEnableExtractPageRangeDC_x64">Extract Page Range UI</string>
            <string id="bEnableExtractPageRangeDC_x64_Explain">Specifies whether to show the page range UI in the Extract Page dialog.

0: Don't show the page range UI. 1: Show the page range UI.</string>
            <string id="ADC4275034DC_x64">Fill &amp; Sign Color Picker</string>
            <string id="ADC4275034DC_x64_Explain">Specifies whether to disable the color picker in the Fill and Sign tool.

The color picker is only supported on the Continuous track.

Possible values include:
0: Disable the color picker
1: Enable the color picker</string>
            <string id="ProtectOldExperienceDC_x64">Legacy Protect Tool Menu</string>
            <string id="ProtectOldExperienceDC_x64_Explain">Specifies whether to disable the new Protect tool and revert to the old menu

The Protect tool provides options for encrypting and password protecting documents. The new UI provides some streamlined options, but this preference supports using the old menus.

Possible values include:
0 or null: Use the new protect app experience.
1: Revert to the existing (pre October, 2019) protect app experience.</string>
            <string id="bDisableAcrobatShortcutCustomizationDC_x64">Lock Tool Shortcut Customization</string>
            <string id="bDisableAcrobatShortcutCustomizationDC_x64_Explain">Prevents end users from modifying the tool shortcuts in the right hand pane.

Possible values include:
0: Don't disable shortcuts.
1: Disable shortcuts.</string>
            <string id="bEnableAV2EnterpriseDC_x64">Modern Viewer</string>
            <string id="bEnableAV2EnterpriseDC_x64_Explain">Specifies whether to enable the Modern Viewer.

The new app UI is rolling out in phases over 2023. As of June, 25% of users will see the updated user interface. This preference may interact with bShownViewerOnboarding and bEnableAV2 .

Possible values include:
0: Don't show the Modern Viewer
1: Show the Modern Viewer</string>
            <string id="bEnableRCMNewPOPUpDC_x64">New Right-Click Context Menu</string>
            <string id="bEnableRCMNewPOPUpDC_x64_Explain">Specifies whether to disable the new context menu and use the legacy version.

A new right-click context menu displays icons and additional menu options. 0: Disable the new context menu. 1: Enable the new menu.</string>
            <string id="bFindMoreWorkflowsOnlineDC_x64">Online Actions Library Link</string>
            <string id="bFindMoreWorkflowsOnlineDC_x64_Explain">Specifies whether to show the menu item that opens the online Actions file library.

Possible values include:
0: Disable the menu item.
1 or null: Don't disable the menu item.</string>
            <string id="bFindMoreCustomizationsOnlineDC_x64">Online Tool Set Exchange Link</string>
            <string id="bFindMoreCustomizationsOnlineDC_x64_Explain">Specifies whether to show the menu item that opens the online Acrobat Tool Set Exchange.

Possible values include:
0: Disable the menu item.
1 or null: Don't disable the menu item.</string>
            <string id="bOrganizePagesFromThumbnailsDC_x64">Organize Pages Thumbnail Shortcut</string>
            <string id="bOrganizePagesFromThumbnailsDC_x64_Explain">Specifies whether to show shortcut UI for the Organize tool from thumbnails.

Possible values include:
0: Don't show Organize Pages tool shortcut from thumbnails
1: Show the Organize Pages tool shortcut</string>
            <string id="ADC4302862DC_x64">Paste in Place</string>
            <string id="ADC4302862DC_x64_Explain">Specifies whether to paste copied elements to the exact location as the copied element.

Some copy/paste operations are more efficient when copied elements are pasted to an identical location in the target document. This feature applies to form fields, annotations, and links.

Possible values include:
0: Disable the paste-in-place feature.
1: Enable the paste-in-place feature.</string>
            <string id="ADC4275035DC_x64">Remove Form Editing Tools (2019)</string>
            <string id="ADC4275035DC_x64_Explain">Specifies whether to remove the forms tools delivered with the October, 2019 release.

Editing features are now part of the Form tools. For example, there are AddText and EditText tools in the Prepare Form top toolbar. Systems that encounter issues with these tools (or simply want them removed from the UI) can disable these new features.

Possible values include:
0 or null: Do nothing.
1: Remove the AddText and EditText tools.</string>
            <string id="bRCMCombineFeatureKeyDC_x64">Show Combine Files Context Menu</string>
            <string id="bRCMCombineFeatureKeyDC_x64_Explain">Specifies whether to display the Combine Files item in a document's right-click context menu.

This preference only applies to machines that display the Modern Viewer (a phased rollout over 2023). When the Modern Viewer is disabled, admins can toggle the Combine Files UI off/on.

Possible values include:
0: Don't show the Combine Files UI.
1: Do show the Combine Files UI.</string>
            <string id="bEnableAutoCompleteExactMatchLoaderDC_x64">Show Search Loading Message</string>
            <string id="bEnableAutoCompleteExactMatchLoaderDC_x64_Explain">Specifies whether to show a &quot;Working on it&quot; message when using the cloud-based search service.

The message appears in the Suggestions section of the Find tool's autocomplete list.

Possible values include:
0 or null: Don't show the message
1: Show the message</string>
            <string id="bEnableAutoCompleteNoInternetConnectionHeaderDC_x64">Show Search No Internet Message</string>
            <string id="bEnableAutoCompleteNoInternetConnectionHeaderDC_x64_Explain">Specifies whether to show a &quot;Requires internet connection&quot; message when using the cloud-based search service.

The message appears in the Suggestions section of the Find tool's autocomplete list.

Possible values include:
0 or null: Don't show the message
1: Show the message</string>
            <string id="bEnableAutoCompleteNoExactMatchHeaderDC_x64">Show Search No Match Message</string>
            <string id="bEnableAutoCompleteNoExactMatchHeaderDC_x64_Explain">Specifies whether to show a &quot;No exact match&quot; message when using the cloud-based search service.

The message appears in the Suggestions section of the Find tool's autocomplete list.

Possible values include:
0 or null: Don't show the message
1: Show the message</string>

            <!-- ======================================== -->
            <!--   Documents, Editing and Accessibility   -->
            <!-- ======================================== -->

            <string id="bCloudATFeatureEnableDC_x64">Accessibility Auto Tagging</string>
            <string id="bCloudATFeatureEnableDC_x64_Explain">Specifies whether to show the new auto tagging experience or revert to the old experience.

Possible values include:
0: Disable the new auto tagging feature in the accessibility UI.
1: Enable the new auto tagging feature in the accessibility UI.</string>
            <string id="bBatesLogOriginalFileNameDC_x64">Bates Log Original File Name</string>
            <string id="bBatesLogOriginalFileNameDC_x64_Explain">Specifies whether to use the original filename in the log file when the user selects Bates number-based output filenames.

Users have a UI option to &quot;Replace file names with the starting and ending Bates number.&quot; This setting allows users to see the original file name in the log file.

Possible values include:
0: Use the starting and ending Bates number as the filename in the log.
1: Retain the original file name.</string>
            <string id="BlockEMFParsingDC_x64">Block EMF to PDF Conversion</string>
            <string id="BlockEMFParsingDC_x64_Explain">Specifies whether to disable EMF file conversion to PDF.

When set to 1, Acrobat will display an &quot;unsupported&quot; dialog and block conversion of EMF files to PDF. 0: Enable EMF conversion to PDF. 1: Disable EMF conversion to PDF.

When this policy is Enabled, EMF-to-PDF conversion is blocked. When Disabled, conversion is allowed.</string>
            <string id="BlockXPSParsingDC_x64">Block XPS to PDF Conversion</string>
            <string id="BlockXPSParsingDC_x64_Explain">Specifies whether to disable XPS file conversion to PDF.

When set to 1, Acrobat will display an &quot;unsupported&quot; dialog and block conversion of XPS files to PDF. 0: Enable XPS conversion to PDF. 1: Disable XPS conversion to PDF.

When this policy is Enabled, XPS-to-PDF conversion is blocked. When Disabled, conversion is allowed.</string>
            <string id="bGlobalBarMenuFeatureKeyDC_x64">Create PDF Split Menu</string>
            <string id="bGlobalBarMenuFeatureKeyDC_x64_Explain">Specifies whether to show the Create Split Menu under Create a PDF menu item.

Possible values include:
0: Don't show the Create Split menu.
1: Show the Create Split menu.</string>
            <string id="DisableScannedDocumentEditingDC_x64">Disable Scanned PDF Text Recognition</string>
            <string id="DisableScannedDocumentEditingDC_x64_Explain">Specifies whether to disable text recognition while editing scanned PDFs.

Possible values include:
0: Text recognition will be performed when invoking editing on scanned PDFs.
1: Text recognition will not be performed when invoking editing on scanned PDFs.</string>
            <string id="EnablePDFMakerGroupImagesTagCorrectionFeatureDC_x64">PDFMaker Grouped Image Tag Fix</string>
            <string id="EnablePDFMakerGroupImagesTagCorrectionFeatureDC_x64_Explain">Specifies whether to disable accessibility fixes for tagging grouped images.

0: Disable. 1: Enable.</string>
            <string id="EnablePDFMakerTableHeaderCellTagAndScopeUpdateFeatureDC_x64">PDFMaker Table Header Tag Fix</string>
            <string id="EnablePDFMakerTableHeaderCellTagAndScopeUpdateFeatureDC_x64_Explain">Specifies whether to disable accessibility fixes for tagging table headers.

0: Disable. 1: Enable.</string>
            <string id="EnablePDFMakerSplitTextPathElemsFeatureDC_x64">PDFMaker Text Path Tag Fix</string>
            <string id="EnablePDFMakerSplitTextPathElemsFeatureDC_x64_Explain">Specifies whether to enable the &quot;SplitTextPathElemsFeature&quot; tags correction feature when creating a PDF with Acrobat.

This preference addresses a bug introduced in 2020 which resulted in certain document elements such as element borders and alt text incorrectly rendering as the strings &quot;PathPath&quot;. This feature is enabled and mitigates the bug by default. 0: Disable tag correction. 1: Enable the SplitTextPathElemsFeature tags correction feature.</string>
            <string id="bEnableReflowEditingDC_x64">Reflow Editing</string>
            <string id="bEnableReflowEditingDC_x64_Explain">Specifies whether to lock ReflowEditing and the reflow feature.

See ReflowEditing for feature details.

Possible values include:
0: Disable and lock the feature.
1: Don't lock the feature and allow the user to toggle it off and on from the Preferences UI.</string>
            <string id="bIgnoreDataSchemaDC_x64">Restrict Form Data to Schema</string>
            <string id="bIgnoreDataSchemaDC_x64_Explain">Specifies whether all data in a form is saved rather than only data related to the form's schema.

Possible values include:
null: Save form data even when it's not part of a schema.
1: Save only form data that's part of the schema.</string>

            <!-- ======================================== -->
            <!--         Microsoft Purview (MIP)          -->
            <!-- ======================================== -->

            <string id="bMIPCheckPolicyOnDocSaveDC_x64">Check MIP Policy on Save</string>
            <string id="bMIPCheckPolicyOnDocSaveDC_x64_Explain">Locks enforcement of default or mandatory Microsoft Purview Information Protection labeling checks when saving documents.

Machine-level FeatureLockDown lockdown; grays out the related Preferences UI once set. Requires default or mandatory labeling to be configured in the Microsoft Purview compliance portal.

Possible values include:
0: Do not lock save-time MIP policy check.
1: Lock save-time MIP policy check enabled. This is admin lockdown under HKLM, not the per-user MicrosoftAIP preferences in User ADMX.</string>
            <string id="bMIPLabellingDC_x64">Enable MIP Labelling</string>
            <string id="bMIPLabellingDC_x64_Explain">Locks the Enable Microsoft Purview Information Protection option in Preferences ) Security.

Machine-level FeatureLockDown lockdown; end users cannot change the checkbox once this policy is applied.

Possible values include:
0: Do not lock MIP labelling preference.
1: Lock MIP labelling enabled. Complements per-user MicrosoftAIP preferences in User ADMX; this policy controls admin lockdown only.</string>
            <string id="bEnableDKEAdminDC_x64">MIP Double Key Encryption</string>
            <string id="bEnableDKEAdminDC_x64_Explain">Locks double key encryption (DKE) label support for Microsoft Purview Information Protection.

Machine-level FeatureLockDown lockdown for MIP DKE workflows.

Possible values include:
0: Lock DKE disabled.
1: Lock DKE enabled.</string>
            <string id="bMIPExternalAuthAdminDC_x64">MIP External Browser Auth</string>
            <string id="bMIPExternalAuthAdminDC_x64_Explain">Locks browser-based authentication for Microsoft Purview Information Protection operations.

Machine-level FeatureLockDown lockdown.

Possible values include:
0: Lock external browser auth disabled.
1: Lock external browser auth enabled.</string>
            <string id="iMIPCloudDC_x64">MIP Sovereign Cloud</string>
            <string id="iMIPCloudDC_x64_Explain">Locks which Microsoft cloud instance Acrobat and Reader use for MIP SDK operations.

Machine-level FeatureLockDown lockdown. Relevant for sovereign and government tenants. MIP SDK Cloud enum values: 0: Unknown. 1: Custom. 2: Test. 3: Commercial (default/global). 4: Germany. 5: US DoD. 6: US GCC. 7: US GCC High. 8: US Sec. 9: US Nat. 10: China.</string>
            <string id="iMIPCloudDC_x64_opt0">Unknown</string>
            <string id="iMIPCloudDC_x64_opt1">Custom</string>
            <string id="iMIPCloudDC_x64_opt2">Test</string>
            <string id="iMIPCloudDC_x64_opt3">Commercial</string>
            <string id="iMIPCloudDC_x64_opt4">Germany</string>
            <string id="iMIPCloudDC_x64_opt5">US DoD</string>
            <string id="iMIPCloudDC_x64_opt6">US GCC</string>
            <string id="iMIPCloudDC_x64_opt7">US GCC High</string>
            <string id="iMIPCloudDC_x64_opt8">US Sec</string>
            <string id="iMIPCloudDC_x64_opt9">US Nat</string>
            <string id="iMIPCloudDC_x64_opt10">China</string>
            <string id="bSilentAuthDC_x64">Suppress OS Auth Prompts (MIP)</string>
            <string id="bSilentAuthDC_x64_Explain">Locks whether operating-system authentication prompts are suppressed during MIP operations.

By default, OS-driven auth prompts for MIP are suppressed. Set policy Disabled to write DWORD 0 and allow OS auth prompts (useful when troubleshooting AADSTS50020-type errors).

Possible values include:
0: Allow OS auth prompts.
1: Suppress OS auth prompts.</string>

            <!-- ======================================== -->
            <!--    Security: Execution and Protection    -->
            <!-- ======================================== -->

            <string id="bEnable3DDC_x64">3D Content in PDFs</string>
            <string id="bEnable3DDC_x64_Explain">Specifies whether to trust and render 3D content in PDFs.

This setting can override b3DEnableContent.

Possible values include:
0: Don't render 3D content.
1: Trust and render 3D files.</string>
            <string id="bEnableProtectedModeAppContainerDC_x64">AppContainer Sandbox</string>
            <string id="bEnableProtectedModeAppContainerDC_x64_Explain">Specifies whether to enable the AppContainer sandbox.

Possible values include:
0: Disable Microsoft's AppContainer sandbox
1: Enable Microsoft's AppContainer sandbox</string>
            <string id="bEnableBlacklistForOpenSaveDC_x64">Attachment Extension Blocklist in Dialogs</string>
            <string id="bEnableBlacklistForOpenSaveDC_x64_Explain">Reverts the tBuiltInPermList behavior to that of the pre 21.011.20029 build.

Beginning with build 21.011.20029, extensions added in the tBuiltInPermList with restriction level 3 will be missing from the menu items in all the save and open dialogs. This feature is enabled by default. Users can revert to the old behavior by setting FeatureLockDown/bEnableBlacklistForOpenSave to 0.

Possible values include:
0: Revert to the legacy behavior.
1: Do nothing. Retain the new behavior.</string>
            <string id="bDisableJavaScriptDC_x64">Block JavaScript Execution</string>
            <string id="bDisableJavaScriptDC_x64_Explain">Blocks and locks JavaScript execution in PDF documents, preventing users from bypassing via privileged locations.

This lockable setting overrides bEnableJS and prevents users from re-enabling JavaScript through the Yellow Message Bar or Trusted Locations.

Possible values include:
0 or null: Don't disable JS.
1: Disable and lock JS.</string>
            <string id="iFileAttachmentPermsDC_x64">Block non-PDF file attachments</string>
            <string id="iFileAttachmentPermsDC_x64_Explain">Controls whether embedded file attachments of types other than PDF or FDF can be opened from within a PDF.

Restricting file attachments prevents users from launching non-PDF embedded files with external applications, reducing the risk of executing malicious payloads delivered inside PDF documents.

Possible values include:
1: Block non-PDF file attachments.
3: Prompt the user before opening non-PDF file attachments.</string>
            <string id="bDisablePDFRedirectionActionsDC_x64">Block PDF Link Actions</string>
            <string id="bDisablePDFRedirectionActionsDC_x64_Explain">Specifies whether to block specific PDF actions (listed below) which result in opening a link.

This preference does not block regular web links. Enabling this feature blocks PDF actions that open links, including GoToE, GoToR, Launch, Thread, Import Data, Export Form Data, Submit Form, and Reset Form.

Possible values include:
0 or null: Don't block these opening links.
1: Block links.</string>
            <string id="tBuiltInPermListDC_x64">Built-in Attachment Permissions List</string>
            <string id="tBuiltInPermListDC_x64_Explain">Defines the white and black list of file types that can be saved and opened from a document.

Pipe-separated list of file extensions with permission levels. Format: version:1|.ext:N where N is 0 (prompt, no allow), 1 (prompt, can allow/prohibit), 2 (always open), or 3 (never open). Referenced by bEnableBlacklistForOpenSave. Extensions with level 3 are hidden from save/open dialogs (build 21.011.20029+).</string>
            <string id="bEnablePVCertificateBasedTrustDC_x64">Certification Status in Protected View</string>
            <string id="bEnablePVCertificateBasedTrustDC_x64_Explain">Specifies whether a document's certification status should appear in the Protected View document message bar.

Possible values include:
0: Don't show the document's certification status.
1: Do show the document's certification status.</string>
            <string id="bEnhancedSecurityInBrowserDC_x64">Enhanced Security in Browser</string>
            <string id="bEnhancedSecurityInBrowserDC_x64_Explain">Controls Enhanced Security mode for PDFs opened inside a web browser.

When Enhanced Security is enabled in browser mode, Acrobat and Reader restrict unsafe document behaviors for PDFs viewed via the browser plugin, complementing the standalone application setting (bEnhancedSecurityStandalone).

Possible values include:
0: Disable Enhanced Security in browser mode.
1: Enable Enhanced Security in browser mode.</string>
            <string id="bEnhancedSecurityStandaloneDC_x64">Enhanced Security Standalone</string>
            <string id="bEnhancedSecurityStandaloneDC_x64_Explain">Controls Enhanced Security mode for PDFs opened in the standalone application.

When Enhanced Security is enabled, Acrobat and Reader restrict potentially unsafe document behaviors such as accessing external URLs, running scripts, and silently sending data to remote hosts. This reduces the risk of exploitation by malicious PDFs.

Possible values include:
0: Disable Enhanced Security in standalone mode.
1: Enable Enhanced Security in standalone mode.</string>
            <string id="bEnableFlashDC_x64">Flash Content in PDFs</string>
            <string id="bEnableFlashDC_x64_Explain">Controls whether Adobe Flash Player content embedded in PDF files is permitted to run.

Adobe Flash reached end-of-life in December 2020 and is no longer supported or patched. All Flash content in PDFs should be blocked to prevent exploitation of known unpatched Flash vulnerabilities.

Possible values include:
0: Block Flash content in PDFs.
1: Allow Flash content in PDFs.</string>
            <string id="EnableFlashEditingDC_x64">Flash Editing Tools</string>
            <string id="EnableFlashEditingDC_x64_Explain">Specifies whether to enable the Flash tools for adding annotations or Flash in the Rich Media app.

Possible values include:
0 or null: Remove &quot;Disable Flash ) Add SWF menu item.&quot;
1: Show the menu item.</string>
            <string id="bProtectedModeDC_x64">Protected Mode Sandbox</string>
            <string id="bProtectedModeDC_x64_Explain">Controls Protected Mode, which isolates the PDF rendering engine in a sandboxed process.

Protected Mode uses Windows integrity levels to restrict the renderer's access to the file system, registry, and network. This significantly limits the damage a successful PDF exploit can cause by preventing it from accessing system resources directly.

Possible values include:
0: Disable Protected Mode.
1: Enable Protected Mode.</string>
            <string id="bEnablePVSwitchoutShortcutDC_x64">Protected View Exit Shortcut Key</string>
            <string id="bEnablePVSwitchoutShortcutDC_x64_Explain">Enables a shortcut key that allows users to exit Protected View for a specific document.

This feature allows admins and users to keep Protected View enabled, but also exit that mode on-the-fly when necessary.

Possible values include:
0: Disable the shortcut key.
1: Enable the shortcut key that exits Protected View.</string>
            <string id="iProtectedViewDC_x64">Protected View Mode</string>
            <string id="iProtectedViewDC_x64_Explain">Controls Protected View, which opens PDFs in a restricted read-only mode before granting full access.

In Protected View, most application features are disabled and the document is rendered in a locked-down process. This provides an additional security boundary for files from untrusted sources before full rendering permissions are granted.

Possible values include:
0: Disable Protected View.
1: Enable Protected View for files from potentially unsafe locations.
2: Enable Protected View for all files.</string>
            <string id="iProtectedViewDC_x64_opt0">Disable Protected View</string>
            <string id="iProtectedViewDC_x64_opt1">Enable Protected View for unsafe locations only</string>
            <string id="iProtectedViewDC_x64_opt2">Enable Protected View for all files</string>
            <string id="iUnlistedAttachmentTypePermDC_x64">Unlisted Attachment Type Permissions</string>
            <string id="iUnlistedAttachmentTypePermDC_x64_Explain">Specifies the default permissions for file types that aren't listed in the default or user-specified lists.

Possible values include:
0: Prompt user without ability to set file type as Allowed (two choices: Open File, Never Allow).
1 (default): Prompt user with ability to Allow or Prohibit (three choices).
2: Always open unlisted file types.
3: Never open unlisted file types.</string>
            <string id="iUnlistedAttachmentTypePermDC_x64_opt0">Prompt without ability to allow (most restrictive prompt)</string>
            <string id="iUnlistedAttachmentTypePermDC_x64_opt1">Prompt with ability to allow or prohibit (default)</string>
            <string id="iUnlistedAttachmentTypePermDC_x64_opt2">Always open unlisted file types</string>
            <string id="iUnlistedAttachmentTypePermDC_x64_opt3">Never open unlisted file types (most restrictive)</string>

            <!-- ======================================== -->
            <!--     Security: Trust and Permissions      -->
            <!-- ======================================== -->

            <string id="bMSStoreTrustedDC_x64">Allow Changes to Windows Certificate Store Trust</string>
            <string id="bMSStoreTrustedDC_x64_Explain">Locks the UI so that end users cannot change the value set by iMSStoreTrusted.

Set iMSStoreTrusted first, then use this preference to lock it. Allowable values include: 0: Lock the UI. 1: Same as null. Don't lock the UI.</string>
            <string id="bAllowInvisibleSigDC_x64">Allow Invisible Signatures</string>
            <string id="bAllowInvisibleSigDC_x64_Explain">Specifies whether to allow invisible certification signatures.

False disables the menu option, prevents signing and certifying with invisible signatures, and limits JavaScript support by signature fields.</string>
            <string id="bAllowPasswordSavingDC_x64">Allow Password Caching</string>
            <string id="bAllowPasswordSavingDC_x64_Explain">Controls whether certain passwords can be cached to disk; for example, passwords for digital IDs.

If false, users are prompted to enter a password every time one is required. Not all passwords are affected by this setting.</string>
            <string id="bEnableSignatureClearDC_x64">Allow Signature Clearing</string>
            <string id="bEnableSignatureClearDC_x64_Explain">Specifies whether to disable and lock the ability for a signer to clear their own signature.

Possible values include:
0: Disable signature clearing.
1: Enable signature clearing.</string>
            <string id="bVerifyUseAlwaysDC_x64">Always Use Specified Verify Handler</string>
            <string id="bVerifyUseAlwaysDC_x64_Explain">Qualifies the use of aVerify.

If true and aVerify is set to a handler name, then this handler is used to verify all signatures. If false, then the aVerify handler is used only to verify signatures when the handler specified by the signature dictionary Filter attribute is not present.</string>
            <string id="bDisableExpandEnvironmentVariablesDC_x64">Block User Library Trust in Protected View</string>
            <string id="bDisableExpandEnvironmentVariablesDC_x64_Explain">Provides a method for admins to whitelist user libraries as trusted locations when Protected View is enabled.

Protected View restricts features for all documents that do not reside in a trusted location. This new preference provides a way for admins to specify user-specific locations as trusted; in other words, documents with the path C:\Users\%username%\Desktop will open outside Protected View. For example, the user libraries Documents, Downloads, Desktop, and so on. When this preference is off, admins can only specify trusted locations which are static/identical for all users across their organization.

Possible values include:
0: Trust user-specific locations.
1: Don't trust user-specific locations.</string>
            <string id="bWinCacheSessionHandlesDC_x64">Cache Digital ID Session Handles</string>
            <string id="bWinCacheSessionHandlesDC_x64_Explain">Specifies whether to retain cryptographic service provider (CSP) handles when a user authenticates to a digital ID.

If true, a user does not have to re-authenticate to use the ID unless they log out or the session ends. The impact of this preference will vary based on the CSP in use; however, the setting does not affect the Windows CSPs.</string>
            <string id="bDisableOSTrustedSitesDC_x64">Disable IE Trusted Sites as Privileged Locations</string>
            <string id="bDisableOSTrustedSitesDC_x64_Explain">Locks the ability to treat IE trusted sites as privileged locations either on or off so the users can't change the bTrustOSTrustedSites value via the user interface.

If set, bTrustOSTrustedSites is simply ignored.

Possible values include:
0 or null: Enables and locks trusting sites from IE.
1: Disables and locks trusting sites from IE.</string>
            <string id="bAllowAPSConfigDC_x64">LiveCycle RMS Server Config</string>
            <string id="bAllowAPSConfigDC_x64_Explain">Prevents a LiveCycle Right Management Server from being configured by disabling the menu option in the Security Settings Console.

By default, configuration is allowed.</string>
            <string id="bReqRevCheckDC_x64">Lock Revocation Check Setting</string>
            <string id="bReqRevCheckDC_x64_Explain">Locks Security\cASPKI\cASPKI\cVerify\iReqRevCheck and disables the user interface item.</string>
            <string id="bReasonsDC_x64">Lock Signing Reasons Settings</string>
            <string id="bReasonsDC_x64_Explain">Prevents users from modifying reason settings.

v8.1: If locked and cReasons is empty, bAllowSigningReasons is 0 and read only. If locked and cReasons has values, then bAllowSigningReasons is true and read only.</string>
            <string id="bDisableTrustedFoldersDC_x64">Lock Trusted Folders and Files</string>
            <string id="bDisableTrustedFoldersDC_x64_Explain">Prevents users from adding trusted file and folder locations to Privileged Locations.

Privileged Locations bypass Enhanced Security restrictions. Allowing users to define them creates a pathway to weaken document security. Locking this setting prevents users from creating local exceptions that could expose the application to malicious PDFs.

Possible values include:
0: Allow users to configure trusted folder and file locations.
1: Disable and lock trusted folder and file locations.</string>
            <string id="bDisableTrustedSitesDC_x64">Lock Trusted Host Sites</string>
            <string id="bDisableTrustedSitesDC_x64_Explain">Prevents Internet Explorer Trusted Sites from being elevated to Privileged Locations.

Privileged Locations bypass Enhanced Security restrictions. Importing IE Trusted Sites as privileged locations could allow a broad set of sites to bypass document security controls. Locking this setting keeps the Privileged Locations list under administrator control.

Possible values include:
0: Allow IE Trusted Sites to be added as Privileged Locations.
1: Disable and lock the IE Trusted Sites elevation.</string>
            <string id="bEnableCEFBasedUIDC_x64">Modern Digital Signature UI</string>
            <string id="bEnableCEFBasedUIDC_x64_Explain">Specifies whether to enable the CEF-based, modern UI for digital signature workflows.

The newer UI streamlines the user interface. All values also disable the UI option to change the preference. Note that for products released after June 2016, disabling a user's ability to create a self-signed digital ID requires setting both bSelfSignCertGen and bEnableCEFBasedUI to 0.

Possible values include:
0: Disable the modern UI and shows the legacy UI.
1: Enable the Modern UI.</string>
            <string id="bUseTSAsSigningTimeDC_x64">Show Timestamp in Signature</string>
            <string id="bUseTSAsSigningTimeDC_x64_Explain">Specifies whether the timestamp time should be displayed in the signature appearance.

By default, the signature appearance displays the signing time from the signer's computer clock. To display the timestamp server time in a signature appearance: Go to HKLM\SOFTWARE\WOW6432Node\Policies\Adobe\(product)\(version)\FeatureLockDown\cSecurity\cPubSec\ Create the new DWORD bUseTSAsSigningTime and set it to 1. Go to HKCU\Software\Adobe\(product)\(version)\Security\cASPKI\cASPKI\cSign. Set bReqSigPropRetrieval to 1. Create the preference if it does not exist. Verify the computer time does not vary from the signature validation revocation check response time specified by HKCU\Software\Adobe\(product)\(version)\Security\cPubSec\ iMaxClockSkew . The default is 65 minutes. iMaxClockSkew allows admins to account for a network delay, time synchronization issues, and so on without invalidating signatures.

Possible values include:
0: Don't show the timestamp time.
1: Do show the timestamp time.</string>
            <string id="bShowSignMenuDC_x64">Sign Menu in Menu Bar</string>
            <string id="bShowSignMenuDC_x64_Explain">Specifies whether to show the Sign menu in Acrobat's top level menu bar.

Possible values include:
0 or null: Disable the Sign menu item.
1: Enable the menu item.</string>
            <string id="bAllowReasonWhenSigningDC_x64">Signing Reason UI</string>
            <string id="bAllowReasonWhenSigningDC_x64_Explain">Specifies whether the reason UI will appear during signing.

The preference can be overridden by a document seed value set on a field. For 8.1 and later, if cReasons is locked and is empty, bAllowSigningReasons is 0 and read only (The UI is turned off). If cReasons is locked and has values, then bAllowSigningReasons is true and read only.</string>
            <string id="bEnableCertificateBasedTrustDC_x64">Trust Certified Documents</string>
            <string id="bEnableCertificateBasedTrustDC_x64_Explain">Elevates (trusts) certified documents as a privileged location.

This lockable counterpart to bTrustCertifiedDocuments allows certified documents to bypass all the security restrictions that may be bypassed by other privileged locations. The exception is that this level of trust does not apply when the PDF is viewed in Protected View.

Possible values include:
0 or null: Don't make certified documents equivalent to privileged locations.
1: Do make certified documents equivalent to privileged locations (trusted).</string>
            <string id="iUnknownURLPermsDC_x64">Unknown URL Access Policy</string>
            <string id="iUnknownURLPermsDC_x64_Explain">Controls access to websites not explicitly listed in the user's Privileged Locations URL list.

This setting determines how Acrobat handles attempts to access URLs that are not in the trusted or blocked lists. It overrides trusted host settings for URLs that fall outside the configured list.

Possible values include:
1: Always ask before accessing unknown URLs.
2: Always allow access to unknown URLs.
3: Always block access to unknown URLs.</string>
            <string id="iUnknownURLPermsDC_x64_opt0">Always ask</string>
            <string id="iUnknownURLPermsDC_x64_opt1">Always allow</string>
            <string id="iUnknownURLPermsDC_x64_opt2">Always block</string>
            <string id="bValidateOnOpenDC_x64">Validate Signatures on Open</string>
            <string id="bValidateOnOpenDC_x64_Explain">Specifies whether to automatically validate all signatures on document open.

Note that the lockable setting does not configure the feature; instead, it locks what is set in HKCU and the user interface. 0: Don't validate signatures on document open. 1: Validate signatures on document open.</string>

            <!-- ======================================== -->
            <!--           Sharing and Features           -->
            <!-- ======================================== -->

            <string id="bToggleAdobeSignDC_x64">Adobe Acrobat Sign</string>
            <string id="bToggleAdobeSignDC_x64_Explain">Controls the Adobe Acrobat Sign (Send for Signature) service integration.

When disabled, the Send for Signature workflow is removed from the interface. For Continuous track installations, bToggleManageSign should also be set to 1 to fully remove the Acrobat Sign tracking tab from the Home view.

Possible values include:
0: Enable Adobe Acrobat Sign integration.
1: Disable Adobe Acrobat Sign integration.</string>
            <string id="bToggleSendAndTrackDC_x64">Adobe Send &amp; Track</string>
            <string id="bToggleSendAndTrackDC_x64_Explain">Disables Adobe Send and Track (some UI is renamed to &quot;Share&quot; since October, 2018)

Possible values include:
0: Enable Adobe Send and Track.
1: Disable Adobe Send and Track.</string>
            <string id="bEnableRecipientMentionDC_x64">Allow @Mention Non-Reviewers</string>
            <string id="bEnableRecipientMentionDC_x64_Explain">Specifies whether to allow participants in a shared review to @mention people who are not review collaborators.

Prior to this release, reviewers could only @mention other reviewers in the review comments.

Possible values include:
0: Don't allow mentioning non-reviewers.
1: Allow mentioning non-reviewers.</string>
            <string id="bDisableSharePointFeaturesDC_x64">Disable SharePoint &amp; Office 365 Integration</string>
            <string id="bDisableSharePointFeaturesDC_x64_Explain">Controls integration with SharePoint and Office 365 for file check-out and related menu items.

When disabled, the application does not detect SharePoint-hosted files, suppresses the check-out prompt, and removes SharePoint-specific menu items from the interface. This prevents unintended document synchronization with SharePoint environments.

Possible values include:
0: Enable SharePoint and Office 365 integration.
1: Disable SharePoint and Office 365 integration.</string>
            <string id="bDisableWebmailDC_x64">Disable WebMail Integration</string>
            <string id="bDisableWebmailDC_x64_Explain">Controls whether users can configure webmail profiles for sending PDF files by email.

When disabled, users cannot select a webmail profile from the Share pane email workflow. If bSendMailShareRedirection is also set to 1, clicking the email icon attaches the PDF directly to a new mail message instead.

Possible values include:
0: Enable webmail integration.
1: Disable webmail integration.</string>
            <string id="bToggleAdobeReviewDC_x64">Document Cloud Review Service</string>
            <string id="bToggleAdobeReviewDC_x64_Explain">Specifies whether to remove all UI related to the Document Cloud Review service.

When set to 1, this preference removes all cloud-based review UI, including the Review tab on the Home screen. Review tools such as the Send for Review tool in the tool's pane invoke legacy review types rather than DC reviews. The Share button also does not lead users to review workflows.

Possible values include:
0 (or null): Enable the Document Cloud Review service.
1: Disable the Document Cloud Review service.</string>
            <string id="bSendMailShareRedirectionDC_x64">Email Icon Attach to Email Behavior</string>
            <string id="bSendMailShareRedirectionDC_x64_Explain">Change the email icon behavior so that it attaches the document to an email.

With the new unified sharing experience, UI for sharing such as the Send, Attach to Email, and the email icon in the top bar, invokes the new unified share pane. However, when users frequently use &quot;Send documents as Attachment&quot;, set this preference to 1 to change the behavior of the Email icon so that one-click attaches the file to an email.

Possible values include:
0 or null: The email icon opens the share pane.
1: Change the email icon behavior to automatically attach the file to an email.</string>
            <string id="bMixRecentFilesFeatureLockDownDC_x64">Hide Shared Files from Recent List</string>
            <string id="bMixRecentFilesFeatureLockDownDC_x64_Explain">Specifies whether to show shared files in the Recent file list.

When enabled, shared files appear in the Recent list when a user successfully shares a file as well as when a recipient accepts an invite to the shared file workflow. This feature makes it easier to track files in live workflows (reviews, shares, signing workflows, and files shared via Send and Track).

Possible values include:
0: Add shared files to Recent list.
1: Don't add shared files to Recent list.</string>
            <string id="bToggleFSSSignatureSavingDC_x64">Save Signature to Cloud</string>
            <string id="bToggleFSSSignatureSavingDC_x64_Explain">Specifies whether to save a newly created signature in the cloud.

When a user creates a new signature, the dialog offers the option to store the signature in the cloud for later use. This preference also controls saving user initials.

Possible values include:
0: Show the Save Signature UI
1: Hide the Save Signature UI</string>
            <string id="bAdobeSendPluginToggleDC_x64">Send &amp; Track Outlook Plugin</string>
            <string id="bAdobeSendPluginToggleDC_x64_Explain">Controls the Adobe Send &amp; Track plugin for Microsoft Outlook.

When enabled, a Send &amp; Track button appears in Outlook that allows users to share large files as links via Adobe Document Cloud. Disabling this plugin reduces the application attack surface in environments that do not use this feature.

Possible values include:
0: Enable the Send &amp; Track Outlook plugin.
1: Disable the Send &amp; Track Outlook plugin.</string>
            <string id="bEnableReviewPromoteDC_x64">Share and Review Reminder Tip</string>
            <string id="bEnableReviewPromoteDC_x64_Explain">Specifies whether to display a Share/Review feature reminder message when users have used those features in the past.

If the user has not used the review service for 30 days AND has previously opened a PDF with review comments, Acrobat displays a tip reminding the user the review/share service is available.

Possible values include:
0: Don't show a tip.
1: Show tip.</string>
            <string id="bPreviouslyEnabledSharePointInChromeExtnDC_x64">SharePoint Chrome Extension Previous State</string>
            <string id="bPreviouslyEnabledSharePointInChromeExtnDC_x64_Explain">Stores the previous state of the SharePoint FeatureLockDown settings.

Possible values include:
Same as bEnableSharePointInChromeExtn in FeatureLockDown.</string>
            <string id="bEnableSharePointInChromeExtnDC_x64">SharePoint in Chrome Extension</string>
            <string id="bEnableSharePointInChromeExtnDC_x64_Explain">Specifies whether to integrate SharePoint into the Acrobat's Chrome extension.

Possible values include:
0: Don't enable SharePoint integration.
1: Enable.</string>
            <string id="bToggleManageSignDC_x64">Show Acrobat Sign Tracking Tab</string>
            <string id="bToggleManageSignDC_x64_Explain">Specifies whether to remove the Signature tab from the Home page's left-hand pane, notifications, and sign tracking cards.

When set to 1, the signature tab is hidden, the user will not see any agreements received or sent for signature, and all Acrobat Sign notifications are disabled on the desktop. It also removes signature-related cards under the To Do list.

Possible values include:
0: Show the Signature tab.
1: Hide the Signature tab.</string>
            <string id="bDisableOnBehalfOfTextDC_x64">Show Comment Author in Shared Review</string>
            <string id="bDisableOnBehalfOfTextDC_x64_Explain">If false, the string &quot;On behalf of&quot; does not append the author's name in the comment when another person opens the document in a shared-review workflow.

This preference is only used in shared review workflows.

Possible values include:
0: Don't display the comment author's name.
1: Do display the comment author's name.</string>
            <string id="iClientType_GmailDC_x64">WebMail Client Type (Gmail)</string>
            <string id="iClientType_GmailDC_x64_Explain">Identifies the Gmail Mail client type for WebMail.

The value can only be: 1</string>
            <string id="iClientType_GmailDC_x64_opt0">Locked value: 1 (per Adobe PrefRef)</string>
            <string id="iClientType_YahooDC_x64">WebMail Client Type (Yahoo)</string>
            <string id="iClientType_YahooDC_x64_Explain">Identifies the Yahoo Mail client type for WebMail.

The value can only be: 2</string>
            <string id="iClientType_YahooDC_x64_opt0">Locked value: 2 (per Adobe PrefRef)</string>
            <string id="iIMAPPortDC_x64">WebMail IMAP Port</string>
            <string id="iIMAPPortDC_x64_Explain">Identifies the My Profile Mail IMAP server port number for WebMail.

The value can be: Any valid port number.</string>
            <string id="iIMAPPortDC_x64_opt0">143 (Standard IMAP)</string>
            <string id="iIMAPPortDC_x64_opt1">993 (IMAP over SSL/TLS)</string>
            <string id="iIMAPSecurityDC_x64">WebMail IMAP Security</string>
            <string id="iIMAPSecurityDC_x64_Explain">Specifies whether to enable the My Profile Mail IMAP security for WebMail.

The value can be: 0: Don't enable security. 1: Enable security.</string>
            <string id="iSMTPPortDC_x64">WebMail SMTP Port</string>
            <string id="iSMTPPortDC_x64_Explain">Identifies the My Profile Mail SMTP server port number for WebMail.

The value can be: Any valid server port number.</string>
            <string id="iSMTPPortDC_x64_opt0">25 (Standard SMTP)</string>
            <string id="iSMTPPortDC_x64_opt1">465 (SMTP over SSL)</string>
            <string id="iSMTPPortDC_x64_opt2">587 (SMTP Submission / TLS)</string>
            <string id="iSMTPSecurityDC_x64">WebMail SMTP Security</string>
            <string id="iSMTPSecurityDC_x64_Explain">Specifies whether to enable the My Profile Mail SMTP security for WebMail.

The value can be: 0: Don't enable security. 1: Enable security.</string>

            <!-- ======================================== -->
            <!--          Startup and Experience          -->
            <!-- ======================================== -->

            <string id="bShowMsgAtLaunchDC_x64">Adobe Messages at Launch</string>
            <string id="bShowMsgAtLaunchDC_x64_Explain">Specifies whether to show messages from Adobe when the product launches.

This preference also hides the Share Feedback icon, removes messages such as the 11.x &quot;end-of-life&quot; warning, and disables the dialog prompt that urges users to complete their profile. In later product versions, this preference removes the Home banner (top message area) from the Home view.

Possible values include:
0: Don't show messages from Adobe when the product launches.
1: Show messages from Adobe when the product launches.</string>
            <string id="bAllowUserToChangeMsgPrefsDC_x64">Allow Users to Change Message Preferences</string>
            <string id="bAllowUserToChangeMsgPrefsDC_x64_Explain">Locks the features associated with bShowMsgAtLaunch and bDontShowMsgWhenViewingDoc so that end users can't change the settings.

Possible values include:
0: Locks the feature so end users can't change the settings.
1: Allows users to change the settings. A value of 1 has the same effect as this key not existing at all.</string>
            <string id="bToggleNotificationsDC_x64">Desktop Notifications</string>
            <string id="bToggleNotificationsDC_x64_Explain">Specifies whether to disable all in-product and desktop notifications.

When 0 (or null), feature-specific notifications are managed via the related service preference. When set to 1, this preference disables all notifications irrespective of the values of all other keys.

Possible values include:
0: Enable desktop notifications.
1: Disable all desktop notifications.</string>
            <string id="bToggleFTEDC_x64">First Time Experience</string>
            <string id="bToggleFTEDC_x64_Explain">Specifies whether to enable the First Time Experience (FTE) feature (Welcome tour/page).

The first time experience (FTE) feature displays help content and tips when the application starts and also controls access to the Welcome Tour and Welcome page. FTE is also disabled if any of these preferences under FeatureLockDown\cServices are set: bUpdater , bToggleAdobeDocumentServices , bToggleAdobeSign , bTogglePrefsSync , bToggleWebConnectors .

Possible values include:
0 or null: Enable FTE features.
1: Disable FTE features.</string>
            <string id="bDontShowMsgWhenViewingDocDC_x64">Hide Adobe Messages on Document Open</string>
            <string id="bDontShowMsgWhenViewingDocDC_x64_Explain">Specifies whether to show messages from Adobe when a document opens.

This preference also controls messages in the right-hand pane for 12.x and later products as well as the &quot;Learn More&quot; link, including the &quot;Start Free Trial&quot; message promoting Acrobat.

Possible values include:
0: Don't show messages from Adobe when a document opens.
1: Show messages from Adobe when a document opens.</string>
            <string id="bEnableBellButtonDC_x64">Hide In-Product Notifications Bell</string>
            <string id="bEnableBellButtonDC_x64_Explain">Specifies whether to hide in-product messages.

A value of 1 hides notifications, but the product still fetches and caches them.

Possible values include:
0: Show in-product notifications.
1: Hide in-product notifications.</string>
            <string id="bToggleShareFeedbackDC_x64">Hide Send Feedback Icon</string>
            <string id="bToggleShareFeedbackDC_x64_Explain">Specifies whether to show the Send Feedback icon.

By default, the UI displays a feedback icon so that users can easily send feedback to Adobe with one click. This preference replaces bUsageMeasurement for 12.x and later products. Setting bShowMsgAtLaunch to 0 also hides the icon.

Possible values include:
0: Hide the icon.
1: Show the icon.</string>
            <string id="bUsageMeasurementDC_x64">Send Usage Data to Adobe</string>
            <string id="bUsageMeasurementDC_x64_Explain">Legacy master switch controlling whether usage data is collected and sent to Adobe.

Predates DC; superseded for most purposes by bToggleShareFeedback (12.x and later) and bEnableADMAnalytics, but Adobe documentation still references this key as the master switch that disables all data collection, including ADM analytics, when other related preferences are not lockable via HKLM. Retained here for environments that still rely on it.

Possible values include:
0: Disable usage data collection.
1: Enable usage data collection.</string>
            <string id="bToggleToDoListDC_x64">Home Screen To Do List</string>
            <string id="bToggleToDoListDC_x64_Explain">Specifies whether to show a &quot;to do&quot; list on the Home screen.

By default, the Home screen displays a list of action items such as Take a Tour, Export PDF, and so on. For details, see the What's New .

Possible values include:
0: Enable the feature.
1: Disable the feature.</string>
            <string id="bIsSCReducedModeEnforcedExDC_x64">Reader mode on Acrobat (Unified x64)</string>
            <string id="bIsSCReducedModeEnforcedExDC_x64_Explain">Enforces reduced (Reader-like) mode for Unified Acrobat so users can open PDFs without signing in with an Adobe ID.

For enterprise Unified Acrobat (64-bit MUI) deployments.

Possible values include:
0: Do not enforce reduced mode via this policy.
1: Enforce reduced mode (Reader-like experience) without requiring Adobe ID sign-in. See Adobe enterprise KB for full Windows procedure (may include additional cIPM values).</string>
            <string id="bShowScanTabInHomeViewDC_x64">Scan Tab in Home View</string>
            <string id="bShowScanTabInHomeViewDC_x64_Explain">Specifies whether to disable the Scan tab in Home view.

When enabled, links to scans appear under the Scan tab in the Home view.

Possible values include:
0: Hide the scan tab.
1: Show the Scan tab.</string>
            <string id="bToggleNotificationToastsDC_x64">Show Desktop Notification Toasts</string>
            <string id="bToggleNotificationToastsDC_x64_Explain">Specifies whether to hide desktop notifications.

A value of 1 hides notifications, but the product still fetches and caches them.

Possible values include:
0: Show desktop notifications.
1: Hide desktop notifications.</string>
            <string id="bTogglePDFOwnershipToastsDC_x64">Show PDF Ownership Notification</string>
            <string id="bTogglePDFOwnershipToastsDC_x64_Explain">Specifies whether to show a notification on machine startup that allows the user to make Acrobat the default PDF viewer.

When enabled and both Acrobat and Reader are installed, the user can click on the notification to change the default PDF viewer.

Possible values include:
0: Show PDF ownership notification on application startup.
1: Don't show ownership notification.</string>
            <string id="bToggleToDoTilesDC_x64">Show To Do Cards in Recent Tab</string>
            <string id="bToggleToDoTilesDC_x64_Explain">Specifies whether to show To Do Cards in the Recent Tab view

To Do cards list potential action items for members of certain workflows (for example, collaborative reviews). When set to 1, To Do cards do not appear in the Recent tab.

Possible values include:
0 or null: Show cards for unaccepted workflows (reviews, views and sign).
1: Hide cards for unaccepted workflows (reviews, views and sign).</string>
            <string id="bWhatsNewExpDC_x64">What's New Experience</string>
            <string id="bWhatsNewExpDC_x64_Explain">Specifies whether to disable the What's New experience.

This feature was phased in incrementally over 2022. When enabled, the default user on first launch will see a What's New screen as well as a See new features notification. These UI items appear once.

Possible values include:
0: Enable the What's New experience.
1: Disable.</string>

            <!-- ======================================== -->
            <!--     Updates and Desktop Integration      -->
            <!-- ======================================== -->

            <string id="bDisableThirdPartyPluginNotifDC_x64">32-Bit Plugin Upgrade Notification</string>
            <string id="bDisableThirdPartyPluginNotifDC_x64_Explain">Specifies whether to notify users with 32 bit plugins that the app will soon update to 64 bit.

32 bit plugins will not work in the 64 bit app. The notification provides a &quot;Learn more&quot; link that provides additional details about how to upgrade their plugin.

Possible values include:
0: Do not warn the user about 32 bit plugins.
1: Do warn the user.</string>
            <string id="EULADC_x64">Accept EULA for Updater</string>
            <string id="EULADC_x64_Explain">Accepts the Adobe end-user license agreement (EULA) on behalf of the user.

The EULA must be accepted before the built-in updater can download product updates. In enterprise deployments the EULA is typically accepted at install time via the EULA_ACCEPT=YES MSI property; this policy provides an alternative mechanism when the installer property was not set.

Possible values include:
0: EULA not accepted.
1: EULA accepted.</string>
            <string id="bEnableAutoDockUndockHUDDC_x64">Auto Dock HUD Bar</string>
            <string id="bEnableAutoDockUndockHUDDC_x64_Explain">Specifies whether to automatically dock and undock the HUD bar based on the window size.

Possible values include:
0: Disable automatic behavior.
1: Enable auto docking and undocking.</string>
            <string id="bHasAcrobatConsentDC_x64">Auto Open Acrobat from Reader</string>
            <string id="bHasAcrobatConsentDC_x64_Explain">Specifies whether the Reader process should automatically open Acrobat for the current file.

PDF ownership does not change. Reader will continue as the default PDF viewer on this machine.

Possible values include:
0: Don't automatically use Acrobat.
1: Use Acrobat</string>
            <string id="bCrashReporterEnabledDC_x64">Crash Reporter Dialog</string>
            <string id="bCrashReporterEnabledDC_x64_Explain">Specifies whether to show the crash reporter dialog on application crash (Windows only).

This feature is part of the CrashReporter integration on Windows. The dialog allows users to send crash logs to the CrashReporter team.

Possible values include:
0: Don't show the dialog.
1: Show the dialog</string>
            <string id="bAcroSuppressOpenInReaderDC_x64">Disable Chrome PDF Extension</string>
            <string id="bAcroSuppressOpenInReaderDC_x64_Explain">Specifies whether to disable and lock the PDF viewer Chrome extension.

See also ENABLE_CHROMEEXT .

Possible values include:
0 or null: Extension is enabled; users can open PDFs in a browser with Acrobat Reader
1: Disable the browser-based PDF viewer. A tooltip says &quot;The Acrobat Reader extension is currently disabled. Please contact your IT admin.&quot;</string>
            <string id="iDisablePromptForUpgradeDC_x64">Disable Major Version Upgrade Prompt</string>
            <string id="iDisablePromptForUpgradeDC_x64_Explain">Specifies whether the application should show a prompt suggesting the user upgrade to the next major version (for example, 10.0 to 11.0).

If updates have been disabled (bUpdater = 0), then upgrades are also disabled. The feature also requires that the update settings are set to &quot;automatic.&quot; 0 or null: No effect. 1: Disable the prompt asking users if they would like to upgrade to a higher major version.</string>
            <string id="DisableMaintenanceDC_x64">Disable Repair for All Users</string>
            <string id="DisableMaintenanceDC_x64_Explain">Disables the Repair Installation option for all users.

When set, the Help &gt; Repair Acrobat Installation menu item and the repair option in Windows Apps &amp; Features are disabled, preventing users from modifying the installation without administrator involvement.

Possible values include:
0: Allow repair installation.
1: Disable repair installation.</string>
            <string id="Disable_RepairDC_x64">Disable Repair for Standard Users</string>
            <string id="Disable_RepairDC_x64_Explain">Specifies whether to disable the Help ) Repair Installation menu for standard users on virtualized installations.

When working with virtualized installations, users should not be able to run repair from the help menu. Only an administrator should be able to invoke actions that may require a reboot of a Citrix server, WT server, and so on. To disable the menu item, create this preference and set the value to 1. See also DisableMaintenance . The path is as follows: 32 bit machines: HKLM\SOFTWARE\Adobe\(product)\(version)\Installer 64 bit machines: HKLM\SOFTWARE\Wow6432Node\Adobe\(product)\(version)\Installer</string>
            <string id="IsAMTEnforcedDC_x64">Enforce AMT for AppV Deployment</string>
            <string id="IsAMTEnforcedDC_x64_Explain">Allows deployment of Acrobat on AppV for December, 2018 and later products.

0: Do not use. 1: Required after December 2018 for Acrobat on AppV.</string>
            <string id="bSuppressMessageBarDC_x64">Hide Document Message Bar</string>
            <string id="bSuppressMessageBarDC_x64_Explain">Prevents the appearance of the document message bar.

Adversely affects signing when preview mode is used.</string>
            <string id="bDisablePDFHandlerSwitchingDC_x64">Lock Default PDF Viewer</string>
            <string id="bDisablePDFHandlerSwitchingDC_x64_Explain">Prevents users from changing the default PDF viewer application.

When locked, users cannot reassign PDF file handling to a different application through the Acrobat UI or Windows Apps &amp; Features. This ensures the managed Acrobat installation remains the system default PDF handler.

Possible values include:
0: Allow users to change the default PDF viewer.
1: Lock the default PDF viewer setting.</string>
            <string id="bDisableThumbnailPreviewHandlerDC_x64">Lock PDF Thumbnails in Explorer</string>
            <string id="bDisableThumbnailPreviewHandlerDC_x64_Explain">Specifies whether to disable and lock the user interface option that controls Acrobat-generated PDF thumbnail previews in Windows Explorer.

Oct 13, 2015: 32-bit Windows systems only. 64-bit support was enabled on May 9, 2016. This setting disables the user interface checkbox in the UI.

Possible values include:
0: Enable the UI checkbox so users can invoke the installer and enable the thumbnail preview handler.
1: Disable and lock the setting.</string>
            <string id="bMergeMenuBarDC_x64">Merge Title and Menu Bar</string>
            <string id="bMergeMenuBarDC_x64_Explain">Specifies whether to merge the application's title bar and menu bar into a single bar.

Note that &quot;Policies&quot; does not appear in the HKLM path.

Possible values include:
0: Don't merge the title and menu bars
1: Merge the bars</string>
            <string id="PatchCleanFlagDC_x64">Patch Cache Cleanup</string>
            <string id="PatchCleanFlagDC_x64_Explain">Triggers cleanup of old cached update patch files (MSI/MSP) on the next update cycle.

The Adobe ARM updater downloads MSI/MSP patch files that accumulate over time under C:\ProgramData\Adobe\ARM\ and C:\Windows\Installer\, potentially consuming multiple gigabytes of disk space. Setting this value to 1 causes the updater to remove old cached patch files during the next update.

Possible values include:
0: Do not clean up old patch files.
1: Clean up old cached patch files on next update.</string>
            <string id="bUpdater_UpdaterDC_x64">Product Updater</string>
            <string id="bUpdater_UpdaterDC_x64_Explain">Disables the product Updater and removes associated user interface items.

When set to 1, the Preferences &gt; Updater panel and the Help &gt; Check for Updates menu item are removed. This setting writes bUpdater to the FeatureLockDown root key. To also disable cloud services, set bUpdater = 1 in the cServices key using the Cloud Services Updates policy.

Possible values include:
0: Enable the Updater UI.
1: Disable the Updater and remove its UI items.</string>
            <string id="bShouldUseScalableCursorDC_x64">Scalable Cursor</string>
            <string id="bShouldUseScalableCursorDC_x64_Explain">Specifies whether to disable the scalable cursor.

Because Citrix does not provide support for scalable cursors (32-bit cursors with an alpha channel) in legacy graphics mode, scalable cursor performance may be impaired on Citrix. Use this setting to improve performance on Citrix by using a non-scalable cursor.

Possible values include:
0: Don't use a scalable cursor.
1: Use a scalable cursor.</string>
            <string id="dSplitBySizeMaxSizeDC_x64">Split by Size Maximum (MB)</string>
            <string id="dSplitBySizeMaxSizeDC_x64_Explain">Specifies the file size in MB into which a file may be split.

Users or admins can specify any value between 50 and 1024 megabytes. When values outside of that range are used, the default of 50 is enforced.

Possible values include:
Any value between 50 and 1024. On Mac, the key is an Array which should have two items: A Key named &quot;Item 0&quot; where Type=&quot;Number&quot; with a value of 3, and a key named &quot;Item 1&quot; where Type=&quot;Number&quot; with any Value =</string>
            <string id="dSplitBySizeMaxSizeDC_x64_opt0">50 MB (minimum)</string>
            <string id="dSplitBySizeMaxSizeDC_x64_opt1">100 MB</string>
            <string id="dSplitBySizeMaxSizeDC_x64_opt2">250 MB</string>
            <string id="dSplitBySizeMaxSizeDC_x64_opt3">500 MB</string>
            <string id="dSplitBySizeMaxSizeDC_x64_opt4">1024 MB (maximum)</string>
            <string id="bFavoritesFeaturesLockDownDC_x64">Starred Files Feature</string>
            <string id="bFavoritesFeaturesLockDownDC_x64_Explain">Specifies whether to disable and lock the starred file feature.

A starred file is somewhat similar to a &quot;favorited&quot; file. This preference overrides bFavoritesStripInRFL .

Possible values include:
0: Disable and lock starred files in the recent files list.
1: Use bFavoritesStripInRFL to control this feature.</string>
            <string id="iIntervalDC_x64">Update Watchdog Interval (Days)</string>
            <string id="iIntervalDC_x64_Explain">Sets the time that can elapse without a successful update before the Watchdog dialog appears suggesting the user manually update.

This is an internal key that is not visible unless the admin creates it manually. When the Updater successfully obtains a manifest it records the download date. iInterval specifies the time interval that is allowed to pass from that download date to a successful update. The default is 135 days. If the time has elapsed, a dialog appears suggesting the user might want to manually get an update from adobe.com.

Possible values include:
135 days User specified.</string>
            <string id="iIntervalDC_x64_opt0">90 days</string>
            <string id="iIntervalDC_x64_opt1">135 days (default)</string>
            <string id="iIntervalDC_x64_opt2">180 days</string>
            <string id="iIntervalDC_x64_opt3">365 days</string>
            <string id="iLogLevelDC_x64">Updater Log Level</string>
            <string id="iLogLevelDC_x64_Explain">Sets the log level to either brief (0) or verbose (1).

Log file size is not limited during an update. However, since log files are appended to each time the Updater runs, there is a 1MB limit on old logs. Size limit behavior is as follows: If an existing log size is bigger than 1 MB, the Updater truncates the log. Old log files are backed up once as AdobeARM-backup. Logs reside at: Vista-Windows 7 (64 bit systems) %USERPROFILE%\AppData\Local\Temp\AdobeARM.log XP (32bit systems) %USERPROFILE%\Local Settings\Temp\AdobeARM.log Set the log level as follows: 0: Brief 1: Verbose</string>

            <!-- ======================================== -->
            <!--                  Upsell                  -->
            <!-- ======================================== -->

            <string id="bToggleBillingIssueDC_x64">Disable Billing Issue Call to Action</string>
            <string id="bToggleBillingIssueDC_x64_Explain">Specifies whether to show a Call to Action UI item in the top bar if a billing issue is detected.

Possible values include:
0 or null: Disable the CTA UI.
1: Show the CTA UI.</string>
            <string id="bToggleSophiaWebInfraDC_x64">Disable Promotional Campaign Messages</string>
            <string id="bToggleSophiaWebInfraDC_x64_Explain">Specifies whether to show users messages which promote (Trials, Acrobat, PDF Pack etc.)

Subscription users may be prompted to download Acrobat. Theoretically, this preference does not interact with any other upsell preferences.

Possible values include:
0 or null: Disable campaigns in Reader's right-hand pane bottom banner
1: Enable campaigns</string>
            <string id="bMerchandizingEnabledDC_x64">Express Templates in Create PDF</string>
            <string id="bMerchandizingEnabledDC_x64_Explain">Specifies whether to show the Express Templates options in Acrobat's Create PDF UI.

This feature is an experiment not shown to all users.

Possible values include:
0: Do not show the templates
1: Show the templates</string>
            <string id="bLimitPromptsFeatureKeyDC_x64">Limit Informational Prompts</string>
            <string id="bLimitPromptsFeatureKeyDC_x64_Explain">Specifies whether to limit the number of prompts a user will see in a 24 hour period.

Prompts include items like tips, calls-to-action, and feature walk throughs. These are not necessarily upsell items.

Possible values include:
0: Don't restrict informational prompts.
1: Limit prompts to 1 per day and 3 per week.</string>
            <string id="bToggleDCAppCenterDC_x64">Show App Center UI</string>
            <string id="bToggleDCAppCenterDC_x64_Explain">Specifies whether to show the UI that helps users find and download additional apps.

By default, the Home view displays a &quot;get apps&quot; banner and/or a link to the App Center where users can find and download additional apps (such as mobile apps). This preference removes both the banner and the App Center.

Possible values include:
0 (or null): Show the App Center UI.
1: Don't show the App Center UI.</string>
            <string id="bAcroSuppressUpsellDC_x64">Show Upgrade Prompts</string>
            <string id="bAcroSuppressUpsellDC_x64_Explain">Controls whether upgrade prompts and upsell messages are shown to Acrobat Reader users.

When suppressed, in-product prompts encouraging users to upgrade to Acrobat Pro are hidden. Disabling upsell messages reduces distractions and prevents users from purchasing or installing software outside of approved channels.

Possible values include:
0: Show upgrade and upsell prompts.
1: Suppress upgrade and upsell prompts.</string>
            <string id="bEnableTrialistLaunchCardDC_x64">Trial Purchase Prompt</string>
            <string id="bEnableTrialistLaunchCardDC_x64_Explain">Specifies whether to prompt Acrobat trial users to complete the purchase.

Possible values include:
0: Disable the purchase Acrobat prompt.
1: Don't disable the prompt.</string>
            <!-- ======================================== -->
            <!--                                          -->
            <!-- Adobe Acrobat DC (x86) - policy strings  -->
            <!--                                          -->
            <!-- ======================================== -->

            <!-- ======================================== -->
            <!--           Cloud and Connectors           -->
            <!-- ======================================== -->

            <string id="bToggleFillSignDC_x86">Adobe Fill &amp; Sign</string>
            <string id="bToggleFillSignDC_x86_Explain">Disables Adobe Fill and Sign.

Possible values include:
0: Enable Adobe Fill and Sign.
1: Disable Adobe Fill and Sign.</string>
            <string id="bBoxConnectorEnabledDC_x86">Box Cloud Connector</string>
            <string id="bBoxConnectorEnabledDC_x86_Explain">Specifies whether to enable connection to the Box cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Box
1: Enable connection to Box</string>
            <string id="bToggleAdobeDocumentServicesDC_x86">Document Cloud Services</string>
            <string id="bToggleAdobeDocumentServicesDC_x86_Explain">Controls access to Adobe Document Cloud services excluding Acrobat Sign, preference sync, and third-party connectors.

Disabling this removes cloud-based features including Create PDF, Export PDF, Organize Pages, and Combine Files. To disable all hosted services including web-plugin updates, set bUpdater = 1 instead.

Possible values include:
0: Enable Document Cloud services.
1: Disable Document Cloud services.</string>
            <string id="bToggleDocumentCloudDC_x86">Document Cloud Storage</string>
            <string id="bToggleDocumentCloudDC_x86_Explain">Specifies whether to enable Document Cloud storage.

DC storage is enabled by default.

Possible values include:
0: Enable Document Cloud storage.
1: Disable Document Cloud storage.</string>
            <string id="bDropboxConnectorEnabledDC_x86">Dropbox Cloud Connector</string>
            <string id="bDropboxConnectorEnabledDC_x86_Explain">Specifies whether to enable connection to the Dropbox cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Dropbox
1: Enable connection to Dropbox</string>
            <string id="bEnableGentechDC_x86">Generative AI Technology</string>
            <string id="bEnableGentechDC_x86_Explain">Specifies whether to enable generative AI features in Acrobat and Reader.

Possible values include:
0: Disable generative AI features.
1: Enable generative AI features. Generative AI capabilities may rely on cloud services; verify organizational policies and Adobe documentation for data handling.</string>
            <string id="bGoogleDriveConnectorEnabledDC_x86">Google Drive Connector</string>
            <string id="bGoogleDriveConnectorEnabledDC_x86_Explain">Specifies whether to enable connection to the Google Drive cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Google Drive
1: Enable connection to Google Drive</string>
            <string id="bToggleSendACopyDC_x86">Hide Fill &amp; Sign Send a Copy Button</string>
            <string id="bToggleSendACopyDC_x86_Explain">Specifies whether to hide the Send a Copy button from the Fill &amp; Sign tool in Acrobat and Reader.

Possible values include:
0: Hide the button.
1: Show the button.</string>
            <string id="bSuppressSignOutDC_x86">Hide Sign Out Menu Item</string>
            <string id="bSuppressSignOutDC_x86_Explain">Specifies whether the sign-in and sign-out Help menu item should be enabled.

Possible values include:
0 or null: Don't disable the menu item.
1: Disable the Help menu item.</string>
            <string id="bOneDriveConnectorEnabledDC_x86">OneDrive Connector</string>
            <string id="bOneDriveConnectorEnabledDC_x86_Explain">Specifies whether to enable connection to the OneDrive cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to OneDrive
1: Enable connection to OneDrive</string>
            <string id="bTogglePrefsSyncDC_x86">Preferences Synchronization</string>
            <string id="bTogglePrefsSyncDC_x86_Explain">Controls whether application preferences are synchronized across devices via Adobe Document Cloud.

When a user is signed in with an Adobe ID, preferences can sync across desktop and mobile installations. Disabling this prevents preference data from leaving the managed environment and avoids unintended preference changes from personal devices.

Possible values include:
0: Enable preferences synchronization.
1: Disable preferences synchronization.</string>
            <string id="bUpdater_UpdatesDC_x86">Services &amp; Web-Plugin Updates</string>
            <string id="bUpdater_UpdatesDC_x86_Explain">Disables web-plugin component updates and all Adobe hosted services.

This is the master service switch for DC products under the cServices key, replacing the deprecated bEnableAcrobatHS preference. Setting to 1 disables both web-plugin updates and in-product cloud service access. To also remove the Updater UI, set bUpdater = 1 under the FeatureLockDown root key via the Services and Web-Plugin Updates policy.

Possible values include:
0: Enable cloud services and web-plugin updates.
1: Disable cloud services and web-plugin updates.</string>
            <string id="bToggleWebConnectorsDC_x86">Third-Party Cloud Connectors</string>
            <string id="bToggleWebConnectorsDC_x86_Explain">Controls in-product access to third-party cloud storage connectors such as Box, Dropbox, OneDrive, and Google Drive.

Disabling this removes the third-party connectors from the Home view, Open/Save dialogs, and the Add Account option. Individual connectors can be selectively re-enabled using bBoxConnectorEnabled, bDropboxConnectorEnabled, bGoogleDriveConnectorEnabled, and bOneDriveConnectorEnabled.

Possible values include:
0: Enable third-party cloud connectors.
1: Disable third-party cloud connectors.</string>

            <!-- ======================================== -->
            <!--        Context, Tools and Search         -->
            <!-- ======================================== -->

            <string id="bUIDensityAutoDetectionEnabledDC_x86">Auto UI Density Detection</string>
            <string id="bUIDensityAutoDetectionEnabledDC_x86_Explain">Specifies whether to disable the auto detection logic and bezel for changing Acrobat's display size.

By default, the UI is enabled so that a user may change the display size based on device screen size, resolution, and monitor scaling. 0: Disable the UI. 1: Show the UI.</string>
            <string id="ADC4275035_ClickEditDC_x86">Click-to-Edit Mode</string>
            <string id="ADC4275035_ClickEditDC_x86_Explain">Specifies whether to automatically enter edit mode when a user clicks a PDF object.

When enabled, clicking on an image or text results in edit tools appearing in the right-hand pane and edit mode is enabled in the Forms tool. Clicking on any form field enables the form authoring mode.

Possible values include:
0 or null: Do not dynamically switch into edit mode.
1: Automatically enter edit mode on user click.</string>
            <string id="bEnableCloudPoweredSearchTokenCachingDC_x86">Cloud Search Token Caching</string>
            <string id="bEnableCloudPoweredSearchTokenCachingDC_x86_Explain">Specifies whether to cache locally cloud-based search service suggestions.

Possible values include:
0 or null: Don't cache cloud search service suggestions
1: Cache suggestions</string>
            <string id="bEnableCloudPoweredSearchDC_x86">Cloud-Powered Search</string>
            <string id="bEnableCloudPoweredSearchDC_x86_Explain">Specifies whether to enable the cloud-based search service in the Find Tool.

Interacts with bEnableCloudPoweredSearchTokenCaching . Data sent to the cloud is not stored and is encrypted.

Possible values include:
0 or null: Don't enable the cloud search service
1: Enable the cloud search service</string>
            <string id="bEnableContextualTipsDC_x86">Contextual Help Tips</string>
            <string id="bEnableContextualTipsDC_x86_Explain">Controls whether to automatically display help tips based on the current context.

Possible values include:
0: Disable contextual tips.
1: Enable tips.</string>
            <string id="bEnableContextualToolbarDC_x86">Contextual Toolbar</string>
            <string id="bEnableContextualToolbarDC_x86_Explain">Specifies whether to show the context toolbar (popup) when selecting a PDF object.

When enabled, a popup, floating toolbar appears when a user interacts with a PDF. For example, selecting text displays text markup tools. Selecting an image displays sticky note and editing tools.

Possible values include:
0: Don't show context toolbars.
1: Show toolbars.</string>
            <string id="bEnableExtractPageRangeDC_x86">Extract Page Range UI</string>
            <string id="bEnableExtractPageRangeDC_x86_Explain">Specifies whether to show the page range UI in the Extract Page dialog.

0: Don't show the page range UI. 1: Show the page range UI.</string>
            <string id="ADC4275034DC_x86">Fill &amp; Sign Color Picker</string>
            <string id="ADC4275034DC_x86_Explain">Specifies whether to disable the color picker in the Fill and Sign tool.

The color picker is only supported on the Continuous track.

Possible values include:
0: Disable the color picker
1: Enable the color picker</string>
            <string id="ProtectOldExperienceDC_x86">Legacy Protect Tool Menu</string>
            <string id="ProtectOldExperienceDC_x86_Explain">Specifies whether to disable the new Protect tool and revert to the old menu

The Protect tool provides options for encrypting and password protecting documents. The new UI provides some streamlined options, but this preference supports using the old menus.

Possible values include:
0 or null: Use the new protect app experience.
1: Revert to the existing (pre October, 2019) protect app experience.</string>
            <string id="bDisableAcrobatShortcutCustomizationDC_x86">Lock Tool Shortcut Customization</string>
            <string id="bDisableAcrobatShortcutCustomizationDC_x86_Explain">Prevents end users from modifying the tool shortcuts in the right hand pane.

Possible values include:
0: Don't disable shortcuts.
1: Disable shortcuts.</string>
            <string id="bEnableAV2EnterpriseDC_x86">Modern Viewer</string>
            <string id="bEnableAV2EnterpriseDC_x86_Explain">Specifies whether to enable the Modern Viewer.

The new app UI is rolling out in phases over 2023. As of June, 25% of users will see the updated user interface. This preference may interact with bShownViewerOnboarding and bEnableAV2 .

Possible values include:
0: Don't show the Modern Viewer
1: Show the Modern Viewer</string>
            <string id="bEnableRCMNewPOPUpDC_x86">New Right-Click Context Menu</string>
            <string id="bEnableRCMNewPOPUpDC_x86_Explain">Specifies whether to disable the new context menu and use the legacy version.

A new right-click context menu displays icons and additional menu options. 0: Disable the new context menu. 1: Enable the new menu.</string>
            <string id="bFindMoreWorkflowsOnlineDC_x86">Online Actions Library Link</string>
            <string id="bFindMoreWorkflowsOnlineDC_x86_Explain">Specifies whether to show the menu item that opens the online Actions file library.

Possible values include:
0: Disable the menu item.
1 or null: Don't disable the menu item.</string>
            <string id="bFindMoreCustomizationsOnlineDC_x86">Online Tool Set Exchange Link</string>
            <string id="bFindMoreCustomizationsOnlineDC_x86_Explain">Specifies whether to show the menu item that opens the online Acrobat Tool Set Exchange.

Possible values include:
0: Disable the menu item.
1 or null: Don't disable the menu item.</string>
            <string id="bOrganizePagesFromThumbnailsDC_x86">Organize Pages Thumbnail Shortcut</string>
            <string id="bOrganizePagesFromThumbnailsDC_x86_Explain">Specifies whether to show shortcut UI for the Organize tool from thumbnails.

Possible values include:
0: Don't show Organize Pages tool shortcut from thumbnails
1: Show the Organize Pages tool shortcut</string>
            <string id="ADC4302862DC_x86">Paste in Place</string>
            <string id="ADC4302862DC_x86_Explain">Specifies whether to paste copied elements to the exact location as the copied element.

Some copy/paste operations are more efficient when copied elements are pasted to an identical location in the target document. This feature applies to form fields, annotations, and links.

Possible values include:
0: Disable the paste-in-place feature.
1: Enable the paste-in-place feature.</string>
            <string id="ADC4275035DC_x86">Remove Form Editing Tools (2019)</string>
            <string id="ADC4275035DC_x86_Explain">Specifies whether to remove the forms tools delivered with the October, 2019 release.

Editing features are now part of the Form tools. For example, there are AddText and EditText tools in the Prepare Form top toolbar. Systems that encounter issues with these tools (or simply want them removed from the UI) can disable these new features.

Possible values include:
0 or null: Do nothing.
1: Remove the AddText and EditText tools.</string>
            <string id="bRCMCombineFeatureKeyDC_x86">Show Combine Files Context Menu</string>
            <string id="bRCMCombineFeatureKeyDC_x86_Explain">Specifies whether to display the Combine Files item in a document's right-click context menu.

This preference only applies to machines that display the Modern Viewer (a phased rollout over 2023). When the Modern Viewer is disabled, admins can toggle the Combine Files UI off/on.

Possible values include:
0: Don't show the Combine Files UI.
1: Do show the Combine Files UI.</string>
            <string id="bEnableAutoCompleteExactMatchLoaderDC_x86">Show Search Loading Message</string>
            <string id="bEnableAutoCompleteExactMatchLoaderDC_x86_Explain">Specifies whether to show a &quot;Working on it&quot; message when using the cloud-based search service.

The message appears in the Suggestions section of the Find tool's autocomplete list.

Possible values include:
0 or null: Don't show the message
1: Show the message</string>
            <string id="bEnableAutoCompleteNoInternetConnectionHeaderDC_x86">Show Search No Internet Message</string>
            <string id="bEnableAutoCompleteNoInternetConnectionHeaderDC_x86_Explain">Specifies whether to show a &quot;Requires internet connection&quot; message when using the cloud-based search service.

The message appears in the Suggestions section of the Find tool's autocomplete list.

Possible values include:
0 or null: Don't show the message
1: Show the message</string>
            <string id="bEnableAutoCompleteNoExactMatchHeaderDC_x86">Show Search No Match Message</string>
            <string id="bEnableAutoCompleteNoExactMatchHeaderDC_x86_Explain">Specifies whether to show a &quot;No exact match&quot; message when using the cloud-based search service.

The message appears in the Suggestions section of the Find tool's autocomplete list.

Possible values include:
0 or null: Don't show the message
1: Show the message</string>

            <!-- ======================================== -->
            <!--   Documents, Editing and Accessibility   -->
            <!-- ======================================== -->

            <string id="bCloudATFeatureEnableDC_x86">Accessibility Auto Tagging</string>
            <string id="bCloudATFeatureEnableDC_x86_Explain">Specifies whether to show the new auto tagging experience or revert to the old experience.

Possible values include:
0: Disable the new auto tagging feature in the accessibility UI.
1: Enable the new auto tagging feature in the accessibility UI.</string>
            <string id="bBatesLogOriginalFileNameDC_x86">Bates Log Original File Name</string>
            <string id="bBatesLogOriginalFileNameDC_x86_Explain">Specifies whether to use the original filename in the log file when the user selects Bates number-based output filenames.

Users have a UI option to &quot;Replace file names with the starting and ending Bates number.&quot; This setting allows users to see the original file name in the log file.

Possible values include:
0: Use the starting and ending Bates number as the filename in the log.
1: Retain the original file name.</string>
            <string id="BlockEMFParsingDC_x86">Block EMF to PDF Conversion</string>
            <string id="BlockEMFParsingDC_x86_Explain">Specifies whether to disable EMF file conversion to PDF.

When set to 1, Acrobat will display an &quot;unsupported&quot; dialog and block conversion of EMF files to PDF. 0: Enable EMF conversion to PDF. 1: Disable EMF conversion to PDF.

When this policy is Enabled, EMF-to-PDF conversion is blocked. When Disabled, conversion is allowed.</string>
            <string id="BlockXPSParsingDC_x86">Block XPS to PDF Conversion</string>
            <string id="BlockXPSParsingDC_x86_Explain">Specifies whether to disable XPS file conversion to PDF.

When set to 1, Acrobat will display an &quot;unsupported&quot; dialog and block conversion of XPS files to PDF. 0: Enable XPS conversion to PDF. 1: Disable XPS conversion to PDF.

When this policy is Enabled, XPS-to-PDF conversion is blocked. When Disabled, conversion is allowed.</string>
            <string id="bGlobalBarMenuFeatureKeyDC_x86">Create PDF Split Menu</string>
            <string id="bGlobalBarMenuFeatureKeyDC_x86_Explain">Specifies whether to show the Create Split Menu under Create a PDF menu item.

Possible values include:
0: Don't show the Create Split menu.
1: Show the Create Split menu.</string>
            <string id="DisableScannedDocumentEditingDC_x86">Disable Scanned PDF Text Recognition</string>
            <string id="DisableScannedDocumentEditingDC_x86_Explain">Specifies whether to disable text recognition while editing scanned PDFs.

Possible values include:
0: Text recognition will be performed when invoking editing on scanned PDFs.
1: Text recognition will not be performed when invoking editing on scanned PDFs.</string>
            <string id="EnablePDFMakerGroupImagesTagCorrectionFeatureDC_x86">PDFMaker Grouped Image Tag Fix</string>
            <string id="EnablePDFMakerGroupImagesTagCorrectionFeatureDC_x86_Explain">Specifies whether to disable accessibility fixes for tagging grouped images.

0: Disable. 1: Enable.</string>
            <string id="EnablePDFMakerTableHeaderCellTagAndScopeUpdateFeatureDC_x86">PDFMaker Table Header Tag Fix</string>
            <string id="EnablePDFMakerTableHeaderCellTagAndScopeUpdateFeatureDC_x86_Explain">Specifies whether to disable accessibility fixes for tagging table headers.

0: Disable. 1: Enable.</string>
            <string id="EnablePDFMakerSplitTextPathElemsFeatureDC_x86">PDFMaker Text Path Tag Fix</string>
            <string id="EnablePDFMakerSplitTextPathElemsFeatureDC_x86_Explain">Specifies whether to enable the &quot;SplitTextPathElemsFeature&quot; tags correction feature when creating a PDF with Acrobat.

This preference addresses a bug introduced in 2020 which resulted in certain document elements such as element borders and alt text incorrectly rendering as the strings &quot;PathPath&quot;. This feature is enabled and mitigates the bug by default. 0: Disable tag correction. 1: Enable the SplitTextPathElemsFeature tags correction feature.</string>
            <string id="bEnableReflowEditingDC_x86">Reflow Editing</string>
            <string id="bEnableReflowEditingDC_x86_Explain">Specifies whether to lock ReflowEditing and the reflow feature.

See ReflowEditing for feature details.

Possible values include:
0: Disable and lock the feature.
1: Don't lock the feature and allow the user to toggle it off and on from the Preferences UI.</string>
            <string id="bIgnoreDataSchemaDC_x86">Restrict Form Data to Schema</string>
            <string id="bIgnoreDataSchemaDC_x86_Explain">Specifies whether all data in a form is saved rather than only data related to the form's schema.

Possible values include:
null: Save form data even when it's not part of a schema.
1: Save only form data that's part of the schema.</string>

            <!-- ======================================== -->
            <!--         Microsoft Purview (MIP)          -->
            <!-- ======================================== -->

            <string id="bMIPCheckPolicyOnDocSaveDC_x86">Check MIP Policy on Save</string>
            <string id="bMIPCheckPolicyOnDocSaveDC_x86_Explain">Locks enforcement of default or mandatory Microsoft Purview Information Protection labeling checks when saving documents.

Machine-level FeatureLockDown lockdown; grays out the related Preferences UI once set. Requires default or mandatory labeling to be configured in the Microsoft Purview compliance portal.

Possible values include:
0: Do not lock save-time MIP policy check.
1: Lock save-time MIP policy check enabled. This is admin lockdown under HKLM, not the per-user MicrosoftAIP preferences in User ADMX.</string>
            <string id="bMIPLabellingDC_x86">Enable MIP Labelling</string>
            <string id="bMIPLabellingDC_x86_Explain">Locks the Enable Microsoft Purview Information Protection option in Preferences ) Security.

Machine-level FeatureLockDown lockdown; end users cannot change the checkbox once this policy is applied.

Possible values include:
0: Do not lock MIP labelling preference.
1: Lock MIP labelling enabled. Complements per-user MicrosoftAIP preferences in User ADMX; this policy controls admin lockdown only.</string>
            <string id="bEnableDKEAdminDC_x86">MIP Double Key Encryption</string>
            <string id="bEnableDKEAdminDC_x86_Explain">Locks double key encryption (DKE) label support for Microsoft Purview Information Protection.

Machine-level FeatureLockDown lockdown for MIP DKE workflows.

Possible values include:
0: Lock DKE disabled.
1: Lock DKE enabled.</string>
            <string id="bMIPExternalAuthAdminDC_x86">MIP External Browser Auth</string>
            <string id="bMIPExternalAuthAdminDC_x86_Explain">Locks browser-based authentication for Microsoft Purview Information Protection operations.

Machine-level FeatureLockDown lockdown.

Possible values include:
0: Lock external browser auth disabled.
1: Lock external browser auth enabled.</string>
            <string id="iMIPCloudDC_x86">MIP Sovereign Cloud</string>
            <string id="iMIPCloudDC_x86_Explain">Locks which Microsoft cloud instance Acrobat and Reader use for MIP SDK operations.

Machine-level FeatureLockDown lockdown. Relevant for sovereign and government tenants. MIP SDK Cloud enum values: 0: Unknown. 1: Custom. 2: Test. 3: Commercial (default/global). 4: Germany. 5: US DoD. 6: US GCC. 7: US GCC High. 8: US Sec. 9: US Nat. 10: China.</string>
            <string id="iMIPCloudDC_x86_opt0">Unknown</string>
            <string id="iMIPCloudDC_x86_opt1">Custom</string>
            <string id="iMIPCloudDC_x86_opt2">Test</string>
            <string id="iMIPCloudDC_x86_opt3">Commercial</string>
            <string id="iMIPCloudDC_x86_opt4">Germany</string>
            <string id="iMIPCloudDC_x86_opt5">US DoD</string>
            <string id="iMIPCloudDC_x86_opt6">US GCC</string>
            <string id="iMIPCloudDC_x86_opt7">US GCC High</string>
            <string id="iMIPCloudDC_x86_opt8">US Sec</string>
            <string id="iMIPCloudDC_x86_opt9">US Nat</string>
            <string id="iMIPCloudDC_x86_opt10">China</string>
            <string id="bSilentAuthDC_x86">Suppress OS Auth Prompts (MIP)</string>
            <string id="bSilentAuthDC_x86_Explain">Locks whether operating-system authentication prompts are suppressed during MIP operations.

By default, OS-driven auth prompts for MIP are suppressed. Set policy Disabled to write DWORD 0 and allow OS auth prompts (useful when troubleshooting AADSTS50020-type errors).

Possible values include:
0: Allow OS auth prompts.
1: Suppress OS auth prompts.</string>

            <!-- ======================================== -->
            <!--    Security: Execution and Protection    -->
            <!-- ======================================== -->

            <string id="bEnable3DDC_x86">3D Content in PDFs</string>
            <string id="bEnable3DDC_x86_Explain">Specifies whether to trust and render 3D content in PDFs.

This setting can override b3DEnableContent.

Possible values include:
0: Don't render 3D content.
1: Trust and render 3D files.</string>
            <string id="bEnableProtectedModeAppContainerDC_x86">AppContainer Sandbox</string>
            <string id="bEnableProtectedModeAppContainerDC_x86_Explain">Specifies whether to enable the AppContainer sandbox.

Possible values include:
0: Disable Microsoft's AppContainer sandbox
1: Enable Microsoft's AppContainer sandbox</string>
            <string id="bEnableBlacklistForOpenSaveDC_x86">Attachment Extension Blocklist in Dialogs</string>
            <string id="bEnableBlacklistForOpenSaveDC_x86_Explain">Reverts the tBuiltInPermList behavior to that of the pre 21.011.20029 build.

Beginning with build 21.011.20029, extensions added in the tBuiltInPermList with restriction level 3 will be missing from the menu items in all the save and open dialogs. This feature is enabled by default. Users can revert to the old behavior by setting FeatureLockDown/bEnableBlacklistForOpenSave to 0.

Possible values include:
0: Revert to the legacy behavior.
1: Do nothing. Retain the new behavior.</string>
            <string id="bDisableJavaScriptDC_x86">Block JavaScript Execution</string>
            <string id="bDisableJavaScriptDC_x86_Explain">Blocks and locks JavaScript execution in PDF documents, preventing users from bypassing via privileged locations.

This lockable setting overrides bEnableJS and prevents users from re-enabling JavaScript through the Yellow Message Bar or Trusted Locations.

Possible values include:
0 or null: Don't disable JS.
1: Disable and lock JS.</string>
            <string id="iFileAttachmentPermsDC_x86">Block non-PDF file attachments</string>
            <string id="iFileAttachmentPermsDC_x86_Explain">Controls whether embedded file attachments of types other than PDF or FDF can be opened from within a PDF.

Restricting file attachments prevents users from launching non-PDF embedded files with external applications, reducing the risk of executing malicious payloads delivered inside PDF documents.

Possible values include:
1: Block non-PDF file attachments.
3: Prompt the user before opening non-PDF file attachments.</string>
            <string id="bDisablePDFRedirectionActionsDC_x86">Block PDF Link Actions</string>
            <string id="bDisablePDFRedirectionActionsDC_x86_Explain">Specifies whether to block specific PDF actions (listed below) which result in opening a link.

This preference does not block regular web links. Enabling this feature blocks PDF actions that open links, including GoToE, GoToR, Launch, Thread, Import Data, Export Form Data, Submit Form, and Reset Form.

Possible values include:
0 or null: Don't block these opening links.
1: Block links.</string>
            <string id="tBuiltInPermListDC_x86">Built-in Attachment Permissions List</string>
            <string id="tBuiltInPermListDC_x86_Explain">Defines the white and black list of file types that can be saved and opened from a document.

Pipe-separated list of file extensions with permission levels. Format: version:1|.ext:N where N is 0 (prompt, no allow), 1 (prompt, can allow/prohibit), 2 (always open), or 3 (never open). Referenced by bEnableBlacklistForOpenSave. Extensions with level 3 are hidden from save/open dialogs (build 21.011.20029+).</string>
            <string id="bEnablePVCertificateBasedTrustDC_x86">Certification Status in Protected View</string>
            <string id="bEnablePVCertificateBasedTrustDC_x86_Explain">Specifies whether a document's certification status should appear in the Protected View document message bar.

Possible values include:
0: Don't show the document's certification status.
1: Do show the document's certification status.</string>
            <string id="bEnhancedSecurityInBrowserDC_x86">Enhanced Security in Browser</string>
            <string id="bEnhancedSecurityInBrowserDC_x86_Explain">Controls Enhanced Security mode for PDFs opened inside a web browser.

When Enhanced Security is enabled in browser mode, Acrobat and Reader restrict unsafe document behaviors for PDFs viewed via the browser plugin, complementing the standalone application setting (bEnhancedSecurityStandalone).

Possible values include:
0: Disable Enhanced Security in browser mode.
1: Enable Enhanced Security in browser mode.</string>
            <string id="bEnhancedSecurityStandaloneDC_x86">Enhanced Security Standalone</string>
            <string id="bEnhancedSecurityStandaloneDC_x86_Explain">Controls Enhanced Security mode for PDFs opened in the standalone application.

When Enhanced Security is enabled, Acrobat and Reader restrict potentially unsafe document behaviors such as accessing external URLs, running scripts, and silently sending data to remote hosts. This reduces the risk of exploitation by malicious PDFs.

Possible values include:
0: Disable Enhanced Security in standalone mode.
1: Enable Enhanced Security in standalone mode.</string>
            <string id="bEnableFlashDC_x86">Flash Content in PDFs</string>
            <string id="bEnableFlashDC_x86_Explain">Controls whether Adobe Flash Player content embedded in PDF files is permitted to run.

Adobe Flash reached end-of-life in December 2020 and is no longer supported or patched. All Flash content in PDFs should be blocked to prevent exploitation of known unpatched Flash vulnerabilities.

Possible values include:
0: Block Flash content in PDFs.
1: Allow Flash content in PDFs.</string>
            <string id="EnableFlashEditingDC_x86">Flash Editing Tools</string>
            <string id="EnableFlashEditingDC_x86_Explain">Specifies whether to enable the Flash tools for adding annotations or Flash in the Rich Media app.

Possible values include:
0 or null: Remove &quot;Disable Flash ) Add SWF menu item.&quot;
1: Show the menu item.</string>
            <string id="bProtectedModeDC_x86">Protected Mode Sandbox</string>
            <string id="bProtectedModeDC_x86_Explain">Controls Protected Mode, which isolates the PDF rendering engine in a sandboxed process.

Protected Mode uses Windows integrity levels to restrict the renderer's access to the file system, registry, and network. This significantly limits the damage a successful PDF exploit can cause by preventing it from accessing system resources directly.

Possible values include:
0: Disable Protected Mode.
1: Enable Protected Mode.</string>
            <string id="bEnablePVSwitchoutShortcutDC_x86">Protected View Exit Shortcut Key</string>
            <string id="bEnablePVSwitchoutShortcutDC_x86_Explain">Enables a shortcut key that allows users to exit Protected View for a specific document.

This feature allows admins and users to keep Protected View enabled, but also exit that mode on-the-fly when necessary.

Possible values include:
0: Disable the shortcut key.
1: Enable the shortcut key that exits Protected View.</string>
            <string id="iProtectedViewDC_x86">Protected View Mode</string>
            <string id="iProtectedViewDC_x86_Explain">Controls Protected View, which opens PDFs in a restricted read-only mode before granting full access.

In Protected View, most application features are disabled and the document is rendered in a locked-down process. This provides an additional security boundary for files from untrusted sources before full rendering permissions are granted.

Possible values include:
0: Disable Protected View.
1: Enable Protected View for files from potentially unsafe locations.
2: Enable Protected View for all files.</string>
            <string id="iProtectedViewDC_x86_opt0">Disable Protected View</string>
            <string id="iProtectedViewDC_x86_opt1">Enable Protected View for unsafe locations only</string>
            <string id="iProtectedViewDC_x86_opt2">Enable Protected View for all files</string>
            <string id="iUnlistedAttachmentTypePermDC_x86">Unlisted Attachment Type Permissions</string>
            <string id="iUnlistedAttachmentTypePermDC_x86_Explain">Specifies the default permissions for file types that aren't listed in the default or user-specified lists.

Possible values include:
0: Prompt user without ability to set file type as Allowed (two choices: Open File, Never Allow).
1 (default): Prompt user with ability to Allow or Prohibit (three choices).
2: Always open unlisted file types.
3: Never open unlisted file types.</string>
            <string id="iUnlistedAttachmentTypePermDC_x86_opt0">Prompt without ability to allow (most restrictive prompt)</string>
            <string id="iUnlistedAttachmentTypePermDC_x86_opt1">Prompt with ability to allow or prohibit (default)</string>
            <string id="iUnlistedAttachmentTypePermDC_x86_opt2">Always open unlisted file types</string>
            <string id="iUnlistedAttachmentTypePermDC_x86_opt3">Never open unlisted file types (most restrictive)</string>

            <!-- ======================================== -->
            <!--     Security: Trust and Permissions      -->
            <!-- ======================================== -->

            <string id="bMSStoreTrustedDC_x86">Allow Changes to Windows Certificate Store Trust</string>
            <string id="bMSStoreTrustedDC_x86_Explain">Locks the UI so that end users cannot change the value set by iMSStoreTrusted.

Set iMSStoreTrusted first, then use this preference to lock it. Allowable values include: 0: Lock the UI. 1: Same as null. Don't lock the UI.</string>
            <string id="bAllowInvisibleSigDC_x86">Allow Invisible Signatures</string>
            <string id="bAllowInvisibleSigDC_x86_Explain">Specifies whether to allow invisible certification signatures.

False disables the menu option, prevents signing and certifying with invisible signatures, and limits JavaScript support by signature fields.</string>
            <string id="bAllowPasswordSavingDC_x86">Allow Password Caching</string>
            <string id="bAllowPasswordSavingDC_x86_Explain">Controls whether certain passwords can be cached to disk; for example, passwords for digital IDs.

If false, users are prompted to enter a password every time one is required. Not all passwords are affected by this setting.</string>
            <string id="bEnableSignatureClearDC_x86">Allow Signature Clearing</string>
            <string id="bEnableSignatureClearDC_x86_Explain">Specifies whether to disable and lock the ability for a signer to clear their own signature.

Possible values include:
0: Disable signature clearing.
1: Enable signature clearing.</string>
            <string id="bVerifyUseAlwaysDC_x86">Always Use Specified Verify Handler</string>
            <string id="bVerifyUseAlwaysDC_x86_Explain">Qualifies the use of aVerify.

If true and aVerify is set to a handler name, then this handler is used to verify all signatures. If false, then the aVerify handler is used only to verify signatures when the handler specified by the signature dictionary Filter attribute is not present.</string>
            <string id="bDisableExpandEnvironmentVariablesDC_x86">Block User Library Trust in Protected View</string>
            <string id="bDisableExpandEnvironmentVariablesDC_x86_Explain">Provides a method for admins to whitelist user libraries as trusted locations when Protected View is enabled.

Protected View restricts features for all documents that do not reside in a trusted location. This new preference provides a way for admins to specify user-specific locations as trusted; in other words, documents with the path C:\Users\%username%\Desktop will open outside Protected View. For example, the user libraries Documents, Downloads, Desktop, and so on. When this preference is off, admins can only specify trusted locations which are static/identical for all users across their organization.

Possible values include:
0: Trust user-specific locations.
1: Don't trust user-specific locations.</string>
            <string id="bWinCacheSessionHandlesDC_x86">Cache Digital ID Session Handles</string>
            <string id="bWinCacheSessionHandlesDC_x86_Explain">Specifies whether to retain cryptographic service provider (CSP) handles when a user authenticates to a digital ID.

If true, a user does not have to re-authenticate to use the ID unless they log out or the session ends. The impact of this preference will vary based on the CSP in use; however, the setting does not affect the Windows CSPs.</string>
            <string id="bDisableOSTrustedSitesDC_x86">Disable IE Trusted Sites as Privileged Locations</string>
            <string id="bDisableOSTrustedSitesDC_x86_Explain">Locks the ability to treat IE trusted sites as privileged locations either on or off so the users can't change the bTrustOSTrustedSites value via the user interface.

If set, bTrustOSTrustedSites is simply ignored.

Possible values include:
0 or null: Enables and locks trusting sites from IE.
1: Disables and locks trusting sites from IE.</string>
            <string id="bAllowAPSConfigDC_x86">LiveCycle RMS Server Config</string>
            <string id="bAllowAPSConfigDC_x86_Explain">Prevents a LiveCycle Right Management Server from being configured by disabling the menu option in the Security Settings Console.

By default, configuration is allowed.</string>
            <string id="bReqRevCheckDC_x86">Lock Revocation Check Setting</string>
            <string id="bReqRevCheckDC_x86_Explain">Locks Security\cASPKI\cASPKI\cVerify\iReqRevCheck and disables the user interface item.</string>
            <string id="bReasonsDC_x86">Lock Signing Reasons Settings</string>
            <string id="bReasonsDC_x86_Explain">Prevents users from modifying reason settings.

v8.1: If locked and cReasons is empty, bAllowSigningReasons is 0 and read only. If locked and cReasons has values, then bAllowSigningReasons is true and read only.</string>
            <string id="bDisableTrustedFoldersDC_x86">Lock Trusted Folders and Files</string>
            <string id="bDisableTrustedFoldersDC_x86_Explain">Prevents users from adding trusted file and folder locations to Privileged Locations.

Privileged Locations bypass Enhanced Security restrictions. Allowing users to define them creates a pathway to weaken document security. Locking this setting prevents users from creating local exceptions that could expose the application to malicious PDFs.

Possible values include:
0: Allow users to configure trusted folder and file locations.
1: Disable and lock trusted folder and file locations.</string>
            <string id="bDisableTrustedSitesDC_x86">Lock Trusted Host Sites</string>
            <string id="bDisableTrustedSitesDC_x86_Explain">Prevents Internet Explorer Trusted Sites from being elevated to Privileged Locations.

Privileged Locations bypass Enhanced Security restrictions. Importing IE Trusted Sites as privileged locations could allow a broad set of sites to bypass document security controls. Locking this setting keeps the Privileged Locations list under administrator control.

Possible values include:
0: Allow IE Trusted Sites to be added as Privileged Locations.
1: Disable and lock the IE Trusted Sites elevation.</string>
            <string id="bEnableCEFBasedUIDC_x86">Modern Digital Signature UI</string>
            <string id="bEnableCEFBasedUIDC_x86_Explain">Specifies whether to enable the CEF-based, modern UI for digital signature workflows.

The newer UI streamlines the user interface. All values also disable the UI option to change the preference. Note that for products released after June 2016, disabling a user's ability to create a self-signed digital ID requires setting both bSelfSignCertGen and bEnableCEFBasedUI to 0.

Possible values include:
0: Disable the modern UI and shows the legacy UI.
1: Enable the Modern UI.</string>
            <string id="bUseTSAsSigningTimeDC_x86">Show Timestamp in Signature</string>
            <string id="bUseTSAsSigningTimeDC_x86_Explain">Specifies whether the timestamp time should be displayed in the signature appearance.

By default, the signature appearance displays the signing time from the signer's computer clock. To display the timestamp server time in a signature appearance: Go to HKLM\SOFTWARE\WOW6432Node\Policies\Adobe\(product)\(version)\FeatureLockDown\cSecurity\cPubSec\ Create the new DWORD bUseTSAsSigningTime and set it to 1. Go to HKCU\Software\Adobe\(product)\(version)\Security\cASPKI\cASPKI\cSign. Set bReqSigPropRetrieval to 1. Create the preference if it does not exist. Verify the computer time does not vary from the signature validation revocation check response time specified by HKCU\Software\Adobe\(product)\(version)\Security\cPubSec\ iMaxClockSkew . The default is 65 minutes. iMaxClockSkew allows admins to account for a network delay, time synchronization issues, and so on without invalidating signatures.

Possible values include:
0: Don't show the timestamp time.
1: Do show the timestamp time.</string>
            <string id="bShowSignMenuDC_x86">Sign Menu in Menu Bar</string>
            <string id="bShowSignMenuDC_x86_Explain">Specifies whether to show the Sign menu in Acrobat's top level menu bar.

Possible values include:
0 or null: Disable the Sign menu item.
1: Enable the menu item.</string>
            <string id="bAllowReasonWhenSigningDC_x86">Signing Reason UI</string>
            <string id="bAllowReasonWhenSigningDC_x86_Explain">Specifies whether the reason UI will appear during signing.

The preference can be overridden by a document seed value set on a field. For 8.1 and later, if cReasons is locked and is empty, bAllowSigningReasons is 0 and read only (The UI is turned off). If cReasons is locked and has values, then bAllowSigningReasons is true and read only.</string>
            <string id="bEnableCertificateBasedTrustDC_x86">Trust Certified Documents</string>
            <string id="bEnableCertificateBasedTrustDC_x86_Explain">Elevates (trusts) certified documents as a privileged location.

This lockable counterpart to bTrustCertifiedDocuments allows certified documents to bypass all the security restrictions that may be bypassed by other privileged locations. The exception is that this level of trust does not apply when the PDF is viewed in Protected View.

Possible values include:
0 or null: Don't make certified documents equivalent to privileged locations.
1: Do make certified documents equivalent to privileged locations (trusted).</string>
            <string id="iUnknownURLPermsDC_x86">Unknown URL Access Policy</string>
            <string id="iUnknownURLPermsDC_x86_Explain">Controls access to websites not explicitly listed in the user's Privileged Locations URL list.

This setting determines how Acrobat handles attempts to access URLs that are not in the trusted or blocked lists. It overrides trusted host settings for URLs that fall outside the configured list.

Possible values include:
1: Always ask before accessing unknown URLs.
2: Always allow access to unknown URLs.
3: Always block access to unknown URLs.</string>
            <string id="iUnknownURLPermsDC_x86_opt0">Always ask</string>
            <string id="iUnknownURLPermsDC_x86_opt1">Always allow</string>
            <string id="iUnknownURLPermsDC_x86_opt2">Always block</string>
            <string id="bValidateOnOpenDC_x86">Validate Signatures on Open</string>
            <string id="bValidateOnOpenDC_x86_Explain">Specifies whether to automatically validate all signatures on document open.

Note that the lockable setting does not configure the feature; instead, it locks what is set in HKCU and the user interface. 0: Don't validate signatures on document open. 1: Validate signatures on document open.</string>

            <!-- ======================================== -->
            <!--           Sharing and Features           -->
            <!-- ======================================== -->

            <string id="bToggleAdobeSignDC_x86">Adobe Acrobat Sign</string>
            <string id="bToggleAdobeSignDC_x86_Explain">Controls the Adobe Acrobat Sign (Send for Signature) service integration.

When disabled, the Send for Signature workflow is removed from the interface. For Continuous track installations, bToggleManageSign should also be set to 1 to fully remove the Acrobat Sign tracking tab from the Home view.

Possible values include:
0: Enable Adobe Acrobat Sign integration.
1: Disable Adobe Acrobat Sign integration.</string>
            <string id="bToggleSendAndTrackDC_x86">Adobe Send &amp; Track</string>
            <string id="bToggleSendAndTrackDC_x86_Explain">Disables Adobe Send and Track (some UI is renamed to &quot;Share&quot; since October, 2018)

Possible values include:
0: Enable Adobe Send and Track.
1: Disable Adobe Send and Track.</string>
            <string id="bEnableRecipientMentionDC_x86">Allow @Mention Non-Reviewers</string>
            <string id="bEnableRecipientMentionDC_x86_Explain">Specifies whether to allow participants in a shared review to @mention people who are not review collaborators.

Prior to this release, reviewers could only @mention other reviewers in the review comments.

Possible values include:
0: Don't allow mentioning non-reviewers.
1: Allow mentioning non-reviewers.</string>
            <string id="bDisableSharePointFeaturesDC_x86">Disable SharePoint &amp; Office 365 Integration</string>
            <string id="bDisableSharePointFeaturesDC_x86_Explain">Controls integration with SharePoint and Office 365 for file check-out and related menu items.

When disabled, the application does not detect SharePoint-hosted files, suppresses the check-out prompt, and removes SharePoint-specific menu items from the interface. This prevents unintended document synchronization with SharePoint environments.

Possible values include:
0: Enable SharePoint and Office 365 integration.
1: Disable SharePoint and Office 365 integration.</string>
            <string id="bDisableWebmailDC_x86">Disable WebMail Integration</string>
            <string id="bDisableWebmailDC_x86_Explain">Controls whether users can configure webmail profiles for sending PDF files by email.

When disabled, users cannot select a webmail profile from the Share pane email workflow. If bSendMailShareRedirection is also set to 1, clicking the email icon attaches the PDF directly to a new mail message instead.

Possible values include:
0: Enable webmail integration.
1: Disable webmail integration.</string>
            <string id="bToggleAdobeReviewDC_x86">Document Cloud Review Service</string>
            <string id="bToggleAdobeReviewDC_x86_Explain">Specifies whether to remove all UI related to the Document Cloud Review service.

When set to 1, this preference removes all cloud-based review UI, including the Review tab on the Home screen. Review tools such as the Send for Review tool in the tool's pane invoke legacy review types rather than DC reviews. The Share button also does not lead users to review workflows.

Possible values include:
0 (or null): Enable the Document Cloud Review service.
1: Disable the Document Cloud Review service.</string>
            <string id="bSendMailShareRedirectionDC_x86">Email Icon Attach to Email Behavior</string>
            <string id="bSendMailShareRedirectionDC_x86_Explain">Change the email icon behavior so that it attaches the document to an email.

With the new unified sharing experience, UI for sharing such as the Send, Attach to Email, and the email icon in the top bar, invokes the new unified share pane. However, when users frequently use &quot;Send documents as Attachment&quot;, set this preference to 1 to change the behavior of the Email icon so that one-click attaches the file to an email.

Possible values include:
0 or null: The email icon opens the share pane.
1: Change the email icon behavior to automatically attach the file to an email.</string>
            <string id="bMixRecentFilesFeatureLockDownDC_x86">Hide Shared Files from Recent List</string>
            <string id="bMixRecentFilesFeatureLockDownDC_x86_Explain">Specifies whether to show shared files in the Recent file list.

When enabled, shared files appear in the Recent list when a user successfully shares a file as well as when a recipient accepts an invite to the shared file workflow. This feature makes it easier to track files in live workflows (reviews, shares, signing workflows, and files shared via Send and Track).

Possible values include:
0: Add shared files to Recent list.
1: Don't add shared files to Recent list.</string>
            <string id="bToggleFSSSignatureSavingDC_x86">Save Signature to Cloud</string>
            <string id="bToggleFSSSignatureSavingDC_x86_Explain">Specifies whether to save a newly created signature in the cloud.

When a user creates a new signature, the dialog offers the option to store the signature in the cloud for later use. This preference also controls saving user initials.

Possible values include:
0: Show the Save Signature UI
1: Hide the Save Signature UI</string>
            <string id="bAdobeSendPluginToggleDC_x86">Send &amp; Track Outlook Plugin</string>
            <string id="bAdobeSendPluginToggleDC_x86_Explain">Controls the Adobe Send &amp; Track plugin for Microsoft Outlook.

When enabled, a Send &amp; Track button appears in Outlook that allows users to share large files as links via Adobe Document Cloud. Disabling this plugin reduces the application attack surface in environments that do not use this feature.

Possible values include:
0: Enable the Send &amp; Track Outlook plugin.
1: Disable the Send &amp; Track Outlook plugin.</string>
            <string id="bEnableReviewPromoteDC_x86">Share and Review Reminder Tip</string>
            <string id="bEnableReviewPromoteDC_x86_Explain">Specifies whether to display a Share/Review feature reminder message when users have used those features in the past.

If the user has not used the review service for 30 days AND has previously opened a PDF with review comments, Acrobat displays a tip reminding the user the review/share service is available.

Possible values include:
0: Don't show a tip.
1: Show tip.</string>
            <string id="bPreviouslyEnabledSharePointInChromeExtnDC_x86">SharePoint Chrome Extension Previous State</string>
            <string id="bPreviouslyEnabledSharePointInChromeExtnDC_x86_Explain">Stores the previous state of the SharePoint FeatureLockDown settings.

Possible values include:
Same as bEnableSharePointInChromeExtn in FeatureLockDown.</string>
            <string id="bEnableSharePointInChromeExtnDC_x86">SharePoint in Chrome Extension</string>
            <string id="bEnableSharePointInChromeExtnDC_x86_Explain">Specifies whether to integrate SharePoint into the Acrobat's Chrome extension.

Possible values include:
0: Don't enable SharePoint integration.
1: Enable.</string>
            <string id="bToggleManageSignDC_x86">Show Acrobat Sign Tracking Tab</string>
            <string id="bToggleManageSignDC_x86_Explain">Specifies whether to remove the Signature tab from the Home page's left-hand pane, notifications, and sign tracking cards.

When set to 1, the signature tab is hidden, the user will not see any agreements received or sent for signature, and all Acrobat Sign notifications are disabled on the desktop. It also removes signature-related cards under the To Do list.

Possible values include:
0: Show the Signature tab.
1: Hide the Signature tab.</string>
            <string id="bDisableOnBehalfOfTextDC_x86">Show Comment Author in Shared Review</string>
            <string id="bDisableOnBehalfOfTextDC_x86_Explain">If false, the string &quot;On behalf of&quot; does not append the author's name in the comment when another person opens the document in a shared-review workflow.

This preference is only used in shared review workflows.

Possible values include:
0: Don't display the comment author's name.
1: Do display the comment author's name.</string>
            <string id="iClientType_GmailDC_x86">WebMail Client Type (Gmail)</string>
            <string id="iClientType_GmailDC_x86_Explain">Identifies the Gmail Mail client type for WebMail.

The value can only be: 1</string>
            <string id="iClientType_GmailDC_x86_opt0">Locked value: 1 (per Adobe PrefRef)</string>
            <string id="iClientType_YahooDC_x86">WebMail Client Type (Yahoo)</string>
            <string id="iClientType_YahooDC_x86_Explain">Identifies the Yahoo Mail client type for WebMail.

The value can only be: 2</string>
            <string id="iClientType_YahooDC_x86_opt0">Locked value: 2 (per Adobe PrefRef)</string>
            <string id="iIMAPPortDC_x86">WebMail IMAP Port</string>
            <string id="iIMAPPortDC_x86_Explain">Identifies the My Profile Mail IMAP server port number for WebMail.

The value can be: Any valid port number.</string>
            <string id="iIMAPPortDC_x86_opt0">143 (Standard IMAP)</string>
            <string id="iIMAPPortDC_x86_opt1">993 (IMAP over SSL/TLS)</string>
            <string id="iIMAPSecurityDC_x86">WebMail IMAP Security</string>
            <string id="iIMAPSecurityDC_x86_Explain">Specifies whether to enable the My Profile Mail IMAP security for WebMail.

The value can be: 0: Don't enable security. 1: Enable security.</string>
            <string id="iSMTPPortDC_x86">WebMail SMTP Port</string>
            <string id="iSMTPPortDC_x86_Explain">Identifies the My Profile Mail SMTP server port number for WebMail.

The value can be: Any valid server port number.</string>
            <string id="iSMTPPortDC_x86_opt0">25 (Standard SMTP)</string>
            <string id="iSMTPPortDC_x86_opt1">465 (SMTP over SSL)</string>
            <string id="iSMTPPortDC_x86_opt2">587 (SMTP Submission / TLS)</string>
            <string id="iSMTPSecurityDC_x86">WebMail SMTP Security</string>
            <string id="iSMTPSecurityDC_x86_Explain">Specifies whether to enable the My Profile Mail SMTP security for WebMail.

The value can be: 0: Don't enable security. 1: Enable security.</string>

            <!-- ======================================== -->
            <!--          Startup and Experience          -->
            <!-- ======================================== -->

            <string id="bShowMsgAtLaunchDC_x86">Adobe Messages at Launch</string>
            <string id="bShowMsgAtLaunchDC_x86_Explain">Specifies whether to show messages from Adobe when the product launches.

This preference also hides the Share Feedback icon, removes messages such as the 11.x &quot;end-of-life&quot; warning, and disables the dialog prompt that urges users to complete their profile. In later product versions, this preference removes the Home banner (top message area) from the Home view.

Possible values include:
0: Don't show messages from Adobe when the product launches.
1: Show messages from Adobe when the product launches.</string>
            <string id="bAllowUserToChangeMsgPrefsDC_x86">Allow Users to Change Message Preferences</string>
            <string id="bAllowUserToChangeMsgPrefsDC_x86_Explain">Locks the features associated with bShowMsgAtLaunch and bDontShowMsgWhenViewingDoc so that end users can't change the settings.

Possible values include:
0: Locks the feature so end users can't change the settings.
1: Allows users to change the settings. A value of 1 has the same effect as this key not existing at all.</string>
            <string id="bToggleNotificationsDC_x86">Desktop Notifications</string>
            <string id="bToggleNotificationsDC_x86_Explain">Specifies whether to disable all in-product and desktop notifications.

When 0 (or null), feature-specific notifications are managed via the related service preference. When set to 1, this preference disables all notifications irrespective of the values of all other keys.

Possible values include:
0: Enable desktop notifications.
1: Disable all desktop notifications.</string>
            <string id="bToggleFTEDC_x86">First Time Experience</string>
            <string id="bToggleFTEDC_x86_Explain">Specifies whether to enable the First Time Experience (FTE) feature (Welcome tour/page).

The first time experience (FTE) feature displays help content and tips when the application starts and also controls access to the Welcome Tour and Welcome page. FTE is also disabled if any of these preferences under FeatureLockDown\cServices are set: bUpdater , bToggleAdobeDocumentServices , bToggleAdobeSign , bTogglePrefsSync , bToggleWebConnectors .

Possible values include:
0 or null: Enable FTE features.
1: Disable FTE features.</string>
            <string id="bDontShowMsgWhenViewingDocDC_x86">Hide Adobe Messages on Document Open</string>
            <string id="bDontShowMsgWhenViewingDocDC_x86_Explain">Specifies whether to show messages from Adobe when a document opens.

This preference also controls messages in the right-hand pane for 12.x and later products as well as the &quot;Learn More&quot; link, including the &quot;Start Free Trial&quot; message promoting Acrobat.

Possible values include:
0: Don't show messages from Adobe when a document opens.
1: Show messages from Adobe when a document opens.</string>
            <string id="bEnableBellButtonDC_x86">Hide In-Product Notifications Bell</string>
            <string id="bEnableBellButtonDC_x86_Explain">Specifies whether to hide in-product messages.

A value of 1 hides notifications, but the product still fetches and caches them.

Possible values include:
0: Show in-product notifications.
1: Hide in-product notifications.</string>
            <string id="bToggleShareFeedbackDC_x86">Hide Send Feedback Icon</string>
            <string id="bToggleShareFeedbackDC_x86_Explain">Specifies whether to show the Send Feedback icon.

By default, the UI displays a feedback icon so that users can easily send feedback to Adobe with one click. This preference replaces bUsageMeasurement for 12.x and later products. Setting bShowMsgAtLaunch to 0 also hides the icon.

Possible values include:
0: Hide the icon.
1: Show the icon.</string>
            <string id="bUsageMeasurementDC_x86">Send Usage Data to Adobe</string>
            <string id="bUsageMeasurementDC_x86_Explain">Legacy master switch controlling whether usage data is collected and sent to Adobe.

Predates DC; superseded for most purposes by bToggleShareFeedback (12.x and later) and bEnableADMAnalytics, but Adobe documentation still references this key as the master switch that disables all data collection, including ADM analytics, when other related preferences are not lockable via HKLM. Retained here for environments that still rely on it.

Possible values include:
0: Disable usage data collection.
1: Enable usage data collection.</string>
            <string id="bToggleToDoListDC_x86">Home Screen To Do List</string>
            <string id="bToggleToDoListDC_x86_Explain">Specifies whether to show a &quot;to do&quot; list on the Home screen.

By default, the Home screen displays a list of action items such as Take a Tour, Export PDF, and so on. For details, see the What's New .

Possible values include:
0: Enable the feature.
1: Disable the feature.</string>
            <string id="bIsSCReducedModeEnforcedExDC_x86">Reader mode on Acrobat (Unified x64)</string>
            <string id="bIsSCReducedModeEnforcedExDC_x86_Explain">Enforces reduced (Reader-like) mode for Unified Acrobat so users can open PDFs without signing in with an Adobe ID.

For enterprise Unified Acrobat (64-bit MUI) deployments.

Possible values include:
0: Do not enforce reduced mode via this policy.
1: Enforce reduced mode (Reader-like experience) without requiring Adobe ID sign-in. See Adobe enterprise KB for full Windows procedure (may include additional cIPM values).</string>
            <string id="bShowScanTabInHomeViewDC_x86">Scan Tab in Home View</string>
            <string id="bShowScanTabInHomeViewDC_x86_Explain">Specifies whether to disable the Scan tab in Home view.

When enabled, links to scans appear under the Scan tab in the Home view.

Possible values include:
0: Hide the scan tab.
1: Show the Scan tab.</string>
            <string id="bToggleNotificationToastsDC_x86">Show Desktop Notification Toasts</string>
            <string id="bToggleNotificationToastsDC_x86_Explain">Specifies whether to hide desktop notifications.

A value of 1 hides notifications, but the product still fetches and caches them.

Possible values include:
0: Show desktop notifications.
1: Hide desktop notifications.</string>
            <string id="bTogglePDFOwnershipToastsDC_x86">Show PDF Ownership Notification</string>
            <string id="bTogglePDFOwnershipToastsDC_x86_Explain">Specifies whether to show a notification on machine startup that allows the user to make Acrobat the default PDF viewer.

When enabled and both Acrobat and Reader are installed, the user can click on the notification to change the default PDF viewer.

Possible values include:
0: Show PDF ownership notification on application startup.
1: Don't show ownership notification.</string>
            <string id="bToggleToDoTilesDC_x86">Show To Do Cards in Recent Tab</string>
            <string id="bToggleToDoTilesDC_x86_Explain">Specifies whether to show To Do Cards in the Recent Tab view

To Do cards list potential action items for members of certain workflows (for example, collaborative reviews). When set to 1, To Do cards do not appear in the Recent tab.

Possible values include:
0 or null: Show cards for unaccepted workflows (reviews, views and sign).
1: Hide cards for unaccepted workflows (reviews, views and sign).</string>
            <string id="bWhatsNewExpDC_x86">What's New Experience</string>
            <string id="bWhatsNewExpDC_x86_Explain">Specifies whether to disable the What's New experience.

This feature was phased in incrementally over 2022. When enabled, the default user on first launch will see a What's New screen as well as a See new features notification. These UI items appear once.

Possible values include:
0: Enable the What's New experience.
1: Disable.</string>

            <!-- ======================================== -->
            <!--     Updates and Desktop Integration      -->
            <!-- ======================================== -->

            <string id="bDisableThirdPartyPluginNotifDC_x86">32-Bit Plugin Upgrade Notification</string>
            <string id="bDisableThirdPartyPluginNotifDC_x86_Explain">Specifies whether to notify users with 32 bit plugins that the app will soon update to 64 bit.

32 bit plugins will not work in the 64 bit app. The notification provides a &quot;Learn more&quot; link that provides additional details about how to upgrade their plugin.

Possible values include:
0: Do not warn the user about 32 bit plugins.
1: Do warn the user.</string>
            <string id="EULADC_x86">Accept EULA for Updater</string>
            <string id="EULADC_x86_Explain">Accepts the Adobe end-user license agreement (EULA) on behalf of the user.

The EULA must be accepted before the built-in updater can download product updates. In enterprise deployments the EULA is typically accepted at install time via the EULA_ACCEPT=YES MSI property; this policy provides an alternative mechanism when the installer property was not set.

Possible values include:
0: EULA not accepted.
1: EULA accepted.</string>
            <string id="bEnableAutoDockUndockHUDDC_x86">Auto Dock HUD Bar</string>
            <string id="bEnableAutoDockUndockHUDDC_x86_Explain">Specifies whether to automatically dock and undock the HUD bar based on the window size.

Possible values include:
0: Disable automatic behavior.
1: Enable auto docking and undocking.</string>
            <string id="bHasAcrobatConsentDC_x86">Auto Open Acrobat from Reader</string>
            <string id="bHasAcrobatConsentDC_x86_Explain">Specifies whether the Reader process should automatically open Acrobat for the current file.

PDF ownership does not change. Reader will continue as the default PDF viewer on this machine.

Possible values include:
0: Don't automatically use Acrobat.
1: Use Acrobat</string>
            <string id="bCrashReporterEnabledDC_x86">Crash Reporter Dialog</string>
            <string id="bCrashReporterEnabledDC_x86_Explain">Specifies whether to show the crash reporter dialog on application crash (Windows only).

This feature is part of the CrashReporter integration on Windows. The dialog allows users to send crash logs to the CrashReporter team.

Possible values include:
0: Don't show the dialog.
1: Show the dialog</string>
            <string id="bAcroSuppressOpenInReaderDC_x86">Disable Chrome PDF Extension</string>
            <string id="bAcroSuppressOpenInReaderDC_x86_Explain">Specifies whether to disable and lock the PDF viewer Chrome extension.

See also ENABLE_CHROMEEXT .

Possible values include:
0 or null: Extension is enabled; users can open PDFs in a browser with Acrobat Reader
1: Disable the browser-based PDF viewer. A tooltip says &quot;The Acrobat Reader extension is currently disabled. Please contact your IT admin.&quot;</string>
            <string id="iDisablePromptForUpgradeDC_x86">Disable Major Version Upgrade Prompt</string>
            <string id="iDisablePromptForUpgradeDC_x86_Explain">Specifies whether the application should show a prompt suggesting the user upgrade to the next major version (for example, 10.0 to 11.0).

If updates have been disabled (bUpdater = 0), then upgrades are also disabled. The feature also requires that the update settings are set to &quot;automatic.&quot; 0 or null: No effect. 1: Disable the prompt asking users if they would like to upgrade to a higher major version.</string>
            <string id="DisableMaintenanceDC_x86">Disable Repair for All Users</string>
            <string id="DisableMaintenanceDC_x86_Explain">Disables the Repair Installation option for all users.

When set, the Help &gt; Repair Acrobat Installation menu item and the repair option in Windows Apps &amp; Features are disabled, preventing users from modifying the installation without administrator involvement.

Possible values include:
0: Allow repair installation.
1: Disable repair installation.</string>
            <string id="Disable_RepairDC_x86">Disable Repair for Standard Users</string>
            <string id="Disable_RepairDC_x86_Explain">Specifies whether to disable the Help ) Repair Installation menu for standard users on virtualized installations.

When working with virtualized installations, users should not be able to run repair from the help menu. Only an administrator should be able to invoke actions that may require a reboot of a Citrix server, WT server, and so on. To disable the menu item, create this preference and set the value to 1. See also DisableMaintenance . The path is as follows: 32 bit machines: HKLM\SOFTWARE\Adobe\(product)\(version)\Installer 64 bit machines: HKLM\SOFTWARE\Wow6432Node\Adobe\(product)\(version)\Installer</string>
            <string id="IsAMTEnforcedDC_x86">Enforce AMT for AppV Deployment</string>
            <string id="IsAMTEnforcedDC_x86_Explain">Allows deployment of Acrobat on AppV for December, 2018 and later products.

0: Do not use. 1: Required after December 2018 for Acrobat on AppV.</string>
            <string id="bSuppressMessageBarDC_x86">Hide Document Message Bar</string>
            <string id="bSuppressMessageBarDC_x86_Explain">Prevents the appearance of the document message bar.

Adversely affects signing when preview mode is used.</string>
            <string id="bDisablePDFHandlerSwitchingDC_x86">Lock Default PDF Viewer</string>
            <string id="bDisablePDFHandlerSwitchingDC_x86_Explain">Prevents users from changing the default PDF viewer application.

When locked, users cannot reassign PDF file handling to a different application through the Acrobat UI or Windows Apps &amp; Features. This ensures the managed Acrobat installation remains the system default PDF handler.

Possible values include:
0: Allow users to change the default PDF viewer.
1: Lock the default PDF viewer setting.</string>
            <string id="bDisableThumbnailPreviewHandlerDC_x86">Lock PDF Thumbnails in Explorer</string>
            <string id="bDisableThumbnailPreviewHandlerDC_x86_Explain">Specifies whether to disable and lock the user interface option that controls Acrobat-generated PDF thumbnail previews in Windows Explorer.

Oct 13, 2015: 32-bit Windows systems only. 64-bit support was enabled on May 9, 2016. This setting disables the user interface checkbox in the UI.

Possible values include:
0: Enable the UI checkbox so users can invoke the installer and enable the thumbnail preview handler.
1: Disable and lock the setting.</string>
            <string id="bMergeMenuBarDC_x86">Merge Title and Menu Bar</string>
            <string id="bMergeMenuBarDC_x86_Explain">Specifies whether to merge the application's title bar and menu bar into a single bar.

Note that &quot;Policies&quot; does not appear in the HKLM path.

Possible values include:
0: Don't merge the title and menu bars
1: Merge the bars</string>
            <string id="PatchCleanFlagDC_x86">Patch Cache Cleanup</string>
            <string id="PatchCleanFlagDC_x86_Explain">Triggers cleanup of old cached update patch files (MSI/MSP) on the next update cycle.

The Adobe ARM updater downloads MSI/MSP patch files that accumulate over time under C:\ProgramData\Adobe\ARM\ and C:\Windows\Installer\, potentially consuming multiple gigabytes of disk space. Setting this value to 1 causes the updater to remove old cached patch files during the next update.

Possible values include:
0: Do not clean up old patch files.
1: Clean up old cached patch files on next update.</string>
            <string id="bUpdater_UpdaterDC_x86">Product Updater</string>
            <string id="bUpdater_UpdaterDC_x86_Explain">Disables the product Updater and removes associated user interface items.

When set to 1, the Preferences &gt; Updater panel and the Help &gt; Check for Updates menu item are removed. This setting writes bUpdater to the FeatureLockDown root key. To also disable cloud services, set bUpdater = 1 in the cServices key using the Cloud Services Updates policy.

Possible values include:
0: Enable the Updater UI.
1: Disable the Updater and remove its UI items.</string>
            <string id="bShouldUseScalableCursorDC_x86">Scalable Cursor</string>
            <string id="bShouldUseScalableCursorDC_x86_Explain">Specifies whether to disable the scalable cursor.

Because Citrix does not provide support for scalable cursors (32-bit cursors with an alpha channel) in legacy graphics mode, scalable cursor performance may be impaired on Citrix. Use this setting to improve performance on Citrix by using a non-scalable cursor.

Possible values include:
0: Don't use a scalable cursor.
1: Use a scalable cursor.</string>
            <string id="dSplitBySizeMaxSizeDC_x86">Split by Size Maximum (MB)</string>
            <string id="dSplitBySizeMaxSizeDC_x86_Explain">Specifies the file size in MB into which a file may be split.

Users or admins can specify any value between 50 and 1024 megabytes. When values outside of that range are used, the default of 50 is enforced.

Possible values include:
Any value between 50 and 1024. On Mac, the key is an Array which should have two items: A Key named &quot;Item 0&quot; where Type=&quot;Number&quot; with a value of 3, and a key named &quot;Item 1&quot; where Type=&quot;Number&quot; with any Value =</string>
            <string id="dSplitBySizeMaxSizeDC_x86_opt0">50 MB (minimum)</string>
            <string id="dSplitBySizeMaxSizeDC_x86_opt1">100 MB</string>
            <string id="dSplitBySizeMaxSizeDC_x86_opt2">250 MB</string>
            <string id="dSplitBySizeMaxSizeDC_x86_opt3">500 MB</string>
            <string id="dSplitBySizeMaxSizeDC_x86_opt4">1024 MB (maximum)</string>
            <string id="bFavoritesFeaturesLockDownDC_x86">Starred Files Feature</string>
            <string id="bFavoritesFeaturesLockDownDC_x86_Explain">Specifies whether to disable and lock the starred file feature.

A starred file is somewhat similar to a &quot;favorited&quot; file. This preference overrides bFavoritesStripInRFL .

Possible values include:
0: Disable and lock starred files in the recent files list.
1: Use bFavoritesStripInRFL to control this feature.</string>
            <string id="iIntervalDC_x86">Update Watchdog Interval (Days)</string>
            <string id="iIntervalDC_x86_Explain">Sets the time that can elapse without a successful update before the Watchdog dialog appears suggesting the user manually update.

This is an internal key that is not visible unless the admin creates it manually. When the Updater successfully obtains a manifest it records the download date. iInterval specifies the time interval that is allowed to pass from that download date to a successful update. The default is 135 days. If the time has elapsed, a dialog appears suggesting the user might want to manually get an update from adobe.com.

Possible values include:
135 days User specified.</string>
            <string id="iIntervalDC_x86_opt0">90 days</string>
            <string id="iIntervalDC_x86_opt1">135 days (default)</string>
            <string id="iIntervalDC_x86_opt2">180 days</string>
            <string id="iIntervalDC_x86_opt3">365 days</string>
            <string id="iLogLevelDC_x86">Updater Log Level</string>
            <string id="iLogLevelDC_x86_Explain">Sets the log level to either brief (0) or verbose (1).

Log file size is not limited during an update. However, since log files are appended to each time the Updater runs, there is a 1MB limit on old logs. Size limit behavior is as follows: If an existing log size is bigger than 1 MB, the Updater truncates the log. Old log files are backed up once as AdobeARM-backup. Logs reside at: Vista-Windows 7 (64 bit systems) %USERPROFILE%\AppData\Local\Temp\AdobeARM.log XP (32bit systems) %USERPROFILE%\Local Settings\Temp\AdobeARM.log Set the log level as follows: 0: Brief 1: Verbose</string>

            <!-- ======================================== -->
            <!--                  Upsell                  -->
            <!-- ======================================== -->

            <string id="bToggleBillingIssueDC_x86">Disable Billing Issue Call to Action</string>
            <string id="bToggleBillingIssueDC_x86_Explain">Specifies whether to show a Call to Action UI item in the top bar if a billing issue is detected.

Possible values include:
0 or null: Disable the CTA UI.
1: Show the CTA UI.</string>
            <string id="bToggleSophiaWebInfraDC_x86">Disable Promotional Campaign Messages</string>
            <string id="bToggleSophiaWebInfraDC_x86_Explain">Specifies whether to show users messages which promote (Trials, Acrobat, PDF Pack etc.)

Subscription users may be prompted to download Acrobat. Theoretically, this preference does not interact with any other upsell preferences.

Possible values include:
0 or null: Disable campaigns in Reader's right-hand pane bottom banner
1: Enable campaigns</string>
            <string id="bMerchandizingEnabledDC_x86">Express Templates in Create PDF</string>
            <string id="bMerchandizingEnabledDC_x86_Explain">Specifies whether to show the Express Templates options in Acrobat's Create PDF UI.

This feature is an experiment not shown to all users.

Possible values include:
0: Do not show the templates
1: Show the templates</string>
            <string id="bLimitPromptsFeatureKeyDC_x86">Limit Informational Prompts</string>
            <string id="bLimitPromptsFeatureKeyDC_x86_Explain">Specifies whether to limit the number of prompts a user will see in a 24 hour period.

Prompts include items like tips, calls-to-action, and feature walk throughs. These are not necessarily upsell items.

Possible values include:
0: Don't restrict informational prompts.
1: Limit prompts to 1 per day and 3 per week.</string>
            <string id="bToggleDCAppCenterDC_x86">Show App Center UI</string>
            <string id="bToggleDCAppCenterDC_x86_Explain">Specifies whether to show the UI that helps users find and download additional apps.

By default, the Home view displays a &quot;get apps&quot; banner and/or a link to the App Center where users can find and download additional apps (such as mobile apps). This preference removes both the banner and the App Center.

Possible values include:
0 (or null): Show the App Center UI.
1: Don't show the App Center UI.</string>
            <string id="bAcroSuppressUpsellDC_x86">Show Upgrade Prompts</string>
            <string id="bAcroSuppressUpsellDC_x86_Explain">Controls whether upgrade prompts and upsell messages are shown to Acrobat Reader users.

When suppressed, in-product prompts encouraging users to upgrade to Acrobat Pro are hidden. Disabling upsell messages reduces distractions and prevents users from purchasing or installing software outside of approved channels.

Possible values include:
0: Show upgrade and upsell prompts.
1: Suppress upgrade and upsell prompts.</string>
            <string id="bEnableTrialistLaunchCardDC_x86">Trial Purchase Prompt</string>
            <string id="bEnableTrialistLaunchCardDC_x86_Explain">Specifies whether to prompt Acrobat trial users to complete the purchase.

Possible values include:
0: Disable the purchase Acrobat prompt.
1: Don't disable the prompt.</string>
            <!-- ======================================== -->
            <!--                                          -->
            <!--  Adobe Reader DC (x64) - policy strings  -->
            <!--                                          -->
            <!-- ======================================== -->

            <!-- ======================================== -->
            <!--           Cloud and Connectors           -->
            <!-- ======================================== -->

            <string id="bToggleFillSign_x64">Adobe Fill &amp; Sign</string>
            <string id="bToggleFillSign_x64_Explain">Disables Adobe Fill and Sign.

Possible values include:
0: Enable Adobe Fill and Sign.
1: Disable Adobe Fill and Sign.</string>
            <string id="bBoxConnectorEnabled_x64">Box Cloud Connector</string>
            <string id="bBoxConnectorEnabled_x64_Explain">Specifies whether to enable connection to the Box cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Box
1: Enable connection to Box</string>
            <string id="bToggleAdobeDocumentServices_x64">Document Cloud Services</string>
            <string id="bToggleAdobeDocumentServices_x64_Explain">Controls access to Adobe Document Cloud services excluding Acrobat Sign, preference sync, and third-party connectors.

Disabling this removes cloud-based features including Create PDF, Export PDF, Organize Pages, and Combine Files. To disable all hosted services including web-plugin updates, set bUpdater = 1 instead.

Possible values include:
0: Enable Document Cloud services.
1: Disable Document Cloud services.</string>
            <string id="bToggleDocumentCloud_x64">Document Cloud Storage</string>
            <string id="bToggleDocumentCloud_x64_Explain">Specifies whether to enable Document Cloud storage.

DC storage is enabled by default.

Possible values include:
0: Enable Document Cloud storage.
1: Disable Document Cloud storage.</string>
            <string id="bDropboxConnectorEnabled_x64">Dropbox Cloud Connector</string>
            <string id="bDropboxConnectorEnabled_x64_Explain">Specifies whether to enable connection to the Dropbox cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Dropbox
1: Enable connection to Dropbox</string>
            <string id="bEnableGentech_x64">Generative AI Technology</string>
            <string id="bEnableGentech_x64_Explain">Specifies whether to enable generative AI features in Acrobat and Reader.

Possible values include:
0: Disable generative AI features.
1: Enable generative AI features. Generative AI capabilities may rely on cloud services; verify organizational policies and Adobe documentation for data handling.</string>
            <string id="bGoogleDriveConnectorEnabled_x64">Google Drive Connector</string>
            <string id="bGoogleDriveConnectorEnabled_x64_Explain">Specifies whether to enable connection to the Google Drive cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Google Drive
1: Enable connection to Google Drive</string>
            <string id="bToggleSendACopy_x64">Hide Fill &amp; Sign Send a Copy Button</string>
            <string id="bToggleSendACopy_x64_Explain">Specifies whether to hide the Send a Copy button from the Fill &amp; Sign tool in Acrobat and Reader.

Possible values include:
0: Hide the button.
1: Show the button.</string>
            <string id="bSuppressSignOut_x64">Hide Sign Out Menu Item</string>
            <string id="bSuppressSignOut_x64_Explain">Specifies whether the sign-in and sign-out Help menu item should be enabled.

Possible values include:
0 or null: Don't disable the menu item.
1: Disable the Help menu item.</string>
            <string id="bOneDriveConnectorEnabled_x64">OneDrive Connector</string>
            <string id="bOneDriveConnectorEnabled_x64_Explain">Specifies whether to enable connection to the OneDrive cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to OneDrive
1: Enable connection to OneDrive</string>
            <string id="bTogglePrefsSync_x64">Preferences Synchronization</string>
            <string id="bTogglePrefsSync_x64_Explain">Controls whether application preferences are synchronized across devices via Adobe Document Cloud.

When a user is signed in with an Adobe ID, preferences can sync across desktop and mobile installations. Disabling this prevents preference data from leaving the managed environment and avoids unintended preference changes from personal devices.

Possible values include:
0: Enable preferences synchronization.
1: Disable preferences synchronization.</string>
            <string id="bUpdater_Updates_x64">Services &amp; Web-Plugin Updates</string>
            <string id="bUpdater_Updates_x64_Explain">Disables web-plugin component updates and all Adobe hosted services.

This is the master service switch for DC products under the cServices key, replacing the deprecated bEnableAcrobatHS preference. Setting to 1 disables both web-plugin updates and in-product cloud service access. To also remove the Updater UI, set bUpdater = 1 under the FeatureLockDown root key via the Services and Web-Plugin Updates policy.

Possible values include:
0: Enable cloud services and web-plugin updates.
1: Disable cloud services and web-plugin updates.</string>
            <string id="bToggleWebConnectors_x64">Third-Party Cloud Connectors</string>
            <string id="bToggleWebConnectors_x64_Explain">Controls in-product access to third-party cloud storage connectors such as Box, Dropbox, OneDrive, and Google Drive.

Disabling this removes the third-party connectors from the Home view, Open/Save dialogs, and the Add Account option. Individual connectors can be selectively re-enabled using bBoxConnectorEnabled, bDropboxConnectorEnabled, bGoogleDriveConnectorEnabled, and bOneDriveConnectorEnabled.

Possible values include:
0: Enable third-party cloud connectors.
1: Disable third-party cloud connectors.</string>

            <!-- ======================================== -->
            <!--        Context, Tools and Search         -->
            <!-- ======================================== -->

            <string id="bUIDensityAutoDetectionEnabled_x64">Auto UI Density Detection</string>
            <string id="bUIDensityAutoDetectionEnabled_x64_Explain">Specifies whether to disable the auto detection logic and bezel for changing Acrobat's display size.

By default, the UI is enabled so that a user may change the display size based on device screen size, resolution, and monitor scaling. 0: Disable the UI. 1: Show the UI.</string>
            <string id="bEnableContextualTips_x64">Contextual Help Tips</string>
            <string id="bEnableContextualTips_x64_Explain">Controls whether to automatically display help tips based on the current context.

Possible values include:
0: Disable contextual tips.
1: Enable tips.</string>
            <string id="bEnableContextualToolbar_x64">Contextual Toolbar</string>
            <string id="bEnableContextualToolbar_x64_Explain">Specifies whether to show the context toolbar (popup) when selecting a PDF object.

When enabled, a popup, floating toolbar appears when a user interacts with a PDF. For example, selecting text displays text markup tools. Selecting an image displays sticky note and editing tools.

Possible values include:
0: Don't show context toolbars.
1: Show toolbars.</string>
            <string id="bEnableExtractPageRange_x64">Extract Page Range UI</string>
            <string id="bEnableExtractPageRange_x64_Explain">Specifies whether to show the page range UI in the Extract Page dialog.

0: Don't show the page range UI. 1: Show the page range UI.</string>
            <string id="ProtectOldExperience_x64">Legacy Protect Tool Menu</string>
            <string id="ProtectOldExperience_x64_Explain">Specifies whether to disable the new Protect tool and revert to the old menu

The Protect tool provides options for encrypting and password protecting documents. The new UI provides some streamlined options, but this preference supports using the old menus.

Possible values include:
0 or null: Use the new protect app experience.
1: Revert to the existing (pre October, 2019) protect app experience.</string>
            <string id="bDisableAcrobatShortcutCustomization_x64">Lock Tool Shortcut Customization</string>
            <string id="bDisableAcrobatShortcutCustomization_x64_Explain">Prevents end users from modifying the tool shortcuts in the right hand pane.

Possible values include:
0: Don't disable shortcuts.
1: Disable shortcuts.</string>
            <string id="bEnableAV2Enterprise_x64">Modern Viewer</string>
            <string id="bEnableAV2Enterprise_x64_Explain">Specifies whether to enable the Modern Viewer.

The new app UI is rolling out in phases over 2023. As of June, 25% of users will see the updated user interface. This preference may interact with bShownViewerOnboarding and bEnableAV2 .

Possible values include:
0: Don't show the Modern Viewer
1: Show the Modern Viewer</string>
            <string id="bEnableRCMNewPOPUp_x64">New Right-Click Context Menu</string>
            <string id="bEnableRCMNewPOPUp_x64_Explain">Specifies whether to disable the new context menu and use the legacy version.

A new right-click context menu displays icons and additional menu options. 0: Disable the new context menu. 1: Enable the new menu.</string>
            <string id="bFindMoreWorkflowsOnline_x64">Online Actions Library Link</string>
            <string id="bFindMoreWorkflowsOnline_x64_Explain">Specifies whether to show the menu item that opens the online Actions file library.

Possible values include:
0: Disable the menu item.
1 or null: Don't disable the menu item.</string>
            <string id="bFindMoreCustomizationsOnline_x64">Online Tool Set Exchange Link</string>
            <string id="bFindMoreCustomizationsOnline_x64_Explain">Specifies whether to show the menu item that opens the online Acrobat Tool Set Exchange.

Possible values include:
0: Disable the menu item.
1 or null: Don't disable the menu item.</string>
            <string id="ADC4302862_x64">Paste in Place</string>
            <string id="ADC4302862_x64_Explain">Specifies whether to paste copied elements to the exact location as the copied element.

Some copy/paste operations are more efficient when copied elements are pasted to an identical location in the target document. This feature applies to form fields, annotations, and links.

Possible values include:
0: Disable the paste-in-place feature.
1: Enable the paste-in-place feature.</string>
            <string id="bRCMCombineFeatureKey_x64">Show Combine Files Context Menu</string>
            <string id="bRCMCombineFeatureKey_x64_Explain">Specifies whether to display the Combine Files item in a document's right-click context menu.

This preference only applies to machines that display the Modern Viewer (a phased rollout over 2023). When the Modern Viewer is disabled, admins can toggle the Combine Files UI off/on.

Possible values include:
0: Don't show the Combine Files UI.
1: Do show the Combine Files UI.</string>

            <!-- ======================================== -->
            <!--   Documents, Editing and Accessibility   -->
            <!-- ======================================== -->

            <string id="bGlobalBarMenuFeatureKey_x64">Create PDF Split Menu</string>
            <string id="bGlobalBarMenuFeatureKey_x64_Explain">Specifies whether to show the Create Split Menu under Create a PDF menu item.

Possible values include:
0: Don't show the Create Split menu.
1: Show the Create Split menu.</string>
            <string id="DisableScannedDocumentEditing_x64">Disable Scanned PDF Text Recognition</string>
            <string id="DisableScannedDocumentEditing_x64_Explain">Specifies whether to disable text recognition while editing scanned PDFs.

Possible values include:
0: Text recognition will be performed when invoking editing on scanned PDFs.
1: Text recognition will not be performed when invoking editing on scanned PDFs.</string>
            <string id="bEnableFrictionlessInChromeExtn_x64">Online Create PDF in Reader</string>
            <string id="bEnableFrictionlessInChromeExtn_x64_Explain">Specifies whether to show Reader users the online Create PDF service option.

Possible values include:
0 or null: Don't show the Create PDF UI
1: Show the convert web content to PDF UI</string>
            <string id="bIgnoreDataSchema_x64">Restrict Form Data to Schema</string>
            <string id="bIgnoreDataSchema_x64_Explain">Specifies whether all data in a form is saved rather than only data related to the form's schema.

Possible values include:
null: Save form data even when it's not part of a schema.
1: Save only form data that's part of the schema.</string>

            <!-- ======================================== -->
            <!--         Microsoft Purview (MIP)          -->
            <!-- ======================================== -->

            <string id="bMIPCheckPolicyOnDocSave_x64">Check MIP Policy on Save</string>
            <string id="bMIPCheckPolicyOnDocSave_x64_Explain">Locks enforcement of default or mandatory Microsoft Purview Information Protection labeling checks when saving documents.

Machine-level FeatureLockDown lockdown; grays out the related Preferences UI once set. Requires default or mandatory labeling to be configured in the Microsoft Purview compliance portal.

Possible values include:
0: Do not lock save-time MIP policy check.
1: Lock save-time MIP policy check enabled. This is admin lockdown under HKLM, not the per-user MicrosoftAIP preferences in User ADMX.</string>
            <string id="bMIPLabelling_x64">Enable MIP Labelling</string>
            <string id="bMIPLabelling_x64_Explain">Locks the Enable Microsoft Purview Information Protection option in Preferences ) Security.

Machine-level FeatureLockDown lockdown; end users cannot change the checkbox once this policy is applied.

Possible values include:
0: Do not lock MIP labelling preference.
1: Lock MIP labelling enabled. Complements per-user MicrosoftAIP preferences in User ADMX; this policy controls admin lockdown only.</string>
            <string id="bEnableDKEAdmin_x64">MIP Double Key Encryption</string>
            <string id="bEnableDKEAdmin_x64_Explain">Locks double key encryption (DKE) label support for Microsoft Purview Information Protection.

Machine-level FeatureLockDown lockdown for MIP DKE workflows.

Possible values include:
0: Lock DKE disabled.
1: Lock DKE enabled.</string>
            <string id="bMIPExternalAuthAdmin_x64">MIP External Browser Auth</string>
            <string id="bMIPExternalAuthAdmin_x64_Explain">Locks browser-based authentication for Microsoft Purview Information Protection operations.

Machine-level FeatureLockDown lockdown.

Possible values include:
0: Lock external browser auth disabled.
1: Lock external browser auth enabled.</string>
            <string id="iMIPCloud_x64">MIP Sovereign Cloud</string>
            <string id="iMIPCloud_x64_Explain">Locks which Microsoft cloud instance Acrobat and Reader use for MIP SDK operations.

Machine-level FeatureLockDown lockdown. Relevant for sovereign and government tenants. MIP SDK Cloud enum values: 0: Unknown. 1: Custom. 2: Test. 3: Commercial (default/global). 4: Germany. 5: US DoD. 6: US GCC. 7: US GCC High. 8: US Sec. 9: US Nat. 10: China.</string>
            <string id="iMIPCloud_x64_opt0">Unknown</string>
            <string id="iMIPCloud_x64_opt1">Custom</string>
            <string id="iMIPCloud_x64_opt2">Test</string>
            <string id="iMIPCloud_x64_opt3">Commercial</string>
            <string id="iMIPCloud_x64_opt4">Germany</string>
            <string id="iMIPCloud_x64_opt5">US DoD</string>
            <string id="iMIPCloud_x64_opt6">US GCC</string>
            <string id="iMIPCloud_x64_opt7">US GCC High</string>
            <string id="iMIPCloud_x64_opt8">US Sec</string>
            <string id="iMIPCloud_x64_opt9">US Nat</string>
            <string id="iMIPCloud_x64_opt10">China</string>
            <string id="bSilentAuth_x64">Suppress OS Auth Prompts (MIP)</string>
            <string id="bSilentAuth_x64_Explain">Locks whether operating-system authentication prompts are suppressed during MIP operations.

By default, OS-driven auth prompts for MIP are suppressed. Set policy Disabled to write DWORD 0 and allow OS auth prompts (useful when troubleshooting AADSTS50020-type errors).

Possible values include:
0: Allow OS auth prompts.
1: Suppress OS auth prompts.</string>

            <!-- ======================================== -->
            <!--    Security: Execution and Protection    -->
            <!-- ======================================== -->

            <string id="bEnable3D_x64">3D Content in PDFs</string>
            <string id="bEnable3D_x64_Explain">Specifies whether to trust and render 3D content in PDFs.

This setting can override b3DEnableContent.

Possible values include:
0: Don't render 3D content.
1: Trust and render 3D files.</string>
            <string id="bEnableProtectedModeAppContainer_x64">AppContainer Sandbox</string>
            <string id="bEnableProtectedModeAppContainer_x64_Explain">Specifies whether to enable the AppContainer sandbox.

Possible values include:
0: Disable Microsoft's AppContainer sandbox
1: Enable Microsoft's AppContainer sandbox</string>
            <string id="bEnableBlacklistForOpenSave_x64">Attachment Extension Blocklist in Dialogs</string>
            <string id="bEnableBlacklistForOpenSave_x64_Explain">Reverts the tBuiltInPermList behavior to that of the pre 21.011.20029 build.

Beginning with build 21.011.20029, extensions added in the tBuiltInPermList with restriction level 3 will be missing from the menu items in all the save and open dialogs. This feature is enabled by default. Users can revert to the old behavior by setting FeatureLockDown/bEnableBlacklistForOpenSave to 0.

Possible values include:
0: Revert to the legacy behavior.
1: Do nothing. Retain the new behavior.</string>
            <string id="bDisableJavaScript_x64">Block JavaScript Execution</string>
            <string id="bDisableJavaScript_x64_Explain">Blocks and locks JavaScript execution in PDF documents, preventing users from bypassing via privileged locations.

This lockable setting overrides bEnableJS and prevents users from re-enabling JavaScript through the Yellow Message Bar or Trusted Locations.

Possible values include:
0 or null: Don't disable JS.
1: Disable and lock JS.</string>
            <string id="iFileAttachmentPerms_x64">Block non-PDF file attachments</string>
            <string id="iFileAttachmentPerms_x64_Explain">Controls whether embedded file attachments of types other than PDF or FDF can be opened from within a PDF.

Restricting file attachments prevents users from launching non-PDF embedded files with external applications, reducing the risk of executing malicious payloads delivered inside PDF documents.

Possible values include:
1: Block non-PDF file attachments.
3: Prompt the user before opening non-PDF file attachments.</string>
            <string id="bDisablePDFRedirectionActions_x64">Block PDF Link Actions</string>
            <string id="bDisablePDFRedirectionActions_x64_Explain">Specifies whether to block specific PDF actions (listed below) which result in opening a link.

This preference does not block regular web links. Enabling this feature blocks PDF actions that open links, including GoToE, GoToR, Launch, Thread, Import Data, Export Form Data, Submit Form, and Reset Form.

Possible values include:
0 or null: Don't block these opening links.
1: Block links.</string>
            <string id="tBuiltInPermList_x64">Built-in Attachment Permissions List</string>
            <string id="tBuiltInPermList_x64_Explain">Defines the white and black list of file types that can be saved and opened from a document.

Pipe-separated list of file extensions with permission levels. Format: version:1|.ext:N where N is 0 (prompt, no allow), 1 (prompt, can allow/prohibit), 2 (always open), or 3 (never open). Referenced by bEnableBlacklistForOpenSave. Extensions with level 3 are hidden from save/open dialogs (build 21.011.20029+).</string>
            <string id="bEnablePVCertificateBasedTrust_x64">Certification Status in Protected View</string>
            <string id="bEnablePVCertificateBasedTrust_x64_Explain">Specifies whether a document's certification status should appear in the Protected View document message bar.

Possible values include:
0: Don't show the document's certification status.
1: Do show the document's certification status.</string>
            <string id="bEnhancedSecurityInBrowser_x64">Enhanced Security in Browser</string>
            <string id="bEnhancedSecurityInBrowser_x64_Explain">Controls Enhanced Security mode for PDFs opened inside a web browser.

When Enhanced Security is enabled in browser mode, Acrobat and Reader restrict unsafe document behaviors for PDFs viewed via the browser plugin, complementing the standalone application setting (bEnhancedSecurityStandalone).

Possible values include:
0: Disable Enhanced Security in browser mode.
1: Enable Enhanced Security in browser mode.</string>
            <string id="bEnhancedSecurityStandalone_x64">Enhanced Security Standalone</string>
            <string id="bEnhancedSecurityStandalone_x64_Explain">Controls Enhanced Security mode for PDFs opened in the standalone application.

When Enhanced Security is enabled, Acrobat and Reader restrict potentially unsafe document behaviors such as accessing external URLs, running scripts, and silently sending data to remote hosts. This reduces the risk of exploitation by malicious PDFs.

Possible values include:
0: Disable Enhanced Security in standalone mode.
1: Enable Enhanced Security in standalone mode.</string>
            <string id="bEnableFlash_x64">Flash Content in PDFs</string>
            <string id="bEnableFlash_x64_Explain">Controls whether Adobe Flash Player content embedded in PDF files is permitted to run.

Adobe Flash reached end-of-life in December 2020 and is no longer supported or patched. All Flash content in PDFs should be blocked to prevent exploitation of known unpatched Flash vulnerabilities.

Possible values include:
0: Block Flash content in PDFs.
1: Allow Flash content in PDFs.</string>
            <string id="EnableFlashEditing_x64">Flash Editing Tools</string>
            <string id="EnableFlashEditing_x64_Explain">Specifies whether to enable the Flash tools for adding annotations or Flash in the Rich Media app.

Possible values include:
0 or null: Remove &quot;Disable Flash ) Add SWF menu item.&quot;
1: Show the menu item.</string>
            <string id="bProtectedMode_x64">Protected Mode Sandbox</string>
            <string id="bProtectedMode_x64_Explain">Controls Protected Mode, which isolates the PDF rendering engine in a sandboxed process.

Protected Mode uses Windows integrity levels to restrict the renderer's access to the file system, registry, and network. This significantly limits the damage a successful PDF exploit can cause by preventing it from accessing system resources directly.

Possible values include:
0: Disable Protected Mode.
1: Enable Protected Mode.</string>
            <string id="bUseWhitelistConfigFile_x64">Protected Mode Whitelist Config</string>
            <string id="bUseWhitelistConfigFile_x64_Explain">Allows the use of the policy whitelist to allow behavior that Protected Mode would otherwise prevent.

This preference just toggles the ability of the application to read policy files.</string>
            <string id="bEnablePVSwitchoutShortcut_x64">Protected View Exit Shortcut Key</string>
            <string id="bEnablePVSwitchoutShortcut_x64_Explain">Enables a shortcut key that allows users to exit Protected View for a specific document.

This feature allows admins and users to keep Protected View enabled, but also exit that mode on-the-fly when necessary.

Possible values include:
0: Disable the shortcut key.
1: Enable the shortcut key that exits Protected View.</string>
            <string id="iUnlistedAttachmentTypePerm_x64">Unlisted Attachment Type Permissions</string>
            <string id="iUnlistedAttachmentTypePerm_x64_Explain">Specifies the default permissions for file types that aren't listed in the default or user-specified lists.

Possible values include:
0: Prompt user without ability to set file type as Allowed (two choices: Open File, Never Allow).
1 (default): Prompt user with ability to Allow or Prohibit (three choices).
2: Always open unlisted file types.
3: Never open unlisted file types.</string>
            <string id="iUnlistedAttachmentTypePerm_x64_opt0">Prompt without ability to allow (most restrictive prompt)</string>
            <string id="iUnlistedAttachmentTypePerm_x64_opt1">Prompt with ability to allow or prohibit (default)</string>
            <string id="iUnlistedAttachmentTypePerm_x64_opt2">Always open unlisted file types</string>
            <string id="iUnlistedAttachmentTypePerm_x64_opt3">Never open unlisted file types (most restrictive)</string>

            <!-- ======================================== -->
            <!--     Security: Trust and Permissions      -->
            <!-- ======================================== -->

            <string id="bMSStoreTrusted_x64">Allow Changes to Windows Certificate Store Trust</string>
            <string id="bMSStoreTrusted_x64_Explain">Locks the UI so that end users cannot change the value set by iMSStoreTrusted.

Set iMSStoreTrusted first, then use this preference to lock it. Allowable values include: 0: Lock the UI. 1: Same as null. Don't lock the UI.</string>
            <string id="bAllowInvisibleSig_x64">Allow Invisible Signatures</string>
            <string id="bAllowInvisibleSig_x64_Explain">Specifies whether to allow invisible certification signatures.

False disables the menu option, prevents signing and certifying with invisible signatures, and limits JavaScript support by signature fields.</string>
            <string id="bAllowPasswordSaving_x64">Allow Password Caching</string>
            <string id="bAllowPasswordSaving_x64_Explain">Controls whether certain passwords can be cached to disk; for example, passwords for digital IDs.

If false, users are prompted to enter a password every time one is required. Not all passwords are affected by this setting.</string>
            <string id="bEnableSignatureClear_x64">Allow Signature Clearing</string>
            <string id="bEnableSignatureClear_x64_Explain">Specifies whether to disable and lock the ability for a signer to clear their own signature.

Possible values include:
0: Disable signature clearing.
1: Enable signature clearing.</string>
            <string id="bVerifyUseAlways_x64">Always Use Specified Verify Handler</string>
            <string id="bVerifyUseAlways_x64_Explain">Qualifies the use of aVerify.

If true and aVerify is set to a handler name, then this handler is used to verify all signatures. If false, then the aVerify handler is used only to verify signatures when the handler specified by the signature dictionary Filter attribute is not present.</string>
            <string id="bDisableExpandEnvironmentVariables_x64">Block User Library Trust in Protected View</string>
            <string id="bDisableExpandEnvironmentVariables_x64_Explain">Provides a method for admins to whitelist user libraries as trusted locations when Protected View is enabled.

Protected View restricts features for all documents that do not reside in a trusted location. This new preference provides a way for admins to specify user-specific locations as trusted; in other words, documents with the path C:\Users\%username%\Desktop will open outside Protected View. For example, the user libraries Documents, Downloads, Desktop, and so on. When this preference is off, admins can only specify trusted locations which are static/identical for all users across their organization.

Possible values include:
0: Trust user-specific locations.
1: Don't trust user-specific locations.</string>
            <string id="bWinCacheSessionHandles_x64">Cache Digital ID Session Handles</string>
            <string id="bWinCacheSessionHandles_x64_Explain">Specifies whether to retain cryptographic service provider (CSP) handles when a user authenticates to a digital ID.

If true, a user does not have to re-authenticate to use the ID unless they log out or the session ends. The impact of this preference will vary based on the CSP in use; however, the setting does not affect the Windows CSPs.</string>
            <string id="bDisableOSTrustedSites_x64">Disable IE Trusted Sites as Privileged Locations</string>
            <string id="bDisableOSTrustedSites_x64_Explain">Locks the ability to treat IE trusted sites as privileged locations either on or off so the users can't change the bTrustOSTrustedSites value via the user interface.

If set, bTrustOSTrustedSites is simply ignored.

Possible values include:
0 or null: Enables and locks trusting sites from IE.
1: Disables and locks trusting sites from IE.</string>
            <string id="bAllowAPSConfig_x64">LiveCycle RMS Server Config</string>
            <string id="bAllowAPSConfig_x64_Explain">Prevents a LiveCycle Right Management Server from being configured by disabling the menu option in the Security Settings Console.

By default, configuration is allowed.</string>
            <string id="bReqRevCheck_x64">Lock Revocation Check Setting</string>
            <string id="bReqRevCheck_x64_Explain">Locks Security\cASPKI\cASPKI\cVerify\iReqRevCheck and disables the user interface item.</string>
            <string id="bReasons_x64">Lock Signing Reasons Settings</string>
            <string id="bReasons_x64_Explain">Prevents users from modifying reason settings.

v8.1: If locked and cReasons is empty, bAllowSigningReasons is 0 and read only. If locked and cReasons has values, then bAllowSigningReasons is true and read only.</string>
            <string id="bDisableTrustedFolders_x64">Lock Trusted Folders and Files</string>
            <string id="bDisableTrustedFolders_x64_Explain">Prevents users from adding trusted file and folder locations to Privileged Locations.

Privileged Locations bypass Enhanced Security restrictions. Allowing users to define them creates a pathway to weaken document security. Locking this setting prevents users from creating local exceptions that could expose the application to malicious PDFs.

Possible values include:
0: Allow users to configure trusted folder and file locations.
1: Disable and lock trusted folder and file locations.</string>
            <string id="bDisableTrustedSites_x64">Lock Trusted Host Sites</string>
            <string id="bDisableTrustedSites_x64_Explain">Prevents Internet Explorer Trusted Sites from being elevated to Privileged Locations.

Privileged Locations bypass Enhanced Security restrictions. Importing IE Trusted Sites as privileged locations could allow a broad set of sites to bypass document security controls. Locking this setting keeps the Privileged Locations list under administrator control.

Possible values include:
0: Allow IE Trusted Sites to be added as Privileged Locations.
1: Disable and lock the IE Trusted Sites elevation.</string>
            <string id="bEnableCEFBasedUI_x64">Modern Digital Signature UI</string>
            <string id="bEnableCEFBasedUI_x64_Explain">Specifies whether to enable the CEF-based, modern UI for digital signature workflows.

The newer UI streamlines the user interface. All values also disable the UI option to change the preference. Note that for products released after June 2016, disabling a user's ability to create a self-signed digital ID requires setting both bSelfSignCertGen and bEnableCEFBasedUI to 0.

Possible values include:
0: Disable the modern UI and shows the legacy UI.
1: Enable the Modern UI.</string>
            <string id="bUseTSAsSigningTime_x64">Show Timestamp in Signature</string>
            <string id="bUseTSAsSigningTime_x64_Explain">Specifies whether the timestamp time should be displayed in the signature appearance.

By default, the signature appearance displays the signing time from the signer's computer clock. To display the timestamp server time in a signature appearance: Go to HKLM\SOFTWARE\WOW6432Node\Policies\Adobe\(product)\(version)\FeatureLockDown\cSecurity\cPubSec\ Create the new DWORD bUseTSAsSigningTime and set it to 1. Go to HKCU\Software\Adobe\(product)\(version)\Security\cASPKI\cASPKI\cSign. Set bReqSigPropRetrieval to 1. Create the preference if it does not exist. Verify the computer time does not vary from the signature validation revocation check response time specified by HKCU\Software\Adobe\(product)\(version)\Security\cPubSec\ iMaxClockSkew . The default is 65 minutes. iMaxClockSkew allows admins to account for a network delay, time synchronization issues, and so on without invalidating signatures.

Possible values include:
0: Don't show the timestamp time.
1: Do show the timestamp time.</string>
            <string id="bAllowReasonWhenSigning_x64">Signing Reason UI</string>
            <string id="bAllowReasonWhenSigning_x64_Explain">Specifies whether the reason UI will appear during signing.

The preference can be overridden by a document seed value set on a field. For 8.1 and later, if cReasons is locked and is empty, bAllowSigningReasons is 0 and read only (The UI is turned off). If cReasons is locked and has values, then bAllowSigningReasons is true and read only.</string>
            <string id="bEnableCertificateBasedTrust_x64">Trust Certified Documents</string>
            <string id="bEnableCertificateBasedTrust_x64_Explain">Elevates (trusts) certified documents as a privileged location.

This lockable counterpart to bTrustCertifiedDocuments allows certified documents to bypass all the security restrictions that may be bypassed by other privileged locations. The exception is that this level of trust does not apply when the PDF is viewed in Protected View.

Possible values include:
0 or null: Don't make certified documents equivalent to privileged locations.
1: Do make certified documents equivalent to privileged locations (trusted).</string>
            <string id="iUnknownURLPerms_x64">Unknown URL Access Policy</string>
            <string id="iUnknownURLPerms_x64_Explain">Controls access to websites not explicitly listed in the user's Privileged Locations URL list.

This setting determines how Acrobat handles attempts to access URLs that are not in the trusted or blocked lists. It overrides trusted host settings for URLs that fall outside the configured list.

Possible values include:
1: Always ask before accessing unknown URLs.
2: Always allow access to unknown URLs.
3: Always block access to unknown URLs.</string>
            <string id="iUnknownURLPerms_x64_opt0">Always ask</string>
            <string id="iUnknownURLPerms_x64_opt1">Always allow</string>
            <string id="iUnknownURLPerms_x64_opt2">Always block</string>
            <string id="bValidateOnOpen_x64">Validate Signatures on Open</string>
            <string id="bValidateOnOpen_x64_Explain">Specifies whether to automatically validate all signatures on document open.

Note that the lockable setting does not configure the feature; instead, it locks what is set in HKCU and the user interface. 0: Don't validate signatures on document open. 1: Validate signatures on document open.</string>

            <!-- ======================================== -->
            <!--           Sharing and Features           -->
            <!-- ======================================== -->

            <string id="bToggleAdobeSign_x64">Adobe Acrobat Sign</string>
            <string id="bToggleAdobeSign_x64_Explain">Controls the Adobe Acrobat Sign (Send for Signature) service integration.

When disabled, the Send for Signature workflow is removed from the interface. For Continuous track installations, bToggleManageSign should also be set to 1 to fully remove the Acrobat Sign tracking tab from the Home view.

Possible values include:
0: Enable Adobe Acrobat Sign integration.
1: Disable Adobe Acrobat Sign integration.</string>
            <string id="bToggleSendAndTrack_x64">Adobe Send &amp; Track</string>
            <string id="bToggleSendAndTrack_x64_Explain">Disables Adobe Send and Track (some UI is renamed to &quot;Share&quot; since October, 2018)

Possible values include:
0: Enable Adobe Send and Track.
1: Disable Adobe Send and Track.</string>
            <string id="bDisableSharePointFeatures_x64">Disable SharePoint &amp; Office 365 Integration</string>
            <string id="bDisableSharePointFeatures_x64_Explain">Controls integration with SharePoint and Office 365 for file check-out and related menu items.

When disabled, the application does not detect SharePoint-hosted files, suppresses the check-out prompt, and removes SharePoint-specific menu items from the interface. This prevents unintended document synchronization with SharePoint environments.

Possible values include:
0: Enable SharePoint and Office 365 integration.
1: Disable SharePoint and Office 365 integration.</string>
            <string id="bDisableWebmail_x64">Disable WebMail Integration</string>
            <string id="bDisableWebmail_x64_Explain">Controls whether users can configure webmail profiles for sending PDF files by email.

When disabled, users cannot select a webmail profile from the Share pane email workflow. If bSendMailShareRedirection is also set to 1, clicking the email icon attaches the PDF directly to a new mail message instead.

Possible values include:
0: Enable webmail integration.
1: Disable webmail integration.</string>
            <string id="bToggleAdobeReview_x64">Document Cloud Review Service</string>
            <string id="bToggleAdobeReview_x64_Explain">Specifies whether to remove all UI related to the Document Cloud Review service.

When set to 1, this preference removes all cloud-based review UI, including the Review tab on the Home screen. Review tools such as the Send for Review tool in the tool's pane invoke legacy review types rather than DC reviews. The Share button also does not lead users to review workflows.

Possible values include:
0 (or null): Enable the Document Cloud Review service.
1: Disable the Document Cloud Review service.</string>
            <string id="bSendMailShareRedirection_x64">Email Icon Attach to Email Behavior</string>
            <string id="bSendMailShareRedirection_x64_Explain">Change the email icon behavior so that it attaches the document to an email.

With the new unified sharing experience, UI for sharing such as the Send, Attach to Email, and the email icon in the top bar, invokes the new unified share pane. However, when users frequently use &quot;Send documents as Attachment&quot;, set this preference to 1 to change the behavior of the Email icon so that one-click attaches the file to an email.

Possible values include:
0 or null: The email icon opens the share pane.
1: Change the email icon behavior to automatically attach the file to an email.</string>
            <string id="bMixRecentFilesFeatureLockDown_x64">Hide Shared Files from Recent List</string>
            <string id="bMixRecentFilesFeatureLockDown_x64_Explain">Specifies whether to show shared files in the Recent file list.

When enabled, shared files appear in the Recent list when a user successfully shares a file as well as when a recipient accepts an invite to the shared file workflow. This feature makes it easier to track files in live workflows (reviews, shares, signing workflows, and files shared via Send and Track).

Possible values include:
0: Add shared files to Recent list.
1: Don't add shared files to Recent list.</string>
            <string id="bToggleFSSSignatureSaving_x64">Save Signature to Cloud</string>
            <string id="bToggleFSSSignatureSaving_x64_Explain">Specifies whether to save a newly created signature in the cloud.

When a user creates a new signature, the dialog offers the option to store the signature in the cloud for later use. This preference also controls saving user initials.

Possible values include:
0: Show the Save Signature UI
1: Hide the Save Signature UI</string>
            <string id="bAdobeSendPluginToggle_x64">Send &amp; Track Outlook Plugin</string>
            <string id="bAdobeSendPluginToggle_x64_Explain">Controls the Adobe Send &amp; Track plugin for Microsoft Outlook.

When enabled, a Send &amp; Track button appears in Outlook that allows users to share large files as links via Adobe Document Cloud. Disabling this plugin reduces the application attack surface in environments that do not use this feature.

Possible values include:
0: Enable the Send &amp; Track Outlook plugin.
1: Disable the Send &amp; Track Outlook plugin.</string>
            <string id="bPreviouslyEnabledSharePointInChromeExtn_x64">SharePoint Chrome Extension Previous State</string>
            <string id="bPreviouslyEnabledSharePointInChromeExtn_x64_Explain">Stores the previous state of the SharePoint FeatureLockDown settings.

Possible values include:
Same as bEnableSharePointInChromeExtn in FeatureLockDown.</string>
            <string id="bEnableSharePointInChromeExtn_x64">SharePoint in Chrome Extension</string>
            <string id="bEnableSharePointInChromeExtn_x64_Explain">Specifies whether to integrate SharePoint into the Acrobat's Chrome extension.

Possible values include:
0: Don't enable SharePoint integration.
1: Enable.</string>
            <string id="bToggleManageSign_x64">Show Acrobat Sign Tracking Tab</string>
            <string id="bToggleManageSign_x64_Explain">Specifies whether to remove the Signature tab from the Home page's left-hand pane, notifications, and sign tracking cards.

When set to 1, the signature tab is hidden, the user will not see any agreements received or sent for signature, and all Acrobat Sign notifications are disabled on the desktop. It also removes signature-related cards under the To Do list.

Possible values include:
0: Show the Signature tab.
1: Hide the Signature tab.</string>
            <string id="bDisableOnBehalfOfText_x64">Show Comment Author in Shared Review</string>
            <string id="bDisableOnBehalfOfText_x64_Explain">If false, the string &quot;On behalf of&quot; does not append the author's name in the comment when another person opens the document in a shared-review workflow.

This preference is only used in shared review workflows.

Possible values include:
0: Don't display the comment author's name.
1: Do display the comment author's name.</string>
            <string id="iClientType_Gmail_x64">WebMail Client Type (Gmail)</string>
            <string id="iClientType_Gmail_x64_Explain">Identifies the Gmail Mail client type for WebMail.

The value can only be: 1</string>
            <string id="iClientType_Gmail_x64_opt0">Locked value: 1 (per Adobe PrefRef)</string>
            <string id="iClientType_Yahoo_x64">WebMail Client Type (Yahoo)</string>
            <string id="iClientType_Yahoo_x64_Explain">Identifies the Yahoo Mail client type for WebMail.

The value can only be: 2</string>
            <string id="iClientType_Yahoo_x64_opt0">Locked value: 2 (per Adobe PrefRef)</string>
            <string id="iIMAPPort_x64">WebMail IMAP Port</string>
            <string id="iIMAPPort_x64_Explain">Identifies the My Profile Mail IMAP server port number for WebMail.

The value can be: Any valid port number.</string>
            <string id="iIMAPPort_x64_opt0">143 (Standard IMAP)</string>
            <string id="iIMAPPort_x64_opt1">993 (IMAP over SSL/TLS)</string>
            <string id="iIMAPSecurity_x64">WebMail IMAP Security</string>
            <string id="iIMAPSecurity_x64_Explain">Specifies whether to enable the My Profile Mail IMAP security for WebMail.

The value can be: 0: Don't enable security. 1: Enable security.</string>
            <string id="iSMTPPort_x64">WebMail SMTP Port</string>
            <string id="iSMTPPort_x64_Explain">Identifies the My Profile Mail SMTP server port number for WebMail.

The value can be: Any valid server port number.</string>
            <string id="iSMTPPort_x64_opt0">25 (Standard SMTP)</string>
            <string id="iSMTPPort_x64_opt1">465 (SMTP over SSL)</string>
            <string id="iSMTPPort_x64_opt2">587 (SMTP Submission / TLS)</string>
            <string id="iSMTPSecurity_x64">WebMail SMTP Security</string>
            <string id="iSMTPSecurity_x64_Explain">Specifies whether to enable the My Profile Mail SMTP security for WebMail.

The value can be: 0: Don't enable security. 1: Enable security.</string>

            <!-- ======================================== -->
            <!--          Startup and Experience          -->
            <!-- ======================================== -->

            <string id="bShowMsgAtLaunch_x64">Adobe Messages at Launch</string>
            <string id="bShowMsgAtLaunch_x64_Explain">Specifies whether to show messages from Adobe when the product launches.

This preference also hides the Share Feedback icon, removes messages such as the 11.x &quot;end-of-life&quot; warning, and disables the dialog prompt that urges users to complete their profile. In later product versions, this preference removes the Home banner (top message area) from the Home view.

Possible values include:
0: Don't show messages from Adobe when the product launches.
1: Show messages from Adobe when the product launches.</string>
            <string id="bAllowUserToChangeMsgPrefs_x64">Allow Users to Change Message Preferences</string>
            <string id="bAllowUserToChangeMsgPrefs_x64_Explain">Locks the features associated with bShowMsgAtLaunch and bDontShowMsgWhenViewingDoc so that end users can't change the settings.

Possible values include:
0: Locks the feature so end users can't change the settings.
1: Allows users to change the settings. A value of 1 has the same effect as this key not existing at all.</string>
            <string id="bToggleNotifications_x64">Desktop Notifications</string>
            <string id="bToggleNotifications_x64_Explain">Specifies whether to disable all in-product and desktop notifications.

When 0 (or null), feature-specific notifications are managed via the related service preference. When set to 1, this preference disables all notifications irrespective of the values of all other keys.

Possible values include:
0: Enable desktop notifications.
1: Disable all desktop notifications.</string>
            <string id="bToggleFTE_x64">First Time Experience</string>
            <string id="bToggleFTE_x64_Explain">Specifies whether to enable the First Time Experience (FTE) feature (Welcome tour/page).

The first time experience (FTE) feature displays help content and tips when the application starts and also controls access to the Welcome Tour and Welcome page. FTE is also disabled if any of these preferences under FeatureLockDown\cServices are set: bUpdater , bToggleAdobeDocumentServices , bToggleAdobeSign , bTogglePrefsSync , bToggleWebConnectors .

Possible values include:
0 or null: Enable FTE features.
1: Disable FTE features.</string>
            <string id="bDontShowMsgWhenViewingDoc_x64">Hide Adobe Messages on Document Open</string>
            <string id="bDontShowMsgWhenViewingDoc_x64_Explain">Specifies whether to show messages from Adobe when a document opens.

This preference also controls messages in the right-hand pane for 12.x and later products as well as the &quot;Learn More&quot; link, including the &quot;Start Free Trial&quot; message promoting Acrobat.

Possible values include:
0: Don't show messages from Adobe when a document opens.
1: Show messages from Adobe when a document opens.</string>
            <string id="bEnableBellButton_x64">Hide In-Product Notifications Bell</string>
            <string id="bEnableBellButton_x64_Explain">Specifies whether to hide in-product messages.

A value of 1 hides notifications, but the product still fetches and caches them.

Possible values include:
0: Show in-product notifications.
1: Hide in-product notifications.</string>
            <string id="bToggleShareFeedback_x64">Hide Send Feedback Icon</string>
            <string id="bToggleShareFeedback_x64_Explain">Specifies whether to show the Send Feedback icon.

By default, the UI displays a feedback icon so that users can easily send feedback to Adobe with one click. This preference replaces bUsageMeasurement for 12.x and later products. Setting bShowMsgAtLaunch to 0 also hides the icon.

Possible values include:
0: Hide the icon.
1: Show the icon.</string>
            <string id="bUsageMeasurement_x64">Send Usage Data to Adobe</string>
            <string id="bUsageMeasurement_x64_Explain">Legacy master switch controlling whether usage data is collected and sent to Adobe.

Predates DC; superseded for most purposes by bToggleShareFeedback (12.x and later) and bEnableADMAnalytics, but Adobe documentation still references this key as the master switch that disables all data collection, including ADM analytics, when other related preferences are not lockable via HKLM. Retained here for environments that still rely on it.

Possible values include:
0: Disable usage data collection.
1: Enable usage data collection.</string>
            <string id="bToggleToDoList_x64">Home Screen To Do List</string>
            <string id="bToggleToDoList_x64_Explain">Specifies whether to show a &quot;to do&quot; list on the Home screen.

By default, the Home screen displays a list of action items such as Take a Tour, Export PDF, and so on. For details, see the What's New .

Possible values include:
0: Enable the feature.
1: Disable the feature.</string>
            <string id="bShowScanTabInHomeView_x64">Scan Tab in Home View</string>
            <string id="bShowScanTabInHomeView_x64_Explain">Specifies whether to disable the Scan tab in Home view.

When enabled, links to scans appear under the Scan tab in the Home view.

Possible values include:
0: Hide the scan tab.
1: Show the Scan tab.</string>
            <string id="bToggleNotificationToasts_x64">Show Desktop Notification Toasts</string>
            <string id="bToggleNotificationToasts_x64_Explain">Specifies whether to hide desktop notifications.

A value of 1 hides notifications, but the product still fetches and caches them.

Possible values include:
0: Show desktop notifications.
1: Hide desktop notifications.</string>
            <string id="bTogglePDFOwnershipToasts_x64">Show PDF Ownership Notification</string>
            <string id="bTogglePDFOwnershipToasts_x64_Explain">Specifies whether to show a notification on machine startup that allows the user to make Acrobat the default PDF viewer.

When enabled and both Acrobat and Reader are installed, the user can click on the notification to change the default PDF viewer.

Possible values include:
0: Show PDF ownership notification on application startup.
1: Don't show ownership notification.</string>
            <string id="bToggleToDoTiles_x64">Show To Do Cards in Recent Tab</string>
            <string id="bToggleToDoTiles_x64_Explain">Specifies whether to show To Do Cards in the Recent Tab view

To Do cards list potential action items for members of certain workflows (for example, collaborative reviews). When set to 1, To Do cards do not appear in the Recent tab.

Possible values include:
0 or null: Show cards for unaccepted workflows (reviews, views and sign).
1: Hide cards for unaccepted workflows (reviews, views and sign).</string>
            <string id="bWhatsNewExp_x64">What's New Experience</string>
            <string id="bWhatsNewExp_x64_Explain">Specifies whether to disable the What's New experience.

This feature was phased in incrementally over 2022. When enabled, the default user on first launch will see a What's New screen as well as a See new features notification. These UI items appear once.

Possible values include:
0: Enable the What's New experience.
1: Disable.</string>

            <!-- ======================================== -->
            <!--     Updates and Desktop Integration      -->
            <!-- ======================================== -->

            <string id="bDisableThirdPartyPluginNotif_x64">32-Bit Plugin Upgrade Notification</string>
            <string id="bDisableThirdPartyPluginNotif_x64_Explain">Specifies whether to notify users with 32 bit plugins that the app will soon update to 64 bit.

32 bit plugins will not work in the 64 bit app. The notification provides a &quot;Learn more&quot; link that provides additional details about how to upgrade their plugin.

Possible values include:
0: Do not warn the user about 32 bit plugins.
1: Do warn the user.</string>
            <string id="EULA_x64">Accept EULA for Updater</string>
            <string id="EULA_x64_Explain">Accepts the Adobe end-user license agreement (EULA) on behalf of the user.

The EULA must be accepted before the built-in updater can download product updates. In enterprise deployments the EULA is typically accepted at install time via the EULA_ACCEPT=YES MSI property; this policy provides an alternative mechanism when the installer property was not set.

Possible values include:
0: EULA not accepted.
1: EULA accepted.</string>
            <string id="bEnableAutoDockUndockHUD_x64">Auto Dock HUD Bar</string>
            <string id="bEnableAutoDockUndockHUD_x64_Explain">Specifies whether to automatically dock and undock the HUD bar based on the window size.

Possible values include:
0: Disable automatic behavior.
1: Enable auto docking and undocking.</string>
            <string id="bHasAcrobatConsent_x64">Auto Open Acrobat from Reader</string>
            <string id="bHasAcrobatConsent_x64_Explain">Specifies whether the Reader process should automatically open Acrobat for the current file.

PDF ownership does not change. Reader will continue as the default PDF viewer on this machine.

Possible values include:
0: Don't automatically use Acrobat.
1: Use Acrobat</string>
            <string id="bAcroSuppressOpenInReader_x64">Disable Chrome PDF Extension</string>
            <string id="bAcroSuppressOpenInReader_x64_Explain">Specifies whether to disable and lock the PDF viewer Chrome extension.

See also ENABLE_CHROMEEXT .

Possible values include:
0 or null: Extension is enabled; users can open PDFs in a browser with Acrobat Reader
1: Disable the browser-based PDF viewer. A tooltip says &quot;The Acrobat Reader extension is currently disabled. Please contact your IT admin.&quot;</string>
            <string id="iDisablePromptForUpgrade_x64">Disable Major Version Upgrade Prompt</string>
            <string id="iDisablePromptForUpgrade_x64_Explain">Specifies whether the application should show a prompt suggesting the user upgrade to the next major version (for example, 10.0 to 11.0).

If updates have been disabled (bUpdater = 0), then upgrades are also disabled. The feature also requires that the update settings are set to &quot;automatic.&quot; 0 or null: No effect. 1: Disable the prompt asking users if they would like to upgrade to a higher major version.</string>
            <string id="DisableMaintenance_x64">Disable Repair for All Users</string>
            <string id="DisableMaintenance_x64_Explain">Disables the Repair Installation option for all users.

When set, the Help &gt; Repair Acrobat Installation menu item and the repair option in Windows Apps &amp; Features are disabled, preventing users from modifying the installation without administrator involvement.

Possible values include:
0: Allow repair installation.
1: Disable repair installation.</string>
            <string id="Disable_Repair_x64">Disable Repair for Standard Users</string>
            <string id="Disable_Repair_x64_Explain">Specifies whether to disable the Help ) Repair Installation menu for standard users on virtualized installations.

When working with virtualized installations, users should not be able to run repair from the help menu. Only an administrator should be able to invoke actions that may require a reboot of a Citrix server, WT server, and so on. To disable the menu item, create this preference and set the value to 1. See also DisableMaintenance . The path is as follows: 32 bit machines: HKLM\SOFTWARE\Adobe\(product)\(version)\Installer 64 bit machines: HKLM\SOFTWARE\Wow6432Node\Adobe\(product)\(version)\Installer</string>
            <string id="bSuppressMessageBar_x64">Hide Document Message Bar</string>
            <string id="bSuppressMessageBar_x64_Explain">Prevents the appearance of the document message bar.

Adversely affects signing when preview mode is used.</string>
            <string id="bDisablePDFHandlerSwitching_x64">Lock Default PDF Viewer</string>
            <string id="bDisablePDFHandlerSwitching_x64_Explain">Prevents users from changing the default PDF viewer application.

When locked, users cannot reassign PDF file handling to a different application through the Acrobat UI or Windows Apps &amp; Features. This ensures the managed Acrobat installation remains the system default PDF handler.

Possible values include:
0: Allow users to change the default PDF viewer.
1: Lock the default PDF viewer setting.</string>
            <string id="bDisableThumbnailPreviewHandler_x64">Lock PDF Thumbnails in Explorer</string>
            <string id="bDisableThumbnailPreviewHandler_x64_Explain">Specifies whether to disable and lock the user interface option that controls Acrobat-generated PDF thumbnail previews in Windows Explorer.

Oct 13, 2015: 32-bit Windows systems only. 64-bit support was enabled on May 9, 2016. This setting disables the user interface checkbox in the UI.

Possible values include:
0: Enable the UI checkbox so users can invoke the installer and enable the thumbnail preview handler.
1: Disable and lock the setting.</string>
            <string id="bMergeMenuBar_x64">Merge Title and Menu Bar</string>
            <string id="bMergeMenuBar_x64_Explain">Specifies whether to merge the application's title bar and menu bar into a single bar.

Note that &quot;Policies&quot; does not appear in the HKLM path.

Possible values include:
0: Don't merge the title and menu bars
1: Merge the bars</string>
            <string id="PatchCleanFlag_x64">Patch Cache Cleanup</string>
            <string id="PatchCleanFlag_x64_Explain">Triggers cleanup of old cached update patch files (MSI/MSP) on the next update cycle.

The Adobe ARM updater downloads MSI/MSP patch files that accumulate over time under C:\ProgramData\Adobe\ARM\ and C:\Windows\Installer\, potentially consuming multiple gigabytes of disk space. Setting this value to 1 causes the updater to remove old cached patch files during the next update.

Possible values include:
0: Do not clean up old patch files.
1: Clean up old cached patch files on next update.</string>
            <string id="bUpdater_Updater_x64">Product Updater</string>
            <string id="bUpdater_Updater_x64_Explain">Disables the product Updater and removes associated user interface items.

When set to 1, the Preferences &gt; Updater panel and the Help &gt; Check for Updates menu item are removed. This setting writes bUpdater to the FeatureLockDown root key. To also disable cloud services, set bUpdater = 1 in the cServices key using the Cloud Services Updates policy.

Possible values include:
0: Enable the Updater UI.
1: Disable the Updater and remove its UI items.</string>
            <string id="bEnableAcrobatPromptForDocOpen_x64">Prompt to Use Acrobat from Reader</string>
            <string id="bEnableAcrobatPromptForDocOpen_x64_Explain">Specifies whether to prompt users to use Acrobat when both Reader and Acrobat are installed.

When Acrobat and Reader are both present, opening a file in Reader prompts the user to switch to Acrobat as well as make Acrobat the default PDF viewer.

Possible values include:
0: Don't prompt to use Acrobat.
1: Prompt to use Acrobat.</string>
            <string id="bShouldUseScalableCursor_x64">Scalable Cursor</string>
            <string id="bShouldUseScalableCursor_x64_Explain">Specifies whether to disable the scalable cursor.

Because Citrix does not provide support for scalable cursors (32-bit cursors with an alpha channel) in legacy graphics mode, scalable cursor performance may be impaired on Citrix. Use this setting to improve performance on Citrix by using a non-scalable cursor.

Possible values include:
0: Don't use a scalable cursor.
1: Use a scalable cursor.</string>
            <string id="bFavoritesFeaturesLockDown_x64">Starred Files Feature</string>
            <string id="bFavoritesFeaturesLockDown_x64_Explain">Specifies whether to disable and lock the starred file feature.

A starred file is somewhat similar to a &quot;favorited&quot; file. This preference overrides bFavoritesStripInRFL .

Possible values include:
0: Disable and lock starred files in the recent files list.
1: Use bFavoritesStripInRFL to control this feature.</string>
            <string id="iInterval_x64">Update Watchdog Interval (Days)</string>
            <string id="iInterval_x64_Explain">Sets the time that can elapse without a successful update before the Watchdog dialog appears suggesting the user manually update.

This is an internal key that is not visible unless the admin creates it manually. When the Updater successfully obtains a manifest it records the download date. iInterval specifies the time interval that is allowed to pass from that download date to a successful update. The default is 135 days. If the time has elapsed, a dialog appears suggesting the user might want to manually get an update from adobe.com.

Possible values include:
135 days User specified.</string>
            <string id="iInterval_x64_opt0">90 days</string>
            <string id="iInterval_x64_opt1">135 days (default)</string>
            <string id="iInterval_x64_opt2">180 days</string>
            <string id="iInterval_x64_opt3">365 days</string>
            <string id="iLogLevel_x64">Updater Log Level</string>
            <string id="iLogLevel_x64_Explain">Sets the log level to either brief (0) or verbose (1).

Log file size is not limited during an update. However, since log files are appended to each time the Updater runs, there is a 1MB limit on old logs. Size limit behavior is as follows: If an existing log size is bigger than 1 MB, the Updater truncates the log. Old log files are backed up once as AdobeARM-backup. Logs reside at: Vista-Windows 7 (64 bit systems) %USERPROFILE%\AppData\Local\Temp\AdobeARM.log XP (32bit systems) %USERPROFILE%\Local Settings\Temp\AdobeARM.log Set the log level as follows: 0: Brief 1: Verbose</string>

            <!-- ======================================== -->
            <!--                  Upsell                  -->
            <!-- ======================================== -->

            <string id="bLimitPromptsFeatureKey_x64">Limit Informational Prompts</string>
            <string id="bLimitPromptsFeatureKey_x64_Explain">Specifies whether to limit the number of prompts a user will see in a 24 hour period.

Prompts include items like tips, calls-to-action, and feature walk throughs. These are not necessarily upsell items.

Possible values include:
0: Don't restrict informational prompts.
1: Limit prompts to 1 per day and 3 per week.</string>
            <string id="bReaderRetentionExperiment_x64">Prompt Reader Users to Download Acrobat</string>
            <string id="bReaderRetentionExperiment_x64_Explain">Specifies whether to prompt Acrobat subscribers using Reader to download Acrobat.

When enabled, download Acrobat prompts appear in Reader workflows where the user might benefit from Acrobat (purchased but not yet downloaded).

Possible values include:
0: Disable &quot;download Acrobat&quot; prompts in Reader.
1: Enable download prompts.</string>
            <string id="bToggleDCAppCenter_x64">Show App Center UI</string>
            <string id="bToggleDCAppCenter_x64_Explain">Specifies whether to show the UI that helps users find and download additional apps.

By default, the Home view displays a &quot;get apps&quot; banner and/or a link to the App Center where users can find and download additional apps (such as mobile apps). This preference removes both the banner and the App Center.

Possible values include:
0 (or null): Show the App Center UI.
1: Don't show the App Center UI.</string>
            <string id="bShowRhpToolSearch_x64">Show Purchasable Tools in Search</string>
            <string id="bShowRhpToolSearch_x64_Explain">Specifies whether to show &quot;for purchase&quot; tools when searching for tools in Reader.

When enabled, searching for tools in Reader shows all possible tool subscriptions.

Possible values include:
0: Don't show tool subscriptions.
1: Show tools which can be purchased.</string>
            <string id="bAcroSuppressUpsell_x64">Show Upgrade Prompts</string>
            <string id="bAcroSuppressUpsell_x64_Explain">Controls whether upgrade prompts and upsell messages are shown to Acrobat Reader users.

When suppressed, in-product prompts encouraging users to upgrade to Acrobat Pro are hidden. Disabling upsell messages reduces distractions and prevents users from purchasing or installing software outside of approved channels.

Possible values include:
0: Show upgrade and upsell prompts.
1: Suppress upgrade and upsell prompts.</string>
            <!-- ======================================== -->
            <!--                                          -->
            <!--  Adobe Reader DC (x86) - policy strings  -->
            <!--                                          -->
            <!-- ======================================== -->

            <!-- ======================================== -->
            <!--           Cloud and Connectors           -->
            <!-- ======================================== -->

            <string id="bToggleFillSign_x86">Adobe Fill &amp; Sign</string>
            <string id="bToggleFillSign_x86_Explain">Disables Adobe Fill and Sign.

Possible values include:
0: Enable Adobe Fill and Sign.
1: Disable Adobe Fill and Sign.</string>
            <string id="bBoxConnectorEnabled_x86">Box Cloud Connector</string>
            <string id="bBoxConnectorEnabled_x86_Explain">Specifies whether to enable connection to the Box cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Box
1: Enable connection to Box</string>
            <string id="bToggleAdobeDocumentServices_x86">Document Cloud Services</string>
            <string id="bToggleAdobeDocumentServices_x86_Explain">Controls access to Adobe Document Cloud services excluding Acrobat Sign, preference sync, and third-party connectors.

Disabling this removes cloud-based features including Create PDF, Export PDF, Organize Pages, and Combine Files. To disable all hosted services including web-plugin updates, set bUpdater = 1 instead.

Possible values include:
0: Enable Document Cloud services.
1: Disable Document Cloud services.</string>
            <string id="bToggleDocumentCloud_x86">Document Cloud Storage</string>
            <string id="bToggleDocumentCloud_x86_Explain">Specifies whether to enable Document Cloud storage.

DC storage is enabled by default.

Possible values include:
0: Enable Document Cloud storage.
1: Disable Document Cloud storage.</string>
            <string id="bDropboxConnectorEnabled_x86">Dropbox Cloud Connector</string>
            <string id="bDropboxConnectorEnabled_x86_Explain">Specifies whether to enable connection to the Dropbox cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Dropbox
1: Enable connection to Dropbox</string>
            <string id="bEnableGentech_x86">Generative AI Technology</string>
            <string id="bEnableGentech_x86_Explain">Specifies whether to enable generative AI features in Acrobat and Reader.

Possible values include:
0: Disable generative AI features.
1: Enable generative AI features. Generative AI capabilities may rely on cloud services; verify organizational policies and Adobe documentation for data handling.</string>
            <string id="bGoogleDriveConnectorEnabled_x86">Google Drive Connector</string>
            <string id="bGoogleDriveConnectorEnabled_x86_Explain">Specifies whether to enable connection to the Google Drive cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to Google Drive
1: Enable connection to Google Drive</string>
            <string id="bToggleSendACopy_x86">Hide Fill &amp; Sign Send a Copy Button</string>
            <string id="bToggleSendACopy_x86_Explain">Specifies whether to hide the Send a Copy button from the Fill &amp; Sign tool in Acrobat and Reader.

Possible values include:
0: Hide the button.
1: Show the button.</string>
            <string id="bSuppressSignOut_x86">Hide Sign Out Menu Item</string>
            <string id="bSuppressSignOut_x86_Explain">Specifies whether the sign-in and sign-out Help menu item should be enabled.

Possible values include:
0 or null: Don't disable the menu item.
1: Disable the Help menu item.</string>
            <string id="bOneDriveConnectorEnabled_x86">OneDrive Connector</string>
            <string id="bOneDriveConnectorEnabled_x86_Explain">Specifies whether to enable connection to the OneDrive cloud when bToggleWebConnectors is set to 1.

Overrides a bToggleWebConnectors value of 1. Only supported on the Continuous track.

Possible values include:
0: Disable connection to OneDrive
1: Enable connection to OneDrive</string>
            <string id="bTogglePrefsSync_x86">Preferences Synchronization</string>
            <string id="bTogglePrefsSync_x86_Explain">Controls whether application preferences are synchronized across devices via Adobe Document Cloud.

When a user is signed in with an Adobe ID, preferences can sync across desktop and mobile installations. Disabling this prevents preference data from leaving the managed environment and avoids unintended preference changes from personal devices.

Possible values include:
0: Enable preferences synchronization.
1: Disable preferences synchronization.</string>
            <string id="bUpdater_Updates_x86">Services &amp; Web-Plugin Updates</string>
            <string id="bUpdater_Updates_x86_Explain">Disables web-plugin component updates and all Adobe hosted services.

This is the master service switch for DC products under the cServices key, replacing the deprecated bEnableAcrobatHS preference. Setting to 1 disables both web-plugin updates and in-product cloud service access. To also remove the Updater UI, set bUpdater = 1 under the FeatureLockDown root key via the Services and Web-Plugin Updates policy.

Possible values include:
0: Enable cloud services and web-plugin updates.
1: Disable cloud services and web-plugin updates.</string>
            <string id="bToggleWebConnectors_x86">Third-Party Cloud Connectors</string>
            <string id="bToggleWebConnectors_x86_Explain">Controls in-product access to third-party cloud storage connectors such as Box, Dropbox, OneDrive, and Google Drive.

Disabling this removes the third-party connectors from the Home view, Open/Save dialogs, and the Add Account option. Individual connectors can be selectively re-enabled using bBoxConnectorEnabled, bDropboxConnectorEnabled, bGoogleDriveConnectorEnabled, and bOneDriveConnectorEnabled.

Possible values include:
0: Enable third-party cloud connectors.
1: Disable third-party cloud connectors.</string>

            <!-- ======================================== -->
            <!--        Context, Tools and Search         -->
            <!-- ======================================== -->

            <string id="bUIDensityAutoDetectionEnabled_x86">Auto UI Density Detection</string>
            <string id="bUIDensityAutoDetectionEnabled_x86_Explain">Specifies whether to disable the auto detection logic and bezel for changing Acrobat's display size.

By default, the UI is enabled so that a user may change the display size based on device screen size, resolution, and monitor scaling. 0: Disable the UI. 1: Show the UI.</string>
            <string id="bEnableContextualTips_x86">Contextual Help Tips</string>
            <string id="bEnableContextualTips_x86_Explain">Controls whether to automatically display help tips based on the current context.

Possible values include:
0: Disable contextual tips.
1: Enable tips.</string>
            <string id="bEnableContextualToolbar_x86">Contextual Toolbar</string>
            <string id="bEnableContextualToolbar_x86_Explain">Specifies whether to show the context toolbar (popup) when selecting a PDF object.

When enabled, a popup, floating toolbar appears when a user interacts with a PDF. For example, selecting text displays text markup tools. Selecting an image displays sticky note and editing tools.

Possible values include:
0: Don't show context toolbars.
1: Show toolbars.</string>
            <string id="bEnableExtractPageRange_x86">Extract Page Range UI</string>
            <string id="bEnableExtractPageRange_x86_Explain">Specifies whether to show the page range UI in the Extract Page dialog.

0: Don't show the page range UI. 1: Show the page range UI.</string>
            <string id="ProtectOldExperience_x86">Legacy Protect Tool Menu</string>
            <string id="ProtectOldExperience_x86_Explain">Specifies whether to disable the new Protect tool and revert to the old menu

The Protect tool provides options for encrypting and password protecting documents. The new UI provides some streamlined options, but this preference supports using the old menus.

Possible values include:
0 or null: Use the new protect app experience.
1: Revert to the existing (pre October, 2019) protect app experience.</string>
            <string id="bDisableAcrobatShortcutCustomization_x86">Lock Tool Shortcut Customization</string>
            <string id="bDisableAcrobatShortcutCustomization_x86_Explain">Prevents end users from modifying the tool shortcuts in the right hand pane.

Possible values include:
0: Don't disable shortcuts.
1: Disable shortcuts.</string>
            <string id="bEnableAV2Enterprise_x86">Modern Viewer</string>
            <string id="bEnableAV2Enterprise_x86_Explain">Specifies whether to enable the Modern Viewer.

The new app UI is rolling out in phases over 2023. As of June, 25% of users will see the updated user interface. This preference may interact with bShownViewerOnboarding and bEnableAV2 .

Possible values include:
0: Don't show the Modern Viewer
1: Show the Modern Viewer</string>
            <string id="bEnableRCMNewPOPUp_x86">New Right-Click Context Menu</string>
            <string id="bEnableRCMNewPOPUp_x86_Explain">Specifies whether to disable the new context menu and use the legacy version.

A new right-click context menu displays icons and additional menu options. 0: Disable the new context menu. 1: Enable the new menu.</string>
            <string id="bFindMoreWorkflowsOnline_x86">Online Actions Library Link</string>
            <string id="bFindMoreWorkflowsOnline_x86_Explain">Specifies whether to show the menu item that opens the online Actions file library.

Possible values include:
0: Disable the menu item.
1 or null: Don't disable the menu item.</string>
            <string id="bFindMoreCustomizationsOnline_x86">Online Tool Set Exchange Link</string>
            <string id="bFindMoreCustomizationsOnline_x86_Explain">Specifies whether to show the menu item that opens the online Acrobat Tool Set Exchange.

Possible values include:
0: Disable the menu item.
1 or null: Don't disable the menu item.</string>
            <string id="ADC4302862_x86">Paste in Place</string>
            <string id="ADC4302862_x86_Explain">Specifies whether to paste copied elements to the exact location as the copied element.

Some copy/paste operations are more efficient when copied elements are pasted to an identical location in the target document. This feature applies to form fields, annotations, and links.

Possible values include:
0: Disable the paste-in-place feature.
1: Enable the paste-in-place feature.</string>
            <string id="bRCMCombineFeatureKey_x86">Show Combine Files Context Menu</string>
            <string id="bRCMCombineFeatureKey_x86_Explain">Specifies whether to display the Combine Files item in a document's right-click context menu.

This preference only applies to machines that display the Modern Viewer (a phased rollout over 2023). When the Modern Viewer is disabled, admins can toggle the Combine Files UI off/on.

Possible values include:
0: Don't show the Combine Files UI.
1: Do show the Combine Files UI.</string>

            <!-- ======================================== -->
            <!--   Documents, Editing and Accessibility   -->
            <!-- ======================================== -->

            <string id="bGlobalBarMenuFeatureKey_x86">Create PDF Split Menu</string>
            <string id="bGlobalBarMenuFeatureKey_x86_Explain">Specifies whether to show the Create Split Menu under Create a PDF menu item.

Possible values include:
0: Don't show the Create Split menu.
1: Show the Create Split menu.</string>
            <string id="DisableScannedDocumentEditing_x86">Disable Scanned PDF Text Recognition</string>
            <string id="DisableScannedDocumentEditing_x86_Explain">Specifies whether to disable text recognition while editing scanned PDFs.

Possible values include:
0: Text recognition will be performed when invoking editing on scanned PDFs.
1: Text recognition will not be performed when invoking editing on scanned PDFs.</string>
            <string id="bEnableFrictionlessInChromeExtn_x86">Online Create PDF in Reader</string>
            <string id="bEnableFrictionlessInChromeExtn_x86_Explain">Specifies whether to show Reader users the online Create PDF service option.

Possible values include:
0 or null: Don't show the Create PDF UI
1: Show the convert web content to PDF UI</string>
            <string id="bIgnoreDataSchema_x86">Restrict Form Data to Schema</string>
            <string id="bIgnoreDataSchema_x86_Explain">Specifies whether all data in a form is saved rather than only data related to the form's schema.

Possible values include:
null: Save form data even when it's not part of a schema.
1: Save only form data that's part of the schema.</string>

            <!-- ======================================== -->
            <!--         Microsoft Purview (MIP)          -->
            <!-- ======================================== -->

            <string id="bMIPCheckPolicyOnDocSave_x86">Check MIP Policy on Save</string>
            <string id="bMIPCheckPolicyOnDocSave_x86_Explain">Locks enforcement of default or mandatory Microsoft Purview Information Protection labeling checks when saving documents.

Machine-level FeatureLockDown lockdown; grays out the related Preferences UI once set. Requires default or mandatory labeling to be configured in the Microsoft Purview compliance portal.

Possible values include:
0: Do not lock save-time MIP policy check.
1: Lock save-time MIP policy check enabled. This is admin lockdown under HKLM, not the per-user MicrosoftAIP preferences in User ADMX.</string>
            <string id="bMIPLabelling_x86">Enable MIP Labelling</string>
            <string id="bMIPLabelling_x86_Explain">Locks the Enable Microsoft Purview Information Protection option in Preferences ) Security.

Machine-level FeatureLockDown lockdown; end users cannot change the checkbox once this policy is applied.

Possible values include:
0: Do not lock MIP labelling preference.
1: Lock MIP labelling enabled. Complements per-user MicrosoftAIP preferences in User ADMX; this policy controls admin lockdown only.</string>
            <string id="bEnableDKEAdmin_x86">MIP Double Key Encryption</string>
            <string id="bEnableDKEAdmin_x86_Explain">Locks double key encryption (DKE) label support for Microsoft Purview Information Protection.

Machine-level FeatureLockDown lockdown for MIP DKE workflows.

Possible values include:
0: Lock DKE disabled.
1: Lock DKE enabled.</string>
            <string id="bMIPExternalAuthAdmin_x86">MIP External Browser Auth</string>
            <string id="bMIPExternalAuthAdmin_x86_Explain">Locks browser-based authentication for Microsoft Purview Information Protection operations.

Machine-level FeatureLockDown lockdown.

Possible values include:
0: Lock external browser auth disabled.
1: Lock external browser auth enabled.</string>
            <string id="iMIPCloud_x86">MIP Sovereign Cloud</string>
            <string id="iMIPCloud_x86_Explain">Locks which Microsoft cloud instance Acrobat and Reader use for MIP SDK operations.

Machine-level FeatureLockDown lockdown. Relevant for sovereign and government tenants. MIP SDK Cloud enum values: 0: Unknown. 1: Custom. 2: Test. 3: Commercial (default/global). 4: Germany. 5: US DoD. 6: US GCC. 7: US GCC High. 8: US Sec. 9: US Nat. 10: China.</string>
            <string id="iMIPCloud_x86_opt0">Unknown</string>
            <string id="iMIPCloud_x86_opt1">Custom</string>
            <string id="iMIPCloud_x86_opt2">Test</string>
            <string id="iMIPCloud_x86_opt3">Commercial</string>
            <string id="iMIPCloud_x86_opt4">Germany</string>
            <string id="iMIPCloud_x86_opt5">US DoD</string>
            <string id="iMIPCloud_x86_opt6">US GCC</string>
            <string id="iMIPCloud_x86_opt7">US GCC High</string>
            <string id="iMIPCloud_x86_opt8">US Sec</string>
            <string id="iMIPCloud_x86_opt9">US Nat</string>
            <string id="iMIPCloud_x86_opt10">China</string>
            <string id="bSilentAuth_x86">Suppress OS Auth Prompts (MIP)</string>
            <string id="bSilentAuth_x86_Explain">Locks whether operating-system authentication prompts are suppressed during MIP operations.

By default, OS-driven auth prompts for MIP are suppressed. Set policy Disabled to write DWORD 0 and allow OS auth prompts (useful when troubleshooting AADSTS50020-type errors).

Possible values include:
0: Allow OS auth prompts.
1: Suppress OS auth prompts.</string>

            <!-- ======================================== -->
            <!--    Security: Execution and Protection    -->
            <!-- ======================================== -->

            <string id="bEnable3D_x86">3D Content in PDFs</string>
            <string id="bEnable3D_x86_Explain">Specifies whether to trust and render 3D content in PDFs.

This setting can override b3DEnableContent.

Possible values include:
0: Don't render 3D content.
1: Trust and render 3D files.</string>
            <string id="bEnableProtectedModeAppContainer_x86">AppContainer Sandbox</string>
            <string id="bEnableProtectedModeAppContainer_x86_Explain">Specifies whether to enable the AppContainer sandbox.

Possible values include:
0: Disable Microsoft's AppContainer sandbox
1: Enable Microsoft's AppContainer sandbox</string>
            <string id="bEnableBlacklistForOpenSave_x86">Attachment Extension Blocklist in Dialogs</string>
            <string id="bEnableBlacklistForOpenSave_x86_Explain">Reverts the tBuiltInPermList behavior to that of the pre 21.011.20029 build.

Beginning with build 21.011.20029, extensions added in the tBuiltInPermList with restriction level 3 will be missing from the menu items in all the save and open dialogs. This feature is enabled by default. Users can revert to the old behavior by setting FeatureLockDown/bEnableBlacklistForOpenSave to 0.

Possible values include:
0: Revert to the legacy behavior.
1: Do nothing. Retain the new behavior.</string>
            <string id="bDisableJavaScript_x86">Block JavaScript Execution</string>
            <string id="bDisableJavaScript_x86_Explain">Blocks and locks JavaScript execution in PDF documents, preventing users from bypassing via privileged locations.

This lockable setting overrides bEnableJS and prevents users from re-enabling JavaScript through the Yellow Message Bar or Trusted Locations.

Possible values include:
0 or null: Don't disable JS.
1: Disable and lock JS.</string>
            <string id="iFileAttachmentPerms_x86">Block non-PDF file attachments</string>
            <string id="iFileAttachmentPerms_x86_Explain">Controls whether embedded file attachments of types other than PDF or FDF can be opened from within a PDF.

Restricting file attachments prevents users from launching non-PDF embedded files with external applications, reducing the risk of executing malicious payloads delivered inside PDF documents.

Possible values include:
1: Block non-PDF file attachments.
3: Prompt the user before opening non-PDF file attachments.</string>
            <string id="bDisablePDFRedirectionActions_x86">Block PDF Link Actions</string>
            <string id="bDisablePDFRedirectionActions_x86_Explain">Specifies whether to block specific PDF actions (listed below) which result in opening a link.

This preference does not block regular web links. Enabling this feature blocks PDF actions that open links, including GoToE, GoToR, Launch, Thread, Import Data, Export Form Data, Submit Form, and Reset Form.

Possible values include:
0 or null: Don't block these opening links.
1: Block links.</string>
            <string id="tBuiltInPermList_x86">Built-in Attachment Permissions List</string>
            <string id="tBuiltInPermList_x86_Explain">Defines the white and black list of file types that can be saved and opened from a document.

Pipe-separated list of file extensions with permission levels. Format: version:1|.ext:N where N is 0 (prompt, no allow), 1 (prompt, can allow/prohibit), 2 (always open), or 3 (never open). Referenced by bEnableBlacklistForOpenSave. Extensions with level 3 are hidden from save/open dialogs (build 21.011.20029+).</string>
            <string id="bEnablePVCertificateBasedTrust_x86">Certification Status in Protected View</string>
            <string id="bEnablePVCertificateBasedTrust_x86_Explain">Specifies whether a document's certification status should appear in the Protected View document message bar.

Possible values include:
0: Don't show the document's certification status.
1: Do show the document's certification status.</string>
            <string id="bEnhancedSecurityInBrowser_x86">Enhanced Security in Browser</string>
            <string id="bEnhancedSecurityInBrowser_x86_Explain">Controls Enhanced Security mode for PDFs opened inside a web browser.

When Enhanced Security is enabled in browser mode, Acrobat and Reader restrict unsafe document behaviors for PDFs viewed via the browser plugin, complementing the standalone application setting (bEnhancedSecurityStandalone).

Possible values include:
0: Disable Enhanced Security in browser mode.
1: Enable Enhanced Security in browser mode.</string>
            <string id="bEnhancedSecurityStandalone_x86">Enhanced Security Standalone</string>
            <string id="bEnhancedSecurityStandalone_x86_Explain">Controls Enhanced Security mode for PDFs opened in the standalone application.

When Enhanced Security is enabled, Acrobat and Reader restrict potentially unsafe document behaviors such as accessing external URLs, running scripts, and silently sending data to remote hosts. This reduces the risk of exploitation by malicious PDFs.

Possible values include:
0: Disable Enhanced Security in standalone mode.
1: Enable Enhanced Security in standalone mode.</string>
            <string id="bEnableFlash_x86">Flash Content in PDFs</string>
            <string id="bEnableFlash_x86_Explain">Controls whether Adobe Flash Player content embedded in PDF files is permitted to run.

Adobe Flash reached end-of-life in December 2020 and is no longer supported or patched. All Flash content in PDFs should be blocked to prevent exploitation of known unpatched Flash vulnerabilities.

Possible values include:
0: Block Flash content in PDFs.
1: Allow Flash content in PDFs.</string>
            <string id="EnableFlashEditing_x86">Flash Editing Tools</string>
            <string id="EnableFlashEditing_x86_Explain">Specifies whether to enable the Flash tools for adding annotations or Flash in the Rich Media app.

Possible values include:
0 or null: Remove &quot;Disable Flash ) Add SWF menu item.&quot;
1: Show the menu item.</string>
            <string id="bProtectedMode_x86">Protected Mode Sandbox</string>
            <string id="bProtectedMode_x86_Explain">Controls Protected Mode, which isolates the PDF rendering engine in a sandboxed process.

Protected Mode uses Windows integrity levels to restrict the renderer's access to the file system, registry, and network. This significantly limits the damage a successful PDF exploit can cause by preventing it from accessing system resources directly.

Possible values include:
0: Disable Protected Mode.
1: Enable Protected Mode.</string>
            <string id="bUseWhitelistConfigFile_x86">Protected Mode Whitelist Config</string>
            <string id="bUseWhitelistConfigFile_x86_Explain">Allows the use of the policy whitelist to allow behavior that Protected Mode would otherwise prevent.

This preference just toggles the ability of the application to read policy files.</string>
            <string id="bEnablePVSwitchoutShortcut_x86">Protected View Exit Shortcut Key</string>
            <string id="bEnablePVSwitchoutShortcut_x86_Explain">Enables a shortcut key that allows users to exit Protected View for a specific document.

This feature allows admins and users to keep Protected View enabled, but also exit that mode on-the-fly when necessary.

Possible values include:
0: Disable the shortcut key.
1: Enable the shortcut key that exits Protected View.</string>
            <string id="iUnlistedAttachmentTypePerm_x86">Unlisted Attachment Type Permissions</string>
            <string id="iUnlistedAttachmentTypePerm_x86_Explain">Specifies the default permissions for file types that aren't listed in the default or user-specified lists.

Possible values include:
0: Prompt user without ability to set file type as Allowed (two choices: Open File, Never Allow).
1 (default): Prompt user with ability to Allow or Prohibit (three choices).
2: Always open unlisted file types.
3: Never open unlisted file types.</string>
            <string id="iUnlistedAttachmentTypePerm_x86_opt0">Prompt without ability to allow (most restrictive prompt)</string>
            <string id="iUnlistedAttachmentTypePerm_x86_opt1">Prompt with ability to allow or prohibit (default)</string>
            <string id="iUnlistedAttachmentTypePerm_x86_opt2">Always open unlisted file types</string>
            <string id="iUnlistedAttachmentTypePerm_x86_opt3">Never open unlisted file types (most restrictive)</string>

            <!-- ======================================== -->
            <!--     Security: Trust and Permissions      -->
            <!-- ======================================== -->

            <string id="bMSStoreTrusted_x86">Allow Changes to Windows Certificate Store Trust</string>
            <string id="bMSStoreTrusted_x86_Explain">Locks the UI so that end users cannot change the value set by iMSStoreTrusted.

Set iMSStoreTrusted first, then use this preference to lock it. Allowable values include: 0: Lock the UI. 1: Same as null. Don't lock the UI.</string>
            <string id="bAllowInvisibleSig_x86">Allow Invisible Signatures</string>
            <string id="bAllowInvisibleSig_x86_Explain">Specifies whether to allow invisible certification signatures.

False disables the menu option, prevents signing and certifying with invisible signatures, and limits JavaScript support by signature fields.</string>
            <string id="bAllowPasswordSaving_x86">Allow Password Caching</string>
            <string id="bAllowPasswordSaving_x86_Explain">Controls whether certain passwords can be cached to disk; for example, passwords for digital IDs.

If false, users are prompted to enter a password every time one is required. Not all passwords are affected by this setting.</string>
            <string id="bEnableSignatureClear_x86">Allow Signature Clearing</string>
            <string id="bEnableSignatureClear_x86_Explain">Specifies whether to disable and lock the ability for a signer to clear their own signature.

Possible values include:
0: Disable signature clearing.
1: Enable signature clearing.</string>
            <string id="bVerifyUseAlways_x86">Always Use Specified Verify Handler</string>
            <string id="bVerifyUseAlways_x86_Explain">Qualifies the use of aVerify.

If true and aVerify is set to a handler name, then this handler is used to verify all signatures. If false, then the aVerify handler is used only to verify signatures when the handler specified by the signature dictionary Filter attribute is not present.</string>
            <string id="bDisableExpandEnvironmentVariables_x86">Block User Library Trust in Protected View</string>
            <string id="bDisableExpandEnvironmentVariables_x86_Explain">Provides a method for admins to whitelist user libraries as trusted locations when Protected View is enabled.

Protected View restricts features for all documents that do not reside in a trusted location. This new preference provides a way for admins to specify user-specific locations as trusted; in other words, documents with the path C:\Users\%username%\Desktop will open outside Protected View. For example, the user libraries Documents, Downloads, Desktop, and so on. When this preference is off, admins can only specify trusted locations which are static/identical for all users across their organization.

Possible values include:
0: Trust user-specific locations.
1: Don't trust user-specific locations.</string>
            <string id="bWinCacheSessionHandles_x86">Cache Digital ID Session Handles</string>
            <string id="bWinCacheSessionHandles_x86_Explain">Specifies whether to retain cryptographic service provider (CSP) handles when a user authenticates to a digital ID.

If true, a user does not have to re-authenticate to use the ID unless they log out or the session ends. The impact of this preference will vary based on the CSP in use; however, the setting does not affect the Windows CSPs.</string>
            <string id="bDisableOSTrustedSites_x86">Disable IE Trusted Sites as Privileged Locations</string>
            <string id="bDisableOSTrustedSites_x86_Explain">Locks the ability to treat IE trusted sites as privileged locations either on or off so the users can't change the bTrustOSTrustedSites value via the user interface.

If set, bTrustOSTrustedSites is simply ignored.

Possible values include:
0 or null: Enables and locks trusting sites from IE.
1: Disables and locks trusting sites from IE.</string>
            <string id="bAllowAPSConfig_x86">LiveCycle RMS Server Config</string>
            <string id="bAllowAPSConfig_x86_Explain">Prevents a LiveCycle Right Management Server from being configured by disabling the menu option in the Security Settings Console.

By default, configuration is allowed.</string>
            <string id="bReqRevCheck_x86">Lock Revocation Check Setting</string>
            <string id="bReqRevCheck_x86_Explain">Locks Security\cASPKI\cASPKI\cVerify\iReqRevCheck and disables the user interface item.</string>
            <string id="bReasons_x86">Lock Signing Reasons Settings</string>
            <string id="bReasons_x86_Explain">Prevents users from modifying reason settings.

v8.1: If locked and cReasons is empty, bAllowSigningReasons is 0 and read only. If locked and cReasons has values, then bAllowSigningReasons is true and read only.</string>
            <string id="bDisableTrustedFolders_x86">Lock Trusted Folders and Files</string>
            <string id="bDisableTrustedFolders_x86_Explain">Prevents users from adding trusted file and folder locations to Privileged Locations.

Privileged Locations bypass Enhanced Security restrictions. Allowing users to define them creates a pathway to weaken document security. Locking this setting prevents users from creating local exceptions that could expose the application to malicious PDFs.

Possible values include:
0: Allow users to configure trusted folder and file locations.
1: Disable and lock trusted folder and file locations.</string>
            <string id="bDisableTrustedSites_x86">Lock Trusted Host Sites</string>
            <string id="bDisableTrustedSites_x86_Explain">Prevents Internet Explorer Trusted Sites from being elevated to Privileged Locations.

Privileged Locations bypass Enhanced Security restrictions. Importing IE Trusted Sites as privileged locations could allow a broad set of sites to bypass document security controls. Locking this setting keeps the Privileged Locations list under administrator control.

Possible values include:
0: Allow IE Trusted Sites to be added as Privileged Locations.
1: Disable and lock the IE Trusted Sites elevation.</string>
            <string id="bEnableCEFBasedUI_x86">Modern Digital Signature UI</string>
            <string id="bEnableCEFBasedUI_x86_Explain">Specifies whether to enable the CEF-based, modern UI for digital signature workflows.

The newer UI streamlines the user interface. All values also disable the UI option to change the preference. Note that for products released after June 2016, disabling a user's ability to create a self-signed digital ID requires setting both bSelfSignCertGen and bEnableCEFBasedUI to 0.

Possible values include:
0: Disable the modern UI and shows the legacy UI.
1: Enable the Modern UI.</string>
            <string id="bUseTSAsSigningTime_x86">Show Timestamp in Signature</string>
            <string id="bUseTSAsSigningTime_x86_Explain">Specifies whether the timestamp time should be displayed in the signature appearance.

By default, the signature appearance displays the signing time from the signer's computer clock. To display the timestamp server time in a signature appearance: Go to HKLM\SOFTWARE\WOW6432Node\Policies\Adobe\(product)\(version)\FeatureLockDown\cSecurity\cPubSec\ Create the new DWORD bUseTSAsSigningTime and set it to 1. Go to HKCU\Software\Adobe\(product)\(version)\Security\cASPKI\cASPKI\cSign. Set bReqSigPropRetrieval to 1. Create the preference if it does not exist. Verify the computer time does not vary from the signature validation revocation check response time specified by HKCU\Software\Adobe\(product)\(version)\Security\cPubSec\ iMaxClockSkew . The default is 65 minutes. iMaxClockSkew allows admins to account for a network delay, time synchronization issues, and so on without invalidating signatures.

Possible values include:
0: Don't show the timestamp time.
1: Do show the timestamp time.</string>
            <string id="bAllowReasonWhenSigning_x86">Signing Reason UI</string>
            <string id="bAllowReasonWhenSigning_x86_Explain">Specifies whether the reason UI will appear during signing.

The preference can be overridden by a document seed value set on a field. For 8.1 and later, if cReasons is locked and is empty, bAllowSigningReasons is 0 and read only (The UI is turned off). If cReasons is locked and has values, then bAllowSigningReasons is true and read only.</string>
            <string id="bEnableCertificateBasedTrust_x86">Trust Certified Documents</string>
            <string id="bEnableCertificateBasedTrust_x86_Explain">Elevates (trusts) certified documents as a privileged location.

This lockable counterpart to bTrustCertifiedDocuments allows certified documents to bypass all the security restrictions that may be bypassed by other privileged locations. The exception is that this level of trust does not apply when the PDF is viewed in Protected View.

Possible values include:
0 or null: Don't make certified documents equivalent to privileged locations.
1: Do make certified documents equivalent to privileged locations (trusted).</string>
            <string id="iUnknownURLPerms_x86">Unknown URL Access Policy</string>
            <string id="iUnknownURLPerms_x86_Explain">Controls access to websites not explicitly listed in the user's Privileged Locations URL list.

This setting determines how Acrobat handles attempts to access URLs that are not in the trusted or blocked lists. It overrides trusted host settings for URLs that fall outside the configured list.

Possible values include:
1: Always ask before accessing unknown URLs.
2: Always allow access to unknown URLs.
3: Always block access to unknown URLs.</string>
            <string id="iUnknownURLPerms_x86_opt0">Always ask</string>
            <string id="iUnknownURLPerms_x86_opt1">Always allow</string>
            <string id="iUnknownURLPerms_x86_opt2">Always block</string>
            <string id="bValidateOnOpen_x86">Validate Signatures on Open</string>
            <string id="bValidateOnOpen_x86_Explain">Specifies whether to automatically validate all signatures on document open.

Note that the lockable setting does not configure the feature; instead, it locks what is set in HKCU and the user interface. 0: Don't validate signatures on document open. 1: Validate signatures on document open.</string>

            <!-- ======================================== -->
            <!--           Sharing and Features           -->
            <!-- ======================================== -->

            <string id="bToggleAdobeSign_x86">Adobe Acrobat Sign</string>
            <string id="bToggleAdobeSign_x86_Explain">Controls the Adobe Acrobat Sign (Send for Signature) service integration.

When disabled, the Send for Signature workflow is removed from the interface. For Continuous track installations, bToggleManageSign should also be set to 1 to fully remove the Acrobat Sign tracking tab from the Home view.

Possible values include:
0: Enable Adobe Acrobat Sign integration.
1: Disable Adobe Acrobat Sign integration.</string>
            <string id="bToggleSendAndTrack_x86">Adobe Send &amp; Track</string>
            <string id="bToggleSendAndTrack_x86_Explain">Disables Adobe Send and Track (some UI is renamed to &quot;Share&quot; since October, 2018)

Possible values include:
0: Enable Adobe Send and Track.
1: Disable Adobe Send and Track.</string>
            <string id="bDisableSharePointFeatures_x86">Disable SharePoint &amp; Office 365 Integration</string>
            <string id="bDisableSharePointFeatures_x86_Explain">Controls integration with SharePoint and Office 365 for file check-out and related menu items.

When disabled, the application does not detect SharePoint-hosted files, suppresses the check-out prompt, and removes SharePoint-specific menu items from the interface. This prevents unintended document synchronization with SharePoint environments.

Possible values include:
0: Enable SharePoint and Office 365 integration.
1: Disable SharePoint and Office 365 integration.</string>
            <string id="bDisableWebmail_x86">Disable WebMail Integration</string>
            <string id="bDisableWebmail_x86_Explain">Controls whether users can configure webmail profiles for sending PDF files by email.

When disabled, users cannot select a webmail profile from the Share pane email workflow. If bSendMailShareRedirection is also set to 1, clicking the email icon attaches the PDF directly to a new mail message instead.

Possible values include:
0: Enable webmail integration.
1: Disable webmail integration.</string>
            <string id="bToggleAdobeReview_x86">Document Cloud Review Service</string>
            <string id="bToggleAdobeReview_x86_Explain">Specifies whether to remove all UI related to the Document Cloud Review service.

When set to 1, this preference removes all cloud-based review UI, including the Review tab on the Home screen. Review tools such as the Send for Review tool in the tool's pane invoke legacy review types rather than DC reviews. The Share button also does not lead users to review workflows.

Possible values include:
0 (or null): Enable the Document Cloud Review service.
1: Disable the Document Cloud Review service.</string>
            <string id="bSendMailShareRedirection_x86">Email Icon Attach to Email Behavior</string>
            <string id="bSendMailShareRedirection_x86_Explain">Change the email icon behavior so that it attaches the document to an email.

With the new unified sharing experience, UI for sharing such as the Send, Attach to Email, and the email icon in the top bar, invokes the new unified share pane. However, when users frequently use &quot;Send documents as Attachment&quot;, set this preference to 1 to change the behavior of the Email icon so that one-click attaches the file to an email.

Possible values include:
0 or null: The email icon opens the share pane.
1: Change the email icon behavior to automatically attach the file to an email.</string>
            <string id="bMixRecentFilesFeatureLockDown_x86">Hide Shared Files from Recent List</string>
            <string id="bMixRecentFilesFeatureLockDown_x86_Explain">Specifies whether to show shared files in the Recent file list.

When enabled, shared files appear in the Recent list when a user successfully shares a file as well as when a recipient accepts an invite to the shared file workflow. This feature makes it easier to track files in live workflows (reviews, shares, signing workflows, and files shared via Send and Track).

Possible values include:
0: Add shared files to Recent list.
1: Don't add shared files to Recent list.</string>
            <string id="bToggleFSSSignatureSaving_x86">Save Signature to Cloud</string>
            <string id="bToggleFSSSignatureSaving_x86_Explain">Specifies whether to save a newly created signature in the cloud.

When a user creates a new signature, the dialog offers the option to store the signature in the cloud for later use. This preference also controls saving user initials.

Possible values include:
0: Show the Save Signature UI
1: Hide the Save Signature UI</string>
            <string id="bAdobeSendPluginToggle_x86">Send &amp; Track Outlook Plugin</string>
            <string id="bAdobeSendPluginToggle_x86_Explain">Controls the Adobe Send &amp; Track plugin for Microsoft Outlook.

When enabled, a Send &amp; Track button appears in Outlook that allows users to share large files as links via Adobe Document Cloud. Disabling this plugin reduces the application attack surface in environments that do not use this feature.

Possible values include:
0: Enable the Send &amp; Track Outlook plugin.
1: Disable the Send &amp; Track Outlook plugin.</string>
            <string id="bDisableADCFileStoreDC_x64">Disable Acrobat.com File Storage</string>
            <string id="bDisableADCFileStoreDC_x64_Explain">Prevents users from saving files to Acrobat.com storage.

Effective when Adobe hosted services are otherwise enabled (bEnableAcrobatHS = 1). Disables the Acrobat.com file storage feature without affecting other hosted services. Note: Deprecated in Acrobat DC 12.x and later -- use bToggleDocumentCloud for DC deployments.

Possible values include:
0: Allow file storage on Acrobat.com.
1: Disable file storage on Acrobat.com.</string>
            <string id="bDisableADCFileStoreDC_x86">Disable Acrobat.com File Storage</string>
            <string id="bDisableADCFileStoreDC_x86_Explain">Prevents users from saving files to Acrobat.com storage.

Effective when Adobe hosted services are otherwise enabled (bEnableAcrobatHS = 1). Disables the Acrobat.com file storage feature without affecting other hosted services. Note: Deprecated in Acrobat DC 12.x and later -- use bToggleDocumentCloud for DC deployments.

Possible values include:
0: Allow file storage on Acrobat.com.
1: Disable file storage on Acrobat.com.</string>
            <string id="bDisableADCFileStore_x64">Disable Acrobat.com File Storage</string>
            <string id="bDisableADCFileStore_x64_Explain">Prevents users from saving files to Acrobat.com storage.

Effective when Adobe hosted services are otherwise enabled (bEnableAcrobatHS = 1). Disables the Acrobat.com file storage feature without affecting other hosted services. Note: Deprecated in Acrobat DC 12.x and later -- use bToggleDocumentCloud for DC deployments.

Possible values include:
0: Allow file storage on Acrobat.com.
1: Disable file storage on Acrobat.com.</string>
            <string id="bDisableADCFileStore_x86">Disable Acrobat.com File Storage</string>
            <string id="bDisableADCFileStore_x86_Explain">Prevents users from saving files to Acrobat.com storage.

Effective when Adobe hosted services are otherwise enabled (bEnableAcrobatHS = 1). Disables the Acrobat.com file storage feature without affecting other hosted services. Note: Deprecated in Acrobat DC 12.x and later -- use bToggleDocumentCloud for DC deployments.

Possible values include:
0: Allow file storage on Acrobat.com.
1: Disable file storage on Acrobat.com.</string>
            <string id="bPreviouslyEnabledSharePointInChromeExtn_x86">SharePoint Chrome Extension Previous State</string>
            <string id="bPreviouslyEnabledSharePointInChromeExtn_x86_Explain">Stores the previous state of the SharePoint FeatureLockDown settings.

Possible values include:
Same as bEnableSharePointInChromeExtn in FeatureLockDown.</string>
            <string id="bEnableSharePointInChromeExtn_x86">SharePoint in Chrome Extension</string>
            <string id="bEnableSharePointInChromeExtn_x86_Explain">Specifies whether to integrate SharePoint into the Acrobat's Chrome extension.

Possible values include:
0: Don't enable SharePoint integration.
1: Enable.</string>
            <string id="bToggleManageSign_x86">Show Acrobat Sign Tracking Tab</string>
            <string id="bToggleManageSign_x86_Explain">Specifies whether to remove the Signature tab from the Home page's left-hand pane, notifications, and sign tracking cards.

When set to 1, the signature tab is hidden, the user will not see any agreements received or sent for signature, and all Acrobat Sign notifications are disabled on the desktop. It also removes signature-related cards under the To Do list.

Possible values include:
0: Show the Signature tab.
1: Hide the Signature tab.</string>
            <string id="bDisableOnBehalfOfText_x86">Show Comment Author in Shared Review</string>
            <string id="bDisableOnBehalfOfText_x86_Explain">If false, the string &quot;On behalf of&quot; does not append the author's name in the comment when another person opens the document in a shared-review workflow.

This preference is only used in shared review workflows.

Possible values include:
0: Don't display the comment author's name.
1: Do display the comment author's name.</string>
            <string id="iClientType_Gmail_x86">WebMail Client Type (Gmail)</string>
            <string id="iClientType_Gmail_x86_Explain">Identifies the Gmail Mail client type for WebMail.

The value can only be: 1</string>
            <string id="iClientType_Gmail_x86_opt0">Locked value: 1 (per Adobe PrefRef)</string>
            <string id="iClientType_Yahoo_x86">WebMail Client Type (Yahoo)</string>
            <string id="iClientType_Yahoo_x86_Explain">Identifies the Yahoo Mail client type for WebMail.

The value can only be: 2</string>
            <string id="iClientType_Yahoo_x86_opt0">Locked value: 2 (per Adobe PrefRef)</string>
            <string id="iIMAPPort_x86">WebMail IMAP Port</string>
            <string id="iIMAPPort_x86_Explain">Identifies the My Profile Mail IMAP server port number for WebMail.

The value can be: Any valid port number.</string>
            <string id="iIMAPPort_x86_opt0">143 (Standard IMAP)</string>
            <string id="iIMAPPort_x86_opt1">993 (IMAP over SSL/TLS)</string>
            <string id="iIMAPSecurity_x86">WebMail IMAP Security</string>
            <string id="iIMAPSecurity_x86_Explain">Specifies whether to enable the My Profile Mail IMAP security for WebMail.

The value can be: 0: Don't enable security. 1: Enable security.</string>
            <string id="iSMTPPort_x86">WebMail SMTP Port</string>
            <string id="iSMTPPort_x86_Explain">Identifies the My Profile Mail SMTP server port number for WebMail.

The value can be: Any valid server port number.</string>
            <string id="iSMTPPort_x86_opt0">25 (Standard SMTP)</string>
            <string id="iSMTPPort_x86_opt1">465 (SMTP over SSL)</string>
            <string id="iSMTPPort_x86_opt2">587 (SMTP Submission / TLS)</string>
            <string id="iSMTPSecurity_x86">WebMail SMTP Security</string>
            <string id="iSMTPSecurity_x86_Explain">Specifies whether to enable the My Profile Mail SMTP security for WebMail.

The value can be: 0: Don't enable security. 1: Enable security.</string>

            <!-- ======================================== -->
            <!--          Startup and Experience          -->
            <!-- ======================================== -->

            <string id="bShowMsgAtLaunch_x86">Adobe Messages at Launch</string>
            <string id="bShowMsgAtLaunch_x86_Explain">Specifies whether to show messages from Adobe when the product launches.

This preference also hides the Share Feedback icon, removes messages such as the 11.x &quot;end-of-life&quot; warning, and disables the dialog prompt that urges users to complete their profile. In later product versions, this preference removes the Home banner (top message area) from the Home view.

Possible values include:
0: Don't show messages from Adobe when the product launches.
1: Show messages from Adobe when the product launches.</string>
            <string id="bAllowUserToChangeMsgPrefs_x86">Allow Users to Change Message Preferences</string>
            <string id="bAllowUserToChangeMsgPrefs_x86_Explain">Locks the features associated with bShowMsgAtLaunch and bDontShowMsgWhenViewingDoc so that end users can't change the settings.

Possible values include:
0: Locks the feature so end users can't change the settings.
1: Allows users to change the settings. A value of 1 has the same effect as this key not existing at all.</string>
            <string id="bToggleNotifications_x86">Desktop Notifications</string>
            <string id="bToggleNotifications_x86_Explain">Specifies whether to disable all in-product and desktop notifications.

When 0 (or null), feature-specific notifications are managed via the related service preference. When set to 1, this preference disables all notifications irrespective of the values of all other keys.

Possible values include:
0: Enable desktop notifications.
1: Disable all desktop notifications.</string>
            <string id="bToggleFTE_x86">First Time Experience</string>
            <string id="bToggleFTE_x86_Explain">Specifies whether to enable the First Time Experience (FTE) feature (Welcome tour/page).

The first time experience (FTE) feature displays help content and tips when the application starts and also controls access to the Welcome Tour and Welcome page. FTE is also disabled if any of these preferences under FeatureLockDown\cServices are set: bUpdater , bToggleAdobeDocumentServices , bToggleAdobeSign , bTogglePrefsSync , bToggleWebConnectors .

Possible values include:
0 or null: Enable FTE features.
1: Disable FTE features.</string>
            <string id="bShowWelcomeScreenDC_x64">Welcome Screen on Startup</string>
            <string id="bShowWelcomeScreenDC_x64_Explain">Controls whether the Welcome screen is displayed when the application starts.

Disable this policy to suppress the Welcome screen on startup. Note: Deprecated in Acrobat DC 12.x and later -- use bToggleFTE for equivalent control on DC deployments.

Possible values include:
0: Do not show the Welcome screen on startup.
1: Show the Welcome screen on startup.</string>
            <string id="bShowWelcomeScreenDC_x86">Welcome Screen on Startup</string>
            <string id="bShowWelcomeScreenDC_x86_Explain">Controls whether the Welcome screen is displayed when the application starts.

Disable this policy to suppress the Welcome screen on startup. Note: Deprecated in Acrobat DC 12.x and later -- use bToggleFTE for equivalent control on DC deployments.

Possible values include:
0: Do not show the Welcome screen on startup.
1: Show the Welcome screen on startup.</string>
            <string id="bShowWelcomeScreen_x64">Welcome Screen on Startup</string>
            <string id="bShowWelcomeScreen_x64_Explain">Controls whether the Welcome screen is displayed when the application starts.

Disable this policy to suppress the Welcome screen on startup. Note: Deprecated in Acrobat DC 12.x and later -- use bToggleFTE for equivalent control on DC deployments.

Possible values include:
0: Do not show the Welcome screen on startup.
1: Show the Welcome screen on startup.</string>
            <string id="bShowWelcomeScreen_x86">Welcome Screen on Startup</string>
            <string id="bShowWelcomeScreen_x86_Explain">Controls whether the Welcome screen is displayed when the application starts.

Disable this policy to suppress the Welcome screen on startup. Note: Deprecated in Acrobat DC 12.x and later -- use bToggleFTE for equivalent control on DC deployments.

Possible values include:
0: Do not show the Welcome screen on startup.
1: Show the Welcome screen on startup.</string>
            <string id="bDontShowMsgWhenViewingDoc_x86">Hide Adobe Messages on Document Open</string>
            <string id="bDontShowMsgWhenViewingDoc_x86_Explain">Specifies whether to show messages from Adobe when a document opens.

This preference also controls messages in the right-hand pane for 12.x and later products as well as the &quot;Learn More&quot; link, including the &quot;Start Free Trial&quot; message promoting Acrobat.

Possible values include:
0: Don't show messages from Adobe when a document opens.
1: Show messages from Adobe when a document opens.</string>
            <string id="bEnableBellButton_x86">Hide In-Product Notifications Bell</string>
            <string id="bEnableBellButton_x86_Explain">Specifies whether to hide in-product messages.

A value of 1 hides notifications, but the product still fetches and caches them.

Possible values include:
0: Show in-product notifications.
1: Hide in-product notifications.</string>
            <string id="bToggleShareFeedback_x86">Hide Send Feedback Icon</string>
            <string id="bToggleShareFeedback_x86_Explain">Specifies whether to show the Send Feedback icon.

By default, the UI displays a feedback icon so that users can easily send feedback to Adobe with one click. This preference replaces bUsageMeasurement for 12.x and later products. Setting bShowMsgAtLaunch to 0 also hides the icon.

Possible values include:
0: Hide the icon.
1: Show the icon.</string>
            <string id="bUsageMeasurement_x86">Send Usage Data to Adobe</string>
            <string id="bUsageMeasurement_x86_Explain">Legacy master switch controlling whether usage data is collected and sent to Adobe.

Predates DC; superseded for most purposes by bToggleShareFeedback (12.x and later) and bEnableADMAnalytics, but Adobe documentation still references this key as the master switch that disables all data collection, including ADM analytics, when other related preferences are not lockable via HKLM. Retained here for environments that still rely on it.

Possible values include:
0: Disable usage data collection.
1: Enable usage data collection.</string>
            <string id="bToggleToDoList_x86">Home Screen To Do List</string>
            <string id="bToggleToDoList_x86_Explain">Specifies whether to show a &quot;to do&quot; list on the Home screen.

By default, the Home screen displays a list of action items such as Take a Tour, Export PDF, and so on. For details, see the What's New .

Possible values include:
0: Enable the feature.
1: Disable the feature.</string>
            <string id="bShowScanTabInHomeView_x86">Scan Tab in Home View</string>
            <string id="bShowScanTabInHomeView_x86_Explain">Specifies whether to disable the Scan tab in Home view.

When enabled, links to scans appear under the Scan tab in the Home view.

Possible values include:
0: Hide the scan tab.
1: Show the Scan tab.</string>
            <string id="bToggleNotificationToasts_x86">Show Desktop Notification Toasts</string>
            <string id="bToggleNotificationToasts_x86_Explain">Specifies whether to hide desktop notifications.

A value of 1 hides notifications, but the product still fetches and caches them.

Possible values include:
0: Show desktop notifications.
1: Hide desktop notifications.</string>
            <string id="bTogglePDFOwnershipToasts_x86">Show PDF Ownership Notification</string>
            <string id="bTogglePDFOwnershipToasts_x86_Explain">Specifies whether to show a notification on machine startup that allows the user to make Acrobat the default PDF viewer.

When enabled and both Acrobat and Reader are installed, the user can click on the notification to change the default PDF viewer.

Possible values include:
0: Show PDF ownership notification on application startup.
1: Don't show ownership notification.</string>
            <string id="bToggleToDoTiles_x86">Show To Do Cards in Recent Tab</string>
            <string id="bToggleToDoTiles_x86_Explain">Specifies whether to show To Do Cards in the Recent Tab view

To Do cards list potential action items for members of certain workflows (for example, collaborative reviews). When set to 1, To Do cards do not appear in the Recent tab.

Possible values include:
0 or null: Show cards for unaccepted workflows (reviews, views and sign).
1: Hide cards for unaccepted workflows (reviews, views and sign).</string>
            <string id="bWhatsNewExp_x86">What's New Experience</string>
            <string id="bWhatsNewExp_x86_Explain">Specifies whether to disable the What's New experience.

This feature was phased in incrementally over 2022. When enabled, the default user on first launch will see a What's New screen as well as a See new features notification. These UI items appear once.

Possible values include:
0: Enable the What's New experience.
1: Disable.</string>

            <!-- ======================================== -->
            <!--     Updates and Desktop Integration      -->
            <!-- ======================================== -->

            <string id="bDisableThirdPartyPluginNotif_x86">32-Bit Plugin Upgrade Notification</string>
            <string id="bDisableThirdPartyPluginNotif_x86_Explain">Specifies whether to notify users with 32 bit plugins that the app will soon update to 64 bit.

32 bit plugins will not work in the 64 bit app. The notification provides a &quot;Learn more&quot; link that provides additional details about how to upgrade their plugin.

Possible values include:
0: Do not warn the user about 32 bit plugins.
1: Do warn the user.</string>
            <string id="EULA_x86">Accept EULA for Updater</string>
            <string id="EULA_x86_Explain">Accepts the Adobe end-user license agreement (EULA) on behalf of the user.

The EULA must be accepted before the built-in updater can download product updates. In enterprise deployments the EULA is typically accepted at install time via the EULA_ACCEPT=YES MSI property; this policy provides an alternative mechanism when the installer property was not set.

Possible values include:
0: EULA not accepted.
1: EULA accepted.</string>
            <string id="bEnableAutoDockUndockHUD_x86">Auto Dock HUD Bar</string>
            <string id="bEnableAutoDockUndockHUD_x86_Explain">Specifies whether to automatically dock and undock the HUD bar based on the window size.

Possible values include:
0: Disable automatic behavior.
1: Enable auto docking and undocking.</string>
            <string id="bHasAcrobatConsent_x86">Auto Open Acrobat from Reader</string>
            <string id="bHasAcrobatConsent_x86_Explain">Specifies whether the Reader process should automatically open Acrobat for the current file.

PDF ownership does not change. Reader will continue as the default PDF viewer on this machine.

Possible values include:
0: Don't automatically use Acrobat.
1: Use Acrobat</string>
            <string id="bAcroSuppressOpenInReader_x86">Disable Chrome PDF Extension</string>
            <string id="bAcroSuppressOpenInReader_x86_Explain">Specifies whether to disable and lock the PDF viewer Chrome extension.

See also ENABLE_CHROMEEXT .

Possible values include:
0 or null: Extension is enabled; users can open PDFs in a browser with Acrobat Reader
1: Disable the browser-based PDF viewer. A tooltip says &quot;The Acrobat Reader extension is currently disabled. Please contact your IT admin.&quot;</string>
            <string id="iDisablePromptForUpgrade_x86">Disable Major Version Upgrade Prompt</string>
            <string id="iDisablePromptForUpgrade_x86_Explain">Specifies whether the application should show a prompt suggesting the user upgrade to the next major version (for example, 10.0 to 11.0).

If updates have been disabled (bUpdater = 0), then upgrades are also disabled. The feature also requires that the update settings are set to &quot;automatic.&quot; 0 or null: No effect. 1: Disable the prompt asking users if they would like to upgrade to a higher major version.</string>
            <string id="DisableMaintenance_x86">Disable Repair for All Users</string>
            <string id="DisableMaintenance_x86_Explain">Disables the Repair Installation option for all users.

When set, the Help &gt; Repair Acrobat Installation menu item and the repair option in Windows Apps &amp; Features are disabled, preventing users from modifying the installation without administrator involvement.

Possible values include:
0: Allow repair installation.
1: Disable repair installation.</string>
            <string id="Disable_Repair_x86">Disable Repair for Standard Users</string>
            <string id="Disable_Repair_x86_Explain">Specifies whether to disable the Help ) Repair Installation menu for standard users on virtualized installations.

When working with virtualized installations, users should not be able to run repair from the help menu. Only an administrator should be able to invoke actions that may require a reboot of a Citrix server, WT server, and so on. To disable the menu item, create this preference and set the value to 1. See also DisableMaintenance . The path is as follows: 32 bit machines: HKLM\SOFTWARE\Adobe\(product)\(version)\Installer 64 bit machines: HKLM\SOFTWARE\Wow6432Node\Adobe\(product)\(version)\Installer</string>
            <string id="bSuppressMessageBar_x86">Hide Document Message Bar</string>
            <string id="bSuppressMessageBar_x86_Explain">Prevents the appearance of the document message bar.

Adversely affects signing when preview mode is used.</string>
            <string id="bDisablePDFHandlerSwitching_x86">Lock Default PDF Viewer</string>
            <string id="bDisablePDFHandlerSwitching_x86_Explain">Prevents users from changing the default PDF viewer application.

When locked, users cannot reassign PDF file handling to a different application through the Acrobat UI or Windows Apps &amp; Features. This ensures the managed Acrobat installation remains the system default PDF handler.

Possible values include:
0: Allow users to change the default PDF viewer.
1: Lock the default PDF viewer setting.</string>
            <string id="bDisableThumbnailPreviewHandler_x86">Lock PDF Thumbnails in Explorer</string>
            <string id="bDisableThumbnailPreviewHandler_x86_Explain">Specifies whether to disable and lock the user interface option that controls Acrobat-generated PDF thumbnail previews in Windows Explorer.

Oct 13, 2015: 32-bit Windows systems only. 64-bit support was enabled on May 9, 2016. This setting disables the user interface checkbox in the UI.

Possible values include:
0: Enable the UI checkbox so users can invoke the installer and enable the thumbnail preview handler.
1: Disable and lock the setting.</string>
            <string id="bMergeMenuBar_x86">Merge Title and Menu Bar</string>
            <string id="bMergeMenuBar_x86_Explain">Specifies whether to merge the application's title bar and menu bar into a single bar.

Note that &quot;Policies&quot; does not appear in the HKLM path.

Possible values include:
0: Don't merge the title and menu bars
1: Merge the bars</string>
            <string id="PatchCleanFlag_x86">Patch Cache Cleanup</string>
            <string id="PatchCleanFlag_x86_Explain">Triggers cleanup of old cached update patch files (MSI/MSP) on the next update cycle.

The Adobe ARM updater downloads MSI/MSP patch files that accumulate over time under C:\ProgramData\Adobe\ARM\ and C:\Windows\Installer\, potentially consuming multiple gigabytes of disk space. Setting this value to 1 causes the updater to remove old cached patch files during the next update.

Possible values include:
0: Do not clean up old patch files.
1: Clean up old cached patch files on next update.</string>
            <string id="bUpdater_Updater_x86">Product Updater</string>
            <string id="bUpdater_Updater_x86_Explain">Disables the product Updater and removes associated user interface items.

When set to 1, the Preferences &gt; Updater panel and the Help &gt; Check for Updates menu item are removed. This setting writes bUpdater to the FeatureLockDown root key. To also disable cloud services, set bUpdater = 1 in the cServices key using the Cloud Services Updates policy.

Possible values include:
0: Enable the Updater UI.
1: Disable the Updater and remove its UI items.</string>
            <string id="bEnableAcrobatPromptForDocOpen_x86">Prompt to Use Acrobat from Reader</string>
            <string id="bEnableAcrobatPromptForDocOpen_x86_Explain">Specifies whether to prompt users to use Acrobat when both Reader and Acrobat are installed.

When Acrobat and Reader are both present, opening a file in Reader prompts the user to switch to Acrobat as well as make Acrobat the default PDF viewer.

Possible values include:
0: Don't prompt to use Acrobat.
1: Prompt to use Acrobat.</string>
            <string id="bShouldUseScalableCursor_x86">Scalable Cursor</string>
            <string id="bShouldUseScalableCursor_x86_Explain">Specifies whether to disable the scalable cursor.

Because Citrix does not provide support for scalable cursors (32-bit cursors with an alpha channel) in legacy graphics mode, scalable cursor performance may be impaired on Citrix. Use this setting to improve performance on Citrix by using a non-scalable cursor.

Possible values include:
0: Don't use a scalable cursor.
1: Use a scalable cursor.</string>
            <string id="bFavoritesFeaturesLockDown_x86">Starred Files Feature</string>
            <string id="bFavoritesFeaturesLockDown_x86_Explain">Specifies whether to disable and lock the starred file feature.

A starred file is somewhat similar to a &quot;favorited&quot; file. This preference overrides bFavoritesStripInRFL .

Possible values include:
0: Disable and lock starred files in the recent files list.
1: Use bFavoritesStripInRFL to control this feature.</string>
            <string id="iInterval_x86">Update Watchdog Interval (Days)</string>
            <string id="iInterval_x86_Explain">Sets the time that can elapse without a successful update before the Watchdog dialog appears suggesting the user manually update.

This is an internal key that is not visible unless the admin creates it manually. When the Updater successfully obtains a manifest it records the download date. iInterval specifies the time interval that is allowed to pass from that download date to a successful update. The default is 135 days. If the time has elapsed, a dialog appears suggesting the user might want to manually get an update from adobe.com.

Possible values include:
135 days User specified.</string>
            <string id="iInterval_x86_opt0">90 days</string>
            <string id="iInterval_x86_opt1">135 days (default)</string>
            <string id="iInterval_x86_opt2">180 days</string>
            <string id="iInterval_x86_opt3">365 days</string>
            <string id="iLogLevel_x86">Updater Log Level</string>
            <string id="iLogLevel_x86_Explain">Sets the log level to either brief (0) or verbose (1).

Log file size is not limited during an update. However, since log files are appended to each time the Updater runs, there is a 1MB limit on old logs. Size limit behavior is as follows: If an existing log size is bigger than 1 MB, the Updater truncates the log. Old log files are backed up once as AdobeARM-backup. Logs reside at: Vista-Windows 7 (64 bit systems) %USERPROFILE%\AppData\Local\Temp\AdobeARM.log XP (32bit systems) %USERPROFILE%\Local Settings\Temp\AdobeARM.log Set the log level as follows: 0: Brief 1: Verbose</string>

            <!-- ======================================== -->
            <!--                  Upsell                  -->
            <!-- ======================================== -->

            <string id="bLimitPromptsFeatureKey_x86">Limit Informational Prompts</string>
            <string id="bLimitPromptsFeatureKey_x86_Explain">Specifies whether to limit the number of prompts a user will see in a 24 hour period.

Prompts include items like tips, calls-to-action, and feature walk throughs. These are not necessarily upsell items.

Possible values include:
0: Don't restrict informational prompts.
1: Limit prompts to 1 per day and 3 per week.</string>
            <string id="bReaderRetentionExperiment_x86">Prompt Reader Users to Download Acrobat</string>
            <string id="bReaderRetentionExperiment_x86_Explain">Specifies whether to prompt Acrobat subscribers using Reader to download Acrobat.

When enabled, download Acrobat prompts appear in Reader workflows where the user might benefit from Acrobat (purchased but not yet downloaded).

Possible values include:
0: Disable &quot;download Acrobat&quot; prompts in Reader.
1: Enable download prompts.</string>
            <string id="bToggleDCAppCenter_x86">Show App Center UI</string>
            <string id="bToggleDCAppCenter_x86_Explain">Specifies whether to show the UI that helps users find and download additional apps.

By default, the Home view displays a &quot;get apps&quot; banner and/or a link to the App Center where users can find and download additional apps (such as mobile apps). This preference removes both the banner and the App Center.

Possible values include:
0 (or null): Show the App Center UI.
1: Don't show the App Center UI.</string>
            <string id="bShowRhpToolSearch_x86">Show Purchasable Tools in Search</string>
            <string id="bShowRhpToolSearch_x86_Explain">Specifies whether to show &quot;for purchase&quot; tools when searching for tools in Reader.

When enabled, searching for tools in Reader shows all possible tool subscriptions.

Possible values include:
0: Don't show tool subscriptions.
1: Show tools which can be purchased.</string>
            <string id="bAcroSuppressUpsell_x86">Show Upgrade Prompts</string>
            <string id="bAcroSuppressUpsell_x86_Explain">Controls whether upgrade prompts and upsell messages are shown to Acrobat Reader users.

When suppressed, in-product prompts encouraging users to upgrade to Acrobat Pro are hidden. Disabling upsell messages reduces distractions and prevents users from purchasing or installing software outside of approved channels.

Possible values include:
0: Show upgrade and upsell prompts.
1: Suppress upgrade and upsell prompts.</string>

            <!-- ======================================== -->
            <!--           Browser Extension              -->
            <!-- ======================================== -->

            <string id="OpenHelpxChrome">Open Help Tab on Install</string>
            <string id="OpenHelpxChrome_Explain">Controls whether the Acrobat browser extension opens its help/onboarding tab automatically.

This configures the extension itself via Chrome's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace. It does not control whether the extension is installed -- use Chrome's own ExtensionInstallForcelist/ExtensionInstallBlocklist policies for that.

Possible values include:
true: Open the help tab automatically on install.
false: Do not open the help tab.</string>
            <string id="OpenHelpxEdge">Open Help Tab on Install</string>
            <string id="OpenHelpxEdge_Explain">Controls whether the Acrobat browser extension opens its help/onboarding tab automatically.

This configures the extension itself via Edge's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace. It does not control whether the extension is installed -- use Edge's own ExtensionInstallForcelist/ExtensionInstallBlocklist policies for that.

Possible values include:
true: Open the help tab automatically on install.
false: Do not open the help tab.</string>

            <string id="UsageMeasurementChrome">Usage Analytics</string>
            <string id="UsageMeasurementChrome_Explain">Controls whether the Acrobat browser extension collects and sends usage analytics.

This is separate from the desktop application's own bUsageMeasurement preference -- it applies only to the Chrome extension. Configured via Chrome's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace.

Possible values include:
true: Enable usage analytics in the extension.
false: Disable usage analytics in the extension.</string>
            <string id="UsageMeasurementEdge">Usage Analytics</string>
            <string id="UsageMeasurementEdge_Explain">Controls whether the Acrobat browser extension collects and sends usage analytics.

This is separate from the desktop application's own bUsageMeasurement preference -- it applies only to the Edge extension. Configured via Edge's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace.

Possible values include:
true: Enable usage analytics in the extension.
false: Disable usage analytics in the extension.</string>

            <string id="UninstallPopupChrome">Uninstall Popup for Free Users</string>
            <string id="UninstallPopupChrome_Explain">Controls whether the Acrobat browser extension shows a popup prompting users who have moved to the free plan to uninstall.

Configured via Chrome's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace.

Possible values include:
true: Show the uninstall popup for free-plan users.
false: Hide the uninstall popup.</string>
            <string id="UninstallPopupEdge">Uninstall Popup for Free Users</string>
            <string id="UninstallPopupEdge_Explain">Controls whether the Acrobat browser extension shows a popup prompting users who have moved to the free plan to uninstall.

Configured via Edge's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace.

Possible values include:
true: Show the uninstall popup for free-plan users.
false: Hide the uninstall popup.</string>

            <string id="DisableGenAIChrome">Disable GenAI Features</string>
            <string id="DisableGenAIChrome_Explain">Disables generative AI features in the Acrobat browser extension.

Configured via Chrome's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace. This is independent of the desktop application's generative AI controls.

Possible values include:
true: Disable generative AI features in the extension.
false: Allow generative AI features in the extension.</string>
            <string id="DisableGenAIEdge">Disable GenAI Features</string>
            <string id="DisableGenAIEdge_Explain">Disables generative AI features in the Acrobat browser extension.

Configured via Edge's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace. This is independent of the desktop application's generative AI controls.

Possible values include:
true: Disable generative AI features in the extension.
false: Allow generative AI features in the extension.</string>

            <string id="DisableWhatsNewAutoOpenChrome">Disable What's New Auto-Open</string>
            <string id="DisableWhatsNewAutoOpenChrome_Explain">Stops the What's New page from automatically opening in the browser when the Acrobat extension updates.

Configured via Chrome's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace.

Possible values include:
true: Suppress the What's New auto-open.
false: Allow the What's New page to open automatically after updates.</string>
            <string id="DisableWhatsNewAutoOpenEdge">Disable What's New Auto-Open</string>
            <string id="DisableWhatsNewAutoOpenEdge_Explain">Stops the What's New page from automatically opening in the browser when the Acrobat extension updates.

Configured via Edge's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace.

Possible values include:
true: Suppress the What's New auto-open.
false: Allow the What's New page to open automatically after updates.</string>

            <string id="DisableExpressChrome">Disable Express Features</string>
            <string id="DisableExpressChrome_Explain">Disables Adobe Express features (such as Edit Image) in the Acrobat browser extension.

Configured via Chrome's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace.

Possible values include:
true: Disable Express features in the extension.
false: Allow Express features in the extension.</string>
            <string id="DisableExpressEdge">Disable Express Features</string>
            <string id="DisableExpressEdge_Explain">Disables Adobe Express features (such as Edit Image) in the Acrobat browser extension.

Configured via Edge's managed-storage policy mechanism (a 3rdparty extension policy), not Adobe's own FeatureLockDown registry namespace.

Possible values include:
true: Disable Express features in the extension.
false: Allow Express features in the extension.</string>

      <!-- User-scope strings -->
      <string id="SupportedAcrobatDC_User">Adobe Acrobat DC</string>
            <string id="SupportedReaderDC_User">Adobe Reader DC</string>

            <string id="AdobeCategory_User">Adobe (User)</string>
            <string id="AcrobatDCCategory_User">Acrobat DC (User)</string>
            <string id="ReaderDCCategory_User">Reader DC (User)</string>

            <string id="Cat_ContextToolsSearch_User">Context, Tools &amp; Search</string>
            <string id="Cat_DocsEditAccess_User">Documents, Editing &amp; Accessibility</string>
            <string id="Cat_MicrosoftPurviewMIP_User">Microsoft Purview (MIP)</string>
            <string id="Cat_SecurityExec_User">Security: Execution &amp; Protection</string>
            <string id="Cat_SecurityTrust_User">Security: Trust &amp; Permissions</string>
            <string id="Cat_SharingFeatures_User">Sharing &amp; Features</string>
            <string id="Cat_StartupExperience_User">Startup &amp; Experience</string>
            <string id="Cat_UpdatesDesktop_User">Updates &amp; Desktop Integration</string>
            <string id="Cat_Upsell_User">Upsell</string>

            <!-- ======================================== -->
            <!--                                          -->
            <!-- Adobe Acrobat DC (User) - policy strings -->
            <!--                                          -->
            <!-- ======================================== -->

            <!-- ======================================== -->
            <!--        Context, Tools and Search         -->
            <!-- ======================================== -->

            <string id="iColumnSelectHaloDC_User">Column Select Halo</string>
            <string id="iColumnSelectHaloDC_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
            <string id="DisableSignInOfficeDC_User">Disable Sign in Office</string>
            <string id="DisableSignInOfficeDC_User_Explain">Specifies whether to install PDFMaker's Acrobat Sign integration component so that the sign user interface appears in Microsoft Office products.

Possible values include:
0: Enable the Office plugin.
1: Disable the plugin.</string>
            <string id="EnableSignInOfficeDC_User">Enable Sign in Office</string>
            <string id="EnableSignInOfficeDC_User_Explain">Specifies whether to install PDFMaker's Acrobat Sign integration component so that the sign user interface appears in Microsoft Office products.

Enabling this feature allows the user to invoke the Acrobat Sign workflow in MS Office products. Note that the Mac pref has a different name and plist location.

Possible values include:
0: Disable PDFMaker's sign component.
1: Enable Acrobat Sign component.</string>
            <string id="bAlwaysUseFileNameAsDocTitleDC_User">Filename as Title</string>
            <string id="bAlwaysUseFileNameAsDocTitleDC_User_Explain">Specifies whether to use the PDF file name as the display name in the application's title bar.

PDF documents have an Initial View property that's set to &quot;Document Title&quot; by default. Enabling this preference overrides any document-level setting with the app-level setting.

Possible values include:
0: Don't use file names.
1: Use file names for the PDF title.</string>
            <string id="bUseFixedSnapshotResolutionDC_User">Fixed Snapshot Resolution</string>
            <string id="bUseFixedSnapshotResolutionDC_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
            <string id="ADC4318556DC_User">Flash Player for 3D</string>
            <string id="ADC4318556DC_User_Explain">Enables playing 3D and multimedia content using a Flash player in PDF.

Since Flash is no longer supported, admins must install and configure the player.

Possible values include:
0 or null: Don't play content with a Flash player.
1: Use the Flash player.</string>
            <string id="bHandSelectsDC_User">Hand Tool Select</string>
            <string id="bHandSelectsDC_User_Explain">Specifies whether the hand tool should be able to select text and images.

With the DC 10/13/2015 release, this setting also works on Windows Touch devices.

Possible values include:
0: Don't select text and images.
1: Select text and images.</string>
            <string id="iMaxMRUCntToBeStoredDC_User">Max Recent Files</string>
            <string id="iMaxMRUCntToBeStoredDC_User_Explain">Stores the number of recent files that should be listed in the recent files list.

The recent files list appears under the file menu (5 item limit), the splash screen (5 item limit), and in My Files View (100 item limit). A number from 0-100. The default is 100.</string>
            <string id="bEnableAv2DC_User">Modern Viewer</string>
            <string id="bEnableAv2DC_User_Explain">Specifies whether to show the modern viewer first released in July 2022.

0: Show the classic viewer. 1: Show the modern viewer.</string>
            <string id="bAllowMultipleExpandedPanelsDC_User">Multiple Comment Panels</string>
            <string id="bAllowMultipleExpandedPanelsDC_User_Explain">Specifies whether multiple comment panels can be expanded.

Possible values include:
0: Don't allow more than one visible panel.
1: Do allow multiple visible panels.</string>
            <string id="iNumSwitcherContextualToolTipAV2ShownDC_User">New Look Coachmark</string>
            <string id="iNumSwitcherContextualToolTipAV2ShownDC_User_Explain">Specifies whether to show the &quot;Acrobat has a new look&quot; coachmark after launching Acrobat the first time.

Once the coachmark displays, the app automatically resets this value to 0. This preference has no effect if bEnableAv2 is 0. 0: Do not show the coachmark. 1: Show the coachmark.</string>
            <string id="bPinHUDDC_User">Pin HUD Toolbar</string>
            <string id="bPinHUDDC_User_Explain">Specifies whether to pin the HUD to the toolbar.

The application automatically creates this key when you click the &quot;pin to menu&quot; icon on the right-hand side of the HUD.

Possible values include:
0: Don't pin the HUD to the toolbar.
1: Pin the HUD to the toolbar.</string>
            <string id="bPromptBeforeClosingMultipleTabsDC_User">Prompt Close Tabs</string>
            <string id="bPromptBeforeClosingMultipleTabsDC_User_Explain">Specifies whether to warn the user before closing documents open in multiple tabs.

The ability to open documents in separate tabs was introduced in October, 2015.

Possible values include:
0: Don't warn the user.
1: Warn the user.</string>
            <string id="bImagesFirstDC_User">Select Images First</string>
            <string id="bImagesFirstDC_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
            <string id="bInfobubbleDC_User">Show Tool Pane Tips</string>
            <string id="bInfobubbleDC_User_Explain">Specifies whether the popup tooltips for the Tools, Comments, and Share panes should appear.

Possible values include:
0: Disable popup tooltips.
1: Enable popup tooltips.</string>
            <string id="bKeyPrefsShowVirtualKeyoardDC_User">Show Touch Keyboard</string>
            <string id="bKeyPrefsShowVirtualKeyoardDC_User_Explain">Specifies whether to show the touch keyboard if device is in touch or tablet mode on Win 8 and later.

In general, the virtual keyboard should only appear on touch devices running Windows 8 and later where the user has detached a soft keyboard. The keyboard should appear when a user taps a text area such as a search box, comment popup, form field, and so on.

Possible values include:</string>
            <string id="iSnapshotResolutionDC_User">Snapshot Resolution DPI</string>
            <string id="iSnapshotResolutionDC_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
            <string id="ADC4406238DC_User">Suppress PDF/UA Dialog</string>
            <string id="ADC4406238DC_User_Explain">Specifies whether to suppress the confirmation dialog when the Acrobat preference Mark PDF/UA compliant is checked in Microsoft Word.

Admins can disable the following dialog when converting a Microsoft Word document to PDF:

Possible values include:
0: Don't show the dialog.
1: Show the dialog.</string>
            <string id="irightPaneStateDC_User">Tools Pane State</string>
            <string id="irightPaneStateDC_User_Explain">Specifies whether to automatically open the Tools Pane on launch.

Possible values include:
0: Use the default.
1: Always closed.
2: Always open.</string>
            <string id="iBasicSharePaneStickyStatusDC_User">Tools Pane Sticky</string>
            <string id="iBasicSharePaneStickyStatusDC_User_Explain">Specifies whether to remember the Tools Pane state across sessions.

For example, if the user closes the Tools Pane, it will not automatically open on launch. Interacts with irightPaneState.

Possible values include:
0: Don't remember the Tool Pane's state. The Pane is always closed on application open.
1: Do remember the Tool Pane's state.</string>
            <string id="iNumSwitcherContextualToolTipAVShownDC_User">Try New Coachmark</string>
            <string id="iNumSwitcherContextualToolTipAVShownDC_User_Explain">Specifies whether to show the &quot;Try the new Acrobat/Reader&quot; coachmark after launching Acrobat the first time.

Once the coachmark displays, the app automatically resets this value to 0. This preference has no effect if bEnableAv2 is 0. 0: Do not show the coachmark. 1: Show the coachmark.</string>
            <string id="iNumSessionAV2DC_User">UI Switcher Sessions</string>
            <string id="iNumSessionAV2DC_User_Explain">Specifies whether to show the UI switcher coachmark based on the number of user sessions.

Interacts with iNumSwitcherContextualToolTipAV2Shown .

Possible values include:
0 or
1: Don't show the UI switcher.
2 or greater: Show the UI switcher if iNumSwitcherContextualToolTipAV2Shown is 0.</string>

            <!-- ======================================== -->
            <!--   Documents, Editing and Accessibility   -->
            <!-- ======================================== -->

            <string id="bUse2DGPUfDC_User">2D GPU Acceleration</string>
            <string id="bUse2DGPUfDC_User_Explain">Specifies whether 2D graphics acceleration should be used.

Possible values include:
0: Disable
1: Enable</string>
            <string id="bAllowDocsToHideUIDC_User">Allow Hide UI</string>
            <string id="bAllowDocsToHideUIDC_User_Explain">Specifies whether to allow documents to hide the menu bar, toolbars, and window controls.

Possible values include:
0: Don't allow documents to hide UI elements.
1: Allow documents to hide UI elements.</string>
            <string id="benableTextSelectionDC_User">Annotation Text Selection</string>
            <string id="benableTextSelectionDC_User_Explain">Specifies whether to enable text selection for annotations such as highlight, strikethrough or underline.

Possible values include:
0: Enable text selection. When enabled, the cursor changes to ][ mode when the annotation (highlight, strikethrough or underline) is clicked and hovered over for more than 2 seconds. The cursor reverts to the previous mode after a time duration of 3 seconds upon hovering outside the bounding box of the annot.
1: Don't enable text selection. When disabled, the cursor changes to ][ mode only upon selecting Enable Text selection in the context menu. It will then remain in ][ mode for all annotations on the page.</string>
            <string id="bEnableATDC_User">Assistive Technology</string>
            <string id="bEnableATDC_User_Explain">Toggles assistive technology on and off.

This preference enables certain workflows when assistive technology such as JAWS is detected. When enabled, a dialog appears in workflows where accessibility might be improved. For example, when processing untagged documents, the user is asked if they would like to use the setup assistant. When processing scanned images, a prompt asks if OCR should run.

Possible values include:
0: Don't enable assistive technology.
1: Enable assistive technology.</string>
            <string id="bAttachLogDC_User">Attach Report</string>
            <string id="bAttachLogDC_User_Explain">Toggles whether to attach the accessibility report to the checked document after running accessibility full check.

Possible values include:
0: Don't attach the report.
1: Do attach the report.</string>
            <string id="bAutoCompleteOnTabDC_User">Auto-Complete on Tab</string>
            <string id="bAutoCompleteOnTabDC_User_Explain">Specifies whether to auto complete form field entries on a tab key action.

This option is enabled when the Advanced option is selected.

Possible values include:
0: Don't auto complete on tab.
1: Auto complete on tab.</string>
            <string id="bautoOpenOtherDC_User">Auto-Open Drawing Popup</string>
            <string id="bautoOpenOtherDC_User_Explain">Automatically adds a popup note when another type of annotation is added.

In other words, a popup note appears when you create a new comment using a drawing tool, the Stamp tool, or the Pencil tool.

Possible values include:
0: Don't add a popup note for other annot types.
1: Do add a popup note for other annot types.</string>
            <string id="bAutoSaveDocsEnabledDC_User">Auto-Save</string>
            <string id="bAutoSaveDocsEnabledDC_User_Explain">Specifies whether or not to automatically save documents.

Interacts with iAutoSaveDocsInterval.

Possible values include:
0: Don't auto save documents
1: Auto save documents.</string>
            <string id="iAutoSaveDocsIntervalDC_User">Auto-Save Interval</string>
            <string id="iAutoSaveDocsIntervalDC_User_Explain">Specifies the time interval in minutes at which to automatically save docs.

Interacts with bAutoSaveDocsEnabled.

Possible values include:
5: Minutes User specified: Any value 1-99</string>
            <string id="bAutoSetLayersDC_User">Auto-Set Layers</string>
            <string id="bAutoSetLayersDC_User_Explain">Specifies whether to allow the document's layer state to be set by user information.

Possible values include:
0: Don't allow layer state to be set by user information.
1: Allow layer state to be set by user information.</string>
            <string id="iAccessBackgroundColorDC_User">Background Color</string>
            <string id="iAccessBackgroundColorDC_User_Explain">Specifies the default document background color (accessibility feature)

The key name is appended with (Blue|Green|Red|Space).

Possible values include:
Green text on black Yellow text on black White text on black Black text on white</string>
            <string id="iPagesDC_User">Check Page Range</string>
            <string id="iPagesDC_User_Explain">Toggles whether to check all pages of a document or a subset of pages when running an accessibility full check.

Possible values include:
0: Don't check all pages.
1: Do check all pages.</string>
            <string id="benableDDRDC_User">ClearType Smoothing</string>
            <string id="benableDDRDC_User_Explain">Specifies whether to further smooth text on LCD screens.

Text smoothing essentially has two levels. First, the text is anti-aliased. Then DDR technology is applied for devices which allow RGB bands to be painted in individual pixels to further smooth text (LCD screens).

Possible values include:
0: None and Monitor
1: Laptop/LCD Screens.</string>
            <string id="bEnableCloudBasedATDC_User">Cloud Auto Tagging</string>
            <string id="bEnableCloudBasedATDC_User_Explain">Specifies whether to enable cloud-based auto-tagging.

When enabled, the app uses an API to call the cloud-based auto-tagging feature.

Possible values include:
0: Disable cloud-based auto-tagging
1: Enable cloud-based auto-tagging</string>
            <string id="iAccessColorPolicyDC_User">Color Replace Policy</string>
            <string id="iAccessColorPolicyDC_User_Explain">Specifies whether all the controls in the Replace Document Colors panel should be enabled.

When disabled, this key is removed from the registry/plist. When this preference is selected, you can choose from a list of contrasting color combinations for text and background or create your own.

Possible values include:
null: User specified.
1: Use Windows Color Scheme
2: Use Custom Colors
4: Use High Contrast Colors</string>
            <string id="bCombineContentDC_User">Combine Reading Order</string>
            <string id="bCombineContentDC_User_Explain">Specifies whether similar content should be displayed together or separately.

Possible values include:
0: Do display similar content types together.
1: Don't display similar content types together.</string>
            <string id="tauthorDC_User">Comment Author</string>
            <string id="tauthorDC_User_Explain">The author name specified by balwaysUseIdent.

Possible values include:
N/A: User specified.</string>
            <string id="dNoteFontSizeDC_User">Comment Font Size</string>
            <string id="dNoteFontSizeDC_User_Explain">Sets the font size.

The font is not embedded in the PDF; this preference merely controls the viewer's preference rather than the author's preference.

Possible values include:
10: Font size. N/A: User specified.</string>
            <string id="iNoteOpacityDC_User">Comment Opacity</string>
            <string id="iNoteOpacityDC_User_Explain">The opacity in percent of all comments.

The number is entered in Hex.

Possible values include:
d99a: 85%. N/A: Any hex value representing 1-100%.</string>
            <string id="iSensDC_User">Compare Sensitivity</string>
            <string id="iSensDC_User_Explain">Last-used compare documents sensitivity (for compare pages).</string>
            <string id="iTypeDC_User">Compare Type</string>
            <string id="iTypeDC_User_Explain">Last-used compare documents type (pages/text/text+fonts).</string>
            <string id="bComplexScriptDC_User">Complex Script Support</string>
            <string id="bComplexScriptDC_User_Explain">Specifies whether to enable support for writing direction switching (complex script).

Possible values include:
0: Don't enable Writing Direction Switching.
1: Enable Writing Direction Switching.</string>
            <string id="bconfirmEBRMergeDC_User">Confirm Review Import</string>
            <string id="bconfirmEBRMergeDC_User_Explain">Displays an alert on document open asking the user to confirm importing comments into an active review.

Possible values include:
0: Disable confirmation alert on import.
1: Enable confirmation alert on import.</string>
            <string id="bcopyTextToDrawAnnotDC_User">Copy Text to Drawing</string>
            <string id="bcopyTextToDrawAnnotDC_User_Explain">Specifies whether to copy the encircled text into drawing comment popups.

Adds a popup comment automatically to other markup types so that they can be annotated.

Possible values include:
0: Don't copy the encircled text into comments.
1: Do copy the encircled text into comments.</string>
            <string id="bcopyTextToMarkupAnnotDC_User">Copy Text to Markup</string>
            <string id="bcopyTextToMarkupAnnotDC_User_Explain">Copies the selected text into highlight, cross-out, and underline comment popups.

Adds a popup comment automatically to specified markup types so that they can be annotated.

Possible values include:
0: Copy selected text.
1: Don't copy selected text.</string>
            <string id="bCreateLogDC_User">Create Report</string>
            <string id="bCreateLogDC_User_Explain">Toggles whether to create an accessibility report when running an accessibility full check.

Possible values include:
0: Don't create report.
1: Do create report.</string>
            <string id="iDictionaryDefaultIDDC_User">Default Dictionary</string>
            <string id="iDictionaryDefaultIDDC_User_Explain">Identifies the default spelling dictionary ID.

The value is an ID from cDictionaryOrderID\i0 . The dictionary name can be found in cDictionaryOrder\t0. Alternatively, set the value in the user interface, close the product, and look here again. Use the value that appears during deployment.</string>
            <string id="iPageViewLayoutModeDC_User">Default Page Layout</string>
            <string id="iPageViewLayoutModeDC_User_Explain">Specifies the default page layout when a PDF opens.

These settings can be overridden by Accessiblity settings such as bOverridePageLayout.

Possible values include:
null: Automatic
1: Single Page
2: Single Page Continuous
3: Two Up Continuous
5: Two Up</string>
            <string id="iParaDirDC_User">Default Paragraph Dir</string>
            <string id="iParaDirDC_User_Explain">Specifies the paragraph direction.

Possible values include:
0: Left to Right
1: Right to Left
2: Infer from document</string>
            <string id="iDefaultZoomScaleDC_User">Default Zoom Scale</string>
            <string id="iDefaultZoomScaleDC_User_Explain">Specifies the zoom scale % to use when a PDF opens.

Possible values include a range beginning with Fit Page to Reflow . To set a value, configure the UI and look at the registry/plist preference to see what has been written.

Possible values include:
199a: 10% 4000 25% 8000: 50% c000: 75% 10000: 100% etc.</string>
            <string id="iDefaultZoomTypeDC_User">Default Zoom Type</string>
            <string id="iDefaultZoomTypeDC_User_Explain">Specifies the default zoom type (other than a %) to use when a PDF opens.

% scales are stored in iZoomScale.

Possible values include:
1: Fit Page (automatic)
2: Fit Width
3: Fit Hieght
4: Fit Visible
6: Reflow</string>
            <string id="imaxPDFCommentsSizeDC_User">Embedded Comment Limit</string>
            <string id="imaxPDFCommentsSizeDC_User_Explain">Sets the comment threshold size for determining whether comments are embedded or sent as FDF files.

When collaboration involves sending comments with a PDF, comments below the threshold size are embedded in the document. Comments above the threshold size are sent as FDF files.

Possible values include:
3: Max size for Reader (Acrobat is 5)</string>
            <string id="bemptyContentToolTipDC_User">Empty Comment Tooltip</string>
            <string id="bemptyContentToolTipDC_User_Explain">Displays a tooltip stating the comment being hovered over is empty.

Possible values include:
0: Don't indicate comment is empty.
1: Do indicate comment is empty.</string>
            <string id="bUseThinCodeDC_User">Enhance Thin Lines</string>
            <string id="bUseThinCodeDC_User_Explain">Specifies whether to enhance thin lines to improve visibility.

Possible values include:
0: Don't enhance thin lines.
1: Enhance thin lines.</string>
            <string id="bSuperFastDrawingDC_User">Fast Scroll Drawing</string>
            <string id="bSuperFastDrawingDC_User_Explain">Specifies whether to use fast, low resolution intermediate representation during scrolling, zooming, etc.

Superfast Drawing was introduced in Acrobat and Reader DC to make interactions with PDF documents smoother and more responsive. Superfast drawing suspends high quality rendering for the duration of operations like fast scrolling, panning, and zooming. This results in a lower quality intermediate representation being temporarily displayed during the current action.

Possible values include:
0: Don't use Superfast Drawing and display high quality intermediates during scrolling, zooming, panning, etc.
1: Use Superfast Drawing to display low resolution intermediates during scrolling, zooming, panning, etc. GUI mapping None.</string>
            <string id="iaskFormsSelectEmailCLientDC_User">Form Email Prompt</string>
            <string id="iaskFormsSelectEmailCLientDC_User_Explain">Specifies whether the dialog confirming selection of desktop vs. internet email on XFA form submit appears.

Possible values include:
0: Don't show the confirmation dialog on each XFA form submit.
1: Do show the confirmation dialog on each XFA form submit.</string>
            <string id="bHidePopupIfShowSummaryDC_User">Hide Popup on Summary</string>
            <string id="bHidePopupIfShowSummaryDC_User_Explain">Hide comment popups when comment's list is open.

Possible values include:
0: Don't hide popups.
1: Do hide popups.</string>
            <string id="bHindiDigitDC_User">Hindi Digits</string>
            <string id="bHindiDigitDC_User_Explain">Specifies whether to enable support for Hindi digits.

Possible values include:
0: Don't enable Hindi digits.
1: Enable Hindi digits.</string>
            <string id="bHoveringPopupsDC_User">Hover Popups</string>
            <string id="bHoveringPopupsDC_User_Explain">Automatically open popups on mouse rollover.

Possible values include:
0: Don't open popups on mouse rollover.
1: Do open popups on mouse rollover.</string>
            <string id="bInlineAutoCompleteDC_User">Inline Auto-Complete</string>
            <string id="bInlineAutoCompleteDC_User_Explain">Specifies whether to auto complete a field based on remembered values when a user starts typing.

This option is enabled for both the Basic and Advanced options.

Possible values include:
0: Don't auto complete.
1: Do autocomplete.</string>
            <string id="iIntlSelectFontDC_User">International Font</string>
            <string id="iIntlSelectFontDC_User_Explain">Specifies the font to use.

Possible values include:
0: Application default
1: GB18030 compatible font
2: HKSCS compatible font</string>
            <string id="bLigaturesDC_User">Ligatures</string>
            <string id="bLigaturesDC_User_Explain">Specifies whether to enable support for ligatures.

Possible values include:
0: Don't enable ligatures.
1: Enable ligatures.</string>
            <string id="balwaysUseIdentDC_User">Login Name as Author</string>
            <string id="balwaysUseIdentDC_User_Explain">Uses the login names as the comment author name.

The login name is the name specified in the identity preferences panel. If it is not present, the login-name is used. If it is not present for comments in collaborative documents (shared-review, browser-based review, email based review), the comment author identity is used that the user has set. For Acrobat, the default is true; for Reader, it is false.

Possible values include:
0: Do use the login name as the comment author name.
1: Don't use the login name as the comment author name.</string>
            <string id="bOpenInPlaceDC_User">Open Links in Place</string>
            <string id="bOpenInPlaceDC_User_Explain">Specifies whether to open cross document links in the same window.

Possible values include:
0: Don't open links in the same window.
1: Do open links in the same window.</string>
            <string id="bOverprintPreviewUseShiftClickDC_User">Overprint Shift+Click</string>
            <string id="bOverprintPreviewUseShiftClickDC_User_Explain">Specifies whether to use Shift + Click for multiple selection or for adding sticky notes containing color value when output preview dialog is open.

Possible values include:
0: Use Shift + Click for adding a sticky note containing the color values.
1: To select multiple objects, use Shift + Click. To add a sticky note containing the color values, use Alt + Click (Windows) or Option + Click (Mac).</string>
            <string id="bAccessOverrideDocColorsDC_User">Override Document Colors</string>
            <string id="bAccessOverrideDocColorsDC_User_Explain">Specifies whether to replace black test or line art colors when iAccessColorPolicy is enabled and a replacement color has been specified.

While the default is 1, the preference is not read unless iAccessPolicy is enabled (1).

Possible values include:
0: Don't replace black text or line art colors.
1: Replace black text or line art colors.</string>
            <string id="bOverrideLineArtColorsDC_User">Override Line Art Colors</string>
            <string id="bOverrideLineArtColorsDC_User_Explain">Limits color changes to black text and line art when iAccessColorPolicy is enabled and a replacement color has been specified.

While the default is 1, the preference is not read unless &quot;Accessibility&quot; enabled (1).

Possible values include:
0: Don't replace text or line art colors.
1: Replace text or line art colors. See also bAccessOverrideDocColors in Originals.</string>
            <string id="iPageLayoutDC_User">Override Page Layout</string>
            <string id="iPageLayoutDC_User_Explain">Specifies the user selected page layout override.

When bOverridePageLayout is set to 1, the override drop down list becomes enabled so that the user can set the desired page layout.

Possible values include:
1: Single Page
2: Single Page Continuous
3: Two Up Continuous
5: Two Up</string>
            <string id="bOverrideZoomDC_User">Override Zoom</string>
            <string id="bOverrideZoomDC_User_Explain">Enables the zoom setting drop down list so that the user can specify a default zoom setting for all documents and overrides Page Display settings.

PDF authors can specify what zoom level a PDF will open at. When enabled (1), the zoom drop down list becomes active so that the user can specify a default zoom level for all documents and set iZoomScale.

Possible values include:
0: Use the documents default zoom setting.
1: Enable the zoom setting drop down list.</string>
            <string id="iZoomScaleDC_User">Override Zoom Scale</string>
            <string id="iZoomScaleDC_User_Explain">Specifies the value in % to zoom when iZoomType is set to a % value and overrides Page Display settings.

Possible values include a range beginning with Fit Page to Reflow . When selected, % values are stored in iZoomScale. To set a value, configure the UI and look at the registry/plist preference to see what has been written.

Possible values include:
199a: 10% 4000 25% 8000: 50% c000: 75% 10000: 100% etc.</string>
            <string id="iZoomTypeDC_User">Override Zoom Type</string>
            <string id="iZoomTypeDC_User_Explain">Specifies the zoom scale for all other documents other than a % scale and overrides Page Display settings.

% scales are stored in iZoomScale.

Possible values include:
1: Fit Page
2: Fit Width
3: Fit Hieght
4: Fit Visible
6: Reflow</string>
            <string id="iParagraphDirectionDC_User">Paragraph Direction</string>
            <string id="iParagraphDirectionDC_User_Explain">Specifies the paragraph direction.

Possible values include:
0: Right to Left
1: Left to Right</string>
            <string id="bPopupsOpenIffSelectedDC_User">Popup When Selected</string>
            <string id="bPopupsOpenIffSelectedDC_User_Explain">Specifies whether to open a popup when it is selected.</string>
            <string id="bPopupsScrollWithPageDC_User">Popups Scroll With Page</string>
            <string id="bPopupsScrollWithPageDC_User_Explain">Specifies whether whether popups are visible when a document is scrolled.

Possible values include:
0: Hide popups on document scroll.
1: Show popups on document scroll.</string>
            <string id="bUseDetailsNavigatorDC_User">Portfolio File List</string>
            <string id="bUseDetailsNavigatorDC_User_Explain">Specifies whether to show portfolio component files and file details in an accessible list.

This preference replaces bUsePlatformNavigator. Files mode provides a better reading experience for people with disabilities such as mobility impairments, blindness, and low vision.

Possible values include:
0: Don't show portfolio components in a list.
1: Do show portfolio components in a list.</string>
            <string id="bPrintAnnotsDC_User">Print Annotations</string>
            <string id="bPrintAnnotsDC_User_Explain">Specifies whether to print notes, popups, and other annotations.

Setting a similar preference from the Print panel sets a corresponding setting in HKU.

Possible values include:
0: Don't print annotations.
1: Do print annotations.</string>
            <string id="bprintCommentPopupsDC_User">Print Comment Popups</string>
            <string id="bprintCommentPopupsDC_User_Explain">Enables printing of comments and other annotations.

Notes and popups that are open will be printed when the rest of the document is printed.

Possible values include:
0: Don't print comments.
1: Do print comments.</string>
            <string id="bprintNotesOpaqueDC_User">Print Popups Opaque</string>
            <string id="bprintNotesOpaqueDC_User_Explain">Makes popups opaque regardless of other settings.

Prints the popups as opaque without honoring the popup opacity specified by the user in commenting preferences (popup-opacity).

Possible values include:
0: Don't make popups opaque.
1: Do make popups opaque.</string>
            <string id="bUserAskedToEnableAutoCompleteDC_User">Prompt Auto-Complete</string>
            <string id="bUserAskedToEnableAutoCompleteDC_User_Explain">Specifies whether the user is asked to enable auto complete at runtime.

This option is enabled for the Advanced option.

Possible values include:
0: Don't ask the user.
1: Do ask the user.</string>
            <string id="iShowOrderDC_User">Reading Order Display</string>
            <string id="iShowOrderDC_User_Explain">Specifies the type of grouping order to display in the touchup reading order panel.

Possible values include:
0: Order (numbered).
1: Structure type.
2: None.</string>
            <string id="bRecordNewEntriesDC_User">Remember Form Entries</string>
            <string id="bRecordNewEntriesDC_User_Explain">Specifies whether to remember form field entries for use with future auto-complete actions.

This option is enabled for both the Basic and Advanced options.

Possible values include:
0: Don't remember entries.
1: Do remember entries.</string>
            <string id="iRememberViewDC_User">Restore Last View</string>
            <string id="iRememberViewDC_User_Explain">Specifies whether to restore last view settings when reopening documents.

Possible values include:
1: Don't restore the last view settings.
2: Do restore the last view settings.</string>
            <string id="bRTLUIDC_User">Right-to-Left UI</string>
            <string id="bRTLUIDC_User_Explain">Specifies whether to enable right to left language options.

Possible values include:
0: Disable right to left language options.
1: Enable right to left language options.</string>
            <string id="bDigitsUIDC_User">RTL Digit Display</string>
            <string id="bDigitsUIDC_User_Explain">Specifies whether to display digits in a way that's consistent with right to left language display.

The value is automatically set when bRTLUI is set via the UI.

Possible values include:
0: Don't display digits in a way that's consistent with right to left language display.
1: Do display digits in a way that's consistent with right to left language display.</string>
            <string id="bPrintSaveTonerDC_User">Save Toner/Ink</string>
            <string id="bPrintSaveTonerDC_User_Explain">Specifies whether to optimize content so that the printer uses less ink.

When checked, this setting optimizes the content so that the printer uses less ink during printing. In some cases, toner savings may reach 15%. Print quality is usually not impaired in any discernable way.

Possible values include:
0: Don't optimize printing.
1: Optimize printing.</string>
            <string id="bSDIModeDC_User">SDI Mode</string>
            <string id="bSDIModeDC_User_Explain">Specifies whether to open documents in a new window or in tabs in the same window.

Possible values include:
0: Open documents in tabs in the same window .
1: Open documents in separate windows.</string>
            <string id="bsendFinalApprovalEmailDC_User">Send Approval Email</string>
            <string id="bsendFinalApprovalEmailDC_User_Explain">Specifies whether to send a notification email when the current approval is identified as the final one.

Only valid for an approval workflow.

Possible values include:
0: Don't send an email on final approval.
1: Do send an email on final approval.</string>
            <string id="bShowOptionsDialogDC_User">Show Check Options</string>
            <string id="bShowOptionsDialogDC_User_Explain">Toggles whether to display the options dialog when running a accessibility full check.

Possible values include:
0: Don't show options dialog.
1: Show options dialog.</string>
            <string id="bcommentPanelOnImportDC_User">Show Comments on Import</string>
            <string id="bcommentPanelOnImportDC_User_Explain">Specifies whether to open the comment list when comments are imported.

Possible values include:
0: Don't open the comment list when comments are imported.
1: Do open the comment list when comments are imported.</string>
            <string id="bShowAnnotConnectorDC_User">Show Connector Lines</string>
            <string id="bShowAnnotConnectorDC_User_Explain">Specifies whether to show lines connecting comment markups to their popups on mouse rollover.

Possible values include:
0: Hide lines connecting comments to popups.
1: Show lines connecting comments to popups.</string>
            <string id="bFocusRectDC_User">Show Focus Rectangle</string>
            <string id="bFocusRectDC_User_Explain">Specifies whether to surround a field with a rectangle when it has focus.

Possible values include:
0: Don't show a rectangle.
1: Do show a rectangle.</string>
            <string id="bShowKeyboardSelectionCursorDC_User">Show Keyboard Cursor</string>
            <string id="bShowKeyboardSelectionCursorDC_User_Explain">Specifies whether the keyboard selection cursor should always be active in the document.

Select this option if you use a screen magnifier.

Possible values include:
0: Don't show the cursor.
1: Always show the cursor.</string>
            <string id="bshowMarkupModifiersDC_User">Show Markup Indicators</string>
            <string id="bshowMarkupModifiersDC_User_Explain">Specifies whether to show markup tool-tips and text indicators.

Possible values include:
0: Don't show markup tool-tips and text indicators.
1: Show markup tool-tips and text indicators.</string>
            <string id="bRulersVisibleDC_User">Show Rulers</string>
            <string id="bRulersVisibleDC_User_Explain">Specifies whether to show or hide rulers for every new document launch.

Possible values include:
0: Don't show rulers on new document launch.
1: Show rulers on new document launch.</string>
            <string id="bStampsPaletteInvisibleDC_User">Show Stamps Palette</string>
            <string id="bStampsPaletteInvisibleDC_User_Explain">Specifies whether to show the stamps palette automatically when the commenting toolbar is displayed.

Possible values include:
0: Show the palette.
1: Don't show the palette.</string>
            <string id="bShowAnnotSequenceDC_User">Show Tab Order</string>
            <string id="bShowAnnotSequenceDC_User_Explain">Specifies whether to show tab order of fields for Acroforms and XFA forms.</string>
            <string id="bsideNotesDC_User">Side-Aligned Popups</string>
            <string id="bsideNotesDC_User_Explain">Creates new popups aligned to the edge of the document.

Controls popup positioning.

Possible values include:
0: Don't align popups at the document edge.
1: Align popups at the document edge.</string>
            <string id="bAntialiasImagesDC_User">Smooth Images</string>
            <string id="bAntialiasImagesDC_User_Explain">Specifies wither to use anti-aliasing (smoothing) for images.

Turning this preference off can improve scrolling performance in Citrix environments.

Possible values include:
0: Don't smooth images.
1: Smooth images.</string>
            <string id="bAntialiasGraphicsDC_User">Smooth Line Art</string>
            <string id="bAntialiasGraphicsDC_User_Explain">Specifies wither to use anti-aliasing (smoothing) for line art.

Turning this preference off can improve scrolling performance in Citrix environments.

Possible values include:
0: Don't smooth line art.
1: Smooth line art.</string>
            <string id="bAntialiasTextDC_User">Smooth Text</string>
            <string id="bAntialiasTextDC_User_Explain">Specifies whether to smooth (anti-alias) text.

This setting only applies when the Smooth Text field is set to Monitor or Laptop/LCD. Text smoothing essentially has two levels. First, the text is anti-aliased. Then, if benableDDR is set to 1, DDR technology is applied for devices which allow RGB bands to be painted in individual pixels to further smooth text.

Possible values include:
0: None.
1: For both monitor and laptop/LCD Screens.</string>
            <string id="bSmoothZoomingDC_User">Smooth Zooming</string>
            <string id="bSmoothZoomingDC_User_Explain">Specifies whether smooth zooming should be enabled.

Possible values include:
0: Disables smooth zooming
1: Enables smooth zooming</string>
            <string id="bSpellingUnderlineDC_User">Spell Check Underline</string>
            <string id="bSpellingUnderlineDC_User_Explain">Turns off and on spell checking as you type.

This key is also duplicated under cPICommonPrefs\cSpelling.</string>
            <string id="bStoreNumericEntriesDC_User">Store Numeric Entries</string>
            <string id="bStoreNumericEntriesDC_User_Explain">Specifies whether to store user entered numeric values.

This option is enabled for both the Basic and Advanced options.

Possible values include:
0: Don't store numeric entries.
1: Do store numeric entries.</string>
            <string id="bUseStructTabOrderDC_User">Structure Tab Order</string>
            <string id="bUseStructTabOrderDC_User_Explain">Specifies whether to use the PDF document structure for determining the tab order.

Possible values include:
0: Don't use document structure.
1: Use document structure.</string>
            <string id="bUseSystemSelectionColorDC_User">System Selection Color</string>
            <string id="bUseSystemSelectionColorDC_User_Explain">Specifies whether the default selection color (blue) is overridden with a color that the system specifies.

Possible values include:
0: Don't use the system selection color.
1: Use the system selection color.</string>
            <string id="iAccessTextColorDC_User">Text Color</string>
            <string id="iAccessTextColorDC_User_Explain">Specifies the default document text color (accessibility feature)

The key name is appended with (Blue|Green|Red|Space).

Possible values include:
null: not set Any RGB color: User specified.</string>
            <string id="bUseLocalFontsDC_User">Use Local Fonts</string>
            <string id="bUseLocalFontsDC_User_Explain">Specifies whether to use local fonts.

Possible values include:
0: Don't use local fonts.
1: Do use local fonts.</string>
            <string id="iEmailClientSelectionDC_User">XFA Email Client</string>
            <string id="iEmailClientSelectionDC_User_Explain">Specifies the email client to use when submitting an XFA form.

Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
            <string id="iRXOPolicyDC_User">XObjects View Mode</string>
            <string id="iRXOPolicyDC_User_Explain">Sets XObject access to either Never (0), Always (1), or Only PDF/X-5 Compliant Ones (2).

The user must also set cRXOLocation and (Windows only) specify a privileged location for each parent (referencing) document.

Possible values include:
0: Never
1: Always
2: Only PDF/X-5 Compliant Ones</string>

            <!-- ======================================== -->
            <!--         Microsoft Purview (MIP)          -->
            <!-- ======================================== -->

            <string id="bEnableLoggingDC_User">MIP Logging</string>
            <string id="bEnableLoggingDC_User_Explain">Specifies whether to enable debug logging for Microsoft Purview Information Protection operations.

Useful for troubleshooting MIP label and authentication issues.

Possible values include:
0: Disable MIP debug logging.
1: Enable MIP debug logging.</string>
            <string id="bEnablePolicyAuthenticationDC_User">MIP Policy Authentication</string>
            <string id="bEnablePolicyAuthenticationDC_User_Explain">Specifies whether MIP policy authentication is enabled for the current user.

Used alongside bShowDMB. Setting both bShowDMB and bEnablePolicyAuthentication to 0 hides the applied label from the current file.

Possible values include:
0: Disable MIP policy authentication.
1: Enable MIP policy authentication.</string>
            <string id="bShowDMBDC_User">Show Document Message Bar (MIP)</string>
            <string id="bShowDMBDC_User_Explain">Specifies whether to show Microsoft Purview Information Protection label information in the document message bar.

Per-user preference under MicrosoftAIP.

Possible values include:
0: Do not show MIP label info in the document message bar.
1: Show MIP label info in the document message bar.</string>

            <!-- ======================================== -->
            <!--    Security: Execution and Protection    -->
            <!-- ======================================== -->

            <string id="b3DEnableContentDC_User">3D Content Trust</string>
            <string id="b3DEnableContentDC_User_Explain">Specifies whether to trust and render 3D content.

This setting can be overridden by bEnable3D .

Possible values include:
0: Don't trust and render 3D content. Show the Yellow Message Bar so the end user can trust the document.
1: Trust and render 3D files.</string>
            <string id="bCrossDomainLoggingDC_User">Cross-Domain Logging</string>
            <string id="bCrossDomainLoggingDC_User_Explain">Enables cross domain logging for communication with a server that uses a cross domain policy file to manage the flow of data that does not conform to a same-origin policy.

Create a logging file by navigating to the user account Application Directory. For example, on XP go to C:\Documents and Settings\(user name)\Application Data\Adobe\(application)\(version)\. Created an empty file called AcrobatCrossDomain.log.</string>
            <string id="bEnableDebuggerDC_User">Enable JS Debugger</string>
            <string id="bEnableDebuggerDC_User_Explain">Enables the debugger.

Requires an application restart.</string>
            <string id="bChooseDialogDC_User">External JS Editor</string>
            <string id="bChooseDialogDC_User_Explain">Specifies wither or not to use the Acrobat editor or an external editor.

When true, the &quot;Choose an external editor&quot; field becomes enabled.</string>
            <string id="bFIPSModeDC_User">FIPS Mode</string>
            <string id="bFIPSModeDC_User_Explain">Controls whether FIPS 140-2 compliant encryption is required.

When FIPS mode is enabled, Acrobat restricts cryptographic operations to FIPS-approved algorithms. This disables certain PDF security features and workflows that rely on non-FIPS algorithms, including some older PDF encryption schemes.

Possible values include:
0: Disable FIPS mode.
1: Enable FIPS mode.</string>
            <string id="bConsoleInputDC_User">JS Console Input</string>
            <string id="bConsoleInputDC_User_Explain">Toggles whether or not the console appears if script execution results in an error or message.</string>
            <string id="bConsoleOpenDC_User">JS Debugger Console</string>
            <string id="bConsoleOpenDC_User_Explain">Enables the interactive debugger console.</string>
            <string id="iExceptionsDC_User">JS Exception Handling</string>
            <string id="iExceptionsDC_User_Explain">Specifies how exceptions should be handled.

Allowable values include: 0: Ignore 1: Trace 2: Break</string>
            <string id="bEnableGlobalSecurityDC_User">JS Global Security</string>
            <string id="bEnableGlobalSecurityDC_User_Explain">Controls whether or not a script in one sandbox can access a script object in another sandbox.

By default, scripts can not access objects outside the current document sandbox. With 9.x and later, such communication only works in the standalone application since both the Acrobat and Reader browser-based viewer opens each window in a discrete browser instance.</string>
            <string id="bEnableMenuItemsDC_User">JS Menu Items</string>
            <string id="bEnableMenuItemsDC_User_Explain">Toggles off and on JavaScript's ability to execute menu items.</string>
            <string id="bEnableAlwaysOutlookAttachmentProtectedViewDC_User">Outlook Protected View</string>
            <string id="bEnableAlwaysOutlookAttachmentProtectedViewDC_User_Explain">Specifies whether Protected View is turned off for Outlook attachments.

Note that earlier versions (e.g. Office 2003 and 2007) do not append origin information to files they download to its temp directory. As a result, there is no way of knowing if the file came from trusted source. Such files do not automatically open in PV.

Possible values include:
0: Enable Protected View for Outlook attachments.
1: Disable Protected View for Outlook attachments.</string>
            <string id="bOldRecentFilesMigratedDC_User">Recent Files Migrated</string>
            <string id="bOldRecentFilesMigratedDC_User_Explain">Indicates whether the recent files list has been migrated.

Admins should not change the preference value.</string>
            <string id="bSaveBreakpointsDC_User">Save JS Breakpoints</string>
            <string id="bSaveBreakpointsDC_User_Explain">Stores breakpoints in a PDF file

Details, interactions with other keys, and allowable values, etc.</string>

            <!-- ======================================== -->
            <!--     Security: Trust and Permissions      -->
            <!-- ======================================== -->

            <string id="bUseExpiredTimestampsDC_User">Accept Expired Timestamps</string>
            <string id="bUseExpiredTimestampsDC_User_Explain">Specifies whether expired timestamps should be used.

If true, an expired timestamp will not invalidate a signature.</string>
            <string id="bAllowConnectViaHTTPDC_User">Allow LiveCycle HTTP</string>
            <string id="bAllowConnectViaHTTPDC_User_Explain">If true, the server connection URI uses the format http://server:port/path; otherwise, it uses the format https://server:port/path.

In either case, if the connection fails, an error message appears. For more information, see Guidelines for Developing CSPs for Acrobat on Windows .</string>
            <string id="bAllowCertNonGreenDC_User">Allow Non-Green Cert</string>
            <string id="bAllowCertNonGreenDC_User_Explain">Specifies whether a certification signature may be applied to a document containing Legal PDF warnings.

If false, then its not allowed and the author is informed of the reason.</string>
            <string id="bAllowOCSPNoCheckDC_User">Allow OCSP NoCheck</string>
            <string id="bAllowOCSPNoCheckDC_User_Explain">Specifies whether the OCSPNoCheck extension is allowed in the response signing certificate.</string>
            <string id="bAlwaysConsultDC_User">Always Consult CDP</string>
            <string id="bAlwaysConsultDC_User_Explain">Determines when the URL is used for an additional URL CRL distribution point.

If false, the URL is only used when the certificate does not have a CRLDp extension.</string>
            <string id="iAuthMechanismsDC_User">Auth Mechanisms</string>
            <string id="iAuthMechanismsDC_User_Explain">Specifies which registered provider(s) to use.

0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
            <string id="iAutoAcceptEDCPrivacyNotificationDC_User">Auto-Accept Privacy</string>
            <string id="iAutoAcceptEDCPrivacyNotificationDC_User_Explain">Specifies whether to show an alert confirming acceptance of the privacy policy.

Possible values include:
0: Don't show an alert.
1: Do show an alert.</string>
            <string id="iAutoAddLTVDC_User">Auto-Add LTV Info</string>
            <string id="iAutoAddLTVDC_User_Explain">Specifies whether LTV information should be automatically added to all signatures.

Possible values include:
0: Never add LTV information.
1: (default) Ask whether LTV information should be added if it is too big.
2: Always add LTV information. When the cumulative size of the LTV data is greater than the sum of 10% of the PDF file size plus 10KB and Automatically add verification information on Save is set to &quot;Ask...&quot; a dialog appears asking the user if they would like to continue embedding the LTV information. Note that in workflows where the dialog appears asking whether to enable LTV, if the user selects the &quot;Do not show this message again&quot; checkbox, AND click the No button, then this preference is set to zero.</string>
            <string id="bSavePasswordDC_User">Cache Server Password</string>
            <string id="bSavePasswordDC_User_Explain">Indicates whether the password has been cached for this server.</string>
            <string id="iSHSDC_User">Console H-Splitter</string>
            <string id="iSHSDC_User_Explain">Indicates (in pixels) the position of the horizontal window splitter.</string>
            <string id="iSVSDC_User">Console V-Splitter</string>
            <string id="iSVSDC_User_Explain">Indicates (in pixels) the position of the vertical window splitter.</string>
            <string id="iMaxRevokeInfoCacheLifetimeDC_User">CRL Cache Lifetime</string>
            <string id="iMaxRevokeInfoCacheLifetimeDC_User_Explain">Maximum lifetime in hours the cached CRL is used for revocation checking.

iMaxRevokeInfoCacheLifetime is only used if the validation method is set to &quot;current time&quot;.

Possible values include:
The number of hours for which the cached CRL is valid.</string>
            <string id="bCustomPrefsCreatedDC_User">Custom Cert Prefs</string>
            <string id="bCustomPrefsCreatedDC_User_Explain">Indicates whether a custom certificate specific preference (e.g. Identrus) has already been created and written to the registry.

If true, it doesn't get created again. Deleting or setting this key to 0 forces Acrobat to recreate custom certificate preferences after which it will reset this key to 1.</string>
            <string id="iDirectoryProviderDC_User">Directory Provider</string>
            <string id="iDirectoryProviderDC_User_Explain">Specifies a directory provider for signature validation.

0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
            <string id="bEnforceSecureChannelDC_User">Enforce Digest Compare</string>
            <string id="bEnforceSecureChannelDC_User_Explain">Specifies whether to prevent signing when the original message digest and the signed message digest do not match.

When set to 1, the user sees a warning dialog when the digest mismatch occurs. This error can be caused by a modification of the original message digest, a modification of the signed message digest, or a mismatch between the private and public key used for signing. When using a certificate that doesn't include a public key (such as a DSA certificate with an omitted public key), the test to detect signature validity is not performed. Do not turn this setting on if such certificates are used.</string>
            <string id="bAutoLaunchAtDocCloseDC_User">Examine on Close</string>
            <string id="bAutoLaunchAtDocCloseDC_User_Explain">Automatically examines the document for hidden content when it is closed.</string>
            <string id="bAutoLaunchAtSendMailDC_User">Examine on Send</string>
            <string id="bAutoLaunchAtSendMailDC_User_Explain">Automatically examines the document for hidden content when it is sent in an email.</string>
            <string id="bExpiredCertGoOnlineDC_User">Expired Cert Go Online</string>
            <string id="bExpiredCertGoOnlineDC_User_Explain">Specifies whether to go online to get the revocation information for an expired certificate.

11.0.16 introduced a signature validation change so that signatures are invalid if they are based on expired certificates and there is no embedded revocation information even if bIgnoreValidityDates is 1. For previous product versions, the signature would be valid. Now, to be standard's compliant, if a certificate has expired, the client should not check for the revocation information online. bExpiredCertGoOnline set to 1 re-enables the pre-11.0.16 behavior. 0: Do not go online for revocation even if bIgnoreValidityDates = 1 1: Do go online.</string>
            <string id="bFDFRequestExcludeCertDC_User">FDF Exclude Cert</string>
            <string id="bFDFRequestExcludeCertDC_User_Explain">Similar to the bFDFRequestSave.

False includes the user's certificate in all certificate requests. True excludes it.</string>
            <string id="bFDFExportSaveDC_User">FDF Export Save</string>
            <string id="bFDFExportSaveDC_User_Explain">Persists whether user chose to save (1) or email (0) the FDF during export.</string>
            <string id="bFDFExportSignDC_User">FDF Export Sign</string>
            <string id="bFDFExportSignDC_User_Explain">Persists whether the user chose to sign the FDF during export.</string>
            <string id="bFDFRequestSaveDC_User">FDF Request Save</string>
            <string id="bFDFRequestSaveDC_User_Explain">Caches a user's answer to the question whether they want to save the request as an FDF or email it directly when that user requests a certificate.</string>
            <string id="bFollowURIsFromAIADC_User">Follow AIA URIs</string>
            <string id="bFollowURIsFromAIADC_User_Explain">Specifies whether to allow the chain builder to follow URIs in AIA certificate extensions so that certificates can be downloaded if they are not available locally.

The default does not allow phone-home capability. CRLdps and OCSP AIA extensions do allow following URIs because they require that the certificate chain up to a trust anchor.</string>
            <string id="bSigAPStatusIconDisableDC_User">Hide Sig Status Icon</string>
            <string id="bSigAPStatusIconDisableDC_User_Explain">Controls whether the signature status icon is displayed in the signature appearance on the document.

If true, status icon is not displayed regardless of signature status. This setting overrides iDisplayValidIcon and bShowWarningForChanges.</string>
            <string id="cDialogs_xSelHandlerDC_User">ID Dialog Position</string>
            <string id="cDialogs_xSelHandlerDC_User_Explain">The last on-screen coordinates of a handler's digital ID selection dialog

It is a subkey containing 4 keys: Top, Bottom, Left, and Right. This preference could be used by 3rd party handlers or by someone invoking a non-signing digital ID selection dialog via JavaScript.</string>
            <string id="bIgnoreNextUpdateDC_User">Ignore OCSP NextUpdate</string>
            <string id="bIgnoreNextUpdateDC_User_Explain">Specifies whether to use embedded OCSP responses when nextUpdate is not present and the validation time is less than the greater of thisUpdate or producedAt time plus the value of iMaxClockSkew .

For 10.1 and later, this preference is used along with iMaxClockSkew to determine whether or not embedded OCSP responses are actually used for signature validation. For details, see the subfeature description above. This behavior is designed to support Acrobat's long term validation feature and allows validating a signature with embedded responses that were valid at signing time.

Possible values include:
0: iMaxClockSkew is applied to thisUpdate on both sides of the validation time, i.e. thisUpdate - iMaxClockSkew ( validation time ( checkTime + iMaxClockSkew where checkTime is the later of the producedAt and thisUpdate. When true, iMaxClockSkew is applied to thisUpdate only before the validation time: thisUpdate - iMaxClockSkew ( validation time.
1: If there is no nextUpdate, then we accept the OCSP response indefinitely (we do not check for if the validation time is too late) and don't check whether validation time is ( than checkTime)</string>
            <string id="iImportAddressBookDC_User">Import Address Book</string>
            <string id="iImportAddressBookDC_User_Explain">Specifies whether the addressbook.acrodata file should be imported during a new install.

Many admins set a value of 2 so that the import dialog does not appear for end users.

Possible values include:
0: Do not copy the old address book. The user is NOT prompted and the address book should NOT be installed.
1 or null: Default: The user is asked whether the address book should either be installed or not.
2: Import the address book silently.</string>
            <string id="bCertStoreImportEnableDC_User">Import Windows Certs</string>
            <string id="bCertStoreImportEnableDC_User_Explain">If true, then users can import from MSCAPI certificate stores into their Trusted Identity Manager.</string>
            <string id="bDontRemoveOverlappingDC_User">Keep Hidden Content</string>
            <string id="bDontRemoveOverlappingDC_User_Explain">Specifies whether to remove hidden content when sanitizing a document.

During sanitization workflows, the app automatically rasterizes the document if overlapping content exists. This can result in a large file size increase. Disable this feature to avoid extremely large files. 0: Remove hidden (overlapping) content. 1: Do not remove hidden content when sanitizing a document.</string>
            <string id="iAPIndexDC_User">Last Sig Appearance</string>
            <string id="iAPIndexDC_User_Explain">Remembers the last used signature appearance index.</string>
            <string id="bIsEnabledDC_User">Long Term Validation</string>
            <string id="bIsEnabledDC_User_Explain">Specifies whether the signature revocation status is included in the signature.

Possible values include:
0: Don't enable LTV and include the signature revocation status information in the signature.
1: Enable LTV.</string>
            <string id="iMaxRevInfoArchiveSizeDC_User">Max Rev Info Archive</string>
            <string id="iMaxRevInfoArchiveSizeDC_User_Explain">The maximum size of the revocation archival information in kilobytes.

An attempt is made to store as much revocation information as possible without exceeding the limit. Note that older product versions may have a smaller supported size limit.</string>
            <string id="iMaxVerifySessionDC_User">Max Verify Sessions</string>
            <string id="iMaxVerifySessionDC_User_Explain">Specifies the maximum number of nested verification sessions allowed.

This is used to prevent the application from going into infinite loop verifying the OCSP and/or CRL signer certificates caused by incorrect OCSP and/or CRL certificate setup.</string>
            <string id="iCreateNewSigFieldAVAlertDC_User">New Sig Field Alert</string>
            <string id="iCreateNewSigFieldAVAlertDC_User_Explain">Specifies whether to show the alert asking whether a new signature field should be created.

Possible values include:
0: Don't show an alert.
1: Do show an alert.</string>
            <string id="bEnNonEmbFontLegPDFWarnDC_User">Non-Embedded Font Warn</string>
            <string id="bEnNonEmbFontLegPDFWarnDC_User_Explain">Turns on and off warnings about non-embedded fonts.

A warning appears when the LegalPDF dictionary NonEmbeddedFonts attribute has a non zero value. Turning this value on causes a warning to appear in the PDF Signature Report which indicates the document contains unembedded fonts.</string>
            <string id="iSendNonceDC_User">OCSP Nonce Behavior</string>
            <string id="iSendNonceDC_User_Explain">Specifies signature validation behavior with respect to nonces.

With 10.0, this preference replaces bSendNonce.

Possible values include:
0: No nonces are sent.
1: Nonces are included in the OCSP request and expected to be present in the response and should match the request's nonce.
2: Nonces are included in the OCSP request, but if none are present in the response, their abscence is ignored.</string>
            <string id="iURLToConsultDC_User">OCSP Responder URL</string>
            <string id="iURLToConsultDC_User_Explain">Specifies how the revocation checker chooses which responder to use.

Possible values include:
0: Use the AIA extension in the certificate.
1: Use the URL key in sURL.
2: Use the AIA extension in the certificate. If it is not present, use the URL key in sURL.
3: Use the OCSP request signer's certificate AIA extension. Relevant only if SignRequest is 0.</string>
            <string id="iResponseFreshnessDC_User">OCSP Response Freshness</string>
            <string id="iResponseFreshnessDC_User_Explain">Specifies the amount of time in minutes after the response's published thisUpdate time for which the response will be valid.

After that time, the response will be invalid.</string>
            <string id="bAllowOpenFileDC_User">Open Non-PDF Attachments</string>
            <string id="bAllowOpenFileDC_User_Explain">Specifies whether to open non-PDF attachments in their native application.

bAllowOpenFile, bSecureOpenFile, and tBuiltInPermsList work in tandem: If any of these are set to prevent the opening of an attachment, then the attachment type won't open (or all attachments depending on the setting).

Possible values include:
0: Prevent attachments from opening in their native application.
1: Allow attachments to open in their native application.</string>
            <string id="bPreviewModeBeforeSigningDC_User">Preview Before Signing</string>
            <string id="bPreviewModeBeforeSigningDC_User_Explain">Specifies whether a signer is forced to use preview mode during signing.

If true, preview mode is automatically invoked on a sign action. Users should read the document message bar text, view a report about any warnings, and then choose Sign Document.</string>
            <string id="bRequireAKIDC_User">Require AKI in CRL</string>
            <string id="bRequireAKIDC_User_Explain">Specifies whether the Authority Key Identifier extension must be present in a CRL.</string>
            <string id="bRequireOCSPCertHashDC_User">Require OCSP Cert Hash</string>
            <string id="bRequireOCSPCertHashDC_User_Explain">Specifies whether a certificate public key hash extension must be present in OCSP responses.</string>
            <string id="iRequireReviewWarningsDC_User">Require Sign Warnings</string>
            <string id="iRequireReviewWarningsDC_User_Explain">Specifies whether the user is required to review document warnings before signing via the signing dialog.

Interacts with iShowDocumentWarnings. The possible values include: 0: Never 1: Show when certifying only 2: Always</string>
            <string id="bReqSigPropRetrievalDC_User">Require Timestamp</string>
            <string id="bReqSigPropRetrievalDC_User_Explain">Indicates whether retrieving a signature property must succeed.

Acrobat currently provides a signature property for timestamps. By default, retrieving a valid and trusted timestamp is not required, and property retrieval failure only results in creating a signature which uses the local time. When property retrieval is required during signature creation and fetching a timestamp fails for any reason (bad URL, no network connection, etc.) the signature creation process is aborted, no signature is created, and an error appears. 0: Make best effort, but success is not required. A signature is created. 1: Property retrieval must succeed. On failure, a signature is not created and an error dialog appears.</string>
            <string id="bRequireValidSigForChainingDC_User">Require Valid Sig Chain</string>
            <string id="bRequireValidSigForChainingDC_User_Explain">Specifies whether to allow the chain builder to build chains with invalid RSA signatures on certificates.

Consider chain CA ) ICA ) EE where the CA's signature on an ICA is invalid. If this setting is true, the chain building will stop at the ICA and the CA will not be included in the chain. If this preference is false, the full 3-certificate chain is produced. This setting does not affect DSA signatures.</string>
            <string id="bReturnRevInfoToUserDC_User">Return Rev Info to JS</string>
            <string id="bReturnRevInfoToUserDC_User_Explain">If true, the revocation information is maintained within the SignatureInfo object and can be retrieved through JavaScript.

For more information, see the Acrobat JavaScript Reference .</string>
            <string id="iRevocationCheckerDC_User">Revocation Checker</string>
            <string id="iRevocationCheckerDC_User_Explain">Specifies a provider for revocation checking.

0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
            <string id="bRevCheckTrustDC_User">Revoke Check Trust</string>
            <string id="bRevCheckTrustDC_User_Explain">Specifies whether to perform revocation checks on intermediate trust anchors (those which aren't roots).

In previous versions, the application did not perform revocation checks on any intermediate trust anchors since it was assumed they were self-signed. With 10.1.2 and 9.5, this setting enables revocation checking on intermediate trust anchors if such information is available. Trust anchors from 3rd parties are often installed locally to facilitate signature validation. Since it is possible that the trust anchors could become compromised and thereby open the host machine to malicious attack, those 3rd party providers in such cases would revoke their certificates. This preference enables detecting that revocation by forcing a revocation check on any intermediate trust anchors. Root and self-signed certificates are exempt from checking.

Possible values include:
0: Don't perform a revocation check on intermediate trust anchors.
1: Perform a revocation check on intermediate trust anchors.</string>
            <string id="iRSAPSSSaltLengthDC_User">RSA-PSS Salt Length</string>
            <string id="iRSAPSSSaltLengthDC_User_Explain">Specifies the Salt Length the RSA-PSS algorithm uses.

When setting the salt length, you must assure the default base is hexadecimal. Either change the base to decimal or input its hex value. For example, if the salt length decimal value is 32, then set the hex value to 20.</string>
            <string id="bEnableRSAPSSSigningDC_User">RSA-PSS Signing</string>
            <string id="bEnableRSAPSSSigningDC_User_Explain">Specifies whether a signature should be created with the RSA-PSS algorithm.

Possible values include:
0: Do not sign with the RSA-PSS algorithm.
1: Use the RSA-PSS algorithm.</string>
            <string id="iDigSigSaveAsCertifiedDC_User">Save Certified Alert</string>
            <string id="iDigSigSaveAsCertifiedDC_User_Explain">

Possible values include:
0: Don't show an alert.
1: Do show an alert.</string>
            <string id="bSecureOpenFileDC_User">Secure Open Attachments</string>
            <string id="bSecureOpenFileDC_User_Explain">Specifies whether to allow opening attachments which are not PDF.

When this pref is set to true, then Acrobat only allows opening PDF attachments. bAllowOpenFile, bSecureOpenFile, and tBuiltInPermsList work in tandem: If any of these are set to prevent the opening of an attachment, then the attachment type won't open (or all attachments depending on the setting).

Possible values include:
0: Allow opening attachments with filetype other than PDF.
1: Don't open non-PDF attachments.</string>
            <string id="bSelfSignCertGenDC_User">Self-Sign ID Create</string>
            <string id="bSelfSignCertGenDC_User_Explain">Specifies whether or not the Create a self-signed ID option in Add ID workflows is available.

Prevents users from creating a self-signed digital ID. Note that for products released after June 2016, disabling a user's ability to create a self-signed digital ID requires setting both bSelfSignCertGen and bEnableCEFBasedUI to 0.

Possible values include:
0: Don't allow creating self-signed digital IDs.
1: Allow self-signed digital IDs.</string>
            <string id="bShowAllChainsDC_User">Show All Chains</string>
            <string id="bShowAllChainsDC_User_Explain">Specifies whether to show all chains in the Certificate Viewer.

If true, the Certificate Viewer shows all the chains; otherwise, it shows only the trusted chain. If there are no trusted chains, then all the chains are shown and this preference is ignored.</string>
            <string id="iShowDocumentWarningsDC_User">Show Document Warnings</string>
            <string id="iShowDocumentWarningsDC_User_Explain">Specifies whether a button to allow reviewing document warnings shows up on the signing dialog.

Interacts with iRequireDocumentWarnings. The possible values include: 0: Never 1: Show when certifying only 2: Always</string>
            <string id="bShowWarningForChangesDC_User">Show Post-Sign Warning</string>
            <string id="bShowWarningForChangesDC_User_Explain">Determines whether or not to show a blue i on validated signature(s) if the document changes after it was signed.

If true, a document change results in a blue i status icon appearing for validated approval signatures. Use this setting when users need to know a document has changed after it was signed. If false, the status icon remains a green check and pen even if a document changes after it is signed. The setting provides a method for administrators to turn off the blue i in workflows where documents can be changed or signed multiple times. This setting does not affect certification signatures. The warning icon never appears for valid certification or approval signatures in certified documents if the signatures were allowed by the certifier. Interacts with iDisplayValidIcon which cannot be set to 2, or the icons will not appear regardless of how bShowWarningForChanges is set.</string>
            <string id="bAllowOtherInfoWhenSigningDC_User">Show Sign Contact Info</string>
            <string id="bAllowOtherInfoWhenSigningDC_User_Explain">Specifies whether the location and contact information UI will appear during signing.</string>
            <string id="bShowSignerWarningsDC_User">Show Signer Warnings</string>
            <string id="bShowSignerWarningsDC_User_Explain">Specifies whether to show a warning that there is a greater forgery risk when revocation information is embedded in the signature.

Because this warning was removed from 10.x products, this preference is only applicable to 9.4.6 and later products in the 9.x line.

Possible values include:
0: Don't show the warnings.
1: Do show the warnings.</string>
            <string id="iDisplayValidIconDC_User">Show Valid Sig Icon</string>
            <string id="iDisplayValidIconDC_User_Explain">Determines when the signature status icon is displayed in a signature appearance.

Possible values include:
0: Always.
1: Display except when the signature is valid.
2: Never. This value disables bShowWarningForChanges and removes the Hide signature field validity icon option from the GUI. This setting does not affect the icons in the Signatures Pane or in the Signature Properties dialog Note : This UI item was removed from versions 9.x and later because signature status was moved to the Document Message Bar.</string>
            <string id="bReqSigPropVerificationDC_User">Sig Property Verify</string>
            <string id="bReqSigPropVerificationDC_User_Explain">Specifies whether signature property verification must succeed for a signature to be valid.

As of 8.0, the only property used is the timestamp URL.</string>
            <string id="iSigVerificationTimeDC_User">Sig Verification Time</string>
            <string id="iSigVerificationTimeDC_User_Explain">Indicates the time at which signature validation should occur.

Possible values include:
0: Always carry out the verification at current time
1: Use the signing time if it's secure (e.g. timestamped), else use current time
2: Always use signing time</string>
            <string id="bAllowSigCertOnlyDC_User">Sign Certified Only</string>
            <string id="bAllowSigCertOnlyDC_User_Explain">Specifies whether any subsequent signers can sign a certified document containing LegalPDF warnings with additional approval signatures.

In other words, the presence of any LegalPDF warning prevent any additonal signatures.</string>
            <string id="isignDoneDC_User">Sign Done Dialog</string>
            <string id="isignDoneDC_User_Explain">Specifies whether to show a dialog indicating that a document was successfully signed.

Possible values include:
0: Show the dialog after signing successfully.
1: Don't show the dialog after signing successfully.</string>
            <string id="bAllowSigCertGreenOnlyDC_User">Sign Green Cert Only</string>
            <string id="bAllowSigCertGreenOnlyDC_User_Explain">Specifies whether any subsequent signers can sign a certified document that does not contain LegalPDF warnings with additional approval signatures.

In other words, the presence of any LegalPDF warning does not prevent any additonal signatures.</string>
            <string id="bSignRequestDC_User">Sign OCSP Requests</string>
            <string id="bSignRequestDC_User_Explain">Specifies whether the OCSP request should be signed.

Some OCSP providers require that OCSP requests are signed (e.g IdenTrust). 0: Don't sign the OCSP request. 1: Force Acrobat to sign OCSP requests prior to sending.</string>
            <string id="iHashAlgoDC_User">Timestamp Hash Algo</string>
            <string id="iHashAlgoDC_User_Explain">Identifies the hashing algorithm used to hash the timestamped data.

The valid values are: 0: MD5 1: SHA1 2: SHA256 For an alternative, see sHashAlgo which supports more options.</string>
            <string id="iSizeDC_User">Timestamp Sig Size</string>
            <string id="iSizeDC_User_Explain">ASPKI requires the signature property to predict the size (in bytes) so that enough space can be set aside.</string>
            <string id="bTrueTypeFontPDFSigQWarnDC_User">TrueType Font Warn</string>
            <string id="bTrueTypeFontPDFSigQWarnDC_User_Explain">Turns on and off warnings about True Type fonts.</string>
            <string id="bTrustCertifiedDocumentsDC_User">Trust Certified Docs</string>
            <string id="bTrustCertifiedDocumentsDC_User_Explain">Elevates (trusts) certified documents as a privileged location.

This setting allows certified documents to bypass all the security restrictions that may be bypassed by other privileged locations. The exception is that this level of trust does not apply when the PDF is viewed in Protected View. To lock this setting, set bEnableCertificateBasedTrust .

Possible values include:
0 or null: Don't make certified documents equivalent to privileged locations.
1: Do make certified documents equivalent to privileged locations (trusted).</string>
            <string id="bTrustOSTrustedSitesDC_User">Trust IE Trusted Sites</string>
            <string id="bTrustOSTrustedSitesDC_User_Explain">Elevates locations that Internet Explorer trusts to privileged locations so that they may bypass security restrictions.

Prior to 10.1.1 and 9.4.7, trust was granted to Trusted Sites. With 10.1.2 and 9.5 and later, trust also includes Local Intranet zones. This setting essentially makes IE trust operate as if they were privileged locations. The feature can be disabled with bDisableOSTrustedSites. 0: Don't automatically trust Windows OS zones. 1: Do automatically trust Windows OS zones.</string>
            <string id="iURLPermsDC_User">URL Access Permissions</string>
            <string id="iURLPermsDC_User_Explain">Specifies whether to allow or block all websites or use a custom setting.

If the user selects Custom Setting, tHostPerms is populated with the user's custom URLs. If Allow or Block is later selected, then iURLPerms overrides tHostPerms and tHostPerms is reset to null (the user list is ignored).

Possible values include:
0: Custom Setting
1: Block all websites
2: Allow all websites</string>
            <string id="tHostPermsDC_User">Trusted/Blocked URL List</string>
            <string id="tHostPermsDC_User_Explain">Stores the list of trusted and blocked URLs used when URL Access Permissions (iURLPerms) is set to Custom Setting.

This is a free-text companion to iURLPerms. It only has effect when iURLPerms is 0 (Custom Setting); selecting Allow or Block instead overrides this list and resets it to null. Not lockable via HKLM -- this preference only exists at User scope.

Format follows Adobe's TrustManager host permission list syntax.</string>
            <string id="iUseArchivedRevInfoDC_User">Use Archived Rev Info</string>
            <string id="iUseArchivedRevInfoDC_User_Explain">Indicates whether the revocation information archived with the signature is used for revocation checking.

Allowable values include: 0: Never (always require fresh revocation information to be successfully downloaded). 1: Deprecated. Do not use. 2: Always use (if embedded revocation information is available do not download fresh revocation information).</string>
            <string id="iValidityModelDC_User">Validity Model</string>
            <string id="iValidityModelDC_User_Explain">Specifies the validity model for validating signatures and certificates.

The application uses shell validation by default, but chain validation may be used when required. Compliance with the German signature law requires chain validation. Allowabled values include: 0: PKIX shell model 1: Chain validity model. Chain validation is used to validate all or part of a certificate chain when any certificate chaining up to a CA certificate containing the qualified certificate policy extension (OID 1.3.36.8.1.1) or the validity model certificate extension OID (1.3.6.1.4.1.8301.3.5) with the value set to the chain model OID (1.3.6.1.4.1.8301.3.5.1).</string>
            <string id="iMSStoreTrustedDC_User">Windows Store Trust</string>
            <string id="iMSStoreTrustedDC_User_Explain">Controls whether or not certificates in the Windows Certificate Store are trusted for signing and certifying.

To lock this setting, use bMSStoreTrusted. Allowable values include: 0x00: No checkbox selected. 0x60: Validating Signatures. 0x62: Validating Certified Documents and Signatures. Note that this setting disables the Validating Signatures checkbox because it also controls non-certified signatures and users should not be able to uncheck that checkbox.</string>

            <string id="bLoadSettingsFromURLAdobeDC_User">Load Security Settings from Server (Adobe Certificates)</string>
            <string id="bLoadSettingsFromURLAdobeDC_User_Explain">Controls whether trust anchors are periodically downloaded from Adobe's certificate server.

When enabled, Acrobat contacts Adobe's server to download updated root certificates and trust anchors used for signature validation. Disabling this prevents the application from making outbound connections to Adobe's certificate infrastructure, which is required in air-gapped or restricted network environments.

Possible values include:
0: Do not load security settings from Adobe's certificate server.
1: Periodically download security settings from Adobe's certificate server.</string>
            <string id="bLoadSettingsFromURLEUTLDC_User">Load Security Settings from Server (European Certificates)</string>
            <string id="bLoadSettingsFromURLEUTLDC_User_Explain">Controls whether trust anchors are periodically downloaded from the European Union Trusted Lists (EUTL) server.

When enabled, Acrobat contacts the EUTL server to download updated European root certificates used for signature validation of EU-issued qualified electronic signatures. Disabling this prevents outbound connections to EUTL infrastructure.

Possible values include:
0: Do not load security settings from the EUTL server.
1: Periodically download security settings from the EUTL server.</string>

            <!-- ======================================== -->
            <!--           Sharing and Features           -->
            <!-- ======================================== -->

            <string id="iSendMailDefaultAccountAlertDC_User">Default Email Prompt</string>
            <string id="iSendMailDefaultAccountAlertDC_User_Explain">Specifies whether a dialog should appear asking if a PDF should be sent via the user's default email account.

When a new user tries to send a PDF via email, a dialog appears and asks &quot;How would you like to send this email.&quot; Users then need to select a choice and check Remember my choice .

Possible values include:
0: Don't show the dialog.
1: Do show the dialog.</string>
            <string id="bDefaultSetDC_User">Default Email Set</string>
            <string id="bDefaultSetDC_User_Explain">Indicates whether a default email client has been set.

Possible values include:
0: Default webmail client is not set.
1: Default webmail client is set.</string>
            <string id="bDisableSharedReviewDC_User">Disable Shared Review</string>
            <string id="bDisableSharedReviewDC_User_Explain">Specifies whether to enable cloud-based shared reviews.

To completely disable the Document Cloud Review service, disable all services or set bToggleAdobeReview (See FeatureLockDown for details). When set to 0, this preference removes Document Cloud Review service, including the Send for Review tool in the tool's pane and its associated menus.

Possible values include:
0: Remove the option to use the DC review service when a user chooses Tools ) Send for Review OR Send for Review in the right-hand pane. Only legacy review types are available.
1: Enable the Document Cloud Review service option.</string>
            <string id="bNeedSynchronizerDC_User">Enable Synchronizer</string>
            <string id="bNeedSynchronizerDC_User_Explain">Disables the synchronizer.

Features that use the synchronizer include services, the Adobe Acrobat Trust List, shared reviews, the recent files list (11.0.07+), and data collection in some forms workflows prior to 11.0.07. Disabling the Synchronizer is not recommended.

Possible values include:
0: Disable the synchronizer.
1: Enable the synchronizer. Note that Acrobat and Reader do not use the same synchronizer. When there is an older minor version of Acrobat or Reader and the newer minor version is 11.0.07-11.1.10: Both Acrobat and Reader get the new synchronizer when updating to .07 or later. If the newer synchronizer is running, it supports older services and non-services operations. If the older synchronizer (pre 11.0.07) is running, sync-dependent operations do not work [3746864]</string>
            <string id="bEnableFillSignDC_User">Fill &amp; Sign Pane</string>
            <string id="bEnableFillSignDC_User_Explain">Specifies whether to remove the Fill and Sign pane without removing the Work with Certificates menu.

11.x products only. This setting allows users to remove the Acrobat Sign menu items without removing the menu item for using digital signatures on the local machine.

Possible values include:
0: Remove the Fill and Sign pane.
1: Don't remove the Fill and Sign pane.</string>
            <string id="bRemoveCommaDelimiterDC_User">Remove Comma Delimiter</string>
            <string id="bRemoveCommaDelimiterDC_User_Explain">Specifies whether to remove the comma in comma-delimited addressbook entries.

During shared review workflows, the user invoke the addressbook to invite participants. In cases where the addressbook is comma-delimited, pre DC versions of the product display an error dialog. Use this prefererence to remove commas.

Possible values include:
0: Don't remove commas.
1: Remove commas.</string>
            <string id="iSendForReviewConfirmDC_User">Review Confirm Alert</string>
            <string id="iSendForReviewConfirmDC_User_Explain"></string>
            <string id="bShowConnectDialogDC_User">Show Connect Dialog</string>
            <string id="bShowConnectDialogDC_User_Explain">Specifies whether to display the Connect dialog in Shared Reviews.

Possible values include:
0: Don't show the Connect dialog.
1: Do show the Connect dialog.</string>
            <string id="bIsUsedShareReviewDC_User">Show Review Tip</string>
            <string id="bIsUsedShareReviewDC_User_Explain">Specifies whether to show a popup tip that informs users of the collaborative review feature.

The popup only appears if the user has opened a review file but has not sent a review file. Once the user has initiated a review, the application sets this value to 1, and the popup no longer appears.

Possible values include:
0: Show the tip.
1: Don't show the tip.</string>
            <string id="bIsUsedShareDC_User">Show Share Tip</string>
            <string id="bIsUsedShareDC_User_Explain">Specifies whether to show a popup tip that informs users of the share file feature.

The popup only appears if the user has opened a shared file but has not shared a file. Once the user has shared a file, the application sets this value to 1, and the popup no longer appears.

Possible values include:
0: Show the tip.
1: Don't show the tip.</string>
            <string id="bShowWelcomeDialogDC_User">Show Welcome Dialog</string>
            <string id="bShowWelcomeDialogDC_User_Explain">Specifies whether to show the Welcome dialog when a shared review is initiated.

Possible values include:
0: Don't show the welcome dialog.
1: Do show the welcome dialog.</string>

            <!-- ======================================== -->
            <!--          Startup and Experience          -->
            <!-- ======================================== -->

            <string id="bActivatedDC_User">App Activated</string>
            <string id="bActivatedDC_User_Explain">Records whether the application has been activated online after installation.

Possible values include:
0: Not activated
1: Activated</string>
            <string id="bHasLaunchedDC_User">App Has Launched</string>
            <string id="bHasLaunchedDC_User_Explain">Records whether the application has been launched after installation.

Possible values include:
0: Not launched
1: Launched</string>
            <string id="bAppInitializedDC_User">App Initialized</string>
            <string id="bAppInitializedDC_User_Explain">Records whether the application has been initialized after installation.

Possible values include:
0: Not initialized
1: Initialized</string>
            <string id="bLaunchedDC_User">App Launched</string>
            <string id="bLaunchedDC_User_Explain">Caches whether or not the application has ever been launched.

Application behavior may vary across versions depending on whether the application has been launched.

Possible values include:
0: The application has not been launched.
1: The application has been launched.</string>
            <string id="EULAAcceptedForBrowserDC_User">Browser EULA Accepted</string>
            <string id="EULAAcceptedForBrowserDC_User_Explain">For Acrobat's browser plugin, caches whether the browser-based EULA has been accepted.

On Macintosh, this preference can not be set in the plist. Use the Mac Wizard or the PRTK tool. Reader uses the key EULA. If the EULA is not accepted, the application stops running after a set period of time.

Possible values include:
0: Show the EULA because it has not been accepted.
1: Don't show the EULA.</string>
            <string id="bChooseLangAtStartupDC_User">Choose Language Startup</string>
            <string id="bChooseLangAtStartupDC_User_Explain">Allows the user to choose the language at startup.</string>
            <string id="bCreateFormDiscoveryShownDC_User">Create Form Onboarding</string>
            <string id="bCreateFormDiscoveryShownDC_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Create Form panel.

Possible values include:
0: Show the onboarding coachmark.
1: Don't show the onboarding coachmark.</string>
            <string id="bEditDiscoveryShownDC_User">Edit Onboarding</string>
            <string id="bEditDiscoveryShownDC_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Edit panel.

Possible values include:
0: Show the onboarding coachmark.
1: Don't show the onboarding coachmark.</string>
            <string id="iEULAAcceptanceTimeDC_User">EULA Accept Timeout</string>
            <string id="iEULAAcceptanceTimeDC_User_Explain">The amount of time granted to users after installation to accept the end user agreement.</string>
            <string id="bFillSignDiscoveryShownDC_User">Fill &amp; Sign Onboarding</string>
            <string id="bFillSignDiscoveryShownDC_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Fill &amp; Sign panel.

Possible values include:
0: Show the onboarding coachmark.
1: Don't show the onboarding coachmark.</string>
            <string id="bHideHelpWelcomeDC_User">Hide Help Welcome</string>
            <string id="bHideHelpWelcomeDC_User_Explain">Specifies whether to disable the Welcome menu item under Help.

Possible values include:
0 or null: Enable the Welcome menu item.
1: Disable the Welcome menu item.</string>
            <string id="bShownHomeOnboardingDC_User">Home Onboarding</string>
            <string id="bShownHomeOnboardingDC_User_Explain">Specifies whether to invoke the home onboarding tour when the modern viewer is invoked the first time.

Once the home onboarding tour displays, the app automatically resets this value to 0. This preference has no effect if AVGeneral/bEnableAv2 is 0.

Possible values include:
0: Show the onboarding tour (not yet shown).
1: Don't show the onboarding tour (already shown or declined).</string>
            <string id="bLoadAllPluginsAtStartupDC_User">Load All Plugins</string>
            <string id="bLoadAllPluginsAtStartupDC_User_Explain">Specifies whether all plugins should be loaded when the application is started.</string>
            <string id="bOrganizeDiscoveryShownDC_User">Organize Onboarding</string>
            <string id="bOrganizeDiscoveryShownDC_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Organize panel.

Possible values include:
0: Show the onboarding coachmark.
1: Don't show the onboarding coachmark.</string>
            <string id="bUsePageCacheDC_User">Page Caching</string>
            <string id="bUsePageCacheDC_User_Explain">Specifies whether to cache pages that have been loaded.

Possible values include:
0: Don't cache pages.
1: Do cache pages</string>
            <string id="bRedactDiscoveryShownDC_User">Redaction Onboarding</string>
            <string id="bRedactDiscoveryShownDC_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Redaction panel.

Possible values include:
0: Show the onboarding coachmark.
1: Don't show the onboarding coachmark.</string>
            <string id="bDisplayAboutDialogDC_User">Show About Dialog</string>
            <string id="bDisplayAboutDialogDC_User_Explain">Specifies whether or not to display the startup splash screen at every launch.

Possible values include:
0: Don't display the startup splash screen.
1: Display the startup splash screen at every launch.</string>
            <string id="idontShowAllImagesHaveAltTextDC_User">Show Alt Text Alert</string>
            <string id="idontShowAllImagesHaveAltTextDC_User_Explain">Toggles whether to show an alert when a user executes the Set Alternate Text dialog and there are no images missing alternate text.

Possible values include:
0: Show alert.
1: Don't show alert.</string>
            <string id="bshowEULADC_User">Show EULA Startup</string>
            <string id="bshowEULADC_User_Explain">Toggles on and off whether the end user license agreement appears.</string>
            <string id="bLastShowStatusDC_User">Show Getting Started</string>
            <string id="bLastShowStatusDC_User_Explain">Specifies whether to show &quot;Get Started with Acrobat&quot; on startup.

Possible values include:
0: Don't show the Getting Started page.
1: Show the Getting Started page.</string>
            <string id="bShowHorizontalScrollbarDC_User">Show H-Scrollbar</string>
            <string id="bShowHorizontalScrollbarDC_User_Explain">Specifies whether to show a horizontal scrollbar when the viewing area is narrower than the width of the loaded document.

Possible values include:
0: Disable the horizontal scrollbar.
1: Enable the horizontal scrollbar.</string>
            <string id="bShowExistingAttachedReportAlertDC_User">Show Report Alert</string>
            <string id="bShowExistingAttachedReportAlertDC_User_Explain">Toggles whether to show an alert when a user tries to attach a report if there is already a report attached.

Possible values include:
0: Show alert.
1: Don't show alert.</string>
            <string id="idontShowSetAltTextInfoDC_User">Show Set Alt Alert</string>
            <string id="idontShowSetAltTextInfoDC_User_Explain">Toggles whether to show an informative alert when a user executes the Set Alternate Text dialog.

Possible values include:
0: Show alert.
1: Don't show alert.</string>
            <string id="bShowedSkipCardDC_User">Show Skip Card</string>
            <string id="bShowedSkipCardDC_User_Explain">Specifies whether to show the skipped onboarding coachmark.

Possible values include:
0: Disables the feature.
1: Enables the feature.</string>
            <string id="bSplashDisplayedAtStartupDC_User">Show Splash Screen</string>
            <string id="bSplashDisplayedAtStartupDC_User_Explain">Toggles whether the splash screen appears on startup.</string>
            <string id="bDisplayedSplashDC_User">Splash Displayed</string>
            <string id="bDisplayedSplashDC_User_Explain">Indicates whether or not the application has started up and invoked the splash screen.

Possible values include:
0: The splash screen has not been invoked yet.
1: The splash screen has been invoked.</string>
            <string id="bInTrialModeDC_User">Trial Mode Active</string>
            <string id="bInTrialModeDC_User_Explain">Records whether the application is operating in Trial Mode.

Possible values include:
0: Not in trial mode
1: In trial mode</string>
            <string id="bShownViewerOnboardingDC_User">Viewer Onboarding</string>
            <string id="bShownViewerOnboardingDC_User_Explain">Specifies whether to invoke the new viewer onboarding tour when a PDF opens in the modern viewer the first time.

Once the viewer onboarding tour displays, the app automatically resets this value to 0. This preference has no effect if AVGeneral/bEnableAv2 is 0.

Possible values include:
0: Show the onboarding tour (not yet shown).
1: Don't show the onboarding tour (already shown or declined).</string>
            <string id="iDelayBeforeQuitViewerDC_User">Viewer Quit Delay</string>
            <string id="iDelayBeforeQuitViewerDC_User_Explain">Specifies the number of seconds the standalone application stays in memory before it shuts down.

Possible values include:
30 Any integer</string>

            <!-- ======================================== -->
            <!--     Updates and Desktop Integration      -->
            <!-- ======================================== -->

            <string id="bDownloadEntireFileDC_User">Background Download</string>
            <string id="bDownloadEntireFileDC_User_Explain">Specifies whether to allow background downloading of resources the view thinks it needs to properly display the PDF.

Possible values include:
0: Don't allow background downloading.
1: Do allow background downloading.</string>
            <string id="iDelayBeforeQuitBrowserDC_User">Browser Quit Delay</string>
            <string id="iDelayBeforeQuitBrowserDC_User_Explain">Specifies the number of seconds the browser-based application stays in memory before it shuts down.

Possible values include:
30 Any integer</string>
            <string id="bBrowserDisplayInReadModeDC_User">Browser Read Mode</string>
            <string id="bBrowserDisplayInReadModeDC_User_Explain">Specifies whether to open documents in a browser in Read Mode.

Read Mode was introduced in Acrobat and Reader 10.0 to enhance the PDF viewing experience for documents in a browser. Read Mode turns off the standard toolbars and menu items and provides a more compact and simple menu bar only when a user hovers over the bottom, middle area of the PDF. For more information, see the Browser Integration Quick Key in the Quick Key Library .

Possible values include:
0: Don't use Read Mode and display the standard toolbars.
1: Use Read Mode and hide the standard toolbars.</string>
            <string id="bInstalledCleanupCheckDoneDC_User">Cleanup Check Done</string>
            <string id="bInstalledCleanupCheckDoneDC_User_Explain">A preference used by the usage measurement feature to determine whether the previously set UsageMeasurement-related keys should be reset.</string>
            <string id="bLoadOnStartDC_User">Collab Sync Startup</string>
            <string id="bLoadOnStartDC_User_Explain">Specifies whether the collaboration executable should be invoked and run as a background process on startup.

When enabled, AdobeCollabSync.exe runs on application startup. This process is used for features like shared reviews and forms data collection .

Possible values include:
0: Start the process.
1: Don't start the process.</string>
            <string id="bAllowByteRangeRequestsDC_User">Fast Web View</string>
            <string id="bAllowByteRangeRequestsDC_User_Explain">Specifies whether to enable Fast Web View by allowing display of the PDF before the entire file is downloaded.

Possible values include:
0: Don't enable Fast Web View.
1: Enable Fast Web View.</string>
            <string id="bFavoriteFilesRememberChoiceDC_User">Remember Stars Choice</string>
            <string id="bFavoriteFilesRememberChoiceDC_User_Explain">Specifies the users choice

When a user selects &quot;Ask every time&quot; and iFavoriteFilesAccessOption is set to 0, this new preference remembers the users choice for each file.

Possible values include:
Application generated.</string>
            <string id="bFavoritesStripInRFLDC_User">Show Starred Files</string>
            <string id="bFavoritesStripInRFLDC_User_Explain">Specifies whether to show starred files in the recent files list.

A starred file is somewhat similar to a &quot;favorited&quot; file. Note that the lockable version of this preference is named bFavoritesFeaturesLockDown .

Possible values include:
0: Show starred files in the recent files list.
1: Don't show starred files in the recent files list.</string>
            <string id="iFavoriteFilesAccessOptionDC_User">Starred Files Action</string>
            <string id="iFavoriteFilesAccessOptionDC_User_Explain">Specifies what action to take when starring a file.

A starred file is somewhat similar to a &quot;favorited&quot; file.

Possible values include:
0: Show a dialog and ask whether to save or upload. This option also results in creating a new bFavoriteFilesRememberChoice .
1: Upload to Document Cloud
2: Save the file locally</string>
            <string id="bStoreCredentialsDC_User">Store Credentials</string>
            <string id="bStoreCredentialsDC_User_Explain">Specifies whether the user logon credentials for the Tracker should be stored.

Possible values include:
0: Don't store credentials.
1: Store credentials.</string>
            <string id="iAVARMNoAutoUpdateWarningDC_User">Suppress Update Warning</string>
            <string id="iAVARMNoAutoUpdateWarningDC_User_Explain">Specifies whether to turn of the &quot;Updater has not been able to check for updates recently&quot; dialog.

Possible values include:
0: Don't turn off the dialog.
1: Do turn off the dialog.</string>

            <!-- ======================================== -->
            <!--                  Upsell                  -->
            <!-- ======================================== -->

            <string id="bAcrobatAppInstalledDC_User">Acrobat App Promo</string>
            <string id="bAcrobatAppInstalledDC_User_Explain">Specifies whether to show the Acrobat mobile app promotion and link in the Home banner.

Disable and lock both the App Center and Home banner with bToggleDCAppCenter under FeatureLockDown.

Possible values include:
0: Promote the mobile app.
1: Don't promote the mobile app.</string>
            <string id="bScanAppInstalledDC_User">Scan App Promo</string>
            <string id="bScanAppInstalledDC_User_Explain">Specifies whether to show the Adobe Scan mobile app promotion and link in the Home banner.

Disable and lock both the App Center and Home banner with bToggleDCAppCenter under FeatureLockDown.

Possible values include:
0: Promote the mobile app.
1: Don't promote the mobile app.</string>
            <string id="bShowTrialNagDC_User">Show Trial Nag</string>
            <string id="bShowTrialNagDC_User_Explain">Specifies whether a &quot;Trial Expired&quot; dialog should appear after 30 days.

This preference is automatically set by the application. When the 30 day trial period expires, Acrobat is launched in reduced functionality mode, and a dialog appears asking if the user would like to purchase the product.

Possible values include:
0: Don't show the &quot;Trial Expired&quot; dialog.
1: &quot;Trial Expired&quot; dialog.</string>

            <!-- ======================================== -->
            <!--                                          -->
            <!-- Adobe Reader DC (User) - policy strings  -->
            <!--                                          -->
            <!-- ======================================== -->

            <!-- ======================================== -->
            <!--        Context, Tools and Search         -->
            <!-- ======================================== -->

            <string id="iColumnSelectHalo_User">Column Select Halo</string>
            <string id="iColumnSelectHalo_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
            <string id="bAlwaysUseFileNameAsDocTitle_User">Filename as Title</string>
            <string id="bAlwaysUseFileNameAsDocTitle_User_Explain">Specifies whether to use the PDF file name as the display name in the application's title bar.

PDF documents have an Initial View property that's set to &quot;Document Title&quot; by default. Enabling this preference overrides any document-level setting with the app-level setting.

Possible values include:
0: Don't use file names.
1: Use file names for the PDF title.</string>
            <string id="bUseFixedSnapshotResolution_User">Fixed Snapshot Resolution</string>
            <string id="bUseFixedSnapshotResolution_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
            <string id="ADC4318556_User">Flash Player for 3D</string>
            <string id="ADC4318556_User_Explain">Enables playing 3D and multimedia content using a Flash player in PDF.

Since Flash is no longer supported, admins must install and configure the player.

Possible values include:
0 or null: Don't play content with a Flash player.
1: Use the Flash player.</string>
            <string id="bHandSelects_User">Hand Tool Select</string>
            <string id="bHandSelects_User_Explain">Specifies whether the hand tool should be able to select text and images.

With the DC 10/13/2015 release, this setting also works on Windows Touch devices.

Possible values include:
0: Don't select text and images.
1: Select text and images.</string>
            <string id="iMaxMRUCntToBeStored_User">Max Recent Files</string>
            <string id="iMaxMRUCntToBeStored_User_Explain">Stores the number of recent files that should be listed in the recent files list.

The recent files list appears under the file menu (5 item limit), the splash screen (5 item limit), and in My Files View (100 item limit). A number from 0-100. The default is 100.</string>
            <string id="bEnableAv2_User">Modern Viewer</string>
            <string id="bEnableAv2_User_Explain">Specifies whether to show the modern viewer first released in July 2022.

0: Show the classic viewer. 1: Show the modern viewer.</string>
            <string id="bAllowMultipleExpandedPanels_User">Multiple Comment Panels</string>
            <string id="bAllowMultipleExpandedPanels_User_Explain">Specifies whether multiple comment panels can be expanded.

Possible values include:
0: Don't allow more than one visible panel.
1: Do allow multiple visible panels.</string>
            <string id="iNumSwitcherContextualToolTipAV2Shown_User">New Look Coachmark</string>
            <string id="iNumSwitcherContextualToolTipAV2Shown_User_Explain">Specifies whether to show the &quot;Acrobat has a new look&quot; coachmark after launching Acrobat the first time.

Once the coachmark displays, the app automatically resets this value to 0. This preference has no effect if bEnableAv2 is 0. 0: Do not show the coachmark. 1: Show the coachmark.</string>
            <string id="bPinHUD_User">Pin HUD Toolbar</string>
            <string id="bPinHUD_User_Explain">Specifies whether to pin the HUD to the toolbar.

The application automatically creates this key when you click the &quot;pin to menu&quot; icon on the right-hand side of the HUD.

Possible values include:
0: Don't pin the HUD to the toolbar.
1: Pin the HUD to the toolbar.</string>
            <string id="bPromptBeforeClosingMultipleTabs_User">Prompt Close Tabs</string>
            <string id="bPromptBeforeClosingMultipleTabs_User_Explain">Specifies whether to warn the user before closing documents open in multiple tabs.

The ability to open documents in separate tabs was introduced in October, 2015.

Possible values include:
0: Don't warn the user.
1: Warn the user.</string>
            <string id="bImagesFirst_User">Select Images First</string>
            <string id="bImagesFirst_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
            <string id="bInfobubble_User">Show Tool Pane Tips</string>
            <string id="bInfobubble_User_Explain">Specifies whether the popup tooltips for the Tools, Comments, and Share panes should appear.

Possible values include:
0: Disable popup tooltips.
1: Enable popup tooltips.</string>
            <string id="bKeyPrefsShowVirtualKeyoard_User">Show Touch Keyboard</string>
            <string id="bKeyPrefsShowVirtualKeyoard_User_Explain">Specifies whether to show the touch keyboard if device is in touch or tablet mode on Win 8 and later.

In general, the virtual keyboard should only appear on touch devices running Windows 8 and later where the user has detached a soft keyboard. The keyboard should appear when a user taps a text area such as a search box, comment popup, form field, and so on.

Possible values include:</string>
            <string id="iSnapshotResolution_User">Snapshot Resolution DPI</string>
            <string id="iSnapshotResolution_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
            <string id="irightPaneState_User">Tools Pane State</string>
            <string id="irightPaneState_User_Explain">Specifies whether to automatically open the Tools Pane on launch.

Possible values include:
0: Use the default.
1: Always closed.
2: Always open.</string>
            <string id="iBasicSharePaneStickyStatus_User">Tools Pane Sticky</string>
            <string id="iBasicSharePaneStickyStatus_User_Explain">Specifies whether to remember the Tools Pane state across sessions.

For example, if the user closes the Tools Pane, it will not automatically open on launch. Interacts with irightPaneState.

Possible values include:
0: Don't remember the Tool Pane's state. The Pane is always closed on application open.
1: Do remember the Tool Pane's state.</string>
            <string id="iNumSwitcherContextualToolTipAVShown_User">Try New Coachmark</string>
            <string id="iNumSwitcherContextualToolTipAVShown_User_Explain">Specifies whether to show the &quot;Try the new Acrobat/Reader&quot; coachmark after launching Acrobat the first time.

Once the coachmark displays, the app automatically resets this value to 0. This preference has no effect if bEnableAv2 is 0. 0: Do not show the coachmark. 1: Show the coachmark.</string>
            <string id="iNumSessionAV2_User">UI Switcher Sessions</string>
            <string id="iNumSessionAV2_User_Explain">Specifies whether to show the UI switcher coachmark based on the number of user sessions.

Interacts with iNumSwitcherContextualToolTipAV2Shown .

Possible values include:
0 or
1: Don't show the UI switcher.
2 or greater: Show the UI switcher if iNumSwitcherContextualToolTipAV2Shown is 0.</string>

            <!-- ======================================== -->
            <!--   Documents, Editing and Accessibility   -->
            <!-- ======================================== -->

            <string id="bUse2DGPUf_User">2D GPU Acceleration</string>
            <string id="bUse2DGPUf_User_Explain">Specifies whether 2D graphics acceleration should be used.

Possible values include:
0: Disable
1: Enable</string>
            <string id="bAllowDocsToHideUI_User">Allow Hide UI</string>
            <string id="bAllowDocsToHideUI_User_Explain">Specifies whether to allow documents to hide the menu bar, toolbars, and window controls.

Possible values include:
0: Don't allow documents to hide UI elements.
1: Allow documents to hide UI elements.</string>
            <string id="benableTextSelection_User">Annotation Text Selection</string>
            <string id="benableTextSelection_User_Explain">Specifies whether to enable text selection for annotations such as highlight, strikethrough or underline.

Possible values include:
0: Enable text selection. When enabled, the cursor changes to ][ mode when the annotation (highlight, strikethrough or underline) is clicked and hovered over for more than 2 seconds. The cursor reverts to the previous mode after a time duration of 3 seconds upon hovering outside the bounding box of the annot.
1: Don't enable text selection. When disabled, the cursor changes to ][ mode only upon selecting Enable Text selection in the context menu. It will then remain in ][ mode for all annotations on the page.</string>
            <string id="bEnableAT_User">Assistive Technology</string>
            <string id="bEnableAT_User_Explain">Toggles assistive technology on and off.

This preference enables certain workflows when assistive technology such as JAWS is detected. When enabled, a dialog appears in workflows where accessibility might be improved. For example, when processing untagged documents, the user is asked if they would like to use the setup assistant. When processing scanned images, a prompt asks if OCR should run.

Possible values include:
0: Don't enable assistive technology.
1: Enable assistive technology.</string>
            <string id="bAttachLog_User">Attach Report</string>
            <string id="bAttachLog_User_Explain">Toggles whether to attach the accessibility report to the checked document after running accessibility full check.

Possible values include:
0: Don't attach the report.
1: Do attach the report.</string>
            <string id="bAutoCompleteOnTab_User">Auto-Complete on Tab</string>
            <string id="bAutoCompleteOnTab_User_Explain">Specifies whether to auto complete form field entries on a tab key action.

This option is enabled when the Advanced option is selected.

Possible values include:
0: Don't auto complete on tab.
1: Auto complete on tab.</string>
            <string id="bautoOpenOther_User">Auto-Open Drawing Popup</string>
            <string id="bautoOpenOther_User_Explain">Automatically adds a popup note when another type of annotation is added.

In other words, a popup note appears when you create a new comment using a drawing tool, the Stamp tool, or the Pencil tool.

Possible values include:
0: Don't add a popup note for other annot types.
1: Do add a popup note for other annot types.</string>
            <string id="bAutoSaveDocsEnabled_User">Auto-Save</string>
            <string id="bAutoSaveDocsEnabled_User_Explain">Specifies whether or not to automatically save documents.

Interacts with iAutoSaveDocsInterval.

Possible values include:
0: Don't auto save documents
1: Auto save documents.</string>
            <string id="iAutoSaveDocsInterval_User">Auto-Save Interval</string>
            <string id="iAutoSaveDocsInterval_User_Explain">Specifies the time interval in minutes at which to automatically save docs.

Interacts with bAutoSaveDocsEnabled.

Possible values include:
5: Minutes User specified: Any value 1-99</string>
            <string id="bAutoSetLayers_User">Auto-Set Layers</string>
            <string id="bAutoSetLayers_User_Explain">Specifies whether to allow the document's layer state to be set by user information.

Possible values include:
0: Don't allow layer state to be set by user information.
1: Allow layer state to be set by user information.</string>
            <string id="iAccessBackgroundColor_User">Background Color</string>
            <string id="iAccessBackgroundColor_User_Explain">Specifies the default document background color (accessibility feature)

The key name is appended with (Blue|Green|Red|Space).

Possible values include:
Green text on black Yellow text on black White text on black Black text on white</string>
            <string id="iPages_User">Check Page Range</string>
            <string id="iPages_User_Explain">Toggles whether to check all pages of a document or a subset of pages when running an accessibility full check.

Possible values include:
0: Don't check all pages.
1: Do check all pages.</string>
            <string id="benableDDR_User">ClearType Smoothing</string>
            <string id="benableDDR_User_Explain">Specifies whether to further smooth text on LCD screens.

Text smoothing essentially has two levels. First, the text is anti-aliased. Then DDR technology is applied for devices which allow RGB bands to be painted in individual pixels to further smooth text (LCD screens).

Possible values include:
0: None and Monitor
1: Laptop/LCD Screens.</string>
            <string id="iAccessColorPolicy_User">Color Replace Policy</string>
            <string id="iAccessColorPolicy_User_Explain">Specifies whether all the controls in the Replace Document Colors panel should be enabled.

When disabled, this key is removed from the registry/plist. When this preference is selected, you can choose from a list of contrasting color combinations for text and background or create your own.

Possible values include:
null: User specified.
1: Use Windows Color Scheme
2: Use Custom Colors
4: Use High Contrast Colors</string>
            <string id="bCombineContent_User">Combine Reading Order</string>
            <string id="bCombineContent_User_Explain">Specifies whether similar content should be displayed together or separately.

Possible values include:
0: Do display similar content types together.
1: Don't display similar content types together.</string>
            <string id="tauthor_User">Comment Author</string>
            <string id="tauthor_User_Explain">The author name specified by balwaysUseIdent.

Possible values include:
N/A: User specified.</string>
            <string id="dNoteFontSize_User">Comment Font Size</string>
            <string id="dNoteFontSize_User_Explain">Sets the font size.

The font is not embedded in the PDF; this preference merely controls the viewer's preference rather than the author's preference.

Possible values include:
10: Font size. N/A: User specified.</string>
            <string id="iNoteOpacity_User">Comment Opacity</string>
            <string id="iNoteOpacity_User_Explain">The opacity in percent of all comments.

The number is entered in Hex.

Possible values include:
d99a: 85%. N/A: Any hex value representing 1-100%.</string>
            <string id="iSens_User">Compare Sensitivity</string>
            <string id="iSens_User_Explain">Last-used compare documents sensitivity (for compare pages).</string>
            <string id="iType_User">Compare Type</string>
            <string id="iType_User_Explain">Last-used compare documents type (pages/text/text+fonts).</string>
            <string id="bComplexScript_User">Complex Script Support</string>
            <string id="bComplexScript_User_Explain">Specifies whether to enable support for writing direction switching (complex script).

Possible values include:
0: Don't enable Writing Direction Switching.
1: Enable Writing Direction Switching.</string>
            <string id="bconfirmEBRMerge_User">Confirm Review Import</string>
            <string id="bconfirmEBRMerge_User_Explain">Displays an alert on document open asking the user to confirm importing comments into an active review.

Possible values include:
0: Disable confirmation alert on import.
1: Enable confirmation alert on import.</string>
            <string id="bcopyTextToDrawAnnot_User">Copy Text to Drawing</string>
            <string id="bcopyTextToDrawAnnot_User_Explain">Specifies whether to copy the encircled text into drawing comment popups.

Adds a popup comment automatically to other markup types so that they can be annotated.

Possible values include:
0: Don't copy the encircled text into comments.
1: Do copy the encircled text into comments.</string>
            <string id="bcopyTextToMarkupAnnot_User">Copy Text to Markup</string>
            <string id="bcopyTextToMarkupAnnot_User_Explain">Copies the selected text into highlight, cross-out, and underline comment popups.

Adds a popup comment automatically to specified markup types so that they can be annotated.

Possible values include:
0: Copy selected text.
1: Don't copy selected text.</string>
            <string id="bCreateLog_User">Create Report</string>
            <string id="bCreateLog_User_Explain">Toggles whether to create an accessibility report when running an accessibility full check.

Possible values include:
0: Don't create report.
1: Do create report.</string>
            <string id="iDictionaryDefaultID_User">Default Dictionary</string>
            <string id="iDictionaryDefaultID_User_Explain">Identifies the default spelling dictionary ID.

The value is an ID from cDictionaryOrderID\i0 . The dictionary name can be found in cDictionaryOrder\t0. Alternatively, set the value in the user interface, close the product, and look here again. Use the value that appears during deployment.</string>
            <string id="iPageViewLayoutMode_User">Default Page Layout</string>
            <string id="iPageViewLayoutMode_User_Explain">Specifies the default page layout when a PDF opens.

These settings can be overridden by Accessiblity settings such as bOverridePageLayout.

Possible values include:
null: Automatic
1: Single Page
2: Single Page Continuous
3: Two Up Continuous
5: Two Up</string>
            <string id="iParaDir_User">Default Paragraph Dir</string>
            <string id="iParaDir_User_Explain">Specifies the paragraph direction.

Possible values include:
0: Left to Right
1: Right to Left
2: Infer from document</string>
            <string id="iDefaultZoomScale_User">Default Zoom Scale</string>
            <string id="iDefaultZoomScale_User_Explain">Specifies the zoom scale % to use when a PDF opens.

Possible values include a range beginning with Fit Page to Reflow . To set a value, configure the UI and look at the registry/plist preference to see what has been written.

Possible values include:
199a: 10% 4000 25% 8000: 50% c000: 75% 10000: 100% etc.</string>
            <string id="iDefaultZoomType_User">Default Zoom Type</string>
            <string id="iDefaultZoomType_User_Explain">Specifies the default zoom type (other than a %) to use when a PDF opens.

% scales are stored in iZoomScale.

Possible values include:
1: Fit Page (automatic)
2: Fit Width
3: Fit Hieght
4: Fit Visible
6: Reflow</string>
            <string id="imaxPDFCommentsSize_User">Embedded Comment Limit</string>
            <string id="imaxPDFCommentsSize_User_Explain">Sets the comment threshold size for determining whether comments are embedded or sent as FDF files.

When collaboration involves sending comments with a PDF, comments below the threshold size are embedded in the document. Comments above the threshold size are sent as FDF files.

Possible values include:
3: Max size for Reader (Acrobat is 5)</string>
            <string id="bemptyContentToolTip_User">Empty Comment Tooltip</string>
            <string id="bemptyContentToolTip_User_Explain">Displays a tooltip stating the comment being hovered over is empty.

Possible values include:
0: Don't indicate comment is empty.
1: Do indicate comment is empty.</string>
            <string id="bUseThinCode_User">Enhance Thin Lines</string>
            <string id="bUseThinCode_User_Explain">Specifies whether to enhance thin lines to improve visibility.

Possible values include:
0: Don't enhance thin lines.
1: Enhance thin lines.</string>
            <string id="bSuperFastDrawing_User">Fast Scroll Drawing</string>
            <string id="bSuperFastDrawing_User_Explain">Specifies whether to use fast, low resolution intermediate representation during scrolling, zooming, etc.

Superfast Drawing was introduced in Acrobat and Reader DC to make interactions with PDF documents smoother and more responsive. Superfast drawing suspends high quality rendering for the duration of operations like fast scrolling, panning, and zooming. This results in a lower quality intermediate representation being temporarily displayed during the current action.

Possible values include:
0: Don't use Superfast Drawing and display high quality intermediates during scrolling, zooming, panning, etc.
1: Use Superfast Drawing to display low resolution intermediates during scrolling, zooming, panning, etc. GUI mapping None.</string>
            <string id="iaskFormsSelectEmailCLient_User">Form Email Prompt</string>
            <string id="iaskFormsSelectEmailCLient_User_Explain">Specifies whether the dialog confirming selection of desktop vs. internet email on XFA form submit appears.

Possible values include:
0: Don't show the confirmation dialog on each XFA form submit.
1: Do show the confirmation dialog on each XFA form submit.</string>
            <string id="bHidePopupIfShowSummary_User">Hide Popup on Summary</string>
            <string id="bHidePopupIfShowSummary_User_Explain">Hide comment popups when comment's list is open.

Possible values include:
0: Don't hide popups.
1: Do hide popups.</string>
            <string id="bHindiDigit_User">Hindi Digits</string>
            <string id="bHindiDigit_User_Explain">Specifies whether to enable support for Hindi digits.

Possible values include:
0: Don't enable Hindi digits.
1: Enable Hindi digits.</string>
            <string id="bHoveringPopups_User">Hover Popups</string>
            <string id="bHoveringPopups_User_Explain">Automatically open popups on mouse rollover.

Possible values include:
0: Don't open popups on mouse rollover.
1: Do open popups on mouse rollover.</string>
            <string id="bInlineAutoComplete_User">Inline Auto-Complete</string>
            <string id="bInlineAutoComplete_User_Explain">Specifies whether to auto complete a field based on remembered values when a user starts typing.

This option is enabled for both the Basic and Advanced options.

Possible values include:
0: Don't auto complete.
1: Do autocomplete.</string>
            <string id="iIntlSelectFont_User">International Font</string>
            <string id="iIntlSelectFont_User_Explain">Specifies the font to use.

Possible values include:
0: Application default
1: GB18030 compatible font
2: HKSCS compatible font</string>
            <string id="bLigatures_User">Ligatures</string>
            <string id="bLigatures_User_Explain">Specifies whether to enable support for ligatures.

Possible values include:
0: Don't enable ligatures.
1: Enable ligatures.</string>
            <string id="balwaysUseIdent_User">Login Name as Author</string>
            <string id="balwaysUseIdent_User_Explain">Uses the login names as the comment author name.

The login name is the name specified in the identity preferences panel. If it is not present, the login-name is used. If it is not present for comments in collaborative documents (shared-review, browser-based review, email based review), the comment author identity is used that the user has set. For Acrobat, the default is true; for Reader, it is false.

Possible values include:
0: Do use the login name as the comment author name.
1: Don't use the login name as the comment author name.</string>
            <string id="bOpenInPlace_User">Open Links in Place</string>
            <string id="bOpenInPlace_User_Explain">Specifies whether to open cross document links in the same window.

Possible values include:
0: Don't open links in the same window.
1: Do open links in the same window.</string>
            <string id="bOverprintPreviewUseShiftClick_User">Overprint Shift+Click</string>
            <string id="bOverprintPreviewUseShiftClick_User_Explain">Specifies whether to use Shift + Click for multiple selection or for adding sticky notes containing color value when output preview dialog is open.

Possible values include:
0: Use Shift + Click for adding a sticky note containing the color values.
1: To select multiple objects, use Shift + Click. To add a sticky note containing the color values, use Alt + Click (Windows) or Option + Click (Mac).</string>
            <string id="bAccessOverrideDocColors_User">Override Document Colors</string>
            <string id="bAccessOverrideDocColors_User_Explain">Specifies whether to replace black test or line art colors when iAccessColorPolicy is enabled and a replacement color has been specified.

While the default is 1, the preference is not read unless iAccessPolicy is enabled (1).

Possible values include:
0: Don't replace black text or line art colors.
1: Replace black text or line art colors.</string>
            <string id="bOverrideLineArtColors_User">Override Line Art Colors</string>
            <string id="bOverrideLineArtColors_User_Explain">Limits color changes to black text and line art when iAccessColorPolicy is enabled and a replacement color has been specified.

While the default is 1, the preference is not read unless &quot;Accessibility&quot; enabled (1).

Possible values include:
0: Don't replace text or line art colors.
1: Replace text or line art colors. See also bAccessOverrideDocColors in Originals.</string>
            <string id="iPageLayout_User">Override Page Layout</string>
            <string id="iPageLayout_User_Explain">Specifies the user selected page layout override.

When bOverridePageLayout is set to 1, the override drop down list becomes enabled so that the user can set the desired page layout.

Possible values include:
1: Single Page
2: Single Page Continuous
3: Two Up Continuous
5: Two Up</string>
            <string id="bOverrideZoom_User">Override Zoom</string>
            <string id="bOverrideZoom_User_Explain">Enables the zoom setting drop down list so that the user can specify a default zoom setting for all documents and overrides Page Display settings.

PDF authors can specify what zoom level a PDF will open at. When enabled (1), the zoom drop down list becomes active so that the user can specify a default zoom level for all documents and set iZoomScale.

Possible values include:
0: Use the documents default zoom setting.
1: Enable the zoom setting drop down list.</string>
            <string id="iZoomScale_User">Override Zoom Scale</string>
            <string id="iZoomScale_User_Explain">Specifies the value in % to zoom when iZoomType is set to a % value and overrides Page Display settings.

Possible values include a range beginning with Fit Page to Reflow . When selected, % values are stored in iZoomScale. To set a value, configure the UI and look at the registry/plist preference to see what has been written.

Possible values include:
199a: 10% 4000 25% 8000: 50% c000: 75% 10000: 100% etc.</string>
            <string id="iZoomType_User">Override Zoom Type</string>
            <string id="iZoomType_User_Explain">Specifies the zoom scale for all other documents other than a % scale and overrides Page Display settings.

% scales are stored in iZoomScale.

Possible values include:
1: Fit Page
2: Fit Width
3: Fit Hieght
4: Fit Visible
6: Reflow</string>
            <string id="iParagraphDirection_User">Paragraph Direction</string>
            <string id="iParagraphDirection_User_Explain">Specifies the paragraph direction.

Possible values include:
0: Right to Left
1: Left to Right</string>
            <string id="bPopupsOpenIffSelected_User">Popup When Selected</string>
            <string id="bPopupsOpenIffSelected_User_Explain">Specifies whether to open a popup when it is selected.</string>
            <string id="bUseDetailsNavigator_User">Portfolio File List</string>
            <string id="bUseDetailsNavigator_User_Explain">Specifies whether to show portfolio component files and file details in an accessible list.

This preference replaces bUsePlatformNavigator. Files mode provides a better reading experience for people with disabilities such as mobility impairments, blindness, and low vision.

Possible values include:
0: Don't show portfolio components in a list.
1: Do show portfolio components in a list.</string>
            <string id="bPrintAnnots_User">Print Annotations</string>
            <string id="bPrintAnnots_User_Explain">Specifies whether to print notes, popups, and other annotations.

Setting a similar preference from the Print panel sets a corresponding setting in HKU.

Possible values include:
0: Don't print annotations.
1: Do print annotations.</string>
            <string id="bprintCommentPopups_User">Print Comment Popups</string>
            <string id="bprintCommentPopups_User_Explain">Enables printing of comments and other annotations.

Notes and popups that are open will be printed when the rest of the document is printed.

Possible values include:
0: Don't print comments.
1: Do print comments.</string>
            <string id="bprintNotesOpaque_User">Print Popups Opaque</string>
            <string id="bprintNotesOpaque_User_Explain">Makes popups opaque regardless of other settings.

Prints the popups as opaque without honoring the popup opacity specified by the user in commenting preferences (popup-opacity).

Possible values include:
0: Don't make popups opaque.
1: Do make popups opaque.</string>
            <string id="bUserAskedToEnableAutoComplete_User">Prompt Auto-Complete</string>
            <string id="bUserAskedToEnableAutoComplete_User_Explain">Specifies whether the user is asked to enable auto complete at runtime.

This option is enabled for the Advanced option.

Possible values include:
0: Don't ask the user.
1: Do ask the user.</string>
            <string id="iShowOrder_User">Reading Order Display</string>
            <string id="iShowOrder_User_Explain">Specifies the type of grouping order to display in the touchup reading order panel.

Possible values include:
0: Order (numbered).
1: Structure type.
2: None.</string>
            <string id="bRecordNewEntries_User">Remember Form Entries</string>
            <string id="bRecordNewEntries_User_Explain">Specifies whether to remember form field entries for use with future auto-complete actions.

This option is enabled for both the Basic and Advanced options.

Possible values include:
0: Don't remember entries.
1: Do remember entries.</string>
            <string id="iRememberView_User">Restore Last View</string>
            <string id="iRememberView_User_Explain">Specifies whether to restore last view settings when reopening documents.

Possible values include:
1: Don't restore the last view settings.
2: Do restore the last view settings.</string>
            <string id="bRTLUI_User">Right-to-Left UI</string>
            <string id="bRTLUI_User_Explain">Specifies whether to enable right to left language options.

Possible values include:
0: Disable right to left language options.
1: Enable right to left language options.</string>
            <string id="bDigitsUI_User">RTL Digit Display</string>
            <string id="bDigitsUI_User_Explain">Specifies whether to display digits in a way that's consistent with right to left language display.

The value is automatically set when bRTLUI is set via the UI.

Possible values include:
0: Don't display digits in a way that's consistent with right to left language display.
1: Do display digits in a way that's consistent with right to left language display.</string>
            <string id="bPrintSaveToner_User">Save Toner/Ink</string>
            <string id="bPrintSaveToner_User_Explain">Specifies whether to optimize content so that the printer uses less ink.

When checked, this setting optimizes the content so that the printer uses less ink during printing. In some cases, toner savings may reach 15%. Print quality is usually not impaired in any discernable way.

Possible values include:
0: Don't optimize printing.
1: Optimize printing.</string>
            <string id="bSDIMode_User">SDI Mode</string>
            <string id="bSDIMode_User_Explain">Specifies whether to open documents in a new window or in tabs in the same window.

Possible values include:
0: Open documents in tabs in the same window .
1: Open documents in separate windows.</string>
            <string id="bsendFinalApprovalEmail_User">Send Approval Email</string>
            <string id="bsendFinalApprovalEmail_User_Explain">Specifies whether to send a notification email when the current approval is identified as the final one.

Only valid for an approval workflow.

Possible values include:
0: Don't send an email on final approval.
1: Do send an email on final approval.</string>
            <string id="bShowOptionsDialog_User">Show Check Options</string>
            <string id="bShowOptionsDialog_User_Explain">Toggles whether to display the options dialog when running a accessibility full check.

Possible values include:
0: Don't show options dialog.
1: Show options dialog.</string>
            <string id="bcommentPanelOnImport_User">Show Comments on Import</string>
            <string id="bcommentPanelOnImport_User_Explain">Specifies whether to open the comment list when comments are imported.

Possible values include:
0: Don't open the comment list when comments are imported.
1: Do open the comment list when comments are imported.</string>
            <string id="bShowAnnotConnector_User">Show Connector Lines</string>
            <string id="bShowAnnotConnector_User_Explain">Specifies whether to show lines connecting comment markups to their popups on mouse rollover.

Possible values include:
0: Hide lines connecting comments to popups.
1: Show lines connecting comments to popups.</string>
            <string id="bFocusRect_User">Show Focus Rectangle</string>
            <string id="bFocusRect_User_Explain">Specifies whether to surround a field with a rectangle when it has focus.

Possible values include:
0: Don't show a rectangle.
1: Do show a rectangle.</string>
            <string id="bShowKeyboardSelectionCursor_User">Show Keyboard Cursor</string>
            <string id="bShowKeyboardSelectionCursor_User_Explain">Specifies whether the keyboard selection cursor should always be active in the document.

Select this option if you use a screen magnifier.

Possible values include:
0: Don't show the cursor.
1: Always show the cursor.</string>
            <string id="bshowMarkupModifiers_User">Show Markup Indicators</string>
            <string id="bshowMarkupModifiers_User_Explain">Specifies whether to show markup tool-tips and text indicators.

Possible values include:
0: Don't show markup tool-tips and text indicators.
1: Show markup tool-tips and text indicators.</string>
            <string id="bStampsPaletteInvisible_User">Show Stamps Palette</string>
            <string id="bStampsPaletteInvisible_User_Explain">Specifies whether to show the stamps palette automatically when the commenting toolbar is displayed.

Possible values include:
0: Show the palette.
1: Don't show the palette.</string>
            <string id="bShowAnnotSequence_User">Show Tab Order</string>
            <string id="bShowAnnotSequence_User_Explain">Specifies whether to show tab order of fields for Acroforms and XFA forms.</string>
            <string id="bsideNotes_User">Side-Aligned Popups</string>
            <string id="bsideNotes_User_Explain">Creates new popups aligned to the edge of the document.

Controls popup positioning.

Possible values include:
0: Don't align popups at the document edge.
1: Align popups at the document edge.</string>
            <string id="bAntialiasImages_User">Smooth Images</string>
            <string id="bAntialiasImages_User_Explain">Specifies wither to use anti-aliasing (smoothing) for images.

Turning this preference off can improve scrolling performance in Citrix environments.

Possible values include:
0: Don't smooth images.
1: Smooth images.</string>
            <string id="bAntialiasGraphics_User">Smooth Line Art</string>
            <string id="bAntialiasGraphics_User_Explain">Specifies wither to use anti-aliasing (smoothing) for line art.

Turning this preference off can improve scrolling performance in Citrix environments.

Possible values include:
0: Don't smooth line art.
1: Smooth line art.</string>
            <string id="bAntialiasText_User">Smooth Text</string>
            <string id="bAntialiasText_User_Explain">Specifies whether to smooth (anti-alias) text.

This setting only applies when the Smooth Text field is set to Monitor or Laptop/LCD. Text smoothing essentially has two levels. First, the text is anti-aliased. Then, if benableDDR is set to 1, DDR technology is applied for devices which allow RGB bands to be painted in individual pixels to further smooth text.

Possible values include:
0: None.
1: For both monitor and laptop/LCD Screens.</string>
            <string id="bSmoothZooming_User">Smooth Zooming</string>
            <string id="bSmoothZooming_User_Explain">Specifies whether smooth zooming should be enabled.

Possible values include:
0: Disables smooth zooming
1: Enables smooth zooming</string>
            <string id="bSpellingUnderline_User">Spell Check Underline</string>
            <string id="bSpellingUnderline_User_Explain">Turns off and on spell checking as you type.

This key is also duplicated under cPICommonPrefs\cSpelling.</string>
            <string id="bStoreNumericEntries_User">Store Numeric Entries</string>
            <string id="bStoreNumericEntries_User_Explain">Specifies whether to store user entered numeric values.

This option is enabled for both the Basic and Advanced options.

Possible values include:
0: Don't store numeric entries.
1: Do store numeric entries.</string>
            <string id="bUseStructTabOrder_User">Structure Tab Order</string>
            <string id="bUseStructTabOrder_User_Explain">Specifies whether to use the PDF document structure for determining the tab order.

Possible values include:
0: Don't use document structure.
1: Use document structure.</string>
            <string id="bUseSystemSelectionColor_User">System Selection Color</string>
            <string id="bUseSystemSelectionColor_User_Explain">Specifies whether the default selection color (blue) is overridden with a color that the system specifies.

Possible values include:
0: Don't use the system selection color.
1: Use the system selection color.</string>
            <string id="iAccessTextColor_User">Text Color</string>
            <string id="iAccessTextColor_User_Explain">Specifies the default document text color (accessibility feature)

The key name is appended with (Blue|Green|Red|Space).

Possible values include:
null: not set Any RGB color: User specified.</string>
            <string id="bUseLocalFonts_User">Use Local Fonts</string>
            <string id="bUseLocalFonts_User_Explain">Specifies whether to use local fonts.

Possible values include:
0: Don't use local fonts.
1: Do use local fonts.</string>
            <string id="iEmailClientSelection_User">XFA Email Client</string>
            <string id="iEmailClientSelection_User_Explain">Specifies the email client to use when submitting an XFA form.

Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
            <string id="iRXOPolicy_User">XObjects View Mode</string>
            <string id="iRXOPolicy_User_Explain">Sets XObject access to either Never (0), Always (1), or Only PDF/X-5 Compliant Ones (2).

The user must also set cRXOLocation and (Windows only) specify a privileged location for each parent (referencing) document.

Possible values include:
0: Never
1: Always
2: Only PDF/X-5 Compliant Ones</string>

            <!-- ======================================== -->
            <!--         Microsoft Purview (MIP)          -->
            <!-- ======================================== -->

            <string id="bEnableLogging_User">MIP Logging</string>
            <string id="bEnableLogging_User_Explain">Specifies whether to enable debug logging for Microsoft Purview Information Protection operations.

Useful for troubleshooting MIP label and authentication issues.

Possible values include:
0: Disable MIP debug logging.
1: Enable MIP debug logging.</string>
            <string id="bEnablePolicyAuthentication_User">MIP Policy Authentication</string>
            <string id="bEnablePolicyAuthentication_User_Explain">Specifies whether MIP policy authentication is enabled for the current user.

Used alongside bShowDMB. Setting both bShowDMB and bEnablePolicyAuthentication to 0 hides the applied label from the current file.

Possible values include:
0: Disable MIP policy authentication.
1: Enable MIP policy authentication.</string>
            <string id="bShowDMB_User">Show Document Message Bar (MIP)</string>
            <string id="bShowDMB_User_Explain">Specifies whether to show Microsoft Purview Information Protection label information in the document message bar.

Per-user preference under MicrosoftAIP.

Possible values include:
0: Do not show MIP label info in the document message bar.
1: Show MIP label info in the document message bar.</string>

            <!-- ======================================== -->
            <!--    Security: Execution and Protection    -->
            <!-- ======================================== -->

            <string id="b3DEnableContent_User">3D Content Trust</string>
            <string id="b3DEnableContent_User_Explain">Specifies whether to trust and render 3D content.

This setting can be overridden by bEnable3D .

Possible values include:
0: Don't trust and render 3D content. Show the Yellow Message Bar so the end user can trust the document.
1: Trust and render 3D files.</string>
            <string id="bCrossDomainLogging_User">Cross-Domain Logging</string>
            <string id="bCrossDomainLogging_User_Explain">Enables cross domain logging for communication with a server that uses a cross domain policy file to manage the flow of data that does not conform to a same-origin policy.

Create a logging file by navigating to the user account Application Directory. For example, on XP go to C:\Documents and Settings\(user name)\Application Data\Adobe\(application)\(version)\. Created an empty file called AcrobatCrossDomain.log.</string>
            <string id="bEnableDebugger_User">Enable JS Debugger</string>
            <string id="bEnableDebugger_User_Explain">Enables the debugger.

Requires an application restart.</string>
            <string id="bFIPSMode_User">FIPS Mode</string>
            <string id="bFIPSMode_User_Explain">Controls whether FIPS 140-2 compliant encryption is required.

When FIPS mode is enabled, Acrobat restricts cryptographic operations to FIPS-approved algorithms. This disables certain PDF security features and workflows that rely on non-FIPS algorithms, including some older PDF encryption schemes.

Possible values include:
0: Disable FIPS mode.
1: Enable FIPS mode.</string>
            <string id="bEnableGlobalSecurity_User">JS Global Security</string>
            <string id="bEnableGlobalSecurity_User_Explain">Controls whether or not a script in one sandbox can access a script object in another sandbox.

By default, scripts can not access objects outside the current document sandbox. With 9.x and later, such communication only works in the standalone application since both the Acrobat and Reader browser-based viewer opens each window in a discrete browser instance.</string>
            <string id="bEnableMenuItems_User">JS Menu Items</string>
            <string id="bEnableMenuItems_User_Explain">Toggles off and on JavaScript's ability to execute menu items.</string>
            <string id="bEnableAlwaysOutlookAttachmentProtectedView_User">Outlook Protected View</string>
            <string id="bEnableAlwaysOutlookAttachmentProtectedView_User_Explain">Specifies whether Protected View is turned off for Outlook attachments.

Note that earlier versions (e.g. Office 2003 and 2007) do not append origin information to files they download to its temp directory. As a result, there is no way of knowing if the file came from trusted source. Such files do not automatically open in PV.

Possible values include:
0: Enable Protected View for Outlook attachments.
1: Disable Protected View for Outlook attachments.</string>
            <string id="bOldRecentFilesMigrated_User">Recent Files Migrated</string>
            <string id="bOldRecentFilesMigrated_User_Explain">Indicates whether the recent files list has been migrated.

Admins should not change the preference value.</string>

            <!-- ======================================== -->
            <!--     Security: Trust and Permissions      -->
            <!-- ======================================== -->

            <string id="bUseExpiredTimestamps_User">Accept Expired Timestamps</string>
            <string id="bUseExpiredTimestamps_User_Explain">Specifies whether expired timestamps should be used.

If true, an expired timestamp will not invalidate a signature.</string>
            <string id="bAllowConnectViaHTTP_User">Allow LiveCycle HTTP</string>
            <string id="bAllowConnectViaHTTP_User_Explain">If true, the server connection URI uses the format http://server:port/path; otherwise, it uses the format https://server:port/path.

In either case, if the connection fails, an error message appears. For more information, see Guidelines for Developing CSPs for Acrobat on Windows .</string>
            <string id="bAllowCertNonGreen_User">Allow Non-Green Cert</string>
            <string id="bAllowCertNonGreen_User_Explain">Specifies whether a certification signature may be applied to a document containing Legal PDF warnings.

If false, then its not allowed and the author is informed of the reason.</string>
            <string id="bAllowOCSPNoCheck_User">Allow OCSP NoCheck</string>
            <string id="bAllowOCSPNoCheck_User_Explain">Specifies whether the OCSPNoCheck extension is allowed in the response signing certificate.</string>
            <string id="bAlwaysConsult_User">Always Consult CDP</string>
            <string id="bAlwaysConsult_User_Explain">Determines when the URL is used for an additional URL CRL distribution point.

If false, the URL is only used when the certificate does not have a CRLDp extension.</string>
            <string id="iAuthMechanisms_User">Auth Mechanisms</string>
            <string id="iAuthMechanisms_User_Explain">Specifies which registered provider(s) to use.

0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
            <string id="iAutoAcceptEDCPrivacyNotification_User">Auto-Accept Privacy</string>
            <string id="iAutoAcceptEDCPrivacyNotification_User_Explain">Specifies whether to show an alert confirming acceptance of the privacy policy.

Possible values include:
0: Don't show an alert.
1: Do show an alert.</string>
            <string id="iAutoAddLTV_User">Auto-Add LTV Info</string>
            <string id="iAutoAddLTV_User_Explain">Specifies whether LTV information should be automatically added to all signatures.

Possible values include:
0: Never add LTV information.
1: (default) Ask whether LTV information should be added if it is too big.
2: Always add LTV information. When the cumulative size of the LTV data is greater than the sum of 10% of the PDF file size plus 10KB and Automatically add verification information on Save is set to &quot;Ask...&quot; a dialog appears asking the user if they would like to continue embedding the LTV information. Note that in workflows where the dialog appears asking whether to enable LTV, if the user selects the &quot;Do not show this message again&quot; checkbox, AND click the No button, then this preference is set to zero.</string>
            <string id="bSavePassword_User">Cache Server Password</string>
            <string id="bSavePassword_User_Explain">Indicates whether the password has been cached for this server.</string>
            <string id="iSHS_User">Console H-Splitter</string>
            <string id="iSHS_User_Explain">Indicates (in pixels) the position of the horizontal window splitter.</string>
            <string id="iSVS_User">Console V-Splitter</string>
            <string id="iSVS_User_Explain">Indicates (in pixels) the position of the vertical window splitter.</string>
            <string id="iMaxRevokeInfoCacheLifetime_User">CRL Cache Lifetime</string>
            <string id="iMaxRevokeInfoCacheLifetime_User_Explain">Maximum lifetime in hours the cached CRL is used for revocation checking.

iMaxRevokeInfoCacheLifetime is only used if the validation method is set to &quot;current time&quot;.

Possible values include:
The number of hours for which the cached CRL is valid.</string>
            <string id="bCustomPrefsCreated_User">Custom Cert Prefs</string>
            <string id="bCustomPrefsCreated_User_Explain">Indicates whether a custom certificate specific preference (e.g. Identrus) has already been created and written to the registry.

If true, it doesn't get created again. Deleting or setting this key to 0 forces Acrobat to recreate custom certificate preferences after which it will reset this key to 1.</string>
            <string id="iDirectoryProvider_User">Directory Provider</string>
            <string id="iDirectoryProvider_User_Explain">Specifies a directory provider for signature validation.

0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
            <string id="bEnforceSecureChannel_User">Enforce Digest Compare</string>
            <string id="bEnforceSecureChannel_User_Explain">Specifies whether to prevent signing when the original message digest and the signed message digest do not match.

When set to 1, the user sees a warning dialog when the digest mismatch occurs. This error can be caused by a modification of the original message digest, a modification of the signed message digest, or a mismatch between the private and public key used for signing. When using a certificate that doesn't include a public key (such as a DSA certificate with an omitted public key), the test to detect signature validity is not performed. Do not turn this setting on if such certificates are used.</string>
            <string id="bAutoLaunchAtDocClose_User">Examine on Close</string>
            <string id="bAutoLaunchAtDocClose_User_Explain">Automatically examines the document for hidden content when it is closed.</string>
            <string id="bAutoLaunchAtSendMail_User">Examine on Send</string>
            <string id="bAutoLaunchAtSendMail_User_Explain">Automatically examines the document for hidden content when it is sent in an email.</string>
            <string id="bExpiredCertGoOnline_User">Expired Cert Go Online</string>
            <string id="bExpiredCertGoOnline_User_Explain">Specifies whether to go online to get the revocation information for an expired certificate.

11.0.16 introduced a signature validation change so that signatures are invalid if they are based on expired certificates and there is no embedded revocation information even if bIgnoreValidityDates is 1. For previous product versions, the signature would be valid. Now, to be standard's compliant, if a certificate has expired, the client should not check for the revocation information online. bExpiredCertGoOnline set to 1 re-enables the pre-11.0.16 behavior. 0: Do not go online for revocation even if bIgnoreValidityDates = 1 1: Do go online.</string>
            <string id="bFDFRequestExcludeCert_User">FDF Exclude Cert</string>
            <string id="bFDFRequestExcludeCert_User_Explain">Similar to the bFDFRequestSave.

False includes the user's certificate in all certificate requests. True excludes it.</string>
            <string id="bFDFExportSave_User">FDF Export Save</string>
            <string id="bFDFExportSave_User_Explain">Persists whether user chose to save (1) or email (0) the FDF during export.</string>
            <string id="bFDFExportSign_User">FDF Export Sign</string>
            <string id="bFDFExportSign_User_Explain">Persists whether the user chose to sign the FDF during export.</string>
            <string id="bFDFRequestSave_User">FDF Request Save</string>
            <string id="bFDFRequestSave_User_Explain">Caches a user's answer to the question whether they want to save the request as an FDF or email it directly when that user requests a certificate.</string>
            <string id="bFollowURIsFromAIA_User">Follow AIA URIs</string>
            <string id="bFollowURIsFromAIA_User_Explain">Specifies whether to allow the chain builder to follow URIs in AIA certificate extensions so that certificates can be downloaded if they are not available locally.

The default does not allow phone-home capability. CRLdps and OCSP AIA extensions do allow following URIs because they require that the certificate chain up to a trust anchor.</string>
            <string id="bSigAPStatusIconDisable_User">Hide Sig Status Icon</string>
            <string id="bSigAPStatusIconDisable_User_Explain">Controls whether the signature status icon is displayed in the signature appearance on the document.

If true, status icon is not displayed regardless of signature status. This setting overrides iDisplayValidIcon and bShowWarningForChanges.</string>
            <string id="cDialogs_xSelHandler_User">ID Dialog Position</string>
            <string id="cDialogs_xSelHandler_User_Explain">The last on-screen coordinates of a handler's digital ID selection dialog

It is a subkey containing 4 keys: Top, Bottom, Left, and Right. This preference could be used by 3rd party handlers or by someone invoking a non-signing digital ID selection dialog via JavaScript.</string>
            <string id="bIgnoreNextUpdate_User">Ignore OCSP NextUpdate</string>
            <string id="bIgnoreNextUpdate_User_Explain">Specifies whether to use embedded OCSP responses when nextUpdate is not present and the validation time is less than the greater of thisUpdate or producedAt time plus the value of iMaxClockSkew .

For 10.1 and later, this preference is used along with iMaxClockSkew to determine whether or not embedded OCSP responses are actually used for signature validation. For details, see the subfeature description above. This behavior is designed to support Acrobat's long term validation feature and allows validating a signature with embedded responses that were valid at signing time.

Possible values include:
0: iMaxClockSkew is applied to thisUpdate on both sides of the validation time, i.e. thisUpdate - iMaxClockSkew ( validation time ( checkTime + iMaxClockSkew where checkTime is the later of the producedAt and thisUpdate. When true, iMaxClockSkew is applied to thisUpdate only before the validation time: thisUpdate - iMaxClockSkew ( validation time.
1: If there is no nextUpdate, then we accept the OCSP response indefinitely (we do not check for if the validation time is too late) and don't check whether validation time is ( than checkTime)</string>
            <string id="iImportAddressBook_User">Import Address Book</string>
            <string id="iImportAddressBook_User_Explain">Specifies whether the addressbook.acrodata file should be imported during a new install.

Many admins set a value of 2 so that the import dialog does not appear for end users.

Possible values include:
0: Do not copy the old address book. The user is NOT prompted and the address book should NOT be installed.
1 or null: Default: The user is asked whether the address book should either be installed or not.
2: Import the address book silently.</string>
            <string id="bCertStoreImportEnable_User">Import Windows Certs</string>
            <string id="bCertStoreImportEnable_User_Explain">If true, then users can import from MSCAPI certificate stores into their Trusted Identity Manager.</string>
            <string id="iAPIndex_User">Last Sig Appearance</string>
            <string id="iAPIndex_User_Explain">Remembers the last used signature appearance index.</string>
            <string id="bIsEnabled_User">Long Term Validation</string>
            <string id="bIsEnabled_User_Explain">Specifies whether the signature revocation status is included in the signature.

Possible values include:
0: Don't enable LTV and include the signature revocation status information in the signature.
1: Enable LTV.</string>
            <string id="iMaxRevInfoArchiveSize_User">Max Rev Info Archive</string>
            <string id="iMaxRevInfoArchiveSize_User_Explain">The maximum size of the revocation archival information in kilobytes.

An attempt is made to store as much revocation information as possible without exceeding the limit. Note that older product versions may have a smaller supported size limit.</string>
            <string id="iMaxVerifySession_User">Max Verify Sessions</string>
            <string id="iMaxVerifySession_User_Explain">Specifies the maximum number of nested verification sessions allowed.

This is used to prevent the application from going into infinite loop verifying the OCSP and/or CRL signer certificates caused by incorrect OCSP and/or CRL certificate setup.</string>
            <string id="iCreateNewSigFieldAVAlert_User">New Sig Field Alert</string>
            <string id="iCreateNewSigFieldAVAlert_User_Explain">Specifies whether to show the alert asking whether a new signature field should be created.

Possible values include:
0: Don't show an alert.
1: Do show an alert.</string>
            <string id="bEnNonEmbFontLegPDFWarn_User">Non-Embedded Font Warn</string>
            <string id="bEnNonEmbFontLegPDFWarn_User_Explain">Turns on and off warnings about non-embedded fonts.

A warning appears when the LegalPDF dictionary NonEmbeddedFonts attribute has a non zero value. Turning this value on causes a warning to appear in the PDF Signature Report which indicates the document contains unembedded fonts.</string>
            <string id="iSendNonce_User">OCSP Nonce Behavior</string>
            <string id="iSendNonce_User_Explain">Specifies signature validation behavior with respect to nonces.

With 10.0, this preference replaces bSendNonce.

Possible values include:
0: No nonces are sent.
1: Nonces are included in the OCSP request and expected to be present in the response and should match the request's nonce.
2: Nonces are included in the OCSP request, but if none are present in the response, their abscence is ignored.</string>
            <string id="iURLToConsult_User">OCSP Responder URL</string>
            <string id="iURLToConsult_User_Explain">Specifies how the revocation checker chooses which responder to use.

Possible values include:
0: Use the AIA extension in the certificate.
1: Use the URL key in sURL.
2: Use the AIA extension in the certificate. If it is not present, use the URL key in sURL.
3: Use the OCSP request signer's certificate AIA extension. Relevant only if SignRequest is 0.</string>
            <string id="iResponseFreshness_User">OCSP Response Freshness</string>
            <string id="iResponseFreshness_User_Explain">Specifies the amount of time in minutes after the response's published thisUpdate time for which the response will be valid.

After that time, the response will be invalid.</string>
            <string id="bAllowOpenFile_User">Open Non-PDF Attachments</string>
            <string id="bAllowOpenFile_User_Explain">Specifies whether to open non-PDF attachments in their native application.

bAllowOpenFile, bSecureOpenFile, and tBuiltInPermsList work in tandem: If any of these are set to prevent the opening of an attachment, then the attachment type won't open (or all attachments depending on the setting).

Possible values include:
0: Prevent attachments from opening in their native application.
1: Allow attachments to open in their native application.</string>
            <string id="bPreviewModeBeforeSigning_User">Preview Before Signing</string>
            <string id="bPreviewModeBeforeSigning_User_Explain">Specifies whether a signer is forced to use preview mode during signing.

If true, preview mode is automatically invoked on a sign action. Users should read the document message bar text, view a report about any warnings, and then choose Sign Document.</string>
            <string id="bRequireAKI_User">Require AKI in CRL</string>
            <string id="bRequireAKI_User_Explain">Specifies whether the Authority Key Identifier extension must be present in a CRL.</string>
            <string id="bRequireOCSPCertHash_User">Require OCSP Cert Hash</string>
            <string id="bRequireOCSPCertHash_User_Explain">Specifies whether a certificate public key hash extension must be present in OCSP responses.</string>
            <string id="iRequireReviewWarnings_User">Require Sign Warnings</string>
            <string id="iRequireReviewWarnings_User_Explain">Specifies whether the user is required to review document warnings before signing via the signing dialog.

Interacts with iShowDocumentWarnings. The possible values include: 0: Never 1: Show when certifying only 2: Always</string>
            <string id="bReqSigPropRetrieval_User">Require Timestamp</string>
            <string id="bReqSigPropRetrieval_User_Explain">Indicates whether retrieving a signature property must succeed.

Acrobat currently provides a signature property for timestamps. By default, retrieving a valid and trusted timestamp is not required, and property retrieval failure only results in creating a signature which uses the local time. When property retrieval is required during signature creation and fetching a timestamp fails for any reason (bad URL, no network connection, etc.) the signature creation process is aborted, no signature is created, and an error appears. 0: Make best effort, but success is not required. A signature is created. 1: Property retrieval must succeed. On failure, a signature is not created and an error dialog appears.</string>
            <string id="bRequireValidSigForChaining_User">Require Valid Sig Chain</string>
            <string id="bRequireValidSigForChaining_User_Explain">Specifies whether to allow the chain builder to build chains with invalid RSA signatures on certificates.

Consider chain CA ) ICA ) EE where the CA's signature on an ICA is invalid. If this setting is true, the chain building will stop at the ICA and the CA will not be included in the chain. If this preference is false, the full 3-certificate chain is produced. This setting does not affect DSA signatures.</string>
            <string id="bReturnRevInfoToUser_User">Return Rev Info to JS</string>
            <string id="bReturnRevInfoToUser_User_Explain">If true, the revocation information is maintained within the SignatureInfo object and can be retrieved through JavaScript.

For more information, see the Acrobat JavaScript Reference .</string>
            <string id="iRevocationChecker_User">Revocation Checker</string>
            <string id="iRevocationChecker_User_Explain">Specifies a provider for revocation checking.

0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
            <string id="bRevCheckTrust_User">Revoke Check Trust</string>
            <string id="bRevCheckTrust_User_Explain">Specifies whether to perform revocation checks on intermediate trust anchors (those which aren't roots).

In previous versions, the application did not perform revocation checks on any intermediate trust anchors since it was assumed they were self-signed. With 10.1.2 and 9.5, this setting enables revocation checking on intermediate trust anchors if such information is available. Trust anchors from 3rd parties are often installed locally to facilitate signature validation. Since it is possible that the trust anchors could become compromised and thereby open the host machine to malicious attack, those 3rd party providers in such cases would revoke their certificates. This preference enables detecting that revocation by forcing a revocation check on any intermediate trust anchors. Root and self-signed certificates are exempt from checking.

Possible values include:
0: Don't perform a revocation check on intermediate trust anchors.
1: Perform a revocation check on intermediate trust anchors.</string>
            <string id="iRSAPSSSaltLength_User">RSA-PSS Salt Length</string>
            <string id="iRSAPSSSaltLength_User_Explain">Specifies the Salt Length the RSA-PSS algorithm uses.

When setting the salt length, you must assure the default base is hexadecimal. Either change the base to decimal or input its hex value. For example, if the salt length decimal value is 32, then set the hex value to 20.</string>
            <string id="bEnableRSAPSSSigning_User">RSA-PSS Signing</string>
            <string id="bEnableRSAPSSSigning_User_Explain">Specifies whether a signature should be created with the RSA-PSS algorithm.

Possible values include:
0: Do not sign with the RSA-PSS algorithm.
1: Use the RSA-PSS algorithm.</string>
            <string id="iDigSigSaveAsCertified_User">Save Certified Alert</string>
            <string id="iDigSigSaveAsCertified_User_Explain">

Possible values include:
0: Don't show an alert.
1: Do show an alert.</string>
            <string id="bSecureOpenFile_User">Secure Open Attachments</string>
            <string id="bSecureOpenFile_User_Explain">Specifies whether to allow opening attachments which are not PDF.

When this pref is set to true, then Acrobat only allows opening PDF attachments. bAllowOpenFile, bSecureOpenFile, and tBuiltInPermsList work in tandem: If any of these are set to prevent the opening of an attachment, then the attachment type won't open (or all attachments depending on the setting).

Possible values include:
0: Allow opening attachments with filetype other than PDF.
1: Don't open non-PDF attachments.</string>
            <string id="bSelfSignCertGen_User">Self-Sign ID Create</string>
            <string id="bSelfSignCertGen_User_Explain">Specifies whether or not the Create a self-signed ID option in Add ID workflows is available.

Prevents users from creating a self-signed digital ID. Note that for products released after June 2016, disabling a user's ability to create a self-signed digital ID requires setting both bSelfSignCertGen and bEnableCEFBasedUI to 0.

Possible values include:
0: Don't allow creating self-signed digital IDs.
1: Allow self-signed digital IDs.</string>
            <string id="bShowAllChains_User">Show All Chains</string>
            <string id="bShowAllChains_User_Explain">Specifies whether to show all chains in the Certificate Viewer.

If true, the Certificate Viewer shows all the chains; otherwise, it shows only the trusted chain. If there are no trusted chains, then all the chains are shown and this preference is ignored.</string>
            <string id="iShowDocumentWarnings_User">Show Document Warnings</string>
            <string id="iShowDocumentWarnings_User_Explain">Specifies whether a button to allow reviewing document warnings shows up on the signing dialog.

Interacts with iRequireDocumentWarnings. The possible values include: 0: Never 1: Show when certifying only 2: Always</string>
            <string id="bShowWarningForChanges_User">Show Post-Sign Warning</string>
            <string id="bShowWarningForChanges_User_Explain">Determines whether or not to show a blue i on validated signature(s) if the document changes after it was signed.

If true, a document change results in a blue i status icon appearing for validated approval signatures. Use this setting when users need to know a document has changed after it was signed. If false, the status icon remains a green check and pen even if a document changes after it is signed. The setting provides a method for administrators to turn off the blue i in workflows where documents can be changed or signed multiple times. This setting does not affect certification signatures. The warning icon never appears for valid certification or approval signatures in certified documents if the signatures were allowed by the certifier. Interacts with iDisplayValidIcon which cannot be set to 2, or the icons will not appear regardless of how bShowWarningForChanges is set.</string>
            <string id="bAllowOtherInfoWhenSigning_User">Show Sign Contact Info</string>
            <string id="bAllowOtherInfoWhenSigning_User_Explain">Specifies whether the location and contact information UI will appear during signing.</string>
            <string id="bShowSignerWarnings_User">Show Signer Warnings</string>
            <string id="bShowSignerWarnings_User_Explain">Specifies whether to show a warning that there is a greater forgery risk when revocation information is embedded in the signature.

Because this warning was removed from 10.x products, this preference is only applicable to 9.4.6 and later products in the 9.x line.

Possible values include:
0: Don't show the warnings.
1: Do show the warnings.</string>
            <string id="iDisplayValidIcon_User">Show Valid Sig Icon</string>
            <string id="iDisplayValidIcon_User_Explain">Determines when the signature status icon is displayed in a signature appearance.

Possible values include:
0: Always.
1: Display except when the signature is valid.
2: Never. This value disables bShowWarningForChanges and removes the Hide signature field validity icon option from the GUI. This setting does not affect the icons in the Signatures Pane or in the Signature Properties dialog Note : This UI item was removed from versions 9.x and later because signature status was moved to the Document Message Bar.</string>
            <string id="bReqSigPropVerification_User">Sig Property Verify</string>
            <string id="bReqSigPropVerification_User_Explain">Specifies whether signature property verification must succeed for a signature to be valid.

As of 8.0, the only property used is the timestamp URL.</string>
            <string id="iSigVerificationTime_User">Sig Verification Time</string>
            <string id="iSigVerificationTime_User_Explain">Indicates the time at which signature validation should occur.

Possible values include:
0: Always carry out the verification at current time
1: Use the signing time if it's secure (e.g. timestamped), else use current time
2: Always use signing time</string>
            <string id="bAllowSigCertOnly_User">Sign Certified Only</string>
            <string id="bAllowSigCertOnly_User_Explain">Specifies whether any subsequent signers can sign a certified document containing LegalPDF warnings with additional approval signatures.

In other words, the presence of any LegalPDF warning prevent any additonal signatures.</string>
            <string id="isignDone_User">Sign Done Dialog</string>
            <string id="isignDone_User_Explain">Specifies whether to show a dialog indicating that a document was successfully signed.

Possible values include:
0: Show the dialog after signing successfully.
1: Don't show the dialog after signing successfully.</string>
            <string id="bAllowSigCertGreenOnly_User">Sign Green Cert Only</string>
            <string id="bAllowSigCertGreenOnly_User_Explain">Specifies whether any subsequent signers can sign a certified document that does not contain LegalPDF warnings with additional approval signatures.

In other words, the presence of any LegalPDF warning does not prevent any additonal signatures.</string>
            <string id="bSignRequest_User">Sign OCSP Requests</string>
            <string id="bSignRequest_User_Explain">Specifies whether the OCSP request should be signed.

Some OCSP providers require that OCSP requests are signed (e.g IdenTrust). 0: Don't sign the OCSP request. 1: Force Acrobat to sign OCSP requests prior to sending.</string>
            <string id="iHashAlgo_User">Timestamp Hash Algo</string>
            <string id="iHashAlgo_User_Explain">Identifies the hashing algorithm used to hash the timestamped data.

The valid values are: 0: MD5 1: SHA1 2: SHA256 For an alternative, see sHashAlgo which supports more options.</string>
            <string id="iSize_User">Timestamp Sig Size</string>
            <string id="iSize_User_Explain">ASPKI requires the signature property to predict the size (in bytes) so that enough space can be set aside.</string>
            <string id="bTrueTypeFontPDFSigQWarn_User">TrueType Font Warn</string>
            <string id="bTrueTypeFontPDFSigQWarn_User_Explain">Turns on and off warnings about True Type fonts.</string>
            <string id="bTrustCertifiedDocuments_User">Trust Certified Docs</string>
            <string id="bTrustCertifiedDocuments_User_Explain">Elevates (trusts) certified documents as a privileged location.

This setting allows certified documents to bypass all the security restrictions that may be bypassed by other privileged locations. The exception is that this level of trust does not apply when the PDF is viewed in Protected View. To lock this setting, set bEnableCertificateBasedTrust .

Possible values include:
0 or null: Don't make certified documents equivalent to privileged locations.
1: Do make certified documents equivalent to privileged locations (trusted).</string>
            <string id="bTrustOSTrustedSites_User">Trust IE Trusted Sites</string>
            <string id="bTrustOSTrustedSites_User_Explain">Elevates locations that Internet Explorer trusts to privileged locations so that they may bypass security restrictions.

Prior to 10.1.1 and 9.4.7, trust was granted to Trusted Sites. With 10.1.2 and 9.5 and later, trust also includes Local Intranet zones. This setting essentially makes IE trust operate as if they were privileged locations. The feature can be disabled with bDisableOSTrustedSites. 0: Don't automatically trust Windows OS zones. 1: Do automatically trust Windows OS zones.</string>
            <string id="iURLPerms_User">URL Access Permissions</string>
            <string id="iURLPerms_User_Explain">Specifies whether to allow or block all websites or use a custom setting.

If the user selects Custom Setting, tHostPerms is populated with the user's custom URLs. If Allow or Block is later selected, then iURLPerms overrides tHostPerms and tHostPerms is reset to null (the user list is ignored).

Possible values include:
0: Custom Setting
1: Block all websites
2: Allow all websites</string>
            <string id="tHostPerms_User">Trusted/Blocked URL List</string>
            <string id="tHostPerms_User_Explain">Stores the list of trusted and blocked URLs used when URL Access Permissions (iURLPerms) is set to Custom Setting.

This is a free-text companion to iURLPerms. It only has effect when iURLPerms is 0 (Custom Setting); selecting Allow or Block instead overrides this list and resets it to null. Not lockable via HKLM -- this preference only exists at User scope.

Format follows Adobe's TrustManager host permission list syntax.</string>
            <string id="iUseArchivedRevInfo_User">Use Archived Rev Info</string>
            <string id="iUseArchivedRevInfo_User_Explain">Indicates whether the revocation information archived with the signature is used for revocation checking.

Allowable values include: 0: Never (always require fresh revocation information to be successfully downloaded). 1: Deprecated. Do not use. 2: Always use (if embedded revocation information is available do not download fresh revocation information).</string>
            <string id="iValidityModel_User">Validity Model</string>
            <string id="iValidityModel_User_Explain">Specifies the validity model for validating signatures and certificates.

The application uses shell validation by default, but chain validation may be used when required. Compliance with the German signature law requires chain validation. Allowabled values include: 0: PKIX shell model 1: Chain validity model. Chain validation is used to validate all or part of a certificate chain when any certificate chaining up to a CA certificate containing the qualified certificate policy extension (OID 1.3.36.8.1.1) or the validity model certificate extension OID (1.3.6.1.4.1.8301.3.5) with the value set to the chain model OID (1.3.6.1.4.1.8301.3.5.1).</string>
            <string id="iMSStoreTrusted_User">Windows Store Trust</string>
            <string id="iMSStoreTrusted_User_Explain">Controls whether or not certificates in the Windows Certificate Store are trusted for signing and certifying.

To lock this setting, use bMSStoreTrusted. Allowable values include: 0x00: No checkbox selected. 0x60: Validating Signatures. 0x62: Validating Certified Documents and Signatures. Note that this setting disables the Validating Signatures checkbox because it also controls non-certified signatures and users should not be able to uncheck that checkbox.</string>

            <string id="bLoadSettingsFromURLAdobe_User">Load Security Settings from Server (Adobe Certificates)</string>
            <string id="bLoadSettingsFromURLAdobe_User_Explain">Controls whether trust anchors are periodically downloaded from Adobe's certificate server.

When enabled, Acrobat Reader contacts Adobe's server to download updated root certificates and trust anchors used for signature validation. Disabling this prevents the application from making outbound connections to Adobe's certificate infrastructure, which is required in air-gapped or restricted network environments.

Possible values include:
0: Do not load security settings from Adobe's certificate server.
1: Periodically download security settings from Adobe's certificate server.</string>
            <string id="bLoadSettingsFromURLEUTL_User">Load Security Settings from Server (European Certificates)</string>
            <string id="bLoadSettingsFromURLEUTL_User_Explain">Controls whether trust anchors are periodically downloaded from the European Union Trusted Lists (EUTL) server.

When enabled, Acrobat Reader contacts the EUTL server to download updated European root certificates used for signature validation of EU-issued qualified electronic signatures. Disabling this prevents outbound connections to EUTL infrastructure.

Possible values include:
0: Do not load security settings from the EUTL server.
1: Periodically download security settings from the EUTL server.</string>

            <!-- ======================================== -->
            <!--           Sharing and Features           -->
            <!-- ======================================== -->

            <string id="iSendMailDefaultAccountAlert_User">Default Email Prompt</string>
            <string id="iSendMailDefaultAccountAlert_User_Explain">Specifies whether a dialog should appear asking if a PDF should be sent via the user's default email account.

When a new user tries to send a PDF via email, a dialog appears and asks &quot;How would you like to send this email.&quot; Users then need to select a choice and check Remember my choice .

Possible values include:
0: Don't show the dialog.
1: Do show the dialog.</string>
            <string id="bDefaultSet_User">Default Email Set</string>
            <string id="bDefaultSet_User_Explain">Indicates whether a default email client has been set.

Possible values include:
0: Default webmail client is not set.
1: Default webmail client is set.</string>
            <string id="bDisableSharedReview_User">Disable Shared Review</string>
            <string id="bDisableSharedReview_User_Explain">Specifies whether to enable cloud-based shared reviews.

To completely disable the Document Cloud Review service, disable all services or set bToggleAdobeReview (See FeatureLockDown for details). When set to 0, this preference removes Document Cloud Review service, including the Send for Review tool in the tool's pane and its associated menus.

Possible values include:
0: Remove the option to use the DC review service when a user chooses Tools ) Send for Review OR Send for Review in the right-hand pane. Only legacy review types are available.
1: Enable the Document Cloud Review service option.</string>
            <string id="bNeedSynchronizer_User">Enable Synchronizer</string>
            <string id="bNeedSynchronizer_User_Explain">Disables the synchronizer.

Features that use the synchronizer include services, the Adobe Acrobat Trust List, shared reviews, the recent files list (11.0.07+), and data collection in some forms workflows prior to 11.0.07. Disabling the Synchronizer is not recommended.

Possible values include:
0: Disable the synchronizer.
1: Enable the synchronizer. Note that Acrobat and Reader do not use the same synchronizer. When there is an older minor version of Acrobat or Reader and the newer minor version is 11.0.07-11.1.10: Both Acrobat and Reader get the new synchronizer when updating to .07 or later. If the newer synchronizer is running, it supports older services and non-services operations. If the older synchronizer (pre 11.0.07) is running, sync-dependent operations do not work [3746864]</string>
            <string id="bEnableFillSign_User">Fill &amp; Sign Pane</string>
            <string id="bEnableFillSign_User_Explain">Specifies whether to remove the Fill and Sign pane without removing the Work with Certificates menu.

11.x products only. This setting allows users to remove the Acrobat Sign menu items without removing the menu item for using digital signatures on the local machine.

Possible values include:
0: Remove the Fill and Sign pane.
1: Don't remove the Fill and Sign pane.</string>
            <string id="bRemoveCommaDelimiter_User">Remove Comma Delimiter</string>
            <string id="bRemoveCommaDelimiter_User_Explain">Specifies whether to remove the comma in comma-delimited addressbook entries.

During shared review workflows, the user invoke the addressbook to invite participants. In cases where the addressbook is comma-delimited, pre DC versions of the product display an error dialog. Use this prefererence to remove commas.

Possible values include:
0: Don't remove commas.
1: Remove commas.</string>
            <string id="iSendForReviewConfirm_User">Review Confirm Alert</string>
            <string id="iSendForReviewConfirm_User_Explain"></string>
            <string id="bShowConnectDialog_User">Show Connect Dialog</string>
            <string id="bShowConnectDialog_User_Explain">Specifies whether to display the Connect dialog in Shared Reviews.

Possible values include:
0: Don't show the Connect dialog.
1: Do show the Connect dialog.</string>
            <string id="bShowWelcomeDialog_User">Show Welcome Dialog</string>
            <string id="bShowWelcomeDialog_User_Explain">Specifies whether to show the Welcome dialog when a shared review is initiated.

Possible values include:
0: Don't show the welcome dialog.
1: Do show the welcome dialog.</string>

            <!-- ======================================== -->
            <!--          Startup and Experience          -->
            <!-- ======================================== -->

            <string id="bActivated_User">App Activated</string>
            <string id="bActivated_User_Explain">Records whether the application has been activated online after installation.

Possible values include:
0: Not activated
1: Activated</string>
            <string id="bHasLaunched_User">App Has Launched</string>
            <string id="bHasLaunched_User_Explain">Records whether the application has been launched after installation.

Possible values include:
0: Not launched
1: Launched</string>
            <string id="bAppInitialized_User">App Initialized</string>
            <string id="bAppInitialized_User_Explain">Records whether the application has been initialized after installation.

Possible values include:
0: Not initialized
1: Initialized</string>
            <string id="bLaunched_User">App Launched</string>
            <string id="bLaunched_User_Explain">Caches whether or not the application has ever been launched.

Application behavior may vary across versions depending on whether the application has been launched.

Possible values include:
0: The application has not been launched.
1: The application has been launched.</string>
            <string id="bChooseLangAtStartup_User">Choose Language Startup</string>
            <string id="bChooseLangAtStartup_User_Explain">Allows the user to choose the language at startup.</string>
            <string id="bCreateFormDiscoveryShown_User">Create Form Onboarding</string>
            <string id="bCreateFormDiscoveryShown_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Create Form panel.

Possible values include:
0: Show the onboarding coachmark.
1: Don't show the onboarding coachmark.</string>
            <string id="bEditDiscoveryShown_User">Edit Onboarding</string>
            <string id="bEditDiscoveryShown_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Edit panel.

Possible values include:
0: Show the onboarding coachmark.
1: Don't show the onboarding coachmark.</string>
            <string id="iEULAAcceptanceTime_User">EULA Accept Timeout</string>
            <string id="iEULAAcceptanceTime_User_Explain">The amount of time granted to users after installation to accept the end user agreement.</string>
            <string id="EULA_User">EULA Acceptance</string>
            <string id="EULA_User_Explain">For Reader, indicates whether the EULA has been accepted.

If the EULA is not accepted, the application stops running after a set period of time.

Possible values include:
0: Show the EULA because it has not been accepted.
1: Don't show the EULA because it has not been accepted.</string>
            <string id="bFillSignDiscoveryShown_User">Fill &amp; Sign Onboarding</string>
            <string id="bFillSignDiscoveryShown_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Fill &amp; Sign panel.

Possible values include:
0: Show the onboarding coachmark.
1: Don't show the onboarding coachmark.</string>
            <string id="bHideHelpWelcome_User">Hide Help Welcome</string>
            <string id="bHideHelpWelcome_User_Explain">Specifies whether to disable the Welcome menu item under Help.

Possible values include:
0 or null: Enable the Welcome menu item.
1: Disable the Welcome menu item.</string>
            <string id="bShownHomeOnboarding_User">Home Onboarding</string>
            <string id="bShownHomeOnboarding_User_Explain">Specifies whether to invoke the home onboarding tour when the modern viewer is invoked the first time.

Once the home onboarding tour displays, the app automatically resets this value to 0. This preference has no effect if AVGeneral/bEnableAv2 is 0.

Possible values include:
0: Show the onboarding tour (not yet shown).
1: Don't show the onboarding tour (already shown or declined).</string>
            <string id="bLoadAllPluginsAtStartup_User">Load All Plugins</string>
            <string id="bLoadAllPluginsAtStartup_User_Explain">Specifies whether all plugins should be loaded when the application is started.</string>
            <string id="bOrganizeDiscoveryShown_User">Organize Onboarding</string>
            <string id="bOrganizeDiscoveryShown_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Organize panel.

Possible values include:
0: Show the onboarding coachmark.
1: Don't show the onboarding coachmark.</string>
            <string id="bUsePageCache_User">Page Caching</string>
            <string id="bUsePageCache_User_Explain">Specifies whether to cache pages that have been loaded.

Possible values include:
0: Don't cache pages.
1: Do cache pages</string>
            <string id="bRedactDiscoveryShown_User">Redaction Onboarding</string>
            <string id="bRedactDiscoveryShown_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Redaction panel.

Possible values include:
0: Show the onboarding coachmark.
1: Don't show the onboarding coachmark.</string>
            <string id="bDisplayAboutDialog_User">Show About Dialog</string>
            <string id="bDisplayAboutDialog_User_Explain">Specifies whether or not to display the startup splash screen at every launch.

Possible values include:
0: Don't display the startup splash screen.
1: Display the startup splash screen at every launch.</string>
            <string id="idontShowAllImagesHaveAltText_User">Show Alt Text Alert</string>
            <string id="idontShowAllImagesHaveAltText_User_Explain">Toggles whether to show an alert when a user executes the Set Alternate Text dialog and there are no images missing alternate text.

Possible values include:
0: Show alert.
1: Don't show alert.</string>
            <string id="bshowEULA_User">Show EULA Startup</string>
            <string id="bshowEULA_User_Explain">Toggles on and off whether the end user license agreement appears.</string>
            <string id="bLastShowStatus_User">Show Getting Started</string>
            <string id="bLastShowStatus_User_Explain">Specifies whether to show &quot;Get Started with Acrobat&quot; on startup.

Possible values include:
0: Don't show the Getting Started page.
1: Show the Getting Started page.</string>
            <string id="bShowHorizontalScrollbar_User">Show H-Scrollbar</string>
            <string id="bShowHorizontalScrollbar_User_Explain">Specifies whether to show a horizontal scrollbar when the viewing area is narrower than the width of the loaded document.

Possible values include:
0: Disable the horizontal scrollbar.
1: Enable the horizontal scrollbar.</string>
            <string id="bShowExistingAttachedReportAlert_User">Show Report Alert</string>
            <string id="bShowExistingAttachedReportAlert_User_Explain">Toggles whether to show an alert when a user tries to attach a report if there is already a report attached.

Possible values include:
0: Show alert.
1: Don't show alert.</string>
            <string id="idontShowSetAltTextInfo_User">Show Set Alt Alert</string>
            <string id="idontShowSetAltTextInfo_User_Explain">Toggles whether to show an informative alert when a user executes the Set Alternate Text dialog.

Possible values include:
0: Show alert.
1: Don't show alert.</string>
            <string id="bShowedSkipCard_User">Show Skip Card</string>
            <string id="bShowedSkipCard_User_Explain">Specifies whether to show the skipped onboarding coachmark.

Possible values include:
0: Disables the feature.
1: Enables the feature.</string>
            <string id="bSplashDisplayedAtStartup_User">Show Splash Screen</string>
            <string id="bSplashDisplayedAtStartup_User_Explain">Toggles whether the splash screen appears on startup.</string>
            <string id="bDisplayedSplash_User">Splash Displayed</string>
            <string id="bDisplayedSplash_User_Explain">Indicates whether or not the application has started up and invoked the splash screen.

Possible values include:
0: The splash screen has not been invoked yet.
1: The splash screen has been invoked.</string>
            <string id="bInTrialMode_User">Trial Mode Active</string>
            <string id="bInTrialMode_User_Explain">Records whether the application is operating in Trial Mode.

Possible values include:
0: Not in trial mode
1: In trial mode</string>
            <string id="bShownViewerOnboarding_User">Viewer Onboarding</string>
            <string id="bShownViewerOnboarding_User_Explain">Specifies whether to invoke the new viewer onboarding tour when a PDF opens in the modern viewer the first time.

Once the viewer onboarding tour displays, the app automatically resets this value to 0. This preference has no effect if AVGeneral/bEnableAv2 is 0.

Possible values include:
0: Show the onboarding tour (not yet shown).
1: Don't show the onboarding tour (already shown or declined).</string>
            <string id="iDelayBeforeQuitViewer_User">Viewer Quit Delay</string>
            <string id="iDelayBeforeQuitViewer_User_Explain">Specifies the number of seconds the standalone application stays in memory before it shuts down.

Possible values include:
30 Any integer</string>

            <!-- ======================================== -->
            <!--     Updates and Desktop Integration      -->
            <!-- ======================================== -->

            <string id="bDownloadEntireFile_User">Background Download</string>
            <string id="bDownloadEntireFile_User_Explain">Specifies whether to allow background downloading of resources the view thinks it needs to properly display the PDF.

Possible values include:
0: Don't allow background downloading.
1: Do allow background downloading.</string>
            <string id="iDelayBeforeQuitBrowser_User">Browser Quit Delay</string>
            <string id="iDelayBeforeQuitBrowser_User_Explain">Specifies the number of seconds the browser-based application stays in memory before it shuts down.

Possible values include:
30 Any integer</string>
            <string id="bBrowserDisplayInReadMode_User">Browser Read Mode</string>
            <string id="bBrowserDisplayInReadMode_User_Explain">Specifies whether to open documents in a browser in Read Mode.

Read Mode was introduced in Acrobat and Reader 10.0 to enhance the PDF viewing experience for documents in a browser. Read Mode turns off the standard toolbars and menu items and provides a more compact and simple menu bar only when a user hovers over the bottom, middle area of the PDF. For more information, see the Browser Integration Quick Key in the Quick Key Library .

Possible values include:
0: Don't use Read Mode and display the standard toolbars.
1: Use Read Mode and hide the standard toolbars.</string>
            <string id="bInstalledCleanupCheckDone_User">Cleanup Check Done</string>
            <string id="bInstalledCleanupCheckDone_User_Explain">A preference used by the usage measurement feature to determine whether the previously set UsageMeasurement-related keys should be reset.</string>
            <string id="bLoadOnStart_User">Collab Sync Startup</string>
            <string id="bLoadOnStart_User_Explain">Specifies whether the collaboration executable should be invoked and run as a background process on startup.

When enabled, AdobeCollabSync.exe runs on application startup. This process is used for features like shared reviews and forms data collection .

Possible values include:
0: Start the process.
1: Don't start the process.</string>
            <string id="bAllowByteRangeRequests_User">Fast Web View</string>
            <string id="bAllowByteRangeRequests_User_Explain">Specifies whether to enable Fast Web View by allowing display of the PDF before the entire file is downloaded.

Possible values include:
0: Don't enable Fast Web View.
1: Enable Fast Web View.</string>
            <string id="bFavoriteFilesRememberChoice_User">Remember Stars Choice</string>
            <string id="bFavoriteFilesRememberChoice_User_Explain">Specifies the users choice

When a user selects &quot;Ask every time&quot; and iFavoriteFilesAccessOption is set to 0, this new preference remembers the users choice for each file.

Possible values include:
Application generated.</string>
            <string id="bFavoritesStripInRFL_User">Show Starred Files</string>
            <string id="bFavoritesStripInRFL_User_Explain">Specifies whether to show starred files in the recent files list.

A starred file is somewhat similar to a &quot;favorited&quot; file. Note that the lockable version of this preference is named bFavoritesFeaturesLockDown .

Possible values include:
0: Show starred files in the recent files list.
1: Don't show starred files in the recent files list.</string>
            <string id="iFavoriteFilesAccessOption_User">Starred Files Action</string>
            <string id="iFavoriteFilesAccessOption_User_Explain">Specifies what action to take when starring a file.

A starred file is somewhat similar to a &quot;favorited&quot; file.

Possible values include:
0: Show a dialog and ask whether to save or upload. This option also results in creating a new bFavoriteFilesRememberChoice .
1: Upload to Document Cloud
2: Save the file locally</string>
            <string id="bStoreCredentials_User">Store Credentials</string>
            <string id="bStoreCredentials_User_Explain">Specifies whether the user logon credentials for the Tracker should be stored.

Possible values include:
0: Don't store credentials.
1: Store credentials.</string>
            <string id="iAVARMNoAutoUpdateWarning_User">Suppress Update Warning</string>
            <string id="iAVARMNoAutoUpdateWarning_User_Explain">Specifies whether to turn of the &quot;Updater has not been able to check for updates recently&quot; dialog.

Possible values include:
0: Don't turn off the dialog.
1: Do turn off the dialog.</string>

            <!-- ======================================== -->
            <!--                  Upsell                  -->
            <!-- ======================================== -->

            <string id="bAcrobatAppInstalled_User">Acrobat App Promo</string>
            <string id="bAcrobatAppInstalled_User_Explain">Specifies whether to show the Acrobat mobile app promotion and link in the Home banner.

Disable and lock both the App Center and Home banner with bToggleDCAppCenter under FeatureLockDown.

Possible values include:
0: Promote the mobile app.
1: Don't promote the mobile app.</string>
            <string id="bScanAppInstalled_User">Scan App Promo</string>
            <string id="bScanAppInstalled_User_Explain">Specifies whether to show the Adobe Scan mobile app promotion and link in the Home banner.

Disable and lock both the App Center and Home banner with bToggleDCAppCenter under FeatureLockDown.

Possible values include:
0: Promote the mobile app.
1: Don't promote the mobile app.</string>
    </stringTable>
